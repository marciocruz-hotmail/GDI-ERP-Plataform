# GDI-ERP-Plataform — .gitignore
#
# Referência rápida (Git × IIS Publish):
#   GIT (versionar)     — código-fonte, Views, LibUI, Web.config, packages.config,
#                         modelos App_Data/Secrets (*.example, *.template.json),
#                         documentação IA (.cursor/, AI-CONTEXT, Scripts/, Tests/),
#                         Rotativa/wkhtmltopdf*.exe (PDF no IIS)
#   IIS (deploy)        — saída de Publish/MSBuild: bin/, DLLs compiladas, views
#                         publicadas; secrets reais no servidor (gitignored aqui)
#   IGNORAR (local)     — bin/, obj/, packages/, .vs/, _filestemp/, secrets locais,
#                         artefactos de teste e publish intermediário
#
# Base: VisualStudio.gitignore (condensado) + regras GDI

############################################################
# GDI — SECRETS, RUNTIME E TEMP (nunca versionar)
############################################################

# Credenciais / config local (modelos versionados: *.example, *.template.json)
App_Data/Secrets/aws-s3.local.json
App_Data/Secrets/aws-ses-smtp.local.json
App_Data/Secrets/sql-server.local.config
App_Data/Secrets/appSettings.local.config
App_Data/Secrets/*Copia*
App_Data/Secrets/* - Copia.*

# Logs de aplicação (LibLogger)
App_Data/Logs/

# Uploads e artefactos temporários (Server.MapPath ~/_filestemp))
_filestemp/
**/_filestemp/

############################################################
# BUILD E PUBLISH (não versionar; gerados no CI/dev/publish IIS)
############################################################

[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
publish/
app.publish/
artifacts/
*.binlog
MSBuild_Logs/

# Não usar *.dll / *.exe globais — ignorariam Rotativa/wkhtmltopdf*.exe (necessários no IIS)

############################################################
# NUGET (restaurar com nuget restore / VS; deploy via bin/)
############################################################

packages/
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

############################################################
# VISUAL STUDIO / RIDER / IDE
############################################################

.vs/
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates
*.rsuser
*.userprefs
.vshistory/
**/.localhistory/

# Publish profiles locais (podem conter credenciais de deploy)
*.pubxml
*.publishproj
*.publishsettings
PublishScripts/

############################################################
# VSCODE / CURSOR (settings locais; .cursor/ DOCS versionam-se no Git)
############################################################

.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/

############################################################
# CLAUDE CODE (overrides locais; commands/scripts versionam-se)
############################################################

.claude/settings.local.json
.claude/worktrees/

############################################################
# TESTES
############################################################

[Tt]est[Rr]esult*/
TestResults/
*.trx
[Bb]uild[Ll]og.*
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml

############################################################
# FERRAMENTAS / SCRIPTS DO REPO (Python inventários)
############################################################

**/__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

############################################################
# NODE (se npm for usado em tooling front-end)
############################################################

node_modules/

############################################################
# AMBIENTE E CREDENCIAIS GERAIS
############################################################

*.env
.env.*
!.env.example

############################################################
# WINDOWS / LIXO LOCAL
############################################################

Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/
*.stackdump
# Artefactos acidentais de redirecionamento no cmd/PowerShell
nul
nul)

# Cópias acidentais de documentação local
* - Copia.md
* - Copia.*

############################################################
# SQL SERVER LOCAL (ficheiros de dados attach)
############################################################

*.mdf
*.ldf
*.ndf

############################################################
# RESHARPER / ANALISADORES
############################################################

_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
*.dotCover

############################################################
# BACKUP / UPGRADE VS
############################################################

_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
MigrationBackup/

############################################################
# ROTATIVA — exceção: binários versionados para PDF no IIS
############################################################

!Rotativa/
!Rotativa/*.exe

############################################################
# OUTROS (template Visual Studio — seletivo)
############################################################

*.tmp
*.temp
*.bak
*.cache
*.log
*.pdb
*.ilk
*.meta
*.obj
ClientBin/
~$*
*~
*.dbmdl
*.jfm
ScaffoldingReadMe.txt
FakesAssemblies/
healthchecksdb
docker-compose.override.yml
