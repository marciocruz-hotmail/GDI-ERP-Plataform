<?xml version="1.0" encoding="utf-8"?>
<!--
  SQL Server — MODELO (versionado).
  Copie para sql-server.local.config (gitignored) e preencha servidor, base e credenciais.
  Nomes dos add name= devem coincidir com SetTenants() em UserIdentityController.cs
  e com base("name=...") em GdiPlataformEntities (Db/ModelDbGdiPlataform.Context1.cs).

  Em produção (IIS): coloque sql-server.local.config em App_Data\Secrets\ do site publicado.
-->
<connectionStrings>
  <!-- Usado pelo construtor sem parâmetro: new GdiPlataformEntities() -->
  <add name="GdiPlataformEntities"
       connectionString="metadata=res://*/Db.ModelDbGdiPlataform.csdl|res://*/Db.ModelDbGdiPlataform.ssdl|res://*/Db.ModelDbGdiPlataform.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=SEU_SERVIDOR;initial catalog=SUA_BASE_DEV;integrated security=True;MultipleActiveResultSets=True;App=EntityFramework&quot;"
       providerName="System.Data.EntityClient" />
  <add name="GdiPlataformEntities_localhost"
       connectionString="metadata=res://*/Db.ModelDbGdiPlataform.csdl|res://*/Db.ModelDbGdiPlataform.ssdl|res://*/Db.ModelDbGdiPlataform.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=SEU_SERVIDOR;initial catalog=SUA_BASE_DEV;integrated security=True;MultipleActiveResultSets=True;App=EntityFramework&quot;"
       providerName="System.Data.EntityClient" />
  <add name="GdiPlataformEntities_gdi_producao"
       connectionString="metadata=res://*/Db.ModelDbGdiPlataform.csdl|res://*/Db.ModelDbGdiPlataform.ssdl|res://*/Db.ModelDbGdiPlataform.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=SEU_SERVIDOR;initial catalog=SUA_BASE_PROD;User ID=SEU_USUARIO;Password=SUA_SENHA;MultipleActiveResultSets=True;App=EntityFramework&quot;"
       providerName="System.Data.EntityClient" />
  <add name="GdiPlataformEntities_gdi_homologacao"
       connectionString="metadata=res://*/Db.ModelDbGdiPlataform.csdl|res://*/Db.ModelDbGdiPlataform.ssdl|res://*/Db.ModelDbGdiPlataform.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=SEU_SERVIDOR;initial catalog=SUA_BASE_HOM;User ID=SEU_USUARIO;Password=SUA_SENHA;MultipleActiveResultSets=True;App=EntityFramework&quot;"
       providerName="System.Data.EntityClient" />
</connectionStrings>
