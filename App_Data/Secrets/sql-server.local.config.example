<?xml version="1.0" encoding="utf-8"?>
<!--
  Credenciais SQL Server — MODELO (versionado).
  Copie este ficheiro para sql-server.local.config (gitignored) e preencha os valores reais.
  Nunca versione sql-server.local.config com credenciais reais.

  Referência de deploy:
    - Servidor de homologação : erp_gdi_homologacao
    - Servidor de produção    : erp_gdi_producao
    - Usuário recomendado     : usuário SQL com permissões mínimas (não "sa")
-->
<connectionStrings>
  <!-- Banco padrão carregado na sessão (definido por CachePersister.dataBase no login) -->
  <add name="GdiPlataformEntities"
       connectionString="metadata=res://*/Db.ModelDbGdiPlataform.csdl|res://*/Db.ModelDbGdiPlataform.ssdl|res://*/Db.ModelDbGdiPlataform.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=SERVIDOR;initial catalog=BANCO_PADRAO;persist security info=True;user id=USUARIO;password=SENHA;multipleactiveresultsets=True;trustservercertificate=True;application name=EntityFramework&quot;"
       providerName="System.Data.EntityClient" />
  <!-- Alias localhost → homologação (usado no login local) -->
  <add name="GdiPlataformEntities_localhost"
       connectionString="metadata=res://*/Db.ModelDbGdiPlataform.csdl|res://*/Db.ModelDbGdiPlataform.ssdl|res://*/Db.ModelDbGdiPlataform.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=SERVIDOR;initial catalog=erp_gdi_homologacao;persist security info=True;user id=USUARIO;password=SENHA;multipleactiveresultsets=True;trustservercertificate=True;application name=EntityFramework&quot;"
       providerName="System.Data.EntityClient" />
  <!-- Produção -->
  <add name="GdiPlataformEntities_gdi_producao"
       connectionString="metadata=res://*/Db.ModelDbGdiPlataform.csdl|res://*/Db.ModelDbGdiPlataform.ssdl|res://*/Db.ModelDbGdiPlataform.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=SERVIDOR;initial catalog=erp_gdi_producao;persist security info=True;user id=USUARIO;password=SENHA;multipleactiveresultsets=True;trustservercertificate=True;application name=EntityFramework&quot;"
       providerName="System.Data.EntityClient" />
  <!-- Homologação -->
  <add name="GdiPlataformEntities_gdi_homologacao"
       connectionString="metadata=res://*/Db.ModelDbGdiPlataform.csdl|res://*/Db.ModelDbGdiPlataform.ssdl|res://*/Db.ModelDbGdiPlataform.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=SERVIDOR;initial catalog=erp_gdi_homologacao;persist security info=True;user id=USUARIO;password=SENHA;multipleactiveresultsets=True;trustservercertificate=True;application name=EntityFramework&quot;"
       providerName="System.Data.EntityClient" />
</connectionStrings>
