<?xml version="1.0" encoding="utf-8"?>
<!--
  Configurações locais da aplicação — MODELO (versionado).
  Copie este ficheiro para appSettings.local.config (gitignored) e preencha os valores reais.
  Nunca versione appSettings.local.config com chaves reais.

  As chaves aqui definidas sobrepõem as de Web.config (atributo file="...").
  Chaves presentes apenas aqui NÃO precisam estar no Web.config.
-->
<appSettings>
  <!-- Chave para autorizar chamadas à API JobServer (deixe vazio para não exigir chave) -->
  <add key="JobServer:Key" value="COLOQUE_A_CHAVE_DO_JOBSERVER_AQUI" />
  <!-- Opcional: força connection EF na API pública lote-documento (vazio = tenant por Host, ex. portalflightx → produção) -->
  <!-- <add key="PublicApi:EntityConnectionName" value="GdiPlataformEntities_gdi_producao" /> -->
  <!-- Relatório gerencial WhatsApp (Job EnviarResumoGerencialWhatsApp): celulares Z-API (DDI 55), separados por ; -->
  <!-- OBRIGATÓRIO no servidor IIS: copie esta linha para App_Data\Secrets\appSettings.local.config (não versionado). -->
  <add key="WhatsAppGerencial:Destinatarios" value="5531985113025" />
</appSettings>
