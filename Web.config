<?xml version="1.0" encoding="utf-8"?>
<!--
  For more information on how to configure your ASP.NET application, please visit
  https://go.microsoft.com/fwlink/?LinkId=301880
  -->
<configuration>
  <configSections>
    <!-- For more information on Entity Framework configuration, visit http://go.microsoft.com/fwlink/?LinkID=237468 -->
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
  </configSections>
  <appSettings file="App_Data\Secrets\appSettings.local.config">
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
    <!-- JobServer:Key movido para App_Data\Secrets\appSettings.local.config (gitignored). -->
    <!-- Copie appSettings.local.config.example para appSettings.local.config e preencha. -->
  </appSettings>
  <system.web>
    <globalization culture="pt-BR" uiCulture="pt-BR" requestEncoding="utf-8" responseEncoding="utf-8" fileEncoding="utf-8" />
    <!-- DEV LOCAL: debug="true" abaixo — NÃO alterar para produção neste ficheiro.
         Produção/IIS: Publish com Configuration=Release; Web.Release.config remove debug e define customErrors mode="On".
         Health: GET /health (HealthController, anónimo). Validar: Scripts/2026_05_20_gdi_verify_web_release_transform.ps1 -->
    <compilation debug="true" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2" maxRequestLength="102400" executionTimeout="600" />
    <!-- DEV LOCAL: mode="Off" abaixo expõe erros detalhados (yellow screen). Em produção vale só o Web.config transformado no publish Release. -->
    <customErrors mode="Off" defaultRedirect="~/Error">
      <error statusCode="404" redirect="~/Error/NotFound" />
      <error statusCode="500" redirect="~/Error" />
    </customErrors>
    <!-- Timeout de sessão alinhado ao controle de inatividade (15 min) -->
    <sessionState timeout="15" />
  </system.web>
  <system.webServer>
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="629145600" />
      </requestFiltering>
    </security>
    <rewrite>
      <rules>
        <rule name="HTTP TO HTTPS" enabled="true" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTPS}" pattern="^OFF$" />
            <add input="{HTTP_HOST}" pattern="^localhost(:\d+)?$" negate="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" appendQueryString="false" />
        </rule>
      </rules>
    </rewrite>
    <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <remove name="OPTIONSVerbHandler" />
      <remove name="TRACEVerbHandler" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0" path="*." verb="*" type="System.Web.Handlers.TransferRequestHandler" preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>
    <httpProtocol>
      <customHeaders>
        <!-- Remove cabeçalho informativo do ASP.NET -->
        <remove name="X-Powered-By" />
        <!-- Impede clickjacking em browsers mais antigos (complementa CSP frame-ancestors) -->
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <!-- Impede MIME-type sniffing pelo browser -->
        <add name="X-Content-Type-Options" value="nosniff" />
        <!-- Reduz vazamento de URL de origem em cross-origin requests -->
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <!--
          Content-Security-Policy — política permissiva inicial (pode ser endurecida gradualmente).
          'unsafe-inline' necessário: views Razor têm blocos <script> inline extensivos.
          'unsafe-eval' incluído: DataTables e libs de terceiros podem usar eval().
          Todos os recursos são self-hosted (sem CDN externo).
          Para endurecer futuramente: substituir 'unsafe-inline' por nonces/hashes nos scripts Razor.
        -->
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://bucket-gdi-public-files.s3.sa-east-1.amazonaws.com; font-src 'self' data:; connect-src 'self'; frame-ancestors 'self'; form-action 'self'; object-src 'none'" />
      </customHeaders>
    </httpProtocol>
    <staticContent>
      <!-- woff2 não está no conjunto padrão de MIME types de IIS mais antigos -->
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>
  </system.webServer>
