  <!-- Publish Web (WPP): apagar PackageTmp\.cursor antes de CopyAllFilesToSingleFolder* — evita aviso RemoveEmptyDirectories "Access to the path 'context' is denied" quando restos ficam só leitura ou o IDE segura ficheiros em .cursor\context. -->
  <Target Name="GdiStripPackageTmpDotCursorBeforeWppCopy" BeforeTargets="CopyAllFilesToSingleFolderForMsdeploy;CopyAllFilesToSingleFolderForPackage" Condition="'$(WPPAllFilesInSingleFolder)' != '' And '$(OS)' == 'Windows_NT'">
    <PropertyGroup>
      <_GdiWppTmp>$([System.IO.Path]::GetFullPath($(WPPAllFilesInSingleFolder)))</_GdiWppTmp>
      <_GdiCursorPkg>$([System.IO.Path]::Combine($(_GdiWppTmp), '.cursor'))</_GdiCursorPkg>
    </PropertyGroup>
    <Exec Command="cmd /c if exist &quot;$(_GdiCursorPkg)&quot; (attrib -r &quot;$(_GdiCursorPkg)\*.*&quot; /s /d 2&gt;nul &amp; rmdir /s /q &quot;$(_GdiCursorPkg)&quot; 2&gt;nul)" IgnoreExitCode="true" />
  </Target>
  <!-- Evita FileLoadException 0x80131040: cópias duplicadas no Explorer geram "Antlr3 (1).Runtime.dll" em bin; o ASP.NET carrega todos os .dll e o nome não bate com o manifesto. -->
  <Target Name="RemoveMisnamedAntlrDuplicatesFromBin" AfterTargets="CopyFilesToOutputDirectory">
    <ItemGroup>
      <_MisnamedAntlr Include="$(OutputPath)Antlr3.Runtime (*).dll" />
      <_MisnamedAntlr Include="$(OutputPath)Antlr3.Runtime (*).pdb" />
      <_MisnamedAntlr Include="$(OutputPath)Antlr3 (*).Runtime.dll" />
      <_MisnamedAntlr Include="$(OutputPath)Antlr3 (*).Runtime.pdb" />
    </ItemGroup>
    <Delete Files="@(_MisnamedAntlr)" ContinueOnError="true" />
  </Target>
