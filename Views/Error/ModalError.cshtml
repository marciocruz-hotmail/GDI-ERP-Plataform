@{ Layout = null; }

@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "ModalError" }))
{
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h4 class="modal-title"><i class="fa-solid fa-circle-exclamation fa-beat-fade" style="color: #d70f0f;"></i>     Erro no Processamento</h4>
            </div>
            <div class="modal-body m-0 p-1">
                <div class="card m-1 p-1">
                    <div class="card-body m-0 p-1" style="height: 100%">
                        <div class="mb-3 row text-sm-end m-0 p-0">
                            <div class="col-sm-12 text-sm-start">
                                <div class="card bg-danger text-white">
                                    <div class="card-header border-0 bg-danger">@Html.Raw((String)@TempData["message"])</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" name="btnFechar" title="Fechar" class="btn btn-warning" data-bs-dismiss="modal"><i class="fa-regular fa-window-close">&nbsp;&nbsp;</i>Fechar</button>
            </div>
        </div>
    </div>
}



<script type="text/javascript">
    $(function () {
        try {
            LibMessageHideAll();
            LibMessageProcessandoHide();
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });
</script>

