@model GdiPlataform.Areas.g.Models.cstUploadGed
@{ Layout = null; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "FormModalEditFileGed", enctype = "multipart/form-data" }))
{
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title d-flex align-items-center gap-2">
    <i class="fa-solid fa-circle-info fa-sm" aria-hidden="true"></i>
    @Html.Raw(@ViewBag.Title)</h5>
                @Html.HiddenFor(model => model.id_arquivo)
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-1">
                <div class="card-body m-0 p-1" style="height: 100%">
                    <div class="form-horizontal m-0 p-0">
                            @Html.ValidationSummary(true)
                            <div class="card-body m-0 p-1" style="height: 100%">
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("Classificação", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-10">
                                        @Html.DropDownListFor(model => model.id_arquivo_tipo, ViewBag.ComboGedTipos as List<SelectListItem>, new { @class = "form-control" })
                                    </div>
                                </div>
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("data_referencia", "Data", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-4">
                                        @* id do .input-group distinto do input para Tempus Dominus *@
                                        <div class='input-group date' id='ig_g_ged_modal_edit_ref'>
                                            @Html.EditorFor(model => model.data_referencia, new { htmlAttributes = new { @class = "form-control", type = "text", data_autofocus = "true" } })
                                            <span class="input-group-text"><i class="fa-regular fa-calendar-alt"></i></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("Descrição", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-10">
                                        @Html.EditorFor(model => model.descricao, new { htmlAttributes = new { @class = "form-control" } })
                                    </div>
                                </div>
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("obs", "Obs", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-10">
                                        @Html.TextAreaFor(model => model.observacao, new { @class = "form-control", @rows = "3" })
                                    </div>
                                </div>
                            </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" name="btnCancelar" title="Cancelar" class="btn btn-warning me-auto d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                <button type="button" name="btnSalvar" title="Confirmar Upload" class="btn btn-success d-inline-flex align-items-center gap-2" onclick="jsSendForm()"><i class="fa-solid fa-cloud-arrow-up me-2" aria-hidden="true"></i>Confirmar Upload</button>
            </div>
        </div>
    </div>
}

<script type="text/javascript">

	$(function ()
    {
        try
        {
            jsDatepicker('#ig_g_ged_modal_edit_ref');
            jsInitModal();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsSendForm()
    {
        try
        {
            LibMessageProcessando("Processando Arquivo . . .")
            var formData = new FormData(document.getElementById("FormModalEditFileGed"));
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxEditFileGed", "Ged", new { Area = "g" })',
                data: formData,
                dataType: 'json',
                contentType: false,
                processData: false,
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        GdiSwal2.alert({
                            title: "<i class='fa-solid fa-check' style='color:#008000'>&nbsp&nbsp&nbsp</i><b>Confirmação</b>",
                            centerVertical: true,
                            message: result.msg,
                            callback: function () {
                                $("#dataTableGedArquivos").DataTable().draw(false);
                                document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                GdiSwal2.hideAll();
                            }
                        })
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias(result.msg);
                    }
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    LibMessageProcessandoHide();
                    var details =
                        "Status: " + jqXHR.status + "\n" +
                        "textStatus: " + textStatus + "\n" +
                        "errorThrown: " + errorThrown + "\n\n" +
                        "responseText:\n" + (jqXHR.responseText || "");
                    GdiAjaxNotifyInconsistencias(details, { title: "Error: Verifique as inconsistências" });
                }
            });
        }
        catch (e)
        {
            LibMessageError("Atenção", "[jsSendForm] " + (e && e.message ? e.message.toString() : String(e)));
        }
    };

    function jsTeclaPessionada(e)
    {
        try {
            if (e.keyCode == 13)
            {
                jsCheckInputs();
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsTeclaPessionada] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }





</script>


