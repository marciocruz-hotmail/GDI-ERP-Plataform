@model GdiPlataform.Areas.g.Models.CstProdutosNcmIndex
@using GdiPlataform.Security
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool podeEditarProdutosNcm = CachePersister.userIdentity.Roles.Contains("g_ProdutosNcm_*")
        || CachePersister.userIdentity.Roles.Contains("g_ProdutosNcm_Actionupdate");
}
<style>
    .gdi-index-produtosncm-dt .btnGProdutosNcmEditRow { gap: 0.125rem; }
</style>
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(ViewBag.Title)</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterController" value="ProdutosNcm" name="yesFilterController" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-header m-0 p-1">
                @if ((CachePersister.userIdentity.Roles.Contains("g_ProdutosNcm_*")) || (CachePersister.userIdentity.Roles.Contains("g_ProdutosNcm_Actioncreate")))
                {<button type="button" name="btnRegistroNovo" title="Novo Registro" class="btn btn-outline-success d-inline-flex align-items-center gap-2" onclick="jsModalCreateEditProdutosNcm(0)"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button> }
                else
                { <button type="button" name="btnRegistroNovo" title="Novo Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button>}
                @if ((CachePersister.userIdentity.Roles.Contains("g_ProdutosNcm_*")) || (CachePersister.userIdentity.Roles.Contains("g_ProdutosNcm_Actiondelete")))
                {<button type="button" name="btnRegistroExcluir" title="Excluir Registro" class="btn btn-outline-danger disabled d-inline-flex align-items-center gap-2"><i class="fa-regular fa-trash-alt me-2" aria-hidden="true"></i>Excluir</button> }
                else
                { <button type="button" name="btnRegistroExcluir" title="Excluir Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa-regular fa-trash-alt me-2" aria-hidden="true"></i>Excluir</button>}
                <div class="btn-group" role="group">
                    <button id="btnGroupDrop1" type="button" class="btn btn-outline-info dropdown-toggle d-inline-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="Processos">
                        <i class="fa-solid fa-cog me-2" aria-hidden="true"></i>Processos
                    </button>
                    <div class="dropdown-menu" aria-labelledby="btnGroupDrop1">
                        <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalAtualizarTabelaIBPT()"><i class="fa-solid fa-upload me-2" aria-hidden="true"></i>Atualizar Tabela IPBTax</a>
                    </div>
                </div>
            </div>
            <div class="card-body m-0 p-1" style="height: 100%">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 mt-1 pt-1">
                        @Html.Label("Id", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-2">
                            @Html.TextBoxFor(model => model.ProdutosNcmIndex_id, new { @class = "form-control", @id = "edit_id_produto_ncm", @placeholder = "Id.", @onkeypress = "keypressedProdutosNcm(event);" })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Código NCM", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-5">
                            @Html.TextBoxFor(model => model.ProdutosNcmIndex_codigo_ncm, new { @class = "form-control", @id = "edit_codigo_ncm", @placeholder = "Código NCM", @onkeypress = "keypressedProdutosNcm(event);" })
                        </div>
                        <div class="col-sm-3 text-sm-start">
                            <button type="button" id="btnPesquisarProdutosNcm" title="Pesquisar NCM" class="btn btn-secondary d-inline-flex align-items-center gap-2" onclick="jsAjaxPesquisarProdutosNcm()"><i class="fa-solid fa-search me-2" aria-hidden="true"></i>Pesquisar</button>
                            <button type="button" id="btnLimparFiltroProdutosNcm" title="Limpar filtro e listar todos" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2 ms-1" onclick="jsLimparFiltroProdutosNcm()"><i class="fa-solid fa-magnifying-glass-minus me-2" aria-hidden="true"></i>Limpar</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body m-0 p-1 gdi-index-produtosncm-dt" style="max-width: 100%; overflow-x: auto;">
                <div class="form-horizontal m-0 p-0">
                    <div class="table-responsive scroll-body-horizontal" style="width:100%">
                        <table class="table table-sm table-hover gdi-dt-zebra align-middle w-100 display compact" style="width:100%" id="dtGProdutosNcm">
                            <thead>
                                <tr>
                                    <th>[x]</th>
                                    <th>Id.</th>
                                    <th>Ativo</th>
                                    <th>Codigo NCM</th>
                                    @if (podeEditarProdutosNcm)
                                    {
                                        <th><i class="fa-regular fa-edit" data-bs-toggle="tooltip" data-bs-placement="top" title="Editar NCM"></i></th>
                                    }
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var otableGProdutosNcm;

    $(function ()
    {
        try
        {
            jsInitForm();
            @if (ViewBag.RestoreFilterAutoSearch != true)
            {
                <text>document.getElementById("yesFilterField").value = "*";</text>
            }
            jsCreateTable();
            jsAtualizarIndicadorFiltroProdutosNcm('0');
            gdiAplicarFoco('#edit_id_produto_ncm', true);
            @if (ViewBag.RestoreFilterAutoSearch == true)
            {
                <text>if (jsProdutosNcmTemCriterioFiltro()) { jsAjaxPesquisarProdutosNcm(); }</text>
            }
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function keypressedProdutosNcm(e)
    {
        if (e.keyCode == 13)
        {
            e.preventDefault();
            jsAjaxPesquisarProdutosNcm();
        }
    }

    function jsProdutosNcmTemCriterioFiltro()
    {
        return !isEmpty($('#edit_id_produto_ncm').val()) || !isEmpty($('#edit_codigo_ncm').val());
    }

    function jsAtualizarIndicadorFiltroProdutosNcm(yesFilterOnOff)
    {
        GdiAtualizarIndicadorFiltro(yesFilterOnOff, {
            btnId: 'btnLimparFiltroProdutosNcm',
            tituloInativo: 'Limpar filtro e listar todos',
            tituloAtivo: 'Filtro ativo — limpar e listar todos os NCM'
        });
    }

    function jsAjaxPesquisarProdutosNcm()
    {
        try
        {
            if (!jsProdutosNcmTemCriterioFiltro())
            {
                LibMessageAlert("Atenção", "Preencha ao menos um campo do <b>filtro</b> (Id. ou Código NCM).");
                return;
            }
            LibMessageProcessando('Pesquisando NCM...');
            document.getElementById("yesFilterField").value = "";
            $("#dtGProdutosNcm").DataTable().draw(false);
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsAjaxPesquisarProdutosNcm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsLimparFiltroProdutosNcm()
    {
        try
        {
            $('#edit_id_produto_ncm').val('');
            $('#edit_codigo_ncm').val('');
            document.getElementById("yesFilterField").value = "*";
            LibMessageProcessando('Atualizando lista...');
            $("#dtGProdutosNcm").DataTable().draw(false);
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsLimparFiltroProdutosNcm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsCreateTable()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            otableGProdutosNcm = $('#dtGProdutosNcm').on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message);
                }).on('xhr.dt', function (e, settings, json, xhr) {
                if (GdiDtNotifyJsonErrorMessage(json)) { return; }
                else if (json && json.yesFilterOnOff !== undefined) {
                    jsAtualizarIndicadorFiltroProdutosNcm(json.yesFilterOnOff);
                }
            }).DataTable({
            processing: true,
            bServerSide: true,
            ajax: {
                url: '@Url.Action("GetDados","ProdutosNcm",new { Area = "g" })',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                dataType: 'json',
                cache: false,
                data: function (d) {
                    return {
                        sEcho: d.draw,
                        iDisplayStart: d.start,
                        iDisplayLength: d.length,
                        yesFilterField: $('#yesFilterField').val().toString(),
                        yesFilterController: $('#yesFilterController').val().toString(),
                        yesCustomField01: emptyIfNull($('#edit_id_produto_ncm').val()).toString(),
                        yesCustomField02: emptyIfNull($('#edit_codigo_ncm').val()).toString()
                    };
                },
                error: function (xhr, textStatus, errorThrown) {
                    LibMessageProcessandoHide();
                    GdiDtNotifyLoadFailure(errorThrown);
                }
            },
            responsive: true,
            bFilter: false,
            bLengthChange: false,
            bProcessing: true,
            pageLength: 20,
            scrollX: false,
            scrollCollapse: false,
            fixedColumns: false,
            bAutoWidth: false,
            pagingType: 'full_numbers',
            aoColumnDefs: [
                { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                { "width": "6%", orderable: true, className: 'text-sm-center', targets: [1] },
                { "width": "8%", orderable: false, className: 'text-sm-center', targets: [2] },
                { "width": "78%", orderable: true, className: 'text-sm-start', targets: [3] }
                @if (podeEditarProdutosNcm)
                {
                <text>,
                { "width": "4%", orderable: false, className: 'text-sm-center dt-no-row-select', targets: [4], data: null, defaultContent: "",
                    render: function (data, type, row) {
                        return '<button type="button" title="Editar NCM Id. ' + row[1] + '" class="btn btn-outline-warning btn-sm p-1 btnGProdutosNcmEditRow d-inline-flex align-items-center" onclick="jsGProdutosNcmEditRow(' + row[1] + ');"><i class="fa-regular fa-edit"></i></button>';
                    }
                }</text>
                }
            ],
            select: {
                style: 'multi',
                selector: 'td:not(.dt-no-row-select)',
                headerCheckbox: true
            },
            order: [[1, 'asc']],
            drawCallback: function (settings) {
                document.querySelectorAll('#dtGProdutosNcm [data-bs-toggle="tooltip"]').forEach(function (el) {
                    bootstrap.Tooltip.getOrCreateInstance(el);
                });
                try { new $.fn.dataTable.Api(settings).columns.adjust(); } catch (e) { }
            },
                language:
                {
                    sEmptyTable: 'Informe Id. ou Código NCM e clique em Pesquisar (ou Limpar para listar todos).',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
            });
            @if (podeEditarProdutosNcm)
            {
                <text>$('#dtGProdutosNcm tbody').on('dblclick', 'tr td:not(.dt-no-row-select)', function () {
                var data = otableGProdutosNcm.row($(this).closest('tr')).data();
                if (data) { jsGProdutosNcmEditRow(data[1]); }
            });</text>
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsModalCreateEditProdutosNcm(idProdutoNcm)
    {
        try
        {
            LibMessageProcessando("");
            $("#mainModal").load('@Url.Action("ModalCreateEditProdutosNcm", "ProdutosNcm", new { Area = "g" })?IdProdutoNcm=' + emptyIfNull(idProdutoNcm).toString(), function () {
                var e = document.getElementById('mainModal');
                if (e) { bootstrap.Modal.getOrCreateInstance(e).show(); }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalCreateEditProdutosNcm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsGProdutosNcmEditRow(idPagRecTipo)
    {
        try {
            var id = parseInt(idPagRecTipo, 10);
            if (!id || id <= 0) { return; }
            jsModalCreateEditProdutosNcm(id);
        }
        catch (err) {
            LibMessageError("Atenção", "[jsGProdutosNcmEditRow] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalAtualizarTabelaIBPT() {
        $("#mainModal").load('@Url.Action("ModalAtualizarTabelaIBPT", "ProdutosNcm", new { Area = "g" })', function () {
            var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
        })
    }

</script>
