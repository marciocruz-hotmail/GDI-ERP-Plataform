@model GdiPlataform.Db.g_classificacao_financeira
@using GdiPlataform.Security
@{Layout = "~/Views/Shared/_Layout.cshtml"; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "formCreateEdit_gClassificacaoFinanceira" }))
{
    <div class="row">
        <div class="col-lg-12 m-0 p-0">
            <div class="card m-0 p-0">
                <div class="card-title m-0 p-1">
                    <h5>@Html.Raw(@ViewBag.Title)</h5>
                    @Html.HiddenFor(model => model.id_classificacao_financeira)
                    @Html.HiddenFor(model => model.id_usuario_cadastro)
                    @Html.HiddenFor(model => model.datahora_cadastro)
                    @Html.HiddenFor(model => model.id_coligada)
                    @Html.HiddenFor(model => model.id_filial)
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)
                </div>
                <div class="card-body m-0 p-0" style="height: 100%">
                    <div class="form-horizontal m-0 p-0">
                        <div class="card shadow-sm gdi-section-accent-secondary m-1 p-0">
                            <div class="section-header"><i class="fa-solid fa-file-pen me-1" aria-hidden="true"></i>Dados da Classificação Financeira</div>
                            <div class="card-body m-0 p-1" style="height: 100%">
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("Ativo", "Ativo", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-1 text-sm-start" style="margin-top:7px">
                                        <div class="form-check form-switch form-switch-lg">
                                            @Html.CheckBoxFor(model => model.ativo, new { @class = "form-check-input switch-success", role = "switch" })
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("codigo", "Código", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-3">
                                        @Html.EditorFor(model => model.codigo, new { htmlAttributes = new { @class = "form-control", data_autofocus = "true" } })
                                    </div>
                                    <div class="col-sm-2 text-sm-start" style="margin-top:7px">
                                        <div class="form-check form-switch d-inline-flex align-items-center flex-nowrap">
                                            @Html.CheckBoxFor(model => model.consolidador, new { @class = "form-check-input switch-success", role = "switch" })
                                            <span class="form-check-label ms-1 mb-0">Consolidador</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("id_classificacao_financeira_pai", "CC Pai", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.id_classificacao_financeira_pai, ViewBag.comboClassificacaoFinanceiraPai as List<SelectListItem>, new { @class = "form-control" })
                                    </div>
                                </div>
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("nome", "Nome", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.nome, new { htmlAttributes = new { @class = "form-control" } })
                                    </div>
                                </div>
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("credito", "Crédito", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-1 text-sm-start" style="margin-top:7px">
                                        <div class="form-check form-switch form-switch-lg">
                                            @Html.CheckBoxFor(model => model.credito, new { @class = "form-check-input switch-success", role = "switch" })
                                        </div>
                                    </div>
                                    @Html.Label("debito", "Débito", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-1 text-sm-start" style="margin-top:7px">
                                        <div class="form-check form-switch form-switch-lg">
                                            @Html.CheckBoxFor(model => model.debito, new { @class = "form-check-input switch-success", role = "switch" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer justify-content-between m-0 p-1">
                    <button type="button" name="btnCancelar" title="Cancelar" class="btn btn-warning d-inline-flex align-items-center gap-2" onclick="window.location.href='@Url.Action("", "ClassificacaoFinanceira", new { area = "g" })'" value="Redirect"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                    <button type="button" name="btnSalvar" title="Salvar" onclick="jsSalvarDados()" class="btn btn-success float-end d-inline-flex align-items-center gap-2"><i class="fa fa-save me-2" aria-hidden="true"></i>Salvar</button>
                </div>
            </div>
        </div>
    </div>
}
<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsInitForm();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsLoadForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsSalvarDados()
    {
        try
        {
            var hasError = false;
            var msgError = "Campos <b>Obrigatórios</b> deverão ser preenchidos!<br/><br/>";

            if (isEmpty($('#codigo').val())) {
                hasError = true;
                msgError += "Campo <b>Código</b> é de preenchimento obrigatório!<br/>";
            }
            if (isEmpty($('#nome').val())) {
                hasError = true;
                msgError += "Campo <b>Nome</b> é de preenchimento obrigatório!<br/>";
            }
            if (($('#credito').is(":checked") == false) && ($('#debito').is(":checked") == false))
            {
                hasError = true;
                msgError += "Informe se a classe é <b>Crédito</b>, <b>Débito</b> ou Ambos!<br/>";
            }
            if (hasError) { LibMessageAlert("Atenção", msgError); }
            else {
                LibMessageProcessando("Salvando Dados . . .")
                $("#formCreateEdit_gClassificacaoFinanceira").submit();
            }
        }
        catch (e) {
            LibMessageError("Atenção", "Erro [jsSalvarDados] (" + (e != null ? String(e) : "") + ")");
        }
    };

</script>
