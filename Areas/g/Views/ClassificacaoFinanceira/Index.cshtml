@model IEnumerable<GdiPlataform.Db.g_classificacao_financeira>
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(ViewBag.Title)</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
            </div>
            <div class="card-header m-0 p-1" style="height:100%;">
                @if ((CachePersister.userIdentity.Roles.Contains("g_ClassificacaoFinanceira_*")) || (CachePersister.userIdentity.Roles.Contains("g_ClassificacaoFinanceira_Actioncreate")))
                {<button type="button" name="btnRegistroNovo" title="Novo Registro" class="btn btn-outline-success d-inline-flex align-items-center gap-2" onclick="JsNewRecord('@Url.Action("Create","ClassificacaoFinanceira",new { Area = "g" })')"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button> }
                else
                { <button type="button" name="btnRegistroNovo" title="Novo Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button>}

                @if ((CachePersister.userIdentity.Roles.Contains("g_ClassificacaoFinanceira_*")) || (CachePersister.userIdentity.Roles.Contains("g_ClassificacaoFinanceira_Actionupdate")))
                {<button type="button" name="btnRegistroEditar" title="Editar Registro" class="btn btn-outline-warning d-inline-flex align-items-center gap-2" onclick="jsYesEditRecordJsTree(ojsTree, '@Url.Action("Edit","ClassificacaoFinanceira",new { Area = "g" })/')"><i class="fa-regular fa-edit me-2" aria-hidden="true"></i>Editar</button> }
                else
                { <button type="button" name="btnRegistroEditar" title="Editar Registro - Não Liberado" class="btn btn-outline-warning disabled d-inline-flex align-items-center gap-2"><i class="fa-regular fa-edit me-2" aria-hidden="true"></i>Editar</button>}

                @if ((CachePersister.userIdentity.Roles.Contains("g_ClassificacaoFinanceira_*")) || (CachePersister.userIdentity.Roles.Contains("g_ClassificacaoFinanceira_Actiondelete")))
                {<button type="button" name="btnRegistroExcluir" title="Excluir Registro" class="btn btn-outline-danger disabled d-inline-flex align-items-center gap-2"><i class="fa-regular fa-trash-alt me-2" aria-hidden="true"></i>Excluir</button> }
                else
                { <button type="button" name="btnRegistroExcluir" title="Excluir Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa-regular fa-trash-alt me-2" aria-hidden="true"></i>Excluir</button>}
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-body m-0 p-1" style="height: 100%">
                <div id="jsTree" class="gdi-wunderbaum-host"></div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

    var ojsTree;

    $(function ()
    {
        try
        {
            jsInitForm();
            jsLoadTree();
        }
        catch (err) {
            LibMessageError("Atenção", "[jsLoadForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    var classificacaoFinanceiraTreeData = @Html.Raw((string)(ViewBag.ClassificacaoFinanceiraTreeJson ?? "null"));

    function jsLoadTree()
    {
        try {
            var initTree = function () {
                if (!classificacaoFinanceiraTreeData) {
                    LibMessageError("Atenção", "[jsLoadTree] Dados da árvore não foram gerados no servidor.");
                    return;
                }
                if (typeof GdiTreeInit !== 'function' || !gdiHasWunderbaum()) {
                    LibMessageError("Atenção", "[jsLoadTree] Biblioteca Wunderbaum indisponível.");
                    return;
                }
                ojsTree = GdiTreeInit('#jsTree', classificacaoFinanceiraTreeData);
            };
            var bootTree = function () {
                if (gdiHasWunderbaum()) {
                    initTree();
                    return;
                }
                if (typeof window.GdiEnsureScriptFlags === 'function') {
                    window.GdiEnsureScriptFlags(16, function (err) {
                        if (err) {
                            LibMessageError("Atenção", "[jsLoadTree] Wunderbaum não carregou: " + String(err));
                            return;
                        }
                        initTree();
                    });
                    return;
                }
                var attempts = 0;
                var timer = window.setInterval(function () {
                    attempts++;
                    if (gdiHasWunderbaum()) {
                        window.clearInterval(timer);
                        initTree();
                    } else if (attempts >= 80) {
                        window.clearInterval(timer);
                        LibMessageError("Atenção", "[jsLoadTree] Timeout aguardando Wunderbaum.");
                    }
                }, 50);
            };
            bootTree();
        }
        catch (err) {
            LibMessageError("Atenção", "[jsLoadTree] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

</script>
