@model IEnumerable<GdiPlataform.Db.g_vendedores>
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@ViewBag.Title</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterOperador" value="" name="yesFilterOperador" />
                <input type="hidden" id="yesFilterText" value="" name="yesFilterText" />
                <input type="hidden" id="yesFilterAdvancedText" value="" name="yesFilterAdvancedText" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-header m-0 p-1">
                @if ((CachePersister.userIdentity.Roles.Contains("g_Vendedores_*")) || (CachePersister.userIdentity.Roles.Contains("g_Vendedores_Actioncreate")))
                {<button type="button" name="btnRegistroNovo" title="Novo Registro" class="btn btn-outline-success d-inline-flex align-items-center gap-2" onclick="JsNewRecord('@Url.Action("Create","Vendedores",new { Area = "g" })')"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button> }
                else
                { <button type="button" name="btnRegistroNovo" title="Novo Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button>}
                @if ((CachePersister.userIdentity.Roles.Contains("g_Vendedores_*")) || (CachePersister.userIdentity.Roles.Contains("g_Vendedores_Actionupdate")))
                {<button type="button" name="btnRegistroEditar" title="Editar Registro" class="btn btn-outline-warning d-inline-flex align-items-center gap-2" onclick="JsEditRecord(otableGVendedores, 'Id.', '@Url.Action("Edit","Vendedores",new { Area = "g" })/')"><i class="fa-regular fa-edit me-2" aria-hidden="true"></i>Editar</button> }
                else
                { <button type="button" name="btnRegistroEditar" title="Editar Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa-regular fa-edit me-2" aria-hidden="true"></i>Editar</button>}
                @if ((CachePersister.userIdentity.Roles.Contains("g_Vendedores_*")) || (CachePersister.userIdentity.Roles.Contains("g_Vendedores_Actiondelete")))
                {<button type="button" name="btnRegistroExcluir" title="Excluir Registro" class="btn btn-outline-danger disabled d-inline-flex align-items-center gap-2"><i class="fa-regular fa-trash-alt me-2" aria-hidden="true"></i>Excluir</button> }
                else
                { <button type="button" name="btnRegistroExcluir" title="Excluir Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa-regular fa-trash-alt me-2" aria-hidden="true"></i>Excluir</button>}
                <button type="button" id="btnFiltroDefault" name="btnFiltroDefault" title="Filtro" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2" onclick="jsModalFiltroDefault()"><i class="fa-solid fa-filter me-2" aria-hidden="true"></i>Filtro</button>
            </div>
            <div class="card-body m-0 p-1" style="max-width: 100%; overflow-x: auto; ">
                <div class="form-horizontal m-0 p-0">
                    <div class="table-responsive scroll-body-horizontal" style="width:100%">
                        <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dtGVendedores">
                            <thead>
                                <tr>
                                    <th>[x]</th>
                                    <th>@Html.DisplayNameFor(model => model.id_vendedor)</th>
                                    <th>@Html.DisplayNameFor(model => model.ativo)</th>
                                    <th>@Html.DisplayNameFor(model => model.nome)</th>
                                    <th>Revenda</th>
                                    <th>@Html.DisplayNameFor(model => model.email)</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var otableGVendedores;

	$(function ()
    {
        try
        {
            jsInitForm();
            jsCreateTable();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsCreateTable()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            otableGVendedores = $('#dtGVendedores').on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) { GdiDtNotifyJsonErrorMessage(json); btnFiltro(json.yesFilterOnOff) }).DataTable({
            processing: true,
            bServerSide: true,
            ajax: {
                url: '@Url.Action("GetDados","Vendedores",new { Area = "g" })',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                dataType: 'json',
                cache: false,
                data: function (d) {
                    return {
                        sEcho: d.draw,
                        iDisplayStart: d.start,
                        iDisplayLength: d.length,
                        yesFilterField: $('#yesFilterField').val().toString(),
                        yesFilterOperador: $('#yesFilterOperador').val().toString(),
                        yesFilterText: $('#yesFilterText').val().toString(),
                        yesFilterAdvancedText: $('#yesFilterAdvancedText').val().toString(),
                    };
                },
                error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
            },
            responsive: true,
            bFilter: false,
            bLengthChange: false,
            bProcessing: true,
            pageLength: 20,
            scrollX: false,
            scrollCollapse: false,
            fixedColumns: false,
            bAutoWidth: false,
            pagingType: 'full_numbers',
            aoColumnDefs: [
                { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                { "width": "6%", orderable: false, className: 'text-sm-center', targets: [1] },
                { "width": "8%", orderable: false, className: 'text-sm-center', targets: [2] },
                { "width": "24%", orderable: false, className: 'text-sm-center', targets: [3] },
                { "width": "30%", orderable: false, className: 'text-sm-center', targets: [4] },
                { "width": "28%", orderable: false, className: 'text-sm-center', targets: [5] }
            ],
            select: {
                style: 'multi',
                selector: 'td:not(.dt-no-row-select)',
                headerCheckbox: true
            },
            order: [[1, 'asc']],

                language:
                {
                    sEmptyTable: 'Nenhum registro encontrado',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
            });
            $('#dtGVendedores tbody').on('dblclick', 'tr td', function () {
                var data = otableGVendedores.row($(this).closest('tr')).data();
                JsEditRecordDoubleClick(data[1],'@Url.Action("Edit", "Vendedores", new { Area = "g" })');
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsModalFiltroDefault()
    {
        try {
            if (document.getElementById("btnFiltroDefault").innerHTML.indexOf("Remover") > 0) {
                document.getElementById("yesFilterField").value = "*";
                document.getElementById("yesFilterOperador").value = "";
                document.getElementById("yesFilterText").value = "";
                document.getElementById("yesFilterAdvancedText").value = "";
                $("#dtGVendedores").DataTable().draw(false);
            }
            else {
                $("#mainModal").load('@Url.Action("ModalFiltroGenericoView", "Filtros", new { Area = "a" })?id=g_Vendedores_Index', function () {
                    var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
                })
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalFiltroDefault] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsRunFiltroDefault(filterField, filterOperador, filterText)
    {
        try {
            document.getElementById("yesFilterField").value = filterField;
            document.getElementById("yesFilterOperador").value = filterOperador;
            document.getElementById("yesFilterText").value = filterText;
            document.getElementById("yesFilterAdvancedText").value = "";
            $("#dtGVendedores").DataTable().draw(false);
        }
        catch (err) {
            LibMessageError("Atenção", "[jsRunFiltroDefault] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalCopiarPrecosDeOutraTabelaVendedor(TableName, columnName, columNomeTabela)
    {
        try {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            var selectedNomeTabela = JsGetSelectedRows(TableName, columNomeTabela);
            if (!selectedIds || selectedIds.length == 0)
            {
                GdiSwal2.hideAll();
                LibMessageAlert("Atenção", "Selecione o registro!");
            }
            else {
                if (selectedIds.indexOf(',') == -1) {
                    $("#mainModal").load('@Url.Action("ModalCopiarPrecosDeOutraTabelaVendedor", "Vendedores", new { Area = "g" })' + "?id=" + selectedIds, function () {
                        var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
                    })
                }
                else {
                    LibMessageAlert("Atenção", "Para executar esse processo, selecione apenas 1(um) registro!");
                }
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalCopiarPrecosDeOutraTabelaVendedor] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsAjaxExportarPrecosTabelasVendedores(TableName, columnName, columNomeTabela)
    {
        try {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            var selectedNomeTabela = JsGetSelectedRows(TableName, columNomeTabela);
            if (!selectedIds || selectedIds.length == 0)
            {
                LibMessageAlert("Atenção", "Selecione o registro!");
            }
            else {
                if (selectedIds.indexOf(',') == -1)
                {
                    GdiSwal2.dialog({
                        title: "<i class='fa-solid fa-question' style='color:#ff9900'>&nbsp&nbsp</i><b>Confirmação</b>",
                        closeButton: false,
                        message: "Deseja <b>REALMENTE</b> exportar os preços da tabela <b>" + selectedNomeTabela + "</b> ?" + "<br/><br/>" + "<b>Atenção:</b> O LOG dessa operação será gravado no Banco de Dados e ficará disponível para futuras consultas!",
                        centerVertical: true,
                        onEscape: false,
                        backdrop: true,
                        buttons: {
                            cancelar: {
                                label: '<i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar',
                                className: 'btn-outline-warning',
                                callback: function () {
                                    GdiSwal2.hideAll();
                                }
                            },
                            confirmar: {
                                label: '<i class="fa-solid fa-save me-2" aria-hidden="true"></i>Confirmar',
                                className: 'btn-outline-success',
                                callback: function () { sendAjaxExportarPrecosTabelasVendedores(selectedIds); }
                            }
                        }
                    })
                }
                else
                {
                    LibMessageAlert("Atenção", "Para executar esse processo, selecione apenas 1(um) registro!");
                }
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsAjaxExportarPrecosTabelasVendedores] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function sendAjaxExportarPrecosTabelasVendedores(selectedIds)
    {
        try {
            LibMessageProcessando("Exportando dados . . .")
            var dataForm =
            {
                record_gdc_consultas_tabelas_vendedores:
                {
                    'id_vendedor': selectedIds,
                }
            };
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxExportarPrecosTabelasVendedores", "Vendedores", new { area = "g" })',
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(dataForm),
                dataType: "json",
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        GdiSwal2.dialog({
                            title: "<i class='fa-solid fa-check' style='color:#008000'>&nbsp&nbsp</i><b>Confirmação</b>",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons: {
                                confirmar: {
                                    label: '&nbsp;OK',
                                    className: 'btn btn-info',
                                    callback: function ()
                                    {
                                        $("#dtGVendedores").DataTable().draw(false);
                                        document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                        window.location = '@Url.Action("AjaxGetFileProcessamento", "Global", new { Area = "g" })' + "?id=" + result.idProcessamento;
                                        GdiSwal2.hideAll();
                                    }
                                }
                            }
                        })
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias(result.msg)
                    }
                },
                error: function (result)
                {
                    GdiAjaxNotifyInconsistencias(result.msg)
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[sendAjaxExportarPrecosTabelasVendedores] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsModalAlterarPrecosTabelaVendedor()
    {
        try {
            $("#mainModal").load('@Url.Action("ModalAlterarPrecosTabelaVendedor", "Vendedores", new { Area = "g" })', function () {
                var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
            })
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalAlterarPrecosTabelaVendedor] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

</script>