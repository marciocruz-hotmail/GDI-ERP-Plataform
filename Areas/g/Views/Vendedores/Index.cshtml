@model GdiPlataform.Areas.g.Models.CstVendedoresIndex
@using GdiPlataform.Security
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool podeEditarVendedores = CachePersister.userIdentity.Roles.Contains("g_Vendedores_*")
        || CachePersister.userIdentity.Roles.Contains("g_Vendedores_Actionupdate");
}
<style>
    .gdi-index-vendedores-dt .btnGVendedoresEditRow { gap: 0.125rem; }
</style>
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(ViewBag.Title)</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterController" value="Vendedores" name="yesFilterController" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-header m-0 p-1">
                @if ((CachePersister.userIdentity.Roles.Contains("g_Vendedores_*")) || (CachePersister.userIdentity.Roles.Contains("g_Vendedores_Actioncreate")))
                { <button type="button" name="btnRegistroNovo" title="Novo Registro" class="btn btn-outline-success d-inline-flex align-items-center gap-2" onclick="JsNewRecord('@Url.Action("Create","Vendedores",new { Area = "g" })')"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button> }
                else
                { <button type="button" name="btnRegistroNovo" title="Novo Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button> }
                @if ((CachePersister.userIdentity.Roles.Contains("g_Vendedores_*")) || (CachePersister.userIdentity.Roles.Contains("g_Vendedores_Actiondelete")))
                {<button type="button" name="btnRegistroExcluir" title="Excluir Registro" class="btn btn-outline-danger disabled d-inline-flex align-items-center gap-2"><i class="fa-regular fa-trash-alt me-2" aria-hidden="true"></i>Excluir</button> }
                else
                { <button type="button" name="btnRegistroExcluir" title="Excluir Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa-regular fa-trash-alt me-2" aria-hidden="true"></i>Excluir</button>}

            </div>
            <div class="card-body m-0 p-1" style="height: 100%">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 mt-1 pt-1">
                        @Html.Label("Id", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-2">
                            @Html.TextBoxFor(model => model.VendedoresIndex_id, new { @class = "form-control", @id = "edit_id_vendedor", @placeholder = "Id.", @onkeypress = "keypressedVendedores(event);" })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Nome", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-5">
                            @Html.TextBoxFor(model => model.VendedoresIndex_nome, new { @class = "form-control", @id = "edit_nome_vendedor", @placeholder = "Nome do vendedor", @onkeypress = "keypressedVendedores(event);" })
                        </div>
                        <div class="col-sm-3 text-sm-start">
                            <button type="button" id="btnPesquisarVendedores" title="Pesquisar vendedores" class="btn btn-secondary d-inline-flex align-items-center gap-2" onclick="jsAjaxPesquisarVendedores()"><i class="fa-solid fa-search me-2" aria-hidden="true"></i>Pesquisar</button>
                            <button type="button" id="btnLimparFiltroVendedores" title="Limpar filtro e listar todos" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2 ms-1" onclick="jsLimparFiltroVendedores()"><i class="fa-solid fa-magnifying-glass-minus me-2" aria-hidden="true"></i>Limpar</button>
                        </div>
                    </div>

                </div>
            </div>
            <div class="card-body m-0 p-1 gdi-index-vendedores-dt" style="max-width: 100%; overflow-x: auto;">
                <div class="form-horizontal m-0 p-0">
                    <div class="table-responsive scroll-body-horizontal" style="width:100%">
                        <table class="table table-sm table-hover gdi-dt-zebra align-middle w-100 display compact" style="width:100%" id="dtGVendedores">
                            <thead>
                                <tr>
                                    <th>[x]</th>
                                    <th>Id.</th>
                                    <th>Ativo</th>
                                    <th>Nome</th>
                                    <th>Revenda</th>
                                    <th>E-mail</th>
                                    @if (podeEditarVendedores)
                                    {
                                        <th><i class="fa-regular fa-edit" data-bs-toggle="tooltip" data-bs-placement="top" title="Editar vendedor"></i></th>
                                    }
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var otableGVendedores;

    $(function ()
    {
        try
        {
            jsInitForm();
            jsCreateTable();
            jsAtualizarIndicadorFiltroVendedores('0');
            gdiAplicarFoco('#edit_id_vendedor', true);
            @if (ViewBag.RestoreFilterAutoSearch == true)
            {
                <text>if (jsVendedoresTemCriterioFiltro()) { jsAjaxPesquisarVendedores(); }</text>
            }
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function keypressedVendedores(e)
    {
        if (e.keyCode == 13)
        {
            e.preventDefault();
            jsAjaxPesquisarVendedores();
        }
    }

    function jsVendedoresTemCriterioFiltro()
    {
        return !isEmpty($('#edit_id_vendedor').val()) || !isEmpty($('#edit_nome_vendedor').val());
    }

    function jsAtualizarIndicadorFiltroVendedores(yesFilterOnOff)
    {
        GdiAtualizarIndicadorFiltro(yesFilterOnOff, {
            btnId: 'btnLimparFiltroVendedores',
            tituloInativo: 'Limpar filtro e listar todos',
            tituloAtivo: 'Filtro ativo — limpar e listar todos os vendedores'
        });
    }

    function jsAjaxPesquisarVendedores()
    {
        try
        {
            if (!jsVendedoresTemCriterioFiltro())
            {
                LibMessageAlert("Atenção", "Preencha ao menos um campo do <b>filtro</b> (Id. ou Nome).");
                return;
            }
            LibMessageProcessando('Pesquisando vendedores...');
            document.getElementById("yesFilterField").value = "";
            $("#dtGVendedores").DataTable().draw(false);
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsAjaxPesquisarVendedores] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsLimparFiltroVendedores()
    {
        try
        {
            $('#edit_id_vendedor').val('');
            $('#edit_nome_vendedor').val('');
            document.getElementById("yesFilterField").value = "*";
            LibMessageProcessando('Atualizando lista...');
            $("#dtGVendedores").DataTable().draw(false);
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsLimparFiltroVendedores] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsCreateTable()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            otableGVendedores = $('#dtGVendedores').on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) {
                if (GdiDtNotifyJsonErrorMessage(json)) { }
                else if (json && json.yesFilterOnOff !== undefined) {
                    jsAtualizarIndicadorFiltroVendedores(json.yesFilterOnOff);
                }
            }).DataTable({
            deferLoading: true,
            processing: true,
            bServerSide: true,
            ajax: {
                url: '@Url.Action("GetDados","Vendedores",new { Area = "g" })',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                dataType: 'json',
                cache: false,
                data: function (d) {
                    return {
                        sEcho: d.draw,
                        iDisplayStart: d.start,
                        iDisplayLength: d.length,
                        yesFilterField: $('#yesFilterField').val().toString(),
                        yesFilterController: $('#yesFilterController').val().toString(),
                        yesCustomField01: emptyIfNull($('#edit_id_vendedor').val()).toString(),
                        yesCustomField02: emptyIfNull($('#edit_nome_vendedor').val()).toString()
                    };
                },
                error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
            },
            responsive: true,
            bFilter: false,
            bLengthChange: false,
            bProcessing: true,
            pageLength: 20,
            scrollX: false,
            scrollCollapse: false,
            fixedColumns: false,
            bAutoWidth: false,
            pagingType: 'full_numbers',
            aoColumnDefs: [
                { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                { "width": "6%", orderable: true, className: 'text-sm-center', targets: [1] },
                { "width": "8%", orderable: false, className: 'text-sm-center', targets: [2] },
                { "width": "24%", orderable: true, targets: [3] },
                { "width": "30%", orderable: false, className: 'text-sm-center', targets: [4] },
                { "width": "28%", orderable: false, className: 'text-sm-center', targets: [5] }
                @if (podeEditarVendedores)
                {
                <text>,
                { "width": "4%", orderable: false, className: 'text-sm-center dt-no-row-select', targets: [6], data: null, defaultContent: "",
                    render: function (data, type, row) {
                        return '<button type="button" title="Editar vendedor Id. ' + row[1] + '" class="btn btn-outline-warning btn-sm p-1 btnGVendedoresEditRow d-inline-flex align-items-center" onclick="jsGVendedoresEditRow(' + row[1] + ');"><i class="fa-regular fa-edit"></i></button>';
                    }
                }</text>
                }
            ],
            select: {
                style: 'multi',
                selector: 'td:not(.dt-no-row-select)',
                headerCheckbox: true
            },
            order: [[1, 'asc']],
            drawCallback: function (settings) {
                document.querySelectorAll('#dtGVendedores [data-bs-toggle="tooltip"]').forEach(function (el) {
                    bootstrap.Tooltip.getOrCreateInstance(el);
                });
                try { new $.fn.dataTable.Api(settings).columns.adjust(); } catch (e) { }
            },
                language:
                {
                    sEmptyTable: 'Informe Id. ou Nome e clique em Pesquisar (ou Limpar para listar todos).',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
            });
            @if (podeEditarVendedores)
            {
                <text>$('#dtGVendedores tbody').on('dblclick', 'tr td:not(.dt-no-row-select)', function () {
                var data = otableGVendedores.row($(this).closest('tr')).data();
                if (data) { jsGVendedoresEditRow(data[1]); }
            });</text>
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsGVendedoresEditRow(idPagRecCondicao)
    {
        try {
            var id = parseInt(idPagRecCondicao, 10);
            if (!id || id <= 0) { return; }
            JsEditRecordDoubleClick(id, '@Url.Action("Edit", "Vendedores", new { Area = "g" })');
        }
        catch (err) {
            LibMessageError("Atenção", "[jsGVendedoresEditRow] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }


    function jsModalCopiarPrecosDeOutraTabelaVendedor(TableName, columnName, columNomeTabela)
    {
        try {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            var selectedNomeTabela = JsGetSelectedRows(TableName, columNomeTabela);
            if (!selectedIds || selectedIds.length == 0)
            {
                LibMessageHideAll();
                LibMessageAlert("Aten??o", "Selecione o registro!");
            }
            else {
                if (selectedIds.indexOf(',') == -1) {
                    $("#mainModal").load('@Url.Action("ModalCopiarPrecosDeOutraTabelaVendedor", "Vendedores", new { Area = "g" })' + "?id=" + selectedIds, function () {
                        var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
                    })
                }
                else {
                    LibMessageAlert("Aten??o", "Para executar esse processo, selecione apenas 1(um) registro!");
                }
            }
        }
        catch (err) {
            LibMessageError("Aten??o", "[jsModalCopiarPrecosDeOutraTabelaVendedor] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsAjaxExportarPrecosTabelasVendedores(TableName, columnName, columNomeTabela)
    {
        try {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            var selectedNomeTabela = JsGetSelectedRows(TableName, columNomeTabela);
            if (!selectedIds || selectedIds.length == 0)
            {
                LibMessageAlert("Aten??o", "Selecione o registro!");
            }
            else {
                if (selectedIds.indexOf(',') == -1)
                {
                    LibMessageDialog({
                        title: "Confirma??o",
                        closeButton: false,
                        message: "Deseja <b>REALMENTE</b> exportar os pre?os da tabela <b>" + selectedNomeTabela + "</b> ?" + "<br/><br/>" + "<b>Aten??o:</b> O LOG dessa opera??o ser? gravado no Banco de Dados e ficar? dispon?vel para futuras consultas!",
                        centerVertical: true,
                        onEscape: false,
                        backdrop: true,
                        buttons: {
                            cancelar: {
                                label: '<i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar',
                                className: 'btn-outline-warning',
                                callback: function () {
                                    LibMessageHideAll();
                                }
                            },
                            confirmar: {
                                label: '<i class="fa-solid fa-save me-2" aria-hidden="true"></i>Confirmar',
                                className: 'btn-outline-success',
                                callback: function () { sendAjaxExportarPrecosTabelasVendedores(selectedIds); }
                            }
                        }
                    })
                }
                else
                {
                    LibMessageAlert("Aten??o", "Para executar esse processo, selecione apenas 1(um) registro!");
                }
            }
        }
        catch (err) {
            LibMessageError("Aten??o", "[jsAjaxExportarPrecosTabelasVendedores] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function sendAjaxExportarPrecosTabelasVendedores(selectedIds)
    {
        try {
            LibMessageProcessando("Exportando dados . . .")
            var dataForm =
            {
                record_gdc_consultas_tabelas_vendedores:
                {
                    'id_vendedor': selectedIds,
                }
            };
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxExportarPrecosTabelasVendedores", "Vendedores", new { area = "g" })',
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(dataForm),
                dataType: "json",
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        LibMessageDialog({
                            title: "Confirma??o",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons: {
                                confirmar: {
                                    label: 'OK',
                                    callback: function ()
                                    {
                                        $("#dtGVendedores").DataTable().draw(false);
                                        document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                        window.location = '@Url.Action("AjaxGetFileProcessamento", "Global", new { Area = "g" })' + "?id=" + result.idProcessamento;
                                        LibMessageHideAll();
                                    }
                                }
                            }
                        })
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias(result.msg)
                    }
                },
                error: function (result)
                {
                    GdiAjaxNotifyInconsistencias(result.msg)
                }
            });
        }
        catch (err) {
            LibMessageError("Aten??o", "[sendAjaxExportarPrecosTabelasVendedores] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsModalAlterarPrecosTabelaVendedor()
    {
        try {
            $("#mainModal").load('@Url.Action("ModalAlterarPrecosTabelaVendedor", "Vendedores", new { Area = "g" })', function () {
                var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
            })
        }
        catch (err) {
            LibMessageError("Aten??o", "[jsModalAlterarPrecosTabelaVendedor] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

</script>