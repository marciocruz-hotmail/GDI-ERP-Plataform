@model GdiPlataform.Areas.g.Models.cstExportacaoDadosNFEModel
@{ Layout = null; }
@using (Html.BeginForm())
{
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title d-flex align-items-center gap-2">
    <i class="fa-solid fa-file-alt fa-sm" aria-hidden="true"></i>
    @ViewBag.Title</h5>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-1">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Data Inicial", new { @class = "col-sm-5 col-form-label" })
                        <div class="col-sm-4">
                            @* id do .input-group distinto do input (EditorFor) para Tempus Dominus *@
                            <div class='input-group date' id='ig_g_nfe_export_pdf_d1'>
                                @Html.EditorFor(model => model.datahora_inicial, new { htmlAttributes = new { @class = "form-control", type = "text" } })
                                <span class="input-group-text"><i class="fa-regular fa-calendar-alt"></i></span>
                            </div>
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Data Final", new { @class = "col-sm-5 col-form-label" })
                        <div class="col-sm-4">
                            <div class='input-group date' id='ig_g_nfe_export_pdf_d2'>
                                @Html.EditorFor(model => model.datahora_final, new { htmlAttributes = new { @class = "form-control", type = "text" } })
                                <span class="input-group-text"><i class="fa-regular fa-calendar-alt"></i></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" name="btnCancelar" class="btn btn-warning me-auto d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                <button type="button" name="btnSalvar" title="Exportar Dados NFE (Geração PDF)" class="btn btn-success d-inline-flex align-items-center gap-2" onclick="jsCheckInputs()"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>Exportar Dados NFE (Geração PDF)</button>
            </div>
        </div>
    </div>
}

<script type="text/javascript">
    $(function () {
        try {
            jsDatepicker('#ig_g_nfe_export_pdf_d1');
            jsDatepicker('#ig_g_nfe_export_pdf_d2');
            jsInitModal();
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsCheckInputs()
    {
        try {
            var valueDate1;
            var valueDate2;
            try
            {
                valueDate1 = jsDatepickerGetDate('#ig_g_nfe_export_pdf_d1');
                valueDate2 = jsDatepickerGetDate('#ig_g_nfe_export_pdf_d2');
                if (valueDate1 > valueDate2)
                {
                    LibMessageAlert("Atenção", "Período de datas inválido!");
                }
                else
                {
                    jsSendForm();
                }
            }
            catch(exception)
            {
                GdiAjaxNotifyInconsistencias(exception.toString())
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCheckInputs] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsSendForm()
    {
        try {
            LibMessageProcessando("Exportando Dados . . .");
            var dataForm =
            {
                record_cstExportacaoDadosNFEModel:
                {
                    'datahora_inicial': jsGetDateDDMMYYYY(jsDatepickerGetDate('#ig_g_nfe_export_pdf_d1')),
                    'datahora_final': jsGetDateDDMMYYYY(jsDatepickerGetDate('#ig_g_nfe_export_pdf_d2'))
                }
            };
            $.ajax({
                type: "POST",
                url: '@Url.Action("ajaxExportarDadosNfePDF", "Nfe", new { area = "g" })',
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(dataForm),
                dataType: "json",
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        GdiSwal2.dialog({
                            title: "<i class='fa-solid fa-check' style='color:#008000'>&nbsp&nbsp</i><b>Confirmação</b>",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons: {
                                confirmar: {
                                    label: '&nbsp;OK',
                                    className: 'btn btn-info',
                                    callback: function () {
                                        document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                        window.location = '@Url.Action("AjaxGetFileProcessamento", "Global", new { Area = "g" })' + "?id=" + result.idProcessamento;
                                        GdiSwal2.hideAll();
                                    }
                                }
                            }
                        })
                    }
                    else {
                        GdiAjaxNotifyInconsistencias(result.msg);
                    }
                },
                error: function (result)
                {
                    GdiAjaxNotifyInconsistencias(result.toString())
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

</script>
