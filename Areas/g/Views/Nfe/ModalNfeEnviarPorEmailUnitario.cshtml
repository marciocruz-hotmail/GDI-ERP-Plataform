@model GdiPlataform.Db.g_nfe
@{ Layout = null; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "formModalNfeEnviarPorEmailUnitario_g_Nfe" }))
{
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title d-flex align-items-center gap-2">@Html.Raw(ViewBag.Title)</h5>
                @Html.HiddenFor(model => model.id_nfe)                
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-1">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Id Nfe", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-7">
                            @Html.Label("Id Nfe", Model.id_nfe.ToString())
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Nome", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-7">
                            @Html.Label("Nome", Model.nome.ToString())
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("CNPJ", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-7">
                            @Html.Label("CNPJ", (string)ViewBag.cnpj)
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("E-mail", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-7">
                            @Html.Label("E-mail", Model.email.ToString())
                        </div>
                    </div>                    
                </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">                
                <button type="button" name="btnCancelar" title="Cancelar" class="btn btn-warning dt-left d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                <button type="button" name="btnSalvar" title="Confirmar" class="btn btn-success d-inline-flex align-items-center gap-2" onclick="jsSendForm()"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>Confirmar</button>
            </div>
        </div>
    </div>
}
<script type="text/javascript">

	$(function ()
    {
        try
        {
            jsInitModal();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsSendForm()
    {        
        try
        {
            LibMessageProcessando("Envio de Emails . . .")
            var form = $('#formModalNfeEnviarPorEmailUnitario_g_Nfe');
            $.ajax({
                cache: false,
                async: true,
                type: "POST",
                url: '@Url.Action("AjaxNfeEnviarPorEmailUnitario", "Nfe", new { area = "g" })',
                data: form.serialize(),
                success: function (result) {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                                                LibMessageSuccess('Processando Envio NFe Por E-mail', result.msg, {
                            backdrop: true,
                            callback: function () {
                            $("#dtGNfe").DataTable().draw(false);
                            document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                            if (result.idProcessamento != "0")
                            {
                            window.location = '@Url.Action("ajaxGetFileProcessamento", "Global", new { Area = "g" })' + "?id=" + result.idProcessamento;
                            }
                            LibMessageHideAll();
                            }
                        });
                    }
                    else {
                        LibMessageProcessandoHide();
                        GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.')
                    }
                },
                error: function (xhr, textStatus, errorThrown) {
                    LibMessageProcessandoHide();
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.')
                }
            });
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };
</script>


