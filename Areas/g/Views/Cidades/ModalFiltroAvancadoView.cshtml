@{ Layout = null; }
@using (Html.BeginForm())
{
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title"><i class="fa-solid fa-filter me-2" aria-hidden="true"></i>@Html.Raw(@ViewBag.Title)</h5>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-1">
                <div class="form-horizontal m-0 p-1">
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Id", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                        <div class="col-sm-3">
                            <input type="text" class="form-control" id="editId" placeholder="Id." onkeypress="keypressed(event)">
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Nome", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="editNome" placeholder="Nome" onkeypress="keypressed(event)">
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" name="btnCancelar" title="Cancelar" class="btn btn-warning me-auto d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                <button type="button" name="btnExec" title="Filtrar" class="btn btn-success d-inline-flex align-items-center gap-2" onclick="jsRunFiltroAvancadoModal()"><i class="fa-solid fa-filter me-2" aria-hidden="true"></i>Filtrar</button>
            </div>
        </div>
    </div>
}

<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsInitModal();
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function keypressed(e) {
        if (e.keyCode == 13) { e.preventDefault(); jsRunFiltroAvancadoModal(); }
    }

    function jsRunFiltroAvancadoModal()
    {
        try
        {
            if (isEmpty($('#editId').val().toString().trim()) && isEmpty($('#editNome').val().toString().trim()))
            {
                yesMessageAlertSmall("Atenção", "Preencha corretamente os campos do <b>Filtro</b>");
            }
            else
            {
                jsRunFiltroAvancado($('#editId').val().toString() + ";" + $('#editNome').val().toString());
                document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsRunFiltroAvancadoModal] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }
</script>



