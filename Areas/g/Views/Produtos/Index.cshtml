@model IEnumerable<GdiPlataform.Db.g_produtos>
@using GdiPlataform.Security
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool podeEditarProduto = CachePersister.userIdentity.Roles.Contains("g_Produtos_*")
        || CachePersister.userIdentity.Roles.Contains("g_Produtos_Actionupdate");
    bool podeVerFichaEstoque = CachePersister.userIdentity.Roles.Contains("g_Produtos_*")
        || CachePersister.userIdentity.Roles.Contains("g_Produtos_Actionread");
}
<style>
    .gdi-index-produtos-dt .btnGProdutosFichaEstoque { gap: 0.125rem; }
</style>
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(ViewBag.Title)</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterController" value="Produtos" name="yesFilterController" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-header m-0 p-1">

                @if ((CachePersister.userIdentity.Roles.Contains("g_Produtos_*")) || (CachePersister.userIdentity.Roles.Contains("g_Produtos_Actionrun")))
                {
                    int qtdMenus = 0;
                    <div class="btn-group" role="group">
                        <button id="btnGroupDrop1" type="button" class="btn btn-outline-info dropdown-toggle d-inline-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="Processos">
                            <i class="fa-solid fa-cog me-2" aria-hidden="true"></i>Processos
                        </button>
                        <div class="dropdown-menu" aria-labelledby="btnGroupDrop1">
                            <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalDesativarCadastroProduto(otableGProdutos, 'Id.')"><i class="fa-solid fa-toggle-off me-2" aria-hidden="true"></i>Produtos - Desativar o Cadastro</a>
                            @if (CachePersister.userIdentity.IdUsuario == 1)
                            {
                                <div class="dropdown-divider"></div>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalAtualizarCadastroProdutos()"><i class="fa-solid fa-sync me-2" aria-hidden="true"></i>Produtos - Atualizar Cadastro</a>
                            }
                        </div>
                    </div>
                }
            </div>
            <div class="card-body m-0 p-1" style="height: 100%">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 mt-1 pt-1">
                        @Html.Label("Id", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-2">
                            <input type="text" class="form-control" id="edit_id_produto" placeholder="Id." value="@(ViewBag.RestoreFilterId ?? "")" onkeypress="keypressed(event);" />
                        </div>
                        @Html.Label("PN", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-2">
                            <input type="text" class="form-control" id="edit_codigo" placeholder="PN" value="@(ViewBag.RestoreFilterPn ?? "")" onkeypress="keypressed(event);" />
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Produto", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-5">
                            <input type="text" class="form-control" id="edit_nome" placeholder="Nome do produto (qualquer parte)" value="@(ViewBag.RestoreFilterNome ?? "")" onkeypress="keypressed(event);" />
                        </div>
                        <div class="col-sm-2 text-sm-start">
                            <button type="button" id="btnPesquisar" name="btnPesquisar" title="Pesquisar produtos" class="btn btn-secondary d-inline-flex align-items-center gap-2" onclick="jsAjaxPesquisarProdutos()"><i class="fa-solid fa-search me-2" aria-hidden="true"></i>Pesquisar</button>
                            <button type="button" id="btnLimparFiltroProdutos" name="btnLimparFiltroProdutos" title="Limpar filtro e listar todos" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2 ms-1" onclick="jsLimparFiltroProdutos()"><i class="fa-solid fa-magnifying-glass-minus me-2" aria-hidden="true"></i>Limpar</button>
                        </div>
                        <div class="col-sm-2 text-sm-start">
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body m-0 p-1 gdi-index-produtos-dt" style="max-width: 100%; overflow-x: auto; ">
                <div class="form-horizontal m-0 p-0">
                    <div class="table-responsive scroll-body-horizontal" style="width:100%">
                        <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dtGProdutos">
                            <thead>
                                <tr>
                                    <th>[x]</th>
                                    <th>@Html.Encode("Id.")</th>
                                    <th>@Html.Encode("Tipo")</th>
                                    <th>@Html.Encode("PN")</th>
                                    <th>@Html.Encode("Produto")</th>
                                    <th>@Html.DisplayName("Fob (US$)")</th>
                                    <th><i class="fa-solid fa-warehouse" style="cursor: pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Estoque BH"></i><br/>BH</th>
                                    <th><i class="fa-solid fa-warehouse" style="cursor: pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Estoque SP"></i><br/>SP</th>
                                    @if (podeVerFichaEstoque)
                                    {
                                        <th><i class="fa-solid fa-warehouse" style="cursor: pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Ficha de estoque do produto"></i><br/>Ficha</th>
                                    }
                                    @if (podeEditarProduto)
                                    {
                                        <th><i class="fa-regular fa-edit" data-bs-toggle="tooltip" data-bs-placement="top" title="Editar produto"></i></th>
                                    }
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var otableGProdutos;

 	$(function ()
    {
        try
        {
            jsInitForm();
            jsCreateTable();
            jsAtualizarIndicadorFiltroProdutos('0');
            gdiAplicarFoco('#edit_id_produto', true);
            @if (ViewBag.RestoreFilterAutoSearch == true)
            {
                <text>if (jsProdutosTemCriterioFiltro()) { jsAjaxPesquisarProdutos(); }</text>
            }
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function keypressed(e)
    {
        if (e.keyCode == 13)
        {
            e.preventDefault();
            jsAjaxPesquisarProdutos();
        }
    }

    function jsProdutosTemCriterioFiltro()
    {
        return !isEmpty($('#edit_id_produto').val())
            || !isEmpty($('#edit_codigo').val())
            || !isEmpty($('#edit_nome').val());
    }

    function jsAtualizarIndicadorFiltroProdutos(yesFilterOnOff)
    {
        GdiAtualizarIndicadorFiltro(yesFilterOnOff, {
            btnId: 'btnLimparFiltroProdutos',
            tituloInativo: 'Limpar filtro e listar todos',
            tituloAtivo: 'Filtro ativo — limpar e listar todos os produtos'
        });
    }

    function jsAjaxPesquisarProdutos()
    {
        try
        {
            if (!jsProdutosTemCriterioFiltro())
            {
                LibMessageAlert("Atenção", "Preencha ao menos um campo do <b>filtro</b> (Id., PN ou Produto).");
                return;
            }
            LibMessageProcessando('Pesquisando produtos...');
            document.getElementById("yesFilterField").value = "";
            $("#dtGProdutos").DataTable().draw(false);
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsAjaxPesquisarProdutos] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsLimparFiltroProdutos()
    {
        try
        {
            $('#edit_id_produto').val('');
            $('#edit_codigo').val('');
            $('#edit_nome').val('');
            document.getElementById("yesFilterField").value = "*";
            LibMessageProcessando('Atualizando lista...');
            $("#dtGProdutos").DataTable().draw(false);
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsLimparFiltroProdutos] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsCreateTable()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            otableGProdutos = $('#dtGProdutos')
                .on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message);
                })
                .on('xhr.dt', function (e, settings, json, xhr) {
                    if (GdiDtNotifyJsonErrorMessage(json)) { return; }
                    else if (json && json.yesFilterOnOff !== undefined) {
                        jsAtualizarIndicadorFiltroProdutos(json.yesFilterOnOff);
                    }
                    LibMessageProcessandoHide();
                })
                .DataTable({
            deferLoading: true,
            processing: true,
            bServerSide: true,
            ajax: {
                url: '@Url.Action("GetDados","Produtos",new { Area = "g" })',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                dataType: 'json',
                cache: false,
                data: function (d) {
                    return {
                        sEcho: d.draw,
                        iDisplayStart: d.start,
                        iDisplayLength: d.length,
                        yesFilterField: $('#yesFilterField').val().toString(),
                        yesFilterController: $('#yesFilterController').val().toString(),
                        yesCustomField01: emptyIfNull($('#edit_id_produto').val()).toString(),
                        yesCustomField02: emptyIfNull($('#edit_codigo').val()).toString(),
                        yesCustomField03: emptyIfNull($('#edit_nome').val()).toString(),
                    };
                },
                error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown);
                }
            },
            responsive: true,
            bFilter: false,
            bLengthChange: false,
            bProcessing: true,
            pageLength: 20,
            scrollX: false,
            scrollCollapse: false,
            fixedColumns: false,
            bAutoWidth: false,
            pagingType: 'full_numbers',
            aoColumnDefs: [
                { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                { "width": "4%", orderable: false, className: 'text-sm-center', targets: [1] },
                { "width": "4%", orderable: false, className: 'text-sm-center', targets: [2] },
                { "width": "10%", orderable: false, className: 'text-sm-start', targets: [3] },
                { "width": "54%", orderable: false, className: 'text-sm-start', targets: [4] },
                { "width": "5%", orderable: false, className: 'text-sm-end', targets: [5] },
                { "width": "5%", orderable: false, className: 'text-sm-end', targets: [6] },
                { "width": "5%", orderable: false, className: 'text-sm-end', targets: [7] }
                @if (podeVerFichaEstoque)
                {
                <text>,
                { "width": "5%", orderable: false, className: 'text-sm-end dt-no-row-select', targets: [8], data: null, defaultContent: "",
                    render: function (data, type, row, meta) {
                        return '<button type="button" name="btnGProdutosFichaEstoque" data-bs-toggle="tooltip" data-bs-placement="top" title="Ficha de estoque — Id. ' + row[1] + '" class="btn btn-outline-info btn-sm p-1 btnGProdutosFichaEstoque d-inline-flex align-items-center" onclick="jsGProdutosFichaEstoque(' + row[1] + ');"><i class="fa-solid fa-warehouse"></i></button>';
                    }
                }</text>
                }
                @if (podeEditarProduto)
                {
                <text>,
                { "width": "4%", orderable: false, className: 'text-sm-center dt-no-row-select', targets: [@(podeVerFichaEstoque ? 9 : 8)], data: null, defaultContent: "",
                    render: function (data, type, row) {
                        return '<button type="button" title="Editar produto Id. ' + row[1] + '" class="btn btn-outline-warning btn-sm p-1 d-inline-flex align-items-center" onclick="jsGProdutosEditRow(' + row[1] + ');"><i class="fa-regular fa-edit"></i></button>';
                    }
                }</text>
                }
            ],
            select: {
                style: 'multi',
                selector: 'td:not(.dt-no-row-select)',
                headerCheckbox: true
            },
            order: [[1, 'desc']],
            drawCallback: function (settings) {
                document.querySelectorAll('#dtGProdutos [data-bs-toggle="tooltip"]').forEach(function (el) {
                    bootstrap.Tooltip.getOrCreateInstance(el);
                });
                try { new $.fn.dataTable.Api(settings).columns.adjust(); } catch (e) { }
            },
            footerCallback: function (row, data, start, end, display) {
                LibMessageProcessandoHide();
                gdiAplicarFoco('#edit_id_produto', true);
            },

                language:
                {
                    sEmptyTable: 'Informe Id., PN ou Produto e clique em Pesquisar (ou Limpar para listar todos).',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
            });
            @if (podeEditarProduto)
            {
                <text>$('#dtGProdutos tbody').on('dblclick', 'tr td:not(.dt-no-row-select)', function () {
                var data = otableGProdutos.row($(this).closest('tr')).data();
                if (data) { jsGProdutosEditRow(data[1]); }
            });</text>
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsModalAtualizarCadastroProdutos()
    {
        try {
            $("#mainModal").load('@Url.Action("ModalAtualizarCadastroProdutos", "Produtos", new { Area = "g" })', function () {
                var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
            })
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalAtualizarCadastroProdutos] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalDesativarCadastroProduto(TableName, columnName)
    {
        try {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            if (!selectedIds || selectedIds.length == 0)
            {
                LibMessageAlert("Atenção", "Selecione o registro!");
            }
            else
            {
                if (selectedIds.indexOf(',') == -1)
                {
                    $("#mainModal").load('@Url.Action("ModalDesativarCadastroProduto", "Produtos", new { Area = "g" })?id=' + selectedIds, function () {
                        var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
                    })
                }
                else
                {
                    LibMessageAlert("Atenção", "Para executar esse processo, selecione apenas 1(um) registro!");
                }
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalDesativarCadastroProduto] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalCreateEditProduto(idProduto)
    {
        try
        {
            LibMessageProcessando("");
            $("#mainModal").load('@Url.Action("ModalCreateEditProduto", "Produtos", new { Area = "g" })?IdProduto=' + emptyIfNull(idProduto).toString(), function () {
                var e = document.getElementById('mainModal');
                if (e) { bootstrap.Modal.getOrCreateInstance(e).show(); }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalCreateEditProduto] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsGProdutosEditRow(idProduto)
    {
        try {
            var id = parseInt(idProduto, 10);
            if (!id || id <= 0) { return; }
            jsModalCreateEditProduto(id);
        }
        catch (err) {
            LibMessageError("Atenção", "[jsGProdutosEditRow] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsGProdutosFichaEstoque(idProduto)
    {
        try {
            var id = parseInt(idProduto, 10);
            if (!id || id <= 0) {
                LibMessageAlert("Atenção", "Identificador do produto inválido.");
                return;
            }
            $("#mainModal").load('@Url.Action("ModalViewFichaEstoqueProduto", "Produtos", new { Area = "g" })?id=' + id, function () {
                var e = document.getElementById('mainModal');
                if (e) { bootstrap.Modal.getOrCreateInstance(e).show(); }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsGProdutosFichaEstoque] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalViewFichaEstoqueProduto(TableName, columnName)
    {
        try {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            if (!selectedIds || selectedIds.length == 0)
            {
                LibMessageAlert("Atenção", "Selecione o registro!");
            }
            else if (selectedIds.indexOf(',') == -1)
            {
                jsGProdutosFichaEstoque(selectedIds);
            }
            else
            {
                LibMessageAlert("Atenção", "Para executar esse processo, selecione apenas 1(um) registro!");
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalViewFichaEstoqueProduto] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

</script>
