@model GdiPlataform.Db.g_produtos
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Modal.cshtml"; }
<style>
    #formCreateEdit_gProdutos .modal-body {
        overflow-y: auto;
        max-height: calc(100vh - 170px);
        overflow-x: hidden;
    }

    #divProdutoAuditDt {
        min-width: 0;
    }

    #divProdutoAuditDt.gdi-dt-scroll-host {
        overflow-x: hidden;
    }
</style>
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "formCreateEdit_gProdutos" }))
{
    <div class="modal-dialog modal-full modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title d-flex align-items-center gap-2">@Html.Raw(ViewBag.Title)</h5>
                @Html.HiddenFor(model => model.id_produto)
                @Html.HiddenFor(model => model.is_servico)
                @Html.HiddenFor(model => model.codigo_auxiliar)
                @Html.HiddenFor(model => model.id_produto_grupo)
                @Html.HiddenFor(model => model.nome_etiqueta)
                @Html.HiddenFor(model => model.codigo_barras)
                @Html.HiddenFor(model => model.id_coligada)
                @Html.HiddenFor(model => model.id_filial)
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-0">
                @if (@Model.bloqueado == true)
                {
                    @Html.Partial("_AlertMsg", AlertMsgItem.Maybe("ATENÇÃO: Esse PRODUTO não poderá ser alterado!", "warning"))
                }
                <ul class="nav nav-tabs" id="crud-tabs" role="tablist">
                        <li class="nav-item"><a class="d-flex align-items-center nav-link active" id="tabDados_tab" data-bs-toggle="pill" href="#tabDados" role="tab" aria-controls="crud-tabs" aria-selected="true"><i class="fa-solid fa-file-pen fa-sm" aria-hidden="true"></i>Dados</a></li>
                        @if (@Model.is_servico == false)
                        {
                            <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabParametros_tab" data-bs-toggle="pill" href="#tabParametros" role="tab" aria-controls="crud-tabs" aria-selected="false"><i class="fa-solid fa-sliders fa-sm" aria-hidden="true"></i>Parâmetros</a></li>
                            <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabEnderecoEstoque_tab" data-bs-toggle="pill" href="#tabEnderecoEstoque" role="tab" aria-controls="crud-tabs" aria-selected="false"><i class="fa-solid fa-location-dot fa-sm" aria-hidden="true"></i>Endereço Estoque</a></li>
                        }
                        @if (@Model.id_produto > 0)
                        {
                            <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabAudit_tab" data-bs-toggle="pill" href="#tabAudit" role="tab" aria-controls="custom-tabs-one-settings" aria-selected="false"><i class="fa-solid fa-magnifying-glass-arrow-right fa-sm" aria-hidden="true"></i>Audit</a></li>
                        }
                    </ul>
                <div class="form-horizontal m-0 p-0">
                        <div class="tab-content" id="crud-tabs-content">
                            <!-- ABA DADOS - INÍCIO -->
                            <div class="tab-pane fade show active" id="tabDados" role="tabpanel" aria-labelledby="tabDados_tab">
                                <div class="card-body m-0 p-1" style="height: 100%">
                                    <div class="card shadow-sm gdi-section-accent-secondary m-1 p-0">
                                        <div class="section-header"><i class="fa-solid fa-boxes-stacked me-1" aria-hidden="true"></i>Dados do Produto</div>
                                        <div class="card-body m-1 p-1" style="height: 100%">
                                            <div class="form-group row text-sm-end m-0 pt-1">
                                                @Html.Label("id_produto_tipo", "Tipo", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                <div class="col-sm-2">
                                                    @Html.DropDownListFor(model => model.id_produto_tipo, ViewBag.comboProdutosTipos as List<SelectListItem>, new { @class = "form-control" })
                                                </div>
                                                @Html.Label("codigo", "PN", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                <div class="col-sm-2">
                                                    @Html.EditorFor(model => model.codigo, new { htmlAttributes = new { @class = "form-control", data_autofocus = "true" } })
                                                </div>
                                                <div class="col-sm-1">
                                                    &nbsp;
                                                </div>
                                                @if (@Model.is_servico == false)
                                                {

                                                    if ((CachePersister.userIdentity.Roles.Contains("g_Produtos_*")) || (CachePersister.userIdentity.Roles.Contains("g_Produtos_Actionupdate")))
                                                    {
                                                        <div class="col-sm-2 text-sm-start" style="margin-top:7px;">
                                                            <div class="form-check form-switch d-inline-flex align-items-center flex-nowrap">
                                                                @Html.CheckBoxFor(model => model.importado, new { @class = "form-check-input switch-success", role = "switch" })
                                                                <span class="form-check-label ms-1 mb-0">Produto Validado</span>
                                                            </div>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        if (@Model.importado == true)
                                                        {
                                                            <div class="col-sm-1 text-sm-start">
                                                                @Html.Label("importado", "Produto Validado", htmlAttributes: new { @class = "col-form-label", @style = "margin-top:5px; color:#0E6655;" })
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="col-sm-1 text-sm-start">
                                                                @Html.Label("importado", "Produto Temporário", htmlAttributes: new { @class = "col-form-label", @style = "margin-top:5px; color:#9A0202;" })
                                                            </div>
                                                        }
                                                    }
                                                    <div class="col-sm-2 text-sm-start" style="margin-top:7px;">
                                                        <div class="form-check form-switch d-inline-flex align-items-center flex-nowrap">
                                                            @Html.CheckBoxFor(model => model.has_corecharge, new { @class = "form-check-input switch-success", role = "switch" })
                                                            <span class="form-check-label ms-1 mb-0">Core Charge</span>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    @Html.HiddenFor(model => model.importado)
                                                    @Html.HiddenFor(model => model.has_corecharge)
                                                }
                                            </div>
                                            <div class="form-group row text-sm-end m-0 pt-1">
                                                @Html.Label("nome", "Produto", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                <div class="col-sm-8">
                                                    @Html.EditorFor(model => model.nome, new { htmlAttributes = new { @class = "form-control" } })
                                                </div>
                                                @if (@Model.is_servico == false)
                                                {
                                                    @Html.Label("nome", "Saldo BH", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                    <div class="col-sm-2">
                                                        @Html.EditorFor(model => model.saldo_01_disponivel, new { htmlAttributes = new { @class = "form-control" } })
                                                    </div>
                                                }

                                            </div>
                                            <div class="form-group row text-sm-end m-0 pt-1">
                                                @Html.Label("descricao", "Descrição", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                <div class="col-sm-8">
                                                    @Html.TextAreaFor(model => model.descricao, new { @class = "form-control", @rows = "3" })
                                                </div>
                                                @if (@Model.is_servico == false)
                                                {
                                                    @Html.Label("nome", "Saldo SP", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                    <div class="col-sm-2">
                                                        @Html.EditorFor(model => model.saldo_03_disponivel, new { htmlAttributes = new { @class = "form-control" } })
                                                    </div>
                                                }
                                            </div>
                                            <div class="form-group row text-sm-end m-0 pt-1">
                                                @if (@Model.is_servico == false)
                                                {
                                                    @Html.Label("NCM", "NCM", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                    <div class="col-sm-3">
                                                        @Html.DropDownListFor(model => model.id_produto_ncm, ViewBag.comboProdutosNCM as List<SelectListItem>, new { @class = "form-control" })
                                                    </div>
                                                    @Html.Label("Un", "Un", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                    <div class="col-sm-1">
                                                        @Html.DropDownListFor(model => model.id_unidade_medida_compra, ViewBag.comboUnidadeMedida as List<SelectListItem>, new { @class = "form-control" })
                                                    </div>
                                                    @Html.Label("Peso", "Peso", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                    <div class="col-sm-2">
                                                        @Html.EditorFor(model => model.peso, new { htmlAttributes = new { @class = "form-control" } })
                                                    </div>
                                                }

                                            </div>
                                        </div>
                                    </div>

                                    @if (@Model.is_servico == false)
                                    {
                                        <div class="card shadow-sm gdi-section-accent-secondary m-1 p-0">
                                            <div class="section-header"><i class="fa-solid fa-circle-info me-1" aria-hidden="true"></i>FOB</div>
                                            <div class="card-body m-1 p-1" style="height: 100%">
                                                <div class="form-group row text-sm-end m-0 pt-1">
                                                    @Html.Label("fob1_dollar", "Fob1 (US$)", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                                    <div class="col-sm-2">
                                                        @Html.EditorFor(model => model.fob1_dollar, new { htmlAttributes = new { @class = "form-control" } })
                                                    </div>
                                                    @Html.Label("fob1_id_importacao", "Importação", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                                    <div class="col-sm-5">
                                                        @Html.DropDownListFor(model => model.fob1_id_importacao, ViewBag.ComboComexImportacoes as List<SelectListItem>, new { @class = "form-control" })
                                                    </div>
                                                </div>
                                                <div class="form-group row text-sm-end m-0 pt-1">
                                                    @Html.Label("fob2_dollar", "Fob2 (US$)", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                                    <div class="col-sm-2">
                                                        @Html.EditorFor(model => model.fob2_dollar, new { htmlAttributes = new { @class = "form-control" } })
                                                    </div>
                                                    @Html.Label("fob2_id_importacao", "Importação", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                                    <div class="col-sm-5">
                                                        @Html.DropDownListFor(model => model.fob2_id_importacao, ViewBag.ComboComexImportacoes as List<SelectListItem>, new { @class = "form-control" })
                                                    </div>
                                                </div>
                                                <div class="form-group row text-sm-end m-0 pt-1">
                                                    @Html.Label("fob3_dollar", "Fob3 (US$)", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                                    <div class="col-sm-2">
                                                        @Html.EditorFor(model => model.fob3_dollar, new { htmlAttributes = new { @class = "form-control" } })
                                                    </div>
                                                    @Html.Label("fob3_id_importacao", "Importação", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                                    <div class="col-sm-5">
                                                        @Html.DropDownListFor(model => model.fob3_id_importacao, ViewBag.ComboComexImportacoes as List<SelectListItem>, new { @class = "form-control" })
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                            <!-- ABA DADOS - FIM -->

                            @if (@Model.is_servico == false)
                            {
                            <!-- ABA PARÂMETROS - INÍCIO -->
                            <div class="tab-pane fade" id="tabParametros" role="tabpanel" aria-labelledby="tabParametros_tab">
                                <div class="card-body m-0 p-1" style="height: 100%">
                                    <div class="card shadow-sm gdi-section-accent-secondary m-1 p-0">
                                        <div class="section-header"><i class="fa-solid fa-circle-info me-1" aria-hidden="true"></i>Parâmetros</div>
                                        <div class="card-body m-1 p-1" style="height: 100%">

                                            <div class="form-group row text-sm-end m-0 pt-1">
                                                <div class="col-sm-1 text-sm-end" style="margin-top:7px;">
                                                    <div class="form-check form-switch d-flex justify-content-end">
                                                        @Html.CheckBoxFor(model => model.item_regulado_ibama, new { @class = "form-check-input switch-success", role = "switch" })
                                                    </div>
                                                </div>
                                                <div class="col-sm-2 text-sm-start" style="margin-top:5px;">
                                                    @Html.Label("item_regulado_ibama", "Regulado IBAMA")
                                                </div>
                                                <div class="col-sm-1 text-sm-end" style="margin-top:7px;">
                                                    <div class="form-check form-switch d-flex justify-content-end">
                                                        @Html.CheckBoxFor(model => model.item_regulado_anp, new { @class = "form-check-input switch-success", role = "switch" })
                                                    </div>
                                                </div>
                                                <div class="col-sm-2 text-sm-start" style="margin-top:5px;">
                                                    @Html.Label("item_regulado_anp", "Regulado ANP")
                                                </div>
                                                @Html.Label("codigo_anp", "Código ANP", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                <div class="col-sm-2">
                                                    @Html.EditorFor(model => model.codigo_anp, new { htmlAttributes = new { @class = "form-control" } })
                                                </div>
                                            </div>
                                            <div class="form-group row text-sm-end m-0 pt-1">
                                                <div class="col-sm-1 text-sm-end" style="margin-top:7px;">
                                                    <div class="form-check form-switch d-flex justify-content-end">
                                                        @Html.CheckBoxFor(model => model.item_regulado_pf, new { @class = "form-check-input switch-success", role = "switch" })
                                                    </div>
                                                </div>
                                                <div class="col-sm-2 text-sm-start" style="margin-top:5px;">
                                                    @Html.Label("item_regulado_pf", "Regulado PF")
                                                </div>
                                                <div class="col-sm-1 text-sm-end" style="margin-top:7px;">
                                                    <div class="form-check form-switch d-flex justify-content-end">
                                                        @Html.CheckBoxFor(model => model.item_regulado_joguelimpo, new { @class = "form-check-input switch-success", role = "switch" })
                                                    </div>
                                                </div>
                                                <div class="col-sm-2 text-sm-start" style="margin-top:5px;">
                                                    @Html.Label("item_regulado_pf", "Regulado Jogue Limpo")
                                                </div>
                                            </div>
                                            <div class="form-group row text-sm-end m-0 pt-1">
                                                <div class="col-sm-1 text-sm-end" style="margin-top:7px;">
                                                    <div class="form-check form-switch d-flex justify-content-end">
                                                        @Html.CheckBoxFor(model => model.controla_estoque, new { @class = "form-check-input switch-success", role = "switch" })
                                                    </div>
                                                </div>
                                                <div class="col-sm-2 text-sm-start" style="margin-top:5px;">
                                                    @Html.Label("controla_estoque", "Controla Estoque")
                                                </div>
                                                <div class="col-sm-1 text-sm-end" style="margin-top:7px;">
                                                    <div class="form-check form-switch d-flex justify-content-end">
                                                        @Html.CheckBoxFor(model => model.controla_serial, new { @class = "form-check-input switch-success", role = "switch" })
                                                    </div>
                                                </div>
                                                <div class="col-sm-2 text-sm-start" style="margin-top:5px;">
                                                    @Html.Label("controla_serial", "Controla Serial")
                                                </div>
                                                <div class="col-sm-1 text-sm-end" style="margin-top:7px;">
                                                    <div class="form-check form-switch d-flex justify-content-end">
                                                        @Html.CheckBoxFor(model => model.controla_lote, new { @class = "form-check-input switch-success", role = "switch" })
                                                    </div>
                                                </div>
                                                <div class="col-sm-2 text-sm-start" style="margin-top:5px;">
                                                    @Html.Label("controla_lote", "Controla Lote")
                                                </div>
                                            </div>
                                            <div class="form-group row text-sm-end m-0 pt-1">
                                                <div class="col-sm-1 text-sm-end" style="margin-top:7px;">
                                                    <div class="form-check form-switch d-flex justify-content-end">
                                                        @Html.CheckBoxFor(model => model.item_venda, new { @class = "form-check-input switch-success", role = "switch" })
                                                    </div>
                                                </div>
                                                <div class="col-sm-2 text-sm-start" style="margin-top:5px;">
                                                    @Html.Label("item_venda", "Item Venda")
                                                </div>

                                                <div class="col-sm-1 text-sm-end" style="margin-top:7px;">
                                                    <div class="form-check form-switch d-flex justify-content-end">
                                                        @Html.CheckBoxFor(model => model.item_revenda, new { @class = "form-check-input switch-success", role = "switch" })
                                                    </div>
                                                </div>
                                                <div class="col-sm-2 text-sm-start" style="margin-top:5px;">
                                                    @Html.Label("item_revenda", "Item Revenda")
                                                </div>

                                                <div class="col-sm-1 text-sm-end" style="margin-top:7px;">
                                                    <div class="form-check form-switch d-flex justify-content-end">
                                                        @Html.CheckBoxFor(model => model.item_uso_consumo, new { @class = "form-check-input switch-success", role = "switch" })
                                                    </div>
                                                </div>
                                                <div class="col-sm-2 text-sm-start" style="margin-top:5px;">
                                                    @Html.Label("item_uso_consumo", "Item Consumo")
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- ABA PARÂMETROS - FIM -->

                            <!-- ABA ENDEREÇO ESTOQUE - INÍCIO -->
                            <div class="tab-pane fade" id="tabEnderecoEstoque" role="tabpanel" aria-labelledby="tabEnderecoEstoque_tab">
                                <div class="card-body m-0 p-1" style="height: 100%">
                                    <div class="card shadow-sm gdi-section-accent-secondary m-1 p-0">
                                        <div class="section-header"><i class="fa-solid fa-location-dot me-1" aria-hidden="true"></i>Endereçamento - Estoque BH</div>
                                        <div class="card-body m-1 p-1" style="height: 100%">
                                            <div class="form-group row text-sm-end m-0 pt-1">
                                                @Html.Label("id_estoque01_area", "Área", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                <div class="col-sm-2">
                                                    @Html.DropDownListFor(model => model.id_estoque01_area, ViewBag.comboEstoqueEnderecoAreaBH as List<SelectListItem>, new { @class = "form-control" })
                                                </div>
                                                @Html.Label("id_estoque01_secao", "Seção", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                <div class="col-sm-2">
                                                    @Html.DropDownListFor(model => model.id_estoque01_secao, ViewBag.comboEstoqueEnderecoSecaoBH as List<SelectListItem>, new { @class = "form-control" })
                                                </div>
                                                @Html.Label("id_estoque01_corredor", "Corredor", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                <div class="col-sm-2">
                                                    @Html.DropDownListFor(model => model.id_estoque01_corredor, ViewBag.comboEstoqueEnderecoCorredorBH as List<SelectListItem>, new { @class = "form-control" })
                                                </div>
                                                @Html.Label("id_estoque01_prateleira", "Prateleira", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                <div class="col-sm-2">
                                                    @Html.DropDownListFor(model => model.id_estoque01_prateleira, ViewBag.comboEstoqueEnderecoPrateleiraBH as List<SelectListItem>, new { @class = "form-control" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card shadow-sm gdi-section-accent-secondary m-1 p-0">
                                        <div class="section-header"><i class="fa-solid fa-location-dot me-1" aria-hidden="true"></i>Endereçamento - Estoque SP</div>
                                        <div class="card-body m-1 p-1" style="height: 100%">
                                            <div class="form-group row text-sm-end m-0 pt-1">
                                                @Html.Label("id_estoque03_area", "Área", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                <div class="col-sm-2">
                                                    @Html.DropDownListFor(model => model.id_estoque03_area, ViewBag.comboEstoqueEnderecoAreaSP as List<SelectListItem>, new { @class = "form-control" })
                                                </div>
                                                @Html.Label("id_estoque03_secao", "Seção", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                <div class="col-sm-2">
                                                    @Html.DropDownListFor(model => model.id_estoque03_secao, ViewBag.comboEstoqueEnderecoSecaoSP as List<SelectListItem>, new { @class = "form-control" })
                                                </div>
                                                @Html.Label("id_estoque03_corredor", "Corredor", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                <div class="col-sm-2">
                                                    @Html.DropDownListFor(model => model.id_estoque03_corredor, ViewBag.comboEstoqueEnderecoCorredorSP as List<SelectListItem>, new { @class = "form-control" })
                                                </div>
                                                @Html.Label("id_estoque03_prateleira", "Prateleira", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                <div class="col-sm-2">
                                                    @Html.DropDownListFor(model => model.id_estoque03_prateleira, ViewBag.comboEstoqueEnderecoPrateleiraSP as List<SelectListItem>, new { @class = "form-control" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- ABA ENDEREÇO ESTOQUE - FIM -->
                            }

                            <!-- Aba AUDIT - INÍCIO -->
                            <div class="tab-pane fade" id="tabAudit" role="tabpanel" aria-labelledby="tabAudit_tab">
                                <div class="card shadow-sm gdi-section-accent-secondary m-1 p-0">
                                    <div class="section-header"><i class="fa-solid fa-file-pen me-1" aria-hidden="true"></i>Trilha de Auditoria</div>
                                    <div id="divProdutoAuditDt" class="card-body m-0 p-1 gdi-dt-scroll-host min-w-0">
                                        <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dtAudit">
                                            <thead>
                                                <tr>
                                                    <th>@Html.Raw("Dt/Hora")</th>
                                                    <th>@Html.Raw("Audit Trail")</th>
                                                </tr>
                                            </thead>
                                            <tbody></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            <!-- Aba AUDIT - FIM -->
                        </div>
                    </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                @if ((CachePersister.userIdentity.Roles.Contains("g_Produtos_*")) || (CachePersister.userIdentity.Roles.Contains("g_Produtos_Actionupdate")))
                {
                    <button type="button" name="btnCancelar" title="Cancelar" class="btn btn-warning d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                    if (@Model.bloqueado == false) { <button type="button" name="btnSalvar" title="Salvar" onclick="JsAjaxCreateEditProduto()" class="btn btn-success float-end d-inline-flex align-items-center gap-2"><i class="fa-solid fa-save me-2" aria-hidden="true"></i>Salvar</button> };
                }
                else
                {
                    <button type="button" name="btnCancelar" title="Fechar" class="btn btn-secondary float-end d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>Fechar</button>
                }
            </div>
        </div>
    </div>
}
