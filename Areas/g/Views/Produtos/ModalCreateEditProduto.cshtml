                        if (body) { body.scrollLeft = 0; }
                    },
                    bFilter: false,
                    bLengthChange: false,
                    bProcessing: true,
                    pageLength: 20,
                    scrollX: false,
                    scrollCollapse: false,
                    fixedColumns: false,
                    bAutoWidth: false,
                    pagingType: 'full_numbers',
                    aoColumnDefs: [
                        { "width": "15%", orderable: false, className: 'text-sm-center', targets: [0] },
                        { "width": "85%", orderable: false, className: 'text-sm-start', targets: [1] }
