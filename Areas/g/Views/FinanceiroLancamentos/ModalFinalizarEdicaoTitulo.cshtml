@{ Layout = null; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "formModalFinalizarEdicaoTitulo_gFinanceiroLancamentos" }))
{
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title d-flex align-items-center gap-2">
    <i class="fa-solid fa-circle-info fa-sm" aria-hidden="true"></i>
    @Html.Raw(ViewBag.Title)</h5>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-1">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Faturamento", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-8 text-sm-start">
                            @Html.DropDownList("Faturamento", ViewBag.comboFinanceiroFaturamentos as List<SelectListItem>, htmlAttributes: new { @id = "edit_faturamento", @class = "form-control" })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Cliente", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-8 text-sm-start">
                            @Html.DropDownList("Cliente", ViewBag.comboClientes as List<SelectListItem>, htmlAttributes: new { @id = "edit_cliente", @class = "form-control" })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Conta Caixa", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-8 text-sm-start">
                            @Html.DropDownList("Conta Caixa", ViewBag.comboContasCaixas as List<SelectListItem>, htmlAttributes: new { @id = "edit_conta_caixa", @class = "form-control" })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Vencimento", new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-4">
                            @* id do .input-group distinto do input (editData1) para Tempus Dominus *@
                            <div class='input-group date' id='ig_g_modal_finalizar_edicao_tit_venc'>
                                @Html.Editor("editData1", new { htmlAttributes = new { @class = "form-control", type = "text" } })
                                <span class="input-group-text"><i class="fa-regular fa-calendar-alt"></i></span>
                            </div>
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("R$ Despesas", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-3">
                            @Html.Editor("R$ Despesas", new { htmlAttributes = new { @id = "edit_valor_despesas_cobranca", @class = "form-control", @Value = "0,00" } })
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" name="btnCancelar" class="btn btn-warning me-auto d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                <button type="button" name="btnSimular" class="btn btn-info me-auto d-inline-flex align-items-center gap-2" onclick="jsCheckInputs(true)"><i class="fa-solid fa-sync me-2" aria-hidden="true"></i>Simular</button>
                <button type="button" name="btnConfirmar" class="btn btn-success d-inline-flex align-items-center gap-2" onclick="jsCheckInputs(false)"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>Confirmar</button>
            </div>
        </div>
    </div>
}
<script type="text/javascript">

	$(function ()
    {
        try
        {
            jsDatepicker('#ig_g_modal_finalizar_edicao_tit_venc');
            jsInitModal();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });
  
    function jsCheckInputs(simulacao)
    {
        try {
            if (simulacao == true)
            { jsSimularFecharLancamentos(); }
            else { jsExecutarFecharLancamentos() }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCheckInputs] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsSimularFecharLancamentos()
    {
        try {
            LibMessageProcessando("Simulando Fechamento Lançamentos . . .")
            var dataForm =
            {
                modal_cstFinanceiroLancamentos:
                {
                    'id_conta_caixa': $("#edit_conta_caixa").val(),
                    'id_financeiro_faturamento': $("#edit_faturamento").val(),
                    'id_cliente': $("#edit_cliente").val(),
                    'valor_despesas_cobranca': $("#edit_valor_despesas_cobranca").val(),
                    'data_vencimento': jsGetDateDDMMYYYY(jsDatepickerGetDate('#ig_g_modal_finalizar_edicao_tit_venc'))
                }
            };
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxSimularFinalizarEdicaoTitulo", "FinanceiroLancamentos", new { area = "g" })',
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(dataForm),
                dataType: "json",
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true) {
                        GdiSwal2.dialog({
                            title: "<i class='fa-solid fa-check' style='color:#008000'>&nbsp&nbsp</i><b>Simulação</b>",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons: {
                                confirmar: {
                                    label: '&nbsp;OK',
                                    className: 'btn btn-info',
                                    callback: function () {
                                        document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                        GdiSwal2.hideAll();
                                    }
                                }
                            }
                        })
                    }
                    else {
                        GdiAjaxNotifyInconsistencias(result.msg);
                    }
                },
                error: function (result)
                {
                    GdiAjaxNotifyInconsistencias(result.toString())
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSimularFecharLancamentos] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };


    function jsExecutarFecharLancamentos()
    {
        try {
            LibMessageProcessando("Fechando Lançamentos . . .")
            var dataForm =
            {
                modal_cstFinanceiroLancamentos:
                {
                    'id_conta_caixa': $("#edit_conta_caixa").val(),
                    'id_financeiro_faturamento': $("#edit_faturamento").val(),
                    'id_cliente': $("#edit_cliente").val(),
                    'valor_despesas_cobranca': $("#edit_valor_despesas_cobranca").val(),
                    'data_vencimento': jsGetDateDDMMYYYY(jsDatepickerGetDate('#ig_g_modal_finalizar_edicao_tit_venc'))
                }
            };
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxExecutarFinalizarEdicaoTitulo", "FinanceiroLancamentos", new { area = "g" })',
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(dataForm),
                dataType: "json",
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true) {
                        GdiSwal2.dialog({
                            title: "<i class='fa-solid fa-check' style='color:#008000'>&nbsp&nbsp</i><b>Confirmação</b>",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons: {
                                confirmar: {
                                    label: '&nbsp;OK',
                                    className: 'btn btn-info',
                                    callback: function () {
                                        ajaxPesquisarLancamentos();
                                        document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                        GdiSwal2.hideAll();
                                    }
                                }
                            }
                        })
                    }
                    else {
                        GdiAjaxNotifyInconsistencias(result.msg);
                    }
                },
                error: function (result)
                {
                    GdiAjaxNotifyInconsistencias(result.toString());
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsExecutarFecharLancamentos] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

</script>



