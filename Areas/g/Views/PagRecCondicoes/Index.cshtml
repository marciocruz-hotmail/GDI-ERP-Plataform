@model IEnumerable<GdiPlataform.Db.g_pagrec_condicoes>
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(@ViewBag.Title)</h5>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-header m-0 p-1">
                @if ((CachePersister.userIdentity.Roles.Contains("g_PagRecCondicoes_*")) || (CachePersister.userIdentity.Roles.Contains("g_PagRecCondicoes_Actioncreate")))
                { <button type="button" name="btnRegistroNovo" title="Novo Registro" class="btn btn-outline-success d-inline-flex align-items-center gap-2"onclick="JsNewRecord('@Url.Action("Create","PagRecCondicoes",new { Area = "g" })')"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button> }
                else
                { <button type="button" name="btnRegistroNovo" title="Novo Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button> }
                @if ((CachePersister.userIdentity.Roles.Contains("g_PagRecCondicoes_*")) || (CachePersister.userIdentity.Roles.Contains("g_PagRecCondicoes_Actionupdate")))
                { <button type="button" name="btnRegistroEditar" title="Editar Registro" class="btn btn-outline-warning d-inline-flex align-items-center gap-2" onclick="JsEditRecord(otableGPagRecCondicoes, 'Id.', '@Url.Action("Edit","PagRecCondicoes",new { Area = "g" })/')"><i class="fa-regular fa-edit me-2" aria-hidden="true"></i>Editar</button> }
                else

                { <button type="button" name="btnRegistroEditar" title="Editar Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa-regular fa-edit me-2" aria-hidden="true"></i>Editar</button> }
            </div>
            <div class="card-body m-0 p-1" style="max-width: 100%; overflow-x: auto; ">
                <div class="form-horizontal m-0 p-0">
                    <div class="table-responsive scroll-body-horizontal" style="width:100%">
                        <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dtGPagRecCondicoes">
                            <thead>
                                <tr>
                                    <th>[x]</th>
                                    <th>@Html.Encode("Id.")</th>
                                    <th>@Html.DisplayName("Ativo")</th>
                                    <th>@Html.DisplayName("Descrição")</th>
                                    <th>@Html.DisplayName("Pagamento")</th>
                                    <th>@Html.DisplayName("Recebimento")</th>
                                    <th>@Html.DisplayName("Qtd. Dias")</th>
                                    <th>@Html.DisplayName("Qtd. Parcela")</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div> 
</div>

<script type="text/javascript">
    var otableGPagRecCondicoesGPagRecCondicoes;

	$(function ()
    {
        try
        {
            jsInitForm();
            jsCreateTable();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsCreateTable()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            otableGPagRecCondicoesGPagRecCondicoes = $('#dtGPagRecCondicoes').on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) { GdiDtNotifyJsonErrorMessage(json); }).DataTable({
            processing: true,
            bServerSide: true,
            ajax: {
                url: '@Url.Action("GetDados","PagRecCondicoes",new { Area = "g" })',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                dataType: 'json',
                cache: false,
                data: function (d) {
                    return {
                        sEcho: d.draw,
                        iDisplayStart: d.start,
                        iDisplayLength: d.length,
                    };
                },
                error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
            },
            responsive: true,
            bFilter: false,
            bLengthChange: false,
            bProcessing: true,
            pageLength: 20,
            scrollX: false,
            scrollCollapse: false,
            fixedColumns: false,
            bAutoWidth: false,
            pagingType: 'full_numbers',
            aoColumnDefs: [
                { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                { "width": "8%", orderable: false, className: 'text-sm-center', targets: [1] },
                { "width": "8%", orderable: false, className: 'text-sm-center', targets: [2] },
                { "width": "40%", orderable: false, className: 'text-sm-center', targets: [3] },
                { "width": "10%", orderable: false, className: 'text-sm-center', targets: [4] },
                { "width": "10%", orderable: false, className: 'text-sm-center', targets: [5] },
                { "width": "10%", orderable: false, className: 'text-sm-center', targets: [6] },
                { "width": "10%", orderable: false, className: 'text-sm-center', targets: [7] }
            ],
            select: {
                style: 'multi',
                selector: 'td:not(.dt-no-row-select)',
                headerCheckbox: true
            },
            order: [[1, 'asc']],

                language:
                {
                    sEmptyTable: 'Nenhum registro encontrado',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
            });
            $('#dtGPagRecCondicoes tbody').on('dblclick', 'tr td', function () {
                var data = otableGPagRecCondicoesGPagRecCondicoes.row($(this).closest('tr')).data();
                JsEditRecordDoubleClick(data[1],'@Url.Action("Edit", "PagRecCondicoes", new { Area = "g" })');
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };
</script>

