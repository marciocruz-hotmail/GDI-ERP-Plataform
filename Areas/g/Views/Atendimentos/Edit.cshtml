                fixedColumns: false,
                bAutoWidth: false,
                pagingType: 'full_numbers',
                aoColumnDefs: [
                    { "width": "5%", orderable: false, className: 'text-center', targets: [0] },
                    { "width": "10%", orderable: false, className: 'text-center', targets: [1] },
