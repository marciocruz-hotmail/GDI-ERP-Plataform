    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            otableGcMovimentosGed = $('#dtGAtendimentosGed').on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) { GdiDtNotifyJsonErrorMessage(json); }).DataTable({
