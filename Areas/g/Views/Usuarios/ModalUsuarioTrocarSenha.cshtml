@{ Layout = null; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "formModalUsuarioTrocarSenha_gUsuarios" }))
{
    @Html.AntiForgeryToken()
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title d-flex align-items-center gap-2">@Html.Raw(ViewBag.Title)</h5>
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-1">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Nova Senha", new { @class = "col-sm-4 col-form-label" })
                        <div class="col-sm-5">
                            @Html.Editor("nova_senha", new { htmlAttributes = new { @id = "nova_senha", @class = "form-control", maxlength = "10", type = "password" } })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Confirmação", new { @class = "col-sm-4 col-form-label" })
                        <div class="col-sm-5">
                            @Html.Editor("confirma_nova_senha", new { htmlAttributes = new { @id = "confirma_nova_senha", @class = "form-control", maxlength = "10", type = "password" } })
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" name="btnCancelar" class="btn btn-warning me-auto d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                <button type="button" name="btnExec" title="Trocar Senha" class="btn btn-success d-inline-flex align-items-center gap-2" onclick="jsAjaxTrocarSenha()"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>Trocar Senha</button>
            </div>
        </div>
    </div>
}

<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsInitModal();
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsAjaxTrocarSenha()
    {
        try {
            var hasError = false;
            var msgErro = "";

            if ((isEmpty($('#nova_senha').val().toString().trim())) || (isEmpty($('#confirma_nova_senha').val().toString().trim())) || ($('#nova_senha').val().toString().trim().length < 3) || ($('#confirma_nova_senha').val().toString().trim().length < 3))
            {
                hasError = true;
                msgErro = "A Senha deve ter no mínimo 3 caracteres"
            }
            else
            {
                if ($('#nova_senha').val().toString().trim() != $('#confirma_nova_senha').val().toString().trim())
                {
                    hasError = true;
                    msgErro = "A Senha/Confirmação devem ser idênticas"
                }
            }

            if (hasError)
            {
                GdiAjaxNotifyInconsistencias(msgErro);
            }
            else
            {
                jsSendForm();
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsAjaxTrocarSenha] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsSendForm()
    {
        try {
            LibMessageProcessando("Processando . . .")
            var dataForm =
            {
                record_g_usuarios:
                {
                    'senha': $('#nova_senha').val().toString(),
                    'login': $('#confirma_nova_senha').val().toString()
                }
            };
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxUsuarioTrocarSenha", "Usuarios", new { area = "g" })',
                headers: GdiAjaxAntiForgeryHeaders('#formModalUsuarioTrocarSenha_gUsuarios'),
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(dataForm),
                dataType: "json",
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true) {
                                                LibMessageSuccess("Confirmação", result.msg, {
                            backdrop: true,
                            callback: function () {
                            $("#dtGUsuarios").DataTable().draw(false);
                            document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                            LibMessageHideAll();
                            }
                        });
                    }
                    else {
                        GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.')
                    }
                },
                error: function (xhr, textStatus, errorThrown)
                {
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.')
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };
</script>
