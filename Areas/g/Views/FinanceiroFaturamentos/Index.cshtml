@model IEnumerable<GdiPlataform.Db.g_financeiro_faturamentos>
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(ViewBag.Title)</h5>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-header m-0 p-1">
                @if ((CachePersister.userIdentity.Roles.Contains("g_FinanceiroFaturamentos_*")) || (CachePersister.userIdentity.Roles.Contains("g_FinanceiroFaturamentos_Actionrun")))
                {
                    <div class="btn-group" role="group">
                        @{int qtdMenusTitulos = 0; }
                        <button id="btnGroupDrop1" type="button" class="btn btn-outline-info dropdown-toggle d-inline-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="Processos">
                            <i class="fa-solid fa-cog me-2" aria-hidden="true"></i>Processos
                        </button>
                        <div class="dropdown-menu" aria-labelledby="btnGroupDrop1">
                            @if ((CachePersister.userIdentity.Roles.Contains("g_FinanceiroFaturamentos_*")) || (CachePersister.userIdentity.Roles.Contains("g_FinanceiroFaturamentos_UploadArquivoFaturamentoGestor")))
                            {
                                if (qtdMenusTitulos > 0)
                                {<div class="dropdown-divider"></div> }
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalImportarArquivoFaturamentoGestorFranquia()"><i class="fa-solid fa-upload me-2" aria-hidden="true"></i>Upload Arquivo Faturamento Gestor Franquia</a>
                                qtdMenusTitulos = qtdMenusTitulos + 1;
                            }

                            @if ((CachePersister.userIdentity.Roles.Contains("g_FinanceiroFaturamentos_*")) || (CachePersister.userIdentity.Roles.Contains("g_FinanceiroFaturamentos_SincronizarFaturamentoGestor")))
                            {
                                if (qtdMenusTitulos > 0)
                                {<div class="dropdown-divider"></div> }
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalAtualizarFaturamentoGestorFranquia()"><i class="fa-solid fa-exchange-alt me-2" aria-hidden="true"></i>Sincronizar Faturamento Gestor Franquia</a>
                                qtdMenusTitulos = qtdMenusTitulos + 1;
                            }
                            @if ((CachePersister.userIdentity.Roles.Contains("g_FinanceiroFaturamentos_*")) || (CachePersister.userIdentity.Roles.Contains("g_FinanceiroFaturamentos_EnviarEmailsClientes")))
                            {
                                if (qtdMenusTitulos > 0)
                                {<div class="dropdown-divider"></div> }

                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalEnviarEmailsClientes(otableFinanceiroFaturamentos, 'Id.')"><i class="fa-regular fa-envelope me-2" aria-hidden="true"></i>Enviar Emails Clientes</a>
                                qtdMenusTitulos = qtdMenusTitulos + 1;
                            }
                            @if ((CachePersister.userIdentity.Roles.Contains("g_FinanceiroFaturamentos_*")) || (CachePersister.userIdentity.Roles.Contains("g_FinanceiroFaturamentos_EnviarEmailNFEClientes")))
                            {
                                if (qtdMenusTitulos > 0)
                                {<div class="dropdown-divider"></div> }

                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalEnviarNFEmailCliente(otableFinanceiroFaturamentos, 'Id.')"><i class="fa-regular fa-envelope me-2" aria-hidden="true"></i>Enviar NF-e Para Email Cliente</a>
                                qtdMenusTitulos = qtdMenusTitulos + 1;
                            }
                            @if ((CachePersister.userIdentity.Roles.Contains("g_FinanceiroFaturamentos_*")) || (CachePersister.userIdentity.Roles.Contains("g_FinanceiroFaturamentos_ExcluirFaturamentoCompleto")))
                            {
                                if (qtdMenusTitulos > 0)
                                {<div class="dropdown-divider"></div> }
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsDeleteFaturamentoCompleto(otableFinanceiroFaturamentos, 'Id.', 'Descrição')"><i class="fa-solid fa-trash-alt me-2" aria-hidden="true"></i>Apagar Faturamento Completo</a>
                                qtdMenusTitulos = qtdMenusTitulos + 1;
                            }
                        </div>
                    </div>
                }
            </div>
            <div class="card-body m-0 p-1" style="max-width: 100%; overflow-x: auto; ">
                <div class="form-horizontal m-0 p-0">
                    <div class="table-responsive scroll-body-horizontal" style="width:100%">
                        <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dtGFinanceiroFaturamentos">
                            <thead>
                                <tr>
                                    <th>[x]</th>
                                    <th>@Html.DisplayNameFor(model => model.id_financeiro_faturamento)</th>
                                    <th>@Html.DisplayNameFor(model => model.descricao)</th>
                                    <th>@Html.Label("", "Concluído")</th>
                                    <th>@Html.Label("", "Clientes Notificados")</th>
                                    <th>@Html.Label("", "Vendedores Notificados")</th>
                                    <th>@Html.DisplayName("Títulos")</th>
                                    <th>@Html.DisplayNameFor(model => model.datahora_cadastro)</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var otableFinanceiroFaturamentos;

	$(function ()
    {
        try
        {
            jsInitForm();
            jsCreateTable();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsCreateTable()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            otableFinanceiroFaturamentos = $('#dtGFinanceiroFaturamentos').on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) { GdiDtNotifyJsonErrorMessage(json); btnFiltro(json.yesFilterOnOff) }).DataTable({
            processing: true,
            bServerSide: true,
            ajax: {
                url: '@Url.Action("GetDados","FinanceiroFaturamentos",new { Area = "g" })',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                dataType: 'json',
                cache: false,
                data: function (d) {
                    return {
                        sEcho: d.draw,
                        iDisplayStart: d.start,
                        iDisplayLength: d.length,
                    };
                },
                error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
            },
            responsive: true,
            bFilter: false,
            bLengthChange: false,
            bProcessing: true,
            pageLength: 20,
            scrollX: false,
            scrollCollapse: false,
            fixedColumns: false,
            bAutoWidth: false,
            pagingType: 'full_numbers',
            aoColumnDefs: [
                { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                { "width": "8%", orderable: false, className: 'text-sm-center', targets: [1] },
                { "width": "40%", orderable: false  , className: 'text-sm-center', targets: [2] },
                { "width": "10%", orderable: false, className: 'text-sm-center', targets: [3] },
                { "width": "10%", orderable: false, className: 'text-sm-center', targets: [4] },
                { "width": "10%", orderable: false, className: 'text-sm-center', targets: [5] },
                { "width": "8%", orderable: false, className: 'text-sm-center', targets: [6] },
                { "width": "10%", orderable: false, className: 'text-sm-center', targets: [7] }
            ],
            select: {
                style: 'multi',
                selector: 'td:not(.dt-no-row-select)',
                headerCheckbox: true
            },
            order: [[1, 'asc']],

                language:
                {
                    sEmptyTable: 'Nenhum registro encontrado',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsModalEnviarEmailsClientes(TableName, columnName)
    {
        try {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            if (!selectedIds || selectedIds.length == 0)
            {
                LibMessageAlert("Atenção", "Selecione o registro!")
            }
            else {
                if (selectedIds.indexOf(',') == -1)
                {
                    $("#mainModal").load('@Url.Action("ModalEnviarEmailsClientes", "FinanceiroFaturamentos", new { Area = "g" })?id=' + selectedIds, function () { var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();} })
                }
                else
                {
                    LibMessageAlert("Atenção", "Para execução do processo, selecione apenas 1(um) registro!")
                }
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalEnviarEmailsClientes] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalEnviarNFEmailCliente(TableName, columnName)
    {
        try {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            if (!selectedIds || selectedIds.length == 0)
            {
                LibMessageAlert("Atenção", "Selecione o registro!")
            }
            else {
                if (selectedIds.indexOf(',') == -1)
                {
                    $("#mainModal").load('@Url.Action("ModalEnviarNFEmailCliente", "FinanceiroFaturamentos", new { Area = "g" })?id=' + selectedIds, function () { var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();} })
                }
                else
                {
                    LibMessageAlert("Atenção", "Para execução do processo, selecione apenas 1(um) registro!")
                }
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalEnviarNFEmailCliente] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalImportarArquivoFaturamentoGestorFranquia()
    {
        try {
            $("#mainModal").load('@Url.Action("ModalImportarArquivoFaturamentoGestorFranquia", "FinanceiroFaturamentos", new { Area = "g" })?idCliente=1', function () {
                var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
            })
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalImportarArquivoFaturamentoGestorFranquia] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalAtualizarFaturamentoGestorFranquia()
    {
        try {
            $("#mainModal").load('@Url.Action("ModalAtualizarFaturamentoGestorFranquia", "FinanceiroFaturamentos", new { Area = "g" })?id=1', function () {
                var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
            })
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalAtualizarFaturamentoGestorFranquia] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsDeleteFaturamentoCompleto(TableName, columnName, columNomeTabela)
    {
        try {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            var selectedNomeTabela = JsGetSelectedRows(TableName, columNomeTabela);
            if (!selectedIds || selectedIds.length == 0)
            {
                LibMessageAlert("Atenção", "Selecione o registro!")
            }
            else {
                if (selectedIds.indexOf(',') == -1)
                {
                    GdiSwal2.dialog({
                        title: "<i class='fa-solid fa-question' style='color:#ff9900'>&nbsp&nbsp</i><b>Confirmação</b>",
                        closeButton: false,
                        message: "Deseja <b>REALMENTE</b> apagar o faturamento ?" + "<br/><br/>" + "<b>" + selectedIds + " - " + selectedNomeTabela + "</b>" + "<br/><br/>" + "<b>Atenção:</b> Só será possivel apagar faturamentos que não tiveram alterações em seus títulos financeiros!",
                        centerVertical: true,
                        onEscape: false,
                        backdrop: true,
                        buttons: {
                            cancelar: {
                                label: '<i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar',
                                className: 'btn-outline-warning',
                                callback: function () {
                                    GdiSwal2.hideAll();
                                }
                            },
                            confirmar: {
                                label: '<i class="fa-solid fa-save me-2" aria-hidden="true"></i>Confirmar',
                                className: 'btn-outline-success',
                                callback: function () {
                                    jsSendDeleteFaturamentoCompleto(selectedIds);
                                    GdiSwal2.hideAll();
                                }
                            }
                        }
                    })
                }
                else
                {
                    LibMessageAlert("Atenção", "Para execução do processo, selecione apenas 1(um) registro!")
                }
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsDeleteFaturamentoCompleto] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsSendDeleteFaturamentoCompleto(selectedIds)
    {
        try {
            LibMessageProcessando("Apagando Faturamento . . .");
            var dataForm =
            {
                record_g_financeiro:
                {
                    'id_financeiro_faturamento': selectedIds,
                }
            };
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxDeleteFaturamentoCompleto", "FinanceiroFaturamentos", new { area = "g" })',
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(dataForm),
                dataType: "json",
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true) {
                        GdiSwal2.dialog({
                            title: "<i class='fa-solid fa-check' style='color:#008000'>&nbsp&nbsp</i><b>Confirmação</b>",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons: {
                                confirmar: {
                                    label: '&nbsp;OK',
                                    className: 'btn btn-info',
                                    callback: function () {
                                        $("#dtGFinanceiroFaturamentos").DataTable().draw(false);
                                        document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                        GdiSwal2.hideAll();
                                    }
                                }
                            }
                        })
                    }
                    else {
                        GdiAjaxNotifyInconsistencias(result.msg);
                    }
                },
                error: function (result)
                {
                    GdiAjaxNotifyInconsistencias(result.toString())
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendDeleteFaturamentoCompleto] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };
</script>

