<script type="text/javascript">
    $(function () {
        try { jsInitModal(); }
        catch (err) { LibMessageError("Atenção", "[jsInitModal] " + (err && err.message ? err.message.toString() : String(err))); }
    });
    function jsAjaxCreateEditContaCaixa() {
        try {
            if (isEmpty($('#nome').val() == null ? '' : $('#nome').val().toString().trim())) {
                LibMessageAlert('Atenção', 'Campo <b>Nome</b> é de preenchimento obrigatório!');
                return;
            }
            LibMessageProcessando('Salvando conta caixa...');
            var form = $('#FormModalCreateEditGContasCaixas');
            $.ajax({
                type: 'POST',
                url: '@Url.Action("AjaxCreateEditContaCaixa", "ContasCaixas", new { area = "g" })',
                data: form.serialize(),
                success: function (result) {
                    LibMessageProcessandoHide();
                    if (result.success === true) {
                        document.querySelectorAll('.modal').forEach(function (m) { var i = bootstrap.Modal.getInstance(m); if (i) i.hide(); });
                        if (typeof otableGContasCaixas !== 'undefined' && otableGContasCaixas) { otableGContasCaixas.draw(false); }
                        else { $('#dtGContasCaixas').DataTable().draw(false); }
                        LibMessageHideAll();
                    } else { GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.'); }
                },
                error: function (xhr, textStatus, errorThrown) {
                    LibMessageProcessandoHide();
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.');
                }
            });
        } catch (err) {
            LibMessageProcessandoHide();
            LibMessageError('Atenção', '[jsAjaxCreateEditContaCaixa] ' + (err && err.message ? err.message.toString() : String(err)));
        }
    };
</script>
