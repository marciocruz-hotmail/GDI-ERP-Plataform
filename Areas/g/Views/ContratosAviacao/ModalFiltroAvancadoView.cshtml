@model GdiPlataform.Areas.g.Models.cstModalFiltroAvancado
@{ Layout = null; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "formModalFiltroAvancadoView_GContratos" }))
{
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title"><i class="fa-solid fa-filter me-2" aria-hidden="true"></i>@Html.Raw(@ViewBag.Title)</h5>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-1">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Field_Text_01", "Id", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-3">
                            @Html.EditorFor(model => model.Field_Text_01, new { htmlAttributes = new { @class = "form-control", @placeholder = "Id.", @onkeypress = "keypressed(event);" } })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Field_Text_02", "Cliente/Fornecedor", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-9">
                            @Html.DropDownListFor(model => model.Field_Text_02, ViewBag.comboClientes as List<SelectListItem>, new { @class = "form-control", @onkeypress = "keypressed(event);" })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Field_Text_03", "Descrição", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-9">
                            @Html.EditorFor(model => model.Field_Text_03, new { htmlAttributes = new { @class = "form-control", @placeholder = "Descrição", @onkeypress = "keypressed(event);" } })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Field_Data_01", "Dt Ass.", new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-4">
                            @* id do .input-group distinto do input (Field_Data_01/02) para Tempus Dominus *@
                            <div class='input-group date' id='ig_g_contratos_filtro_avanc_d1'>
                                @Html.EditorFor(model => model.Field_Data_01, new { htmlAttributes = new { @class = "form-control", type = "text", @onkeypress = "keypressed(event);" } })
                                <span class="input-group-text"><i class="fa-regular fa-calendar-alt"></i></span>
                            </div>
                        </div>
                        @Html.Label("à", new { @class = "col-sm-1 col-form-label text-sm-center" })
                        <div class="col-sm-4">
                            <div class='input-group date' id='ig_g_contratos_filtro_avanc_d2'>
                                @Html.EditorFor(model => model.Field_Data_02, new { htmlAttributes = new { @class = "form-control", type = "text", @onkeypress = "keypressed(event);" } })
                                <span class="input-group-text"><i class="fa-regular fa-calendar-alt"></i></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" name="btnCancelar" title="Cancelar" class="btn btn-warning me-auto d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                <button type="button" name="btnExec" title="Filtrar" class="btn btn-success d-inline-flex align-items-center gap-2" onclick="jsRunFiltroAvancadoModal()"><i class="fa-solid fa-filter me-2" aria-hidden="true"></i>Filtrar</button>
            </div>
        </div>
    </div>
}

<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsDatepicker('#ig_g_contratos_filtro_avanc_d1');
            jsDatepicker('#ig_g_contratos_filtro_avanc_d2');
            jsInitModal();
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function keypressed(e) {
        if (e.keyCode == 13) { e.preventDefault(); jsRunFiltroAvancadoModal(); }
    }

    function jsRunFiltroAvancadoModal()
    {
        try
        {
            jsRunFiltroAvancado($('#Field_Text_01').val().toString() + ";" + $('#Field_Text_02').val().toString() + ";" + $('#Field_Text_03').val().toString() + ";" + jsGetDateDDMMYYYY(jsDatepickerGetDate('#ig_g_contratos_filtro_avanc_d1')) + ";" + jsGetDateDDMMYYYY(jsDatepickerGetDate('#ig_g_contratos_filtro_avanc_d2')));
            document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
        }
        catch (err) {
            LibMessageError("Atenção", "[jsRunFiltroAvancado] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }


</script>



