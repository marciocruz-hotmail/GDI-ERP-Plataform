@model IEnumerable<GdiPlataform.Db.g_contratos_aviacao>
@using GdiPlataform.Security
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(ViewBag.Title)</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterOperador" value="" name="yesFilterOperador" />
                <input type="hidden" id="yesFilterText" value="" name="yesFilterText" />
                <input type="hidden" id="yesFilterAdvancedText" value="" name="yesFilterAdvancedText" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-header m-0 p-1">
                @if ((CachePersister.userIdentity.Roles.Contains("g_ContratosAviacao_*")) || (CachePersister.userIdentity.Roles.Contains("g_ContratosAviacao_Actioncreate")))
                {<button type="button" name="btnRegistroNovo" title="Novo Registro" class="btn btn-outline-success d-inline-flex align-items-center gap-2" onclick="JsNewRecord('@Url.Action("Create","ContratosAviacao",new { Area = "g" })')"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button> }
                else
                { <button type="button" name="btnRegistroNovo" title="Novo Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button>}
                @if ((CachePersister.userIdentity.Roles.Contains("g_ContratosAviacao_*")) || (CachePersister.userIdentity.Roles.Contains("g_ContratosAviacao_Actionupdate")))
                {<button type="button" name="btnRegistroEditar" title="Editar Registro" class="btn btn-outline-warning d-inline-flex align-items-center gap-2" onclick="JsEditRecord(otableGContratos, 'Id.', '@Url.Action("Edit","ContratosAviacao",new { Area = "g" })/')"><i class="fa-regular fa-edit me-2" aria-hidden="true"></i>Editar</button> }
                else
                { <button type="button" name="btnRegistroEditar" title="Editar Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa-regular fa-edit me-2" aria-hidden="true"></i>Editar</button>}
                <button type="button" id="btnFiltroAvancado" name="btnFiltroAvancado" title="Filtro Avançado" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2" onclick="jsModalFiltroAvancado()"><i class="fa-solid fa-filter me-2" aria-hidden="true"></i>Filtro Avançado</button>
                @if ((CachePersister.userIdentity.Roles.Contains("g_ContratosAviacao_*")) || (CachePersister.userIdentity.Roles.Contains("g_ContratosAviacao_Actionrun")))
                {
                    <div class="btn-group" role="group">
                        <button id="btnGroupDrop1" type="button" class="btn btn-outline-info dropdown-toggle d-inline-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="Processos">
                            <i class="fa-solid fa-cog me-2" aria-hidden="true"></i>Processos
                        </button>
                        <div class="dropdown-menu" aria-labelledby="btnGroupDrop1">
                            <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsAjaxDownloadContratoAviacaoPDF(otableGContratos, 'Id.')"><i class="fa-regular fa-file-pdf fa-lg me-2" aria-hidden="true"></i>Gerar Contrato PDF</a>
                            <div class="dropdown-divider"></div>
                            <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalUploadContratoAssinado(otableGContratos, 'Id.')"><i class="fa-solid fa-file-arrow-up fa-lg me-2" aria-hidden="true"></i>Anexar Contrato Assinado</a>
                        </div>
                    </div>
                }
            </div>
            <div class="card-body m-0 p-1" style="max-width: 100%; overflow-x: auto; ">
                <div class="form-horizontal m-0 p-0">
                    <div class="table-responsive scroll-body-horizontal" style="width:100%">
                        <table class="table table-sm table-hover gdi-dt-zebra align-middle w-100 display compact" style="width:100%" id="dtGContratos">
                            <thead>
                                <tr>
                                    <th>[x]</th>
                                    <th>Id.</th>
                                    <th><i class="fa-solid fa-clipboard-check"></i></th>
                                    <th><i class="fa-solid fa-file-pdf"></i></th>
                                    <th>Cliente/Fornecedor</th>
                                    <th>Tipo</th>
                                    <th>Dt. Ass.</th>
                                    <th><i class="fa-solid fa-cloud-download-alt" style="cursor:pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Download Contrato"></i></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var otableGContratos;

    $(function ()
    {
        try
        {
            jsInitForm();
            jsCreateTable();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsLoadForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsCreateTable()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            otableGContratos = $('#dtGContratos').css("font-size", 14).on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) { GdiDtNotifyJsonErrorMessage(json); btnFiltro(json.yesFilterOnOff) }).DataTable({
            processing: true,
            bServerSide: true,
            ajax: {
                url: '@Url.Action("GetDados","ContratosAviacao",new { Area = "g" })',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                dataType: 'json',
                cache: false,
                data: function (d) {
                    return {
                        sEcho: d.draw,
                        iDisplayStart: d.start,
                        iDisplayLength: d.length,
                        yesFilterField: $('#yesFilterField').val().toString(),
                        yesFilterOperador: $('#yesFilterOperador').val().toString(),
                        yesFilterText: $('#yesFilterText').val().toString(),
                        yesFilterAdvancedText: $('#yesFilterAdvancedText').val().toString(),
                    };
                },
                error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
            },

            "createdRow": function (row, data, dataIndex) {
                if (String(data[3]).trim().toUpperCase() === 'BELO HORIZONTE') {
                    row.classList.add('gdi-row-tinted');
                    row.style.setProperty('--gdi-row-bg', '#5DADE2');
                }
            },

            responsive: true,
            bFilter: false,
            bLengthChange: false,
            bProcessing: true,
            pageLength: 20,
            scrollX: false,
            scrollCollapse: false,
            fixedColumns: false,
            bAutoWidth: false,
            pagingType: 'full_numbers',
            aoColumnDefs: [
                { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                { "width": "4%", orderable: false, className: 'text-sm-center', targets: [1] },
                { "width": "5%", orderable: false, className: 'text-sm-center', targets: [2] },
                { "width": "5%", orderable: false, className: 'text-sm-center', targets: [3] },
                { "width": "37%", orderable: false, className: 'text-sm-center', targets: [4] },
                { "width": "30%", orderable: false, className: 'text-sm-center', targets: [5] },
                { "width": "10%", orderable: false, className: 'text-sm-center', targets: [6] },
                { "width": "5%", orderable: false, className: 'text-sm-center dt-no-row-select', targets: [7], data: null, defaultContent: "", render: function (data, type, row, meta) { return '<button type="button" name="btnDownloadFile" data-bs-toggle="tooltip" data-bs-placement="top" title="Download Arquivo Id: ' + data[1] + '" class="btn btn-outline-info btn-sm p-1 btnDownloadFile d-inline-flex align-items-center" onclick="jsDownloadFileContrato(' + data[1] + ');"><i class="fa-solid fa-cloud-download-alt"></i></button>' } }
            ],
            select: {
                style: 'multi',
                selector: 'td:not(.dt-no-row-select)',
                headerCheckbox: true
            },
            order: [[1, 'desc']],
                language:
                {
                    sEmptyTable: 'Nenhum registro encontrado',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
            });
            $('#dtGContratos tbody').on('dblclick', 'tr td', function () {
                var data = otableGContratos.row($(this).closest('tr')).data();
                JsEditRecordDoubleClick(data[1],'@Url.Action("Edit", "ContratosAviacao", new { Area = "g" })');
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsModalFiltroAvancado()
    {
        try {
            if (document.getElementById("btnFiltroAvancado").innerHTML.indexOf("Remover") > 0) {
                document.getElementById("yesFilterField").value = "*";
                document.getElementById("yesFilterOperador").value = "";
                document.getElementById("yesFilterText").value = "";
                document.getElementById("yesFilterAdvancedText").value = "";
                $("#dtGContratos").DataTable().draw(false);
            }
            else {
                $("#mainModal").load('@Url.Action("ModalFiltroAvancadoView", "ContratosAviacao", new { Area = "g" })?id=g_ContratosAviacao_index', function () {
                    var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
                })
                }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalFiltroAvancado] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsRunFiltroAvancado(FilterAdvancedText)
    {
        try {
            document.getElementById("yesFilterAdvancedText").value = FilterAdvancedText;
            $("#dtGContratos").DataTable().draw(false);
        }
        catch (err) {
            LibMessageError("Atenção", "[jsRunFiltroAvancado] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsAjaxDownloadContratoAviacaoPDF(TableName, columnName)
    {
        try {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            if (!selectedIds || selectedIds.length == 0)
            {
                LibMessageAlert("Atenção", "Selecione o registro!");
            }
            else {
                if (selectedIds.indexOf(',') == -1)
                {
                    LibMessageProcessando();
                    var dataForm =
                    {
                        record_g_contrato:
                        {
                            'id_contrato': selectedIds,
                        }
                    };
                    $.ajax({
                        type: "POST",
                        url: '@Url.Action("AjaxDownloadContratoAviacaoPDF", "ContratosAviacao", new { area = "g" })?id=' + selectedIds,
                        contentType: "application/json; charset=utf-8",
                        data: JSON.stringify(dataForm),
                        dataType: "json",
                        success: function (result)
                        {
                            LibMessageProcessandoHide();
                            if (result.success == true)
                            {
                                GdiSwal2.dialog({
                                    title: "<i class='fa-solid fa-check' style='color:#008000'>&nbsp&nbsp</i><b>Confirmação</b>",
                                    closeButton: false,
                                    message: result.msg,
                                    centerVertical: true,
                                    onEscape: false,
                                    backdrop: true,
                                    buttons: {
                                        confirmar: {
                                            label: '&nbsp;OK',
                                            className: 'btn btn-info',
                                            callback: function ()
                                            {
                                                document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                                LibMessageProcessandoHide();
                                                window.location = '@Url.Action("AjaxGetFileProcessamento", "Global", new { Area = "g" })' + "?id=" + result.idProcessamento;
                                            }
                                        }
                                    }
                                })
                            }
                            else
                            {
                                LibMessageProcessandoHide();
                                GdiAjaxNotifyInconsistencias(result.msg)
                            }
                        },
                        error: function (result)
                        {
                            LibMessageProcessandoHide();
                            GdiAjaxNotifyInconsistencias(result.toString());
                        }
                    })
                }
                else
                {
                    LibMessageAlert("Atenção", "Selecione apenas 1(um) registro!");
                }
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsAjaxDownloadContratoAviacaoPDF] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalUploadContratoAssinado(TableName, columnName)
    {
        try
        {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            if (!selectedIds || selectedIds.length == 0) {
                LibMessageAlert("Atenção", "Selecione o registro!");
            }
            else
            {
                if (selectedIds.indexOf(',') == -1)
                {
                    LibMessageProcessando("");
                    $("#mainModal").load('@Url.Action("ModalUploadContratoAssinado", "ContratosAviacao", new { area = "g" })?IdContrato=' + selectedIds, function ()
                    {
                        var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
                    });
                }
                else
                {
                    LibMessageAlert("Atenção", "Selecione apenas 1(um) registro!");
                }
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalUploadContratoAssinado] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsDownloadFileContrato(id)
    {
        try
        {
            LibMessageProcessando();
            var dataForm =
            {
                view_ged_arquivos:
                {
                    'id_arquivo': id,
                }
            };
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxDownloadGedContrato", "Ged", new { area = "g" })',
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(dataForm),
                dataType: "json",
                success: function (result) {
                    LibMessageProcessandoHide();
                    if (result.success == true) {
                        window.open(result.url, 'Ged', '_parent');
                        document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                    }
                    else {
                        LibMessageProcessandoHide();
                        GdiAjaxNotifyInconsistencias(result.msg)
                    }
                },
                error: function (result) {
                    LibMessageProcessandoHide();
                    GdiAjaxNotifyInconsistencias(result.toString());
                }
            })
        }
        catch (e)
        {
            LibMessageError("Atenção", "[jsDownloadFile] " + (e && e.message ? e.message.toString() : String(e)));
        }
    }



</script>


