@model GdiPlataform.Areas.g.Models.CstClientesIndex
@using GdiPlataform.Security
@using GdiPlataform.Lib
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool podeEditarCliente = CachePersister.userIdentity.Roles.Contains("g_Clientes_*")
        || CachePersister.userIdentity.Roles.Contains("g_Clientes_Actionupdate");
}
<style>
    .gdi-index-clientes-dt .btnGClientesEditRow { gap: 0.125rem; }
</style>
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(ViewBag.Title)</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterController" value="Clientes" name="yesFilterController" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-header m-0 p-1 d-flex flex-wrap align-items-center gap-1">
                @if ((CachePersister.userIdentity.Roles.Contains("g_Clientes_*")) || (CachePersister.userIdentity.Roles.Contains("g_Clientes_Actioncreate")))
                {
                    if (CachePersister.userIdentity.record_g_parametros.api_sintegra_ativo)
                    {
                        <button type="button" name="btnRegistroNovo" title="Novo Registro" class="btn btn-outline-success d-inline-flex align-items-center gap-2" onclick="jsModalNovoCadastroRoboSintegra()"><i class="fa fa-plus" aria-hidden="true"></i>Novo</button>
                    }
                    else
                    {
                        <button type="button" name="btnRegistroNovo" title="Novo Registro" class="btn btn-outline-success d-inline-flex align-items-center gap-2" onclick="JsNewRecord('@Url.Action("Create","Clientes",new { Area = "g" })')"><i class="fa fa-plus" aria-hidden="true"></i>Novo</button>
                    }
                }
                else
                { <button type="button" name="btnRegistroNovo" title="Novo Registro - Não Liberado" class="btn btn-outline-success disabled d-inline-flex align-items-center gap-2"><i class="fa fa-plus" aria-hidden="true"></i>Novo</button>}
                @if ((CachePersister.userIdentity.Roles.Contains("g_Clientes_*")) || (CachePersister.userIdentity.Roles.Contains("g_Clientes_AtualizarVendedorConsultor")) || (CachePersister.userIdentity.Roles.Contains("g_Clientes_AtualizarLimiteCredito")) || (CachePersister.userIdentity.IdPerfil == -800) || (CachePersister.allSistemas.FirstOrDefault(p => p.id_sistema == 3)?.ativo ?? false))
                {
                    int qtdMenus = 0;
                    <div class="vr mx-1 align-self-stretch"></div>
                    <div class="btn-group" role="group">
                        <button id="btnGroupDrop1" type="button" class="btn btn-outline-info dropdown-toggle d-inline-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="Processos">
                            <i class="fa-solid fa-cog" aria-hidden="true"></i>Processos
                        </button>
                        <div class="dropdown-menu" aria-labelledby="btnGroupDrop1">
                            @if ((CachePersister.userIdentity.Roles.Contains("g_Clientes_*")) || (CachePersister.userIdentity.Roles.Contains("g_Clientes_AtualizarVendedorConsultor")))
                            {
                                <a class="dropdown-item d-flex align-items-center" href="#" onclick="jsModalAtualizarVendedorConsultor(otableCliente, 'Id.')"><i class="fa-solid fa-image-portrait" aria-hidden="true"></i>Alterar Vendedor/Consultor</a>
                                qtdMenus += 1;
                            }
                            @if ((CachePersister.userIdentity.Roles.Contains("g_Clientes_*")) || (CachePersister.userIdentity.Roles.Contains("g_Clientes_AtualizarLimiteCredito")))
                            {
                                if (qtdMenus > 0)
                                {<div class="dropdown-divider"></div> }
                                <a class="dropdown-item d-flex align-items-center" href="#" onclick="jsModalAtualizarLimiteCredito(otableCliente, 'Id.')"><i class="fa-regular fa-credit-card fa-lg" aria-hidden="true"></i>Atualizar Limite Crédito</a>
                                qtdMenus += 1;
                            }
                        </div>
                    </div>
                }
            </div>
            <div class="card-body m-0 p-1" style="height: 100%">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 mt-1 pt-1">
                        @Html.Label("Id", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-2">
                            @Html.TextBoxFor(model => model.ClientesIndex_id_cliente, new { @class = "form-control", @id = "edit_id_cliente", @placeholder = "Id.", @onkeypress = "keypressed(event);" })
                        </div>
                        @Html.Label("Nome", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-5">
                            @Html.TextBoxFor(model => model.ClientesIndex_nome, new { @class = "form-control", @id = "edit_nome_cliente", @placeholder = "Nome ou razão social (qualquer parte)", @onkeypress = "keypressed(event);" })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("CPF", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-2">
                            @Html.TextBoxFor(model => model.ClientesIndex_cpf, new { @class = "form-control", @id = "edit_cpf", @placeholder = "CPF", @onkeypress = "keypressed(event);" })
                        </div>
                        @Html.Label("CNPJ", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-3">
                            @Html.TextBoxFor(model => model.ClientesIndex_cnpj, new { @class = "form-control", @id = "edit_cnpj", @placeholder = "CNPJ", @onkeypress = "keypressed(event);" })
                        </div>
                        <div class="col-sm-3 text-sm-start">
                            <button type="button" id="btnPesquisar" name="btnPesquisar" title="Pesquisar clientes" class="btn btn-secondary d-inline-flex align-items-center gap-2" onclick="jsAjaxPesquisarClientes()"><i class="fa-solid fa-search me-2" aria-hidden="true"></i>Pesquisar</button>
                            <button type="button" id="btnLimparFiltroClientes" name="btnLimparFiltroClientes" title="Limpar filtro e listar todos" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2 ms-1" onclick="jsLimparFiltroClientes()"><i class="fa-solid fa-magnifying-glass-minus me-2" aria-hidden="true"></i>Limpar</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body m-0 p-1 gdi-index-clientes-dt" style="max-width: 100%; overflow-x: auto;">
                <div class="form-horizontal m-0 p-0">
                    <div class="table-responsive scroll-body-horizontal" style="width:100%">
                        <table class="table table-sm table-striped table-hover align-middle w-100 display compact" id="dtGClientes">
                            <thead>
                                <tr>
                                    <th>[x]</th>
                                    <th>Id.</th>
                                    <th>Tipo</th>
                                    <th>Nome / Razão Social</th>
                                    <th>Consultor</th>
                                    <th>CPF/CNPJ</th>
                                    <th>Dt. Cad.</th>
                                    @if (podeEditarCliente)
                                    {
                                        <th><i class="fa-regular fa-edit" style="cursor: pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Editar cliente"></i></th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var otableCliente;

	$(function ()
    {
        try
        {
            jsInitForm();
            jsCreateTable();
            jsAtualizarIndicadorFiltroClientes('0');
            gdiAplicarFoco('#edit_id_cliente', true);
            @if (ViewBag.RestoreFilterAutoSearch == true)
            {
                <text>if (jsClientesTemCriterioFiltro()) { jsAjaxPesquisarClientes(); }</text>
            }
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function keypressed(e)
    {
        if (e.keyCode == 13)
        {
            e.preventDefault();
            jsAjaxPesquisarClientes();
        }
    }

    function jsClientesTemCriterioFiltro()
    {
        return !isEmpty($('#edit_id_cliente').val())
            || !isEmpty($('#edit_nome_cliente').val())
            || !isEmpty($('#edit_cpf').val())
            || !isEmpty($('#edit_cnpj').val());
    }

    function jsAtualizarIndicadorFiltroClientes(yesFilterOnOff)
    {
        GdiAtualizarIndicadorFiltro(yesFilterOnOff, {
            btnId: 'btnLimparFiltroClientes',
            tituloInativo: 'Limpar filtro e listar todos',
            tituloAtivo: 'Filtro ativo — limpar e listar todos os clientes'
        });
    }

    function jsAjaxPesquisarClientes()
    {
        try
        {
            if (!jsClientesTemCriterioFiltro())
            {
                LibMessageAlert("Atenção", "Preencha ao menos um campo do <b>filtro</b> (Id., Nome, CPF ou CNPJ).");
                return;
            }
            LibMessageProcessando('Pesquisando clientes...');
            document.getElementById("yesFilterField").value = "";
            $("#dtGClientes").DataTable().draw(false);
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsAjaxPesquisarClientes] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsLimparFiltroClientes()
    {
        try
        {
            $('#edit_id_cliente').val('');
            $('#edit_nome_cliente').val('');
            $('#edit_cpf').val('');
            $('#edit_cnpj').val('');
            document.getElementById("yesFilterField").value = "*";
            LibMessageProcessando('Atualizando lista...');
            $("#dtGClientes").DataTable().draw(false);
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsLimparFiltroClientes] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsCreateTable()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            otableCliente = $('#dtGClientes').on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) {
                if (GdiDtNotifyJsonErrorMessage(json)) { return; }
                else if (json && json.yesFilterOnOff !== undefined) {
                    jsAtualizarIndicadorFiltroClientes(json.yesFilterOnOff);
                }
            }).DataTable({
            deferLoading: true,
            processing: true,
            bServerSide: true,
            ajax: {
                url: '@Url.Action("GetDados","Clientes", new { Area = "g" })',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                dataType: 'json',
                cache: false,
                data: function (d) {
                    return {
                        sEcho: d.draw,
                        iDisplayStart: d.start,
                        iDisplayLength: d.length,
                        yesFilterField: $('#yesFilterField').val().toString(),
                        yesFilterController: $('#yesFilterController').val().toString(),
                        yesCustomField01: emptyIfNull($('#edit_id_cliente').val()).toString(),
                        yesCustomField02: emptyIfNull($('#edit_nome_cliente').val()).toString(),
                        yesCustomField03: emptyIfNull($('#edit_cpf').val()).toString(),
                        yesCustomField04: emptyIfNull($('#edit_cnpj').val()).toString()
                    };
                },
                error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
            },
            responsive: true,
            bFilter: false,
            bLengthChange: false,
            bProcessing: true,
            pageLength: 20,
            scrollX: false,
            scrollCollapse: false,
            fixedColumns: false,
            bAutoWidth: false,
            pagingType: 'full_numbers',
            aoColumnDefs: [
                { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                { "width": "6%", orderable: false, className: 'text-sm-center', targets: [1] },
                { "width": "6%", orderable: false, className: 'text-sm-center', targets: [2] },
                { "width": "@(podeEditarCliente ? "46%" : "50%")", orderable: false, targets: [3] },
                { "width": "10%", orderable: false, targets: [4] },
                { "width": "14%", orderable: false, targets: [5] },
                { "width": "10%", orderable: false, targets: [6] }
                @if (podeEditarCliente)
                {
                <text>,
                { "width": "4%", orderable: false, className: 'text-sm-center dt-no-row-select', targets: [7], data: null, defaultContent: "",
                    render: function (data, type, row, meta) {
                        return '<button type="button" name="btnGClientesEditRow" data-bs-toggle="tooltip" data-bs-placement="top" title="Editar cliente Id. ' + data[1] + '" class="btn btn-outline-warning btn-sm p-1 btnGClientesEditRow d-inline-flex align-items-center" onclick="jsGClientesEditRow(' + data[1] + ');"><i class="fa-regular fa-edit"></i></button>';
                    }
                }</text>
                }
            ],
            select: {
                style: 'multi',
                selector: 'td:not(.dt-no-row-select)',
                headerCheckbox: true
            },
            order: [[1, 'desc']],
            drawCallback: function (settings) {
                document.querySelectorAll('#dtGClientes [data-bs-toggle="tooltip"]').forEach(function (el) {
                    bootstrap.Tooltip.getOrCreateInstance(el);
                });
                try { new $.fn.dataTable.Api(settings).columns.adjust(); } catch (e) { }
            },
                language:
                {
                    sEmptyTable: 'Informe Id., Cliente, CPF ou CNPJ e clique em Pesquisar (ou Limpar para listar todos).',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
            });
            @if (podeEditarCliente)
            {
                <text>$('#dtGClientes tbody').on('dblclick', 'tr td:not(.dt-no-row-select)', function () {
                var data = otableCliente.row($(this).closest('tr')).data();
                if (data) { jsGClientesEditRow(data[1]); }
            });</text>
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsGClientesEditRow(idCliente)
    {
        try {
            var id = parseInt(idCliente, 10);
            if (!id || id <= 0) { return; }
            JsEditRecordDoubleClick(id, '@Url.Action("Edit", "Clientes", new { Area = "g" })');
        }
        catch (err) {
            LibMessageError("Atenção", "[jsGClientesEditRow] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalEditStatusCredor(TableName, columnName)
    {
        try {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            if (!selectedIds || selectedIds.length == 0)
            {
                LibMessageAlert("Atenção", "Selecione o registro!");
            }
            else {
                if (selectedIds.indexOf(',') == -1) {
                    $("#mainModal").load('@Url.Action("ModalEditStatusCredor", "Clientes", new { Area = "g" })?id=' + selectedIds, function () {
                        var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
                    })
                }
                else
                {
                    LibMessageAlert("Atenção", "Para executar esse processo, selecione apenas 1(um) registro!");
                }
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalEditStatusCredor] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalValidarPefinOnLine()
    {
        $("#mainModal").load('@Url.Action("ModalValidarPefinOnLine", "Clientes", new { Area = "g" })?id=1', function () {
            var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
        })
    }

    function jsModalNovoCadastroRoboSintegra()
    {
        $("#mainModal").load('@Url.Action("CreateSintegra", "Clientes", new { Area = "g" })?id=1', function () {
            var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
        })
    }

    function jsModalAtualizarVendedorConsultor(TableName, columnName, urlEdit)
    {
        try {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            if (!selectedIds || selectedIds.length == 0)
            {
                LibMessageAlert("Atenção", "Selecione o registro!");
            }
            else
            {
                if (selectedIds.indexOf(',') == -1)
                {
                    LibMessageConfirm('Confirmação',
                        'Deseja REALMENTE atualizar os dados do Vendedor/Consultor do cliente?' + '<br/><br/>' +
                        'ATENÇÃO: O LOG dessa operação será gravado no Banco de Dados e ficará disponível para futuras consultas!',
                        {
                            closeButton: false,
                            onEscape: false,
                            backdrop: true,
                            confirmLabel: '<i class="fa-solid fa-save me-2"></i>Confirmar',
                            onConfirm: function () {
                                LibMessageProcessando('');
                                $('#mainModal').load('@Url.Action("ModalAtualizarVendedorConsultor", "Clientes", new { area = "g" })?idCliente=' + selectedIds, function () {
                                    var e = document.getElementById('mainModal'); if (e) { bootstrap.Modal.getOrCreateInstance(e).show(); }
                                });
                                LibMessageHideAll();
                            }
                        });
                }
                else
                {
                    LibMessageAlert("Atenção", "Para esse processo, selecione apenas 1(um) registro!");
                }
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalAtualizarVendedorConsultor] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalAtualizarLimiteCredito(TableName, columnName, urlEdit)
    {
        try {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            if (!selectedIds || selectedIds.length == 0)
            {
                LibMessageAlert("Atenção", "Selecione o registro!");
            }
            else
            {
                if (selectedIds.indexOf(',') == -1)
                {
                    LibMessageConfirm('Confirmação',
                        'Deseja REALMENTE atualizar o Limite de Crédito do cliente?' + '<br/><br/>' +
                        'ATENÇÃO: O LOG dessa operação será gravado no Banco de Dados e ficará disponível para futuras consultas!',
                        {
                            closeButton: false,
                            onEscape: false,
                            backdrop: true,
                            confirmLabel: '<i class="fa-solid fa-save me-2"></i>Confirmar',
                            onConfirm: function () {
                                LibMessageProcessando('');
                                $('#mainModal').load('@Url.Action("ModalAtualizarLimiteCredito", "Clientes", new { area = "g" })?idCliente=' + selectedIds, function () {
                                    var e = document.getElementById('mainModal'); if (e) { bootstrap.Modal.getOrCreateInstance(e).show(); }
                                });
                                LibMessageHideAll();
                            }
                        });
                }
                else
                {
                    LibMessageAlert("Atenção", "Para esse processo, selecione apenas 1(um) registro!");
                }
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalAtualizarLimiteCredito] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }


</script>
