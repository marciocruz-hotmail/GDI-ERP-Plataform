@model GdiPlataform.Db.g_clientes
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "formCreateEdit_gClientes" }))
{
    <div class="row">
        <div class="col-lg-12 m-0 p-0">
            <div class="card m-0 p-0">
                <div class="card-title m-0 p-1">
                    <h5>@Html.Raw(ViewBag.Title)</h5>
                    @Html.HiddenFor(model => model.id_cliente)
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)
                </div>
                <div class="card-header m-0 p-1">
                    <ul class="nav nav-tabs" id="crud-tabs" role="tablist">
                        <li class="nav-item"><a class="d-flex align-items-center nav-link active" id="tabDados_tab" data-bs-toggle="pill" href="#tabDados" role="tab" aria-controls="crud-tabs" aria-selected="true"><i class="fa-solid fa-file-pen fa-sm" aria-hidden="true"></i>Dados</a></li>
                        <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabDocs_tab" data-bs-toggle="pill" href="#tabDocs" role="tab" aria-controls="crud-tabs" aria-selected="false"><i class="fa-solid fa-file-lines fa-sm" aria-hidden="true"></i>Docs</a></li>
                        <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabEndereco_tab" data-bs-toggle="pill" href="#tabEndereco" role="tab" aria-controls="crud-tabs" aria-selected="false"><i class="fa-solid fa-location-dot fa-sm" aria-hidden="true"></i>Endereço</a></li>
                        <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabComercial_tab" data-bs-toggle="pill" href="#tabComercial" role="tab" aria-controls="crud-tabs" aria-selected="false"><i class="fa-solid fa-handshake fa-sm" aria-hidden="true"></i>Comercial</a></li>
                        @if (Model.id_cliente > 0)
                        {
                            <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabGcDestinatarios_tab" data-bs-toggle="pill" href="#tabGcDestinatarios" role="tab" aria-controls="custom-tabs-one-settings" aria-selected="false"><i class="fa-solid fa-truck fa-sm" aria-hidden="true"></i>Destinatários</a></li>
                        }
                        <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabFaturamento_tab" data-bs-toggle="pill" href="#tabFaturamento" role="tab" aria-controls="crud-tabs" aria-selected="false"><i class="fa-solid fa-file-invoice-dollar fa-sm" aria-hidden="true"></i>Faturamento</a></li>
                        @if (Model.id_cliente > 0)
                        {
                            <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabAudit_tab" data-bs-toggle="pill" href="#tabAudit" role="tab" aria-controls="custom-tabs-one-settings" aria-selected="false"><i class="fa-solid fa-magnifying-glass-arrow-right fa-sm" aria-hidden="true"></i>Audit</a></li>
                        }
                    </ul>
                </div>
                <div class="card-body m-0 p-1" style="height: 100%">
                    <div class="form-horizontal m-0 p-0">
                        <div class="tab-content" id="crud-tabs-content">
                            <!-- Dados - Início -->
                            <div class="tab-pane fade show active" id="tabDados" role="tabpanel" aria-labelledby="tabDados_tab">
                                <div class="card-body m-0 p-1" style="height: 100%">
                                    <div class="card shadow-sm gdi-section-accent-secondary m-0 p-0" style="height:100%;">
                                        <div class="section-header"><i class="fa-solid fa-file-pen me-1" aria-hidden="true"></i>Dados do Cliente/Fornecedor</div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.LabelFor(model => model.ativo, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-1 text-sm-start" style="margin-top:7px;">
                                                <div class="form-check form-switch form-switch-lg">
                                                    @Html.CheckBoxFor(model => model.ativo, new { @class = "form-check-input switch-success", role = "switch" })
                                                </div>
                                            </div>
                                            @Html.Label("is_cliente", "Cliente?", htmlAttributes: new { @class = "col-sm-1 col-form-label text-sm-end" })
                                            <div class="col-sm-1 text-sm-start" style="margin-top:7px">
                                                <div class="form-check form-switch form-switch-lg">
                                                    @Html.CheckBoxFor(model => model.is_cliente, new { @class = "form-check-input switch-success", role = "switch" })
                                                </div>
                                            </div>
                                            @Html.Label("is_fornecedor", "Fornecedor?", htmlAttributes: new { @class = "col-sm-2 col-form-label text-sm-end" })
                                            <div class="col-sm-1 text-sm-start" style="margin-top:7px">
                                                <div class="form-check form-switch form-switch-lg">
                                                    @Html.CheckBoxFor(model => model.is_fornecedor, new { @class = "form-check-input switch-success", role = "switch" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.LabelFor(model => model.nome, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-8">
                                                @Html.EditorFor(model => model.nome, new { htmlAttributes = new { @class = "form-control", data_autofocus = "true" } })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.LabelFor(model => model.razao_social, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-8">
                                                @Html.EditorFor(model => model.razao_social, new { htmlAttributes = new { @class = "form-control" } })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.LabelFor(model => model.nome_fantasia, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-8">
                                                @Html.EditorFor(model => model.nome_fantasia, new { htmlAttributes = new { @class = "form-control" } })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("data_cadastro", "Data Cadastro", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-2">
                                                <div class="input-group" id="ig_data_cadastro" data-td-target-input="nearest" data-td-target-toggle="nearest">
                                                    @Html.EditorFor(model => model.data_cadastro, new { htmlAttributes = new { @class = "form-control tempus-dominus-input", type = "text", data_td_target = "#ig_data_cadastro" } })
                                                    <span class="input-group-text" data-td-target="#ig_data_cadastro" data-td-toggle="datetimepicker" role="button" tabindex="0"><i class="fa-regular fa-calendar-alt" aria-hidden="true"></i></span>
                                                </div>
                                            </div>
                                            @Html.Label("contrato", "Nº Contrato", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.contrato, new { htmlAttributes = new { @class = "form-control" } })
                                            </div>
                                            @Html.Label("identificador", "CHE", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.identificador, new { htmlAttributes = new { @class = "form-control" } })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("obs", "Obs", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-8">
                                                @Html.TextAreaFor(model => model.obs, new { @class = "form-control", @rows = "2" })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("email_notificacao", "Emails Notificações", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-8">
                                                @Html.TextAreaFor(model => model.email_notificacao, new { @class = "form-control", @rows = "2" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body m-0 p-1" style="height: 100%">
                                    <div class="card shadow-sm gdi-section-accent-secondary m-0 p-0" style="height:100%;">
                                        <div class="section-header"><i class="fa-solid fa-people-group me-1" aria-hidden="true"></i>Contatos do Cliente/Fornecedor</div>
                                        @if (Model.id_cliente == 0)
                                        {
                                            <div class="card-body text-sm-center m-1 p-0">
                                                <div class="form-group row text-sm-end m-0 pt-1">
                                                    @Html.Label("contato_principal", "Contato", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                                    <div class="col-sm-3">
                                                        @Html.EditorFor(model => model.contato_principal, new { htmlAttributes = new { @class = "form-control" } })
                                                    </div>
                                                    @Html.Label("contato_principal_setor", "Setor", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                    <div class="col-sm-2">
                                                        @Html.EditorFor(model => model.contato_principal_setor, new { htmlAttributes = new { @class = "form-control" } })
                                                    </div>
                                                    @Html.Label("tipo", "Tipo", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                                    <div class="col-sm-2">
                                                        @Html.DropDownListFor(model => model.contato_principal_tipo, ViewBag.ComboGcClientesContatosTipos as List<SelectListItem>, new { @class = "form-control" })
                                                    </div>
                                                </div>
												<div class="form-group row text-sm-end m-0 pt-1">
													@Html.Label("telefone_principal", "Telefone", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
													<div class="col-sm-3">
														@Html.EditorFor(model => model.telefone_principal, new { htmlAttributes = new { @class = "form-control" } })
													</div>
													@Html.Label("email_principal", "Email", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
													<div class="col-sm-5">
														@Html.EditorFor(model => model.email_principal, new { htmlAttributes = new { @class = "form-control" } })
													</div>
												</div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="card-body text-sm-center m-1 p-0">
                                                <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dataTables-Contatos">
                                                    <thead>
                                                        <tr>
                                                            <th>Id.</th>
                                                            <th><i class="fa-solid fa-toggle-on fa-lg" style="color:#008000; cursor:pointer " data-bs-toggle="tooltip" data-bs-placement="top" title="Ativo/Inativo"></i></th>
                                                            <th>Tipo</th>
                                                            <th>Contato</th>
                                                            <th>Setor</th>
                                                            <th>Telefone</th>
                                                            <th>Email</th>
                                                            <th>Dt. Cad.</th>
                                                            <th>Usuário</th>
                                                            <th><i class="fa-regular fa-edit fa-lg" style="color:#B7950B; cursor: pointer " data-bs-toggle="tooltip" data-bs-placement="top" title="Editar"></i></th>
                                                            <th><i class="fa-solid fa-power-off fa-lg" style="color:#cc0000; cursor: pointer " data-bs-toggle="tooltip" data-bs-placement="top" title="Desativar"></i></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody></tbody>
                                                </table>
                                            </div>
                                            <div class="card-body text-sm-center m-0 p-1">
                                                <button type="button" name="btnCadastrarContato" onclick="jsModalCadastrarContato()" title="Cadastrar Novo Contato" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2"><i class="fa fa-plus me-2" aria-hidden="true"></i>Cadastrar Novo Contato</button>
                                            </div>
                                        }
                                    </div>
                                </div>

                            </div>
                            <!-- Dados - Fim -->
                            <!-- Aba Docs - Início -->
                            <div class="tab-pane fade" id="tabDocs" role="tabpanel" aria-labelledby="tabDocs_tab">
                                <div class="card-body m-0 p-1" style="height: 100%">
                                    <div class="card shadow-sm gdi-section-accent-secondary m-0 p-0" style="height:100%;">
                                        <div class="section-header"><i class="fa-solid fa-people-group me-1" aria-hidden="true"></i>Pessoa Física</div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.LabelFor(model => model.cpf, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-3">
                                                @Html.EditorFor(model => model.cpf, new { htmlAttributes = new { @class = "form-control" } })
                                            </div>
                                            @Html.LabelFor(model => model.data_nasc, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-3">
                                                <div class="input-group" id="ig_data_nasc" data-td-target-input="nearest" data-td-target-toggle="nearest">
                                                    @Html.EditorFor(model => model.data_nasc, new { htmlAttributes = new { @class = "form-control tempus-dominus-input", type = "text", data_td_target = "#ig_data_nasc" } })
                                                    <span class="input-group-text" data-td-target="#ig_data_nasc" data-td-toggle="datetimepicker" role="button" tabindex="0"><i class="fa-regular fa-calendar-alt" aria-hidden="true"></i></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.LabelFor(model => model.matricula, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-3">
                                                @Html.EditorFor(model => model.matricula, new { htmlAttributes = new { @class = "form-control" } })
                                            </div>
                                            @Html.LabelFor(model => model.rg, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-3">
                                                @Html.EditorFor(model => model.rg, new { htmlAttributes = new { @class = "form-control" } })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body m-0 p-1" style="height: 100%">
                                    <div class="card shadow-sm gdi-section-accent-secondary m-0 p-0" style="height:100%;">
                                        <div class="section-header"><i class="fa-solid fa-people-group me-1" aria-hidden="true"></i>Pessoa Jurídica</div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.LabelFor(model => model.cnpj, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-3">
                                                @Html.EditorFor(model => model.cnpj, new { htmlAttributes = new { @class = "form-control" } })
                                            </div>
                                            @Html.LabelFor(model => model.id_indicador_ie, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-3">
                                                @Html.DropDownListFor(model => model.id_indicador_ie, ViewBag.comboIndicadorIE as List<SelectListItem>, new { @class = "form-control" })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.LabelFor(model => model.inscricao_estadual, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-3">
                                                @Html.EditorFor(model => model.inscricao_estadual, new { htmlAttributes = new { @class = "form-control" } })
                                            </div>
                                            @Html.LabelFor(model => model.inscricao_municipal, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-3">
                                                @Html.EditorFor(model => model.inscricao_municipal, new { htmlAttributes = new { @class = "form-control" } })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.LabelFor(model => model.constituicao, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-3">
                                                <div class="input-group" id="ig_constituicao" data-td-target-input="nearest" data-td-target-toggle="nearest">
                                                    @Html.EditorFor(model => model.constituicao, new { htmlAttributes = new { @class = "form-control tempus-dominus-input", type = "text", data_td_target = "#ig_constituicao" } })
                                                    <span class="input-group-text" data-td-target="#ig_constituicao" data-td-toggle="datetimepicker" role="button" tabindex="0"><i class="fa-regular fa-calendar-alt" aria-hidden="true"></i></span>
                                                </div>
                                            </div>
                                            @Html.LabelFor(model => model.inicio_atividade, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-3">
                                                <div class="input-group" id="ig_inicio_atividade" data-td-target-input="nearest" data-td-target-toggle="nearest">
                                                    @Html.EditorFor(model => model.inicio_atividade, new { htmlAttributes = new { @class = "form-control tempus-dominus-input", type = "text", data_td_target = "#ig_inicio_atividade" } })
                                                    <span class="input-group-text" data-td-target="#ig_inicio_atividade" data-td-toggle="datetimepicker" role="button" tabindex="0"><i class="fa-regular fa-calendar-alt" aria-hidden="true"></i></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Aba Docs - Fim -->
                            <!-- Aba Endereço - Início -->
                            <div class="tab-pane fade" id="tabEndereco" role="tabpanel" aria-labelledby="tabEndereco_tab">
                                <div class="card-body m-0 p-1" style="height: 100%">
                                    <div class="card shadow-sm gdi-section-accent-secondary m-0 p-0" style="height:100%;">
                                        <div class="section-header"><i class="fa-solid fa-location-dot me-1" aria-hidden="true"></i>Endereço</div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.LabelFor(model => model.endereco_com, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-6">
                                                @Html.EditorFor(model => model.endereco_com, new { htmlAttributes = new { @class = "form-control" } })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("endereco_com_numero", "Nº", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-1">
                                                @Html.EditorFor(model => model.endereco_com_numero, new { htmlAttributes = new { @class = "form-control" } })
                                            </div>
                                            @Html.Label("endereco_com_complemento", "Complem.", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-3">
                                                @Html.EditorFor(model => model.endereco_com_complemento, new { htmlAttributes = new { @class = "form-control" } })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.LabelFor(model => model.bairro_com, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-6">
                                                @Html.EditorFor(model => model.bairro_com, new { htmlAttributes = new { @class = "form-control" } })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.LabelFor(model => model.id_cidade_com, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-6">
                                                @Html.DropDownListFor(model => model.id_cidade_com, ViewBag.comboCidade as List<SelectListItem>, new { @class = "form-control" })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.LabelFor(model => model.cep_com, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-3">
                                                @Html.EditorFor(model => model.cep_com, new { htmlAttributes = new { @class = "form-control" } })
                                            </div>
                                            @Html.LabelFor(model => model.id_uf_com, htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.DropDownListFor(model => model.id_uf_com, ViewBag.comboUF as List<SelectListItem>, new { @class = "form-control" })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("Pais", "Pais", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-3">
                                                @Html.DropDownListFor(model => model.id_pais, ViewBag.comboPais as List<SelectListItem>, new { @class = "form-control" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Aba Endereço - Fim -->
                            <!-- Aba Comercial - Início -->
                            <div class="tab-pane fade" id="tabComercial" role="tabpanel" aria-labelledby="tabComercial_tab">
                                <div class="card-body m-0 p-1" style="height: 100%">
                                    <div class="card shadow-sm gdi-section-accent-secondary m-0 p-0" style="height:100%;">
                                        <div class="section-header"><i class="fa-solid fa-file-pen me-1" aria-hidden="true"></i>Dados Comerciais</div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.LabelFor(model => model.id_vendedor, htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-6">
                                                @Html.DropDownListFor(model => model.id_vendedor, ViewBag.comboVendedor as List<SelectListItem>, new { @class = "form-control" })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("model.param_gc_transportadora", "Transportadora?", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-1 text-sm-start" style="margin-top:7px;">
                                                <div class="form-check form-switch form-switch-lg">
                                                    @Html.CheckBoxFor(model => model.param_gc_transportadora, new { @class = "form-check-input switch-success", role = "switch" })
                                                </div>
                                            </div>
                                            @Html.Label("model.gc_produtor_rural", "Produtor Rural?", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-1 text-sm-start" style="margin-top:7px;">
                                                <div class="form-check form-switch form-switch-lg">
                                                    @Html.CheckBoxFor(model => model.gc_produtor_rural, new { @class = "form-check-input switch-success", role = "switch" })
                                                </div>
                                            </div>
                                            @Html.Label("model.gc_consultor_aviacao", "Consultor Aviação?", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-1 text-sm-start" style="margin-top:7px;">
                                                <div class="form-check form-switch form-switch-lg">
                                                    @Html.CheckBoxFor(model => model.gc_consultor_aviacao, new { @class = "form-check-input switch-success", role = "switch" })
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
