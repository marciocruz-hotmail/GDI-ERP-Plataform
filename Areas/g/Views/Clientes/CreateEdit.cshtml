    function jsRemoverContato(idContato, contato)
    {
        try
        {
            LibMessageDialog({
                title: "Confirmação",
                closeButton: false,
                message: "Deseja <b>REALMENTE</b> remover o Contato <b>" + contato + "</b> ?" + "<br/><br/>" + "<b>Atenção:</b> O LOG dessa operação será gravado no Banco de Dados e ficará disponível para futuras consultas!",
                centerVertical: true,
                onEscape: false,
                backdrop: true,
                buttons: {
                    cancelar: {
                        label: '<i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar',
                        className: 'btn-outline-warning',
                        callback: function ()
                        {
                            LibMessageHideAll();
                        }
                    },
                    confirmar: {
                        label: '<i class="fa-solid fa-save me-2" aria-hidden="true"></i>Confirmar',
                        className: 'btn-outline-success',
                        callback: function ()
                        {
                            jsSendRemoverContato(idContato);
                            LibMessageHideAll();
                        }
                    }
                }
            })
        }
        catch (err) {
            LibMessageError("Atenção", "[jsRemoverContato] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsSendRemoverContato(idContato)
    {
        LibMessageProcessando("");
        try
        {
            var dataForm =
            {
                record_g_clientes_contatos:
                {
                    'id_contato': idContato
                }
            };
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxRemoverContato", "Clientes", new { area = "g" })',
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(dataForm),
                dataType: "json",
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        LibMessageDialog({
                            title: "Confirmação",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons: {
                                confirmar: {
                                    label: 'OK',
                                    callback: function ()
                                    {
                                        $("#dataTables-Contatos").DataTable().draw(false);
                                        LibMessageHideAll();
                                    }
                                }
                            }
                        })
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias(result.msg)
                    }
                },
                error: function (result)
                {
                    GdiAjaxNotifyInconsistencias(result.msg)
                }
            });
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsSendRemoverContato] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

