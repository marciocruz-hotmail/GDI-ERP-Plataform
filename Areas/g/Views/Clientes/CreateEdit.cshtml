<script type="text/javascript">
    var otableContatos;
    var otableDestinatarios;
    var otableGClientesAudit;
    var otableGcTarefasCliente;

    $(function ()
    {
        try
        {
            jsDatepicker('#ig_data_cadastro');
            jsDatepicker('#ig_data_nasc');
            jsDatepicker('#ig_constituicao');
            jsDatepicker('#ig_inicio_atividade');
            jsInitForm();
            jsSetCampos();
            TableCreateContatos();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsSetCampos()
    {
        try
        {
            if (@Model.id_cliente > 0) {
                $('#cpf').attr('readonly', 'readonly');
                $('#cnpj').attr('readonly', 'readonly');
                $('#id_vendedor').attr('disabled', true);
            }
        }
        catch (err)
        {
            LibMessageProcessandoHide();
            LibMessageError("Atenção", "[jsSetCampos] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalCadastrarContato()
    {
        try
        {
            LibMessageProcessando("");
            var IdCliente = $('#id_cliente').val().toString();
            $("#mainModal").load('@Url.Action("ModalCreateEditContato", "Clientes", new { area = "g" })?IdCliente=' + IdCliente + '&IdContato=0', function () {
                var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
            });
        }
        catch (e) {
            LibMessageError("Atenção", "[jsModalCadastrarContato] " + (e && e.message ? e.message.toString() : String(e)));
        }
    }

