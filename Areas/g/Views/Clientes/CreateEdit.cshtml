        }
    }


    function TableCreateContatos()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            otableContatos = $('#dataTables-Contatos').on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) { GdiDtNotifyJsonErrorMessage(json); btnFiltro(json.yesFilterOnOff) }).DataTable({
                "drawCallback": function (settings) {
                    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) { bootstrap.Tooltip.getOrCreateInstance(el); });
                },
            processing: true,
            bServerSide: true,
            ajax: {
                url: '@Url.Action("GetDadosContatos", "Clientes", new { area = "g" })',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                dataType: 'json',
                cache: false,
                data: function (d) {
                    return {
                        sEcho: d.draw,
                        iDisplayStart: d.start,
                        iDisplayLength: d.length,
                        yesCustomIdPK: $('#id_cliente').val().toString(),
                    };
                },
                error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
            },
            responsive: true,
            bFilter: false,
            bLengthChange: false,
            bProcessing: true,
            pageLength: 10,
            scrollX: false,
            scrollCollapse: false,
            fixedColumns: false,
            bAutoWidth: false,
            pagingType: 'full_numbers',
            aoColumnDefs: [
                { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0] },
                { "width": "5%", orderable: false, className: 'text-sm-center', targets: [1] },
                { "width": "8%", orderable: false, className: 'text-sm-start', targets: [2] },
                { "width": "8%", orderable: false, className: 'text-sm-start', targets: [3] },
                { "width": "10%", orderable: false, className: 'text-sm-start', targets: [4] },
                { "width": "15%", orderable: false, className: 'text-sm-start', targets: [5] },
                { "width": "20%", orderable: false, className: 'text-sm-start', targets: [6] },
