@model GdiPlataform.Db.g_clientes_contatos
@{ Layout = null; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "FormModalDesativarContato" }))
{
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title d-flex align-items-center gap-2">@Html.Raw(ViewBag.Title)</h5>
                @Html.HiddenFor(model => model.id_cliente)
                @Html.HiddenFor(model => model.id_contato)
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-2">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("contato", "Contato", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                        <div class="col-sm-5">
                            @Html.EditorFor(model => model.contato, new { htmlAttributes = new { @class = "form-control", maxlength = "30" } })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("tipo", "Tipo", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                        <div class="col-sm-5">
                            @Html.DropDownListFor(model => model.id_contato_tipo, ViewBag.ComboGcClientesContatosTipos as List<SelectListItem>, new { @class = "form-control" })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("telefone", "Telefone", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                        <div class="col-sm-5">
                            @Html.EditorFor(model => model.telefone, new { htmlAttributes = new { @class = "form-control", maxlength = "20" } })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("email", "Email", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                        <div class="col-sm-8">
                            @Html.EditorFor(model => model.email, new { htmlAttributes = new { @class = "form-control", maxlength = "100" } })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Motivo", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                        <div class="col-sm-8">
                            @Html.EditorFor(model => model.motivo_desativacao, new { htmlAttributes = new { @class = "form-control", maxlength = "80" } })
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" class="btn btn-warning me-auto d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                <button type="button" class="btn btn-success d-inline-flex align-items-center gap-2" onclick="jsSaveForm()"><i class="fa-solid fa-power-off me-2" aria-hidden="true"></i>Desativar Contato</button>
            </div>
        </div>
    </div>
}

<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsInitModal();
            $('#contato').attr('readonly', 'readonly');
            $('#telefone').attr('readonly', 'readonly');
            $('#email').attr('readonly', 'readonly');
            $('#id_contato_tipo').attr('disabled', true);
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsLoadForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsSaveForm()
    {
        try
        {
            LibMessageProcessando("")
            var form = $('#FormModalDesativarContato');
            $.ajax({
                cache: false,
                async: true,
                type: "POST",
                url: '@Url.Action("AjaxDesativarContato", "Clientes", new { area = "g" })',
                data: form.serialize(),
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        LibMessageSuccess("Confirmação", result.msg, {
                            callback: function ()
                            {
                                $("#dataTables-Contatos").DataTable().draw(false);
                                document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                LibMessageHideAll();
                            }
                        })
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias(result.msg);
                    }
                },
                error: function (result)
                {
                    GdiAjaxNotifyInconsistencias(result.toString());
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

</script>


