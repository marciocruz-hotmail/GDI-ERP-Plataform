@model GdiPlataform.Areas.g.Models.cstClienteLimiteCredito
@{ Layout = null; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "formModalAtualizarAtualizarLimiteCredito" }))
{
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title d-flex align-items-center gap-2">
    <i class="fa-solid fa-circle-info fa-sm" aria-hidden="true"></i>
    @Html.Raw(ViewBag.Title)</h5>
                @Html.HiddenFor(model => model.id_cliente)
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-1">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("consulta_cadastral_realizada", "Consulta Realizada?", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-1 text-sm-start" style="margin-top:7px;">
                            <div class="form-check form-switch form-switch-lg">
                                @Html.CheckBoxFor(model => model.consulta_cadastral_realizada, new { @class = "form-check-input switch-success", role = "switch" })
                            </div>
                        </div>
                        @Html.Label("consulta_cadastral_restricoes", "Existem Restrições?", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-1 text-sm-start" style="margin-top:7px;">
                            <div class="form-check form-switch form-switch-lg">
                                @Html.CheckBoxFor(model => model.consulta_cadastral_restricoes, new { @class = "form-check-input switch-success", role = "switch" })
                            </div>
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("consulta_cadastral_data", "Data Consulta", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-3">
                            @* id do .input-group distinto do input para Tempus Dominus *@
                            <div class='input-group date' id='ig_g_cliente_modal_limite_cred_data'>
                                @Html.EditorFor(model => model.consulta_cadastral_data, new { htmlAttributes = new { @class = "form-control", type = "text" } })
                                <span class="input-group-text"><i class="fa-regular fa-calendar-alt"></i></span>
                            </div>
                        </div>
                        @Html.Label("consulta_cadastral_score", "Score", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                        <div class="col-sm-3">
                            @Html.EditorFor(model => model.consulta_cadastral_score, new { htmlAttributes = new { @class = "form-control" } })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("limite_credito_atual", "Limite Atual", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-3">
                            @Html.EditorFor(model => model.limite_credito_atual, new { htmlAttributes = new { @class = "form-control" } })
                        </div>
                        @Html.Label("novo_limite_credito", "Novo Limite", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                        <div class="col-sm-3">
                            @Html.EditorFor(model => model.novo_limite_credito, new { htmlAttributes = new { @class = "form-control" } })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("justificativa", "Justificativa", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-9">
                            @Html.EditorFor(model => model.justificativa, new { htmlAttributes = new { @class = "form-control" } })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("aprovado_por", "Aprovado Por?", htmlAttributes: new { @class = "col-sm-3 col-form-label" })
                        <div class="col-sm-5">
                            @Html.EditorFor(model => model.aprovado_por, new { htmlAttributes = new { @class = "form-control" } })
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" name="btnCancelar" title="Cancelar" class="btn btn-warning d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                <button type="button" name="btnExec" title="Alterar Status Pefin" class="btn btn-success float-end d-inline-flex align-items-center gap-2" onclick="jsSendForm()"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>Confirmar</button>
            </div>
        </div>
    </div>
}

<script type="text/javascript">

	$(function ()
    {
        try
        {
            jsDatepicker('#ig_g_cliente_modal_limite_cred_data');
            jsInitModal();
            $('#limite_credito_atual').attr('disabled', true);
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsSendForm()
    {
        try
        {
            $('#limite_credito_atual').attr('disabled', false);
            var form = $('#formModalAtualizarAtualizarLimiteCredito');
            LibMessageProcessando("");
            $.ajax({
                cache: false,
                async: true,
                type: "POST",
                url: '@Url.Action("AjaxModalAtualizarLimiteCredito", "Clientes", new { area = "g" })',
                data: form.serialize(),
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        LibMessageSuccess("Confirmação", result.msg, {
                            callback: function ()
                            {
                                document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                LibMessageHideAll();
                            }
                        })
                    }
                    else
                    {
                        $('#limite_credito_atual').attr('disabled', true);
                        GdiAjaxNotifyInconsistencias(result.msg);
                    }
                },
                error: function (result)
                {
                    LibMessageProcessandoHide();
                    $('#limite_credito_atual').attr('disabled', true);
                    GdiAjaxNotifyInconsistencias(result.toString());
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };


</script>
