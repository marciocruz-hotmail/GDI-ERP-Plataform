@model GdiPlataform.Areas.g.Models.CstFinanceiroBoletos
@{ Layout = null; }
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="~/LibUI_AdminLTE-4.0.0/css/adminlte.min.css" rel="stylesheet" />
    <link href="~/LibUI_AdminLTE-4.0.0/plugins/startprime/css/start.css" rel="stylesheet" />
</head>

<body>
    <table class="table" style="border:0px">
        <thead>
            <tr>
                <th scope="col" style="border: 0px; width: 20%; vertical-align: central;"><img src="https://bucket-gdi-public-files.s3.sa-east-1.amazonaws.com/FilesImages/logoGdi.png" style="height:100px;width:200px;" /></th>
                <th scope="col" style="border: 0px; width: 60%; vertical-align: central;"><p style="font-size:30px; color:#4D5656">@Model.EDadosCabecalho1</p></th>
                <th scope="col" style="border: 0px; width: 20%; vertical-align: central; "><img src="@Model.ELogoBanco" style="height:80px;width:80px;" /></th>
            </tr>
        </thead>
        <tbody>
            <tr><th colspan=3 style="border:0px; font-size:20px; color:#4D5656; margin:5px; padding:5px">&nbsp;</th></tr>
            <tr><th colspan=3 style="border:0px; font-size:20px; color:#4D5656; margin:5px; padding:5px"><b>Dados do Beneficiário</b></th></tr>
            <tr><th colspan=3 style="border:0px; font-size:14px; color:#4D5656; margin:2px; padding:2px">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<b>Razão Social:</b> @Model.ECedenteNome</th></tr>
            <tr><th colspan=3 style="border:0px; font-size:14px; color:#4D5656; margin:2px; padding:2px">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<b>Endereço:</b> @Model.ECedenteComplemento1</th></tr>
            <tr><th colspan=3 style="border:0px; font-size:14px; color:#4D5656; margin:2px; padding:2px">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<b>Cidade:</b> @Model.ECedenteComplemento2</th></tr>

            <tr><th colspan=3 style="border:0px; font-size:20px; color:#4D5656; margin:5px; padding:5px">&nbsp;</th></tr>
            <tr><th colspan=3 style="border:0px; font-size:20px; color:#4D5656; margin:5px; padding:5px"><b>Dados do Cliente</b></th></tr>
            <tr><th colspan=3 style="border:0px; font-size:14px; color:#4D5656; margin:2px; padding:2px">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<b>Nome:</b> @Model.EClienteNome</th></tr>
            <tr><th colspan=3 style="border:0px; font-size:14px; color:#4D5656; margin:2px; padding:2px">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<b>CPF/CNPJ:</b> @Model.EClienteDocumento</th></tr>
            <tr><th colspan=3 style="border:0px; font-size:14px; color:#4D5656; margin:2px; padding:2px">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<b>Endereço:</b> @Model.EClienteEndereco</th></tr>
            <tr><th colspan=3 style="border:0px; font-size:14px; color:#4D5656; margin:2px; padding:2px">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<b>Cidade:</b> @Model.EClienteEnderecoCidadeUF</th></tr>

            <tr><th colspan=3 style="border:0px; font-size:20px; color:#4D5656; margin:5px; padding:5px">&nbsp;</th></tr>
            <tr><th colspan=3 style="border:0px; font-size:20px; color:#4D5656; margin:5px; padding:5px"><b>Dados do Boleto</b></th></tr>
            <tr><th colspan=3 style="border:0px; font-size:14px; color:#4D5656; margin:2px; padding:2px">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<b>Data Vencimento:</b> @Model.EDataVencimento</th></tr>
            <tr><th colspan=3 style="border:0px; font-size:14px; color:#4D5656; margin:2px; padding:2px">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<b>Nº Boleto:</b> @Model.ENossoNumeroDV</th></tr>
            <tr><th colspan=3 style="border:0px; font-size:14px; color:#4D5656; margin:2px; padding:2px">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<b>Documento:</b> @Model.ENumeroDocumento</th></tr>
            <tr><th colspan=3 style="border:0px; font-size:14px; color:#4D5656; margin:2px; padding:2px">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<b>R$ Valor:</b> @Model.EValorBruto</th></tr>

            <tr><th colspan=3 style="border:0px; font-size:20px; color:#4D5656; margin:5px; padding:5px">&nbsp;</th></tr>
            <tr><th colspan=3 style="border:0px; font-size:20px; color:#4D5656; padding-left:20px; margin:5px; padding:5px"><b>Mensagem de Instrução</b></th></tr>
            <tr><th colspan=3 style="border:0px; font-size:14px; color:#4D5656; margin:0px; padding:0px">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@Html.Raw(@Model.EMensagemCaixa)</th></tr>

            <tr><th colspan=3 style="border:0px; font-size:20px; color:#4D5656; margin:5px; padding:5px">&nbsp;</th></tr>
            <tr><th colspan=3 style="border:0px; font-size:20px; color:#4D5656; margin:5px; padding:5px"><b>Linha Digitável</b></th></tr>
            <tr><th colspan=3 style="border:0px; font-size:14px; color:#4D5656; margin:5px; padding:5px">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@Model.ELinhaDigitavel</th></tr>

            <tr><th colspan=3 style="border:0px; font-size:20px; color:#4D5656; margin:5px; padding:5px">&nbsp;</th></tr>
            <tr><th colspan=3 style="border:0px; font-size:20px; color:#4D5656; margin:5px; padding:5px"><b>Código de Barras</b></th></tr>
            <tr><th colspan=3 style="border:0px;" height=60 valign=top><img src="@Model.EImgBarCode" alt="" height="50" width="500" /></th></tr>

            <tr><th colspan=3 style="border:0px; font-size:20px; color:#4D5656; margin:5px; padding:5px">&nbsp;</th></tr>
            <tr><th colspan=3 style="border:0px; font-size:20px; color:#4D5656; margin:5px; padding:5px"><b>PIX</b></th></tr>
            <tr><th colspan=3 style="border:0px;" height=60 valign=top><img src="@Model.EImgPixQrCode" alt="" height="180" width="180" /></th></tr>
        </tbody>
    </table>
</body>
</html>
