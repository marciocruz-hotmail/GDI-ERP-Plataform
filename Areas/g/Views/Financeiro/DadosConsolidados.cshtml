@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
<style>
    .table th {
        text-align: center;
    }
</style>
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@ViewBag.Title</h5>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-body m-0 p-1" style="max-width: 100%; overflow-x: auto; ">
                <div class="form-horizontal m-0 p-0">
                    <div class="table-responsive scroll-body-horizontal" style="width:100%">
                        <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dtGClientesDadosConsolidados">
                            <thead>
                                <tr>
                                    <th rowspan="2">[x]</th>
                                    <th rowspan="2">Período</th>
                                    <th colspan="2">Quitados</th>
                                    <th colspan="2">Abertos</th>
                                    <th colspan="2">Transferido</th>
                                    <th colspan="2">Total</th>
                                </tr>
                                <tr>
                                    <th>Qtd</th>
                                    <th>R$</th>
                                    <th>Qtd</th>
                                    <th>R$</th>
                                    <th>Qtd</th>
                                    <th>R$</th>
                                    <th>Qtd</th>
                                    <th>R$</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                </div>
            </div>
            <!-- Gráfico -->
            <div class="card-body m-0 p-1" style="height: 100%">
                <div class="card-title m-0 p-1">
                    Demonstração Gráfica
                </div>
                <div class="card-body m-0 p-1" style="height: 100%">
                    <div class="flot-chart">
                        <div class="flot-chart-content" id="flot-custom-4"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script type="text/javascript">
    var oTableGClientesDadosConsolidados;

	$(function ()
    {
        try
        {
            jsInitForm();
            jsCreateTable();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsCreateTable()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            oTableGClientesDadosConsolidados = $('#dtGClientesDadosConsolidados').on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) { GdiDtNotifyJsonErrorMessage(json); }).DataTable({
            processing: true,
            bServerSide: true,
            ajax: {
                url: '@Url.Action("getValoresConsolidados", "Financeiro", new { Area = "g" })',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                dataType: 'json',
                cache: false,
                data: function (d) {
                    return {
                        sEcho: d.draw,
                        iDisplayStart: d.start,
                        iDisplayLength: d.length,
                    };
                },
                error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
            },
            responsive: true,
            bFilter: false,
            bLengthChange: false,
            bProcessing: true,
            pageLength: 12,
            scrollX: false,
            scrollCollapse: false,
            fixedColumns: false,
            bAutoWidth: false,
            pagingType: 'full_numbers',
            aoColumnDefs: [
                { "width": "5%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                { "width": "11%", orderable: false, className: 'text-sm-center', targets: [1] },
                { "width": "6%", orderable: false, className: 'text-sm-center', targets: [2] },
                { "width": "15%", orderable: false, className: 'text-sm-end', targets: [3] },
                { "width": "6%", orderable: false, className: 'text-sm-center', targets: [4] },
                { "width": "15%", orderable: false, className: 'text-sm-end', targets: [5] },
                { "width": "6%", orderable: false, className: 'text-sm-center', targets: [6] },
                { "width": "15%", orderable: false, className: 'text-sm-end', targets: [7] },
                { "width": "6%", orderable: false, className: 'text-sm-center', targets: [8] },
                { "width": "15%", orderable: false, className: 'text-sm-end', targets: [9] }
            ],
            select: {
                style: 'multi',
                selector: 'td:not(.dt-no-row-select)',
                headerCheckbox: true
            },
            order: [[1, 'asc']],

                language:
                {
                    sEmptyTable: 'Nenhum registro encontrado',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    $(function ()
    {
        try
        {
            $.ajax({
                type: "GET",
                contentType: 'application/json; charset=utf-8',
                dataType: 'json',
                url: '@Url.Action("GetDadosGrafico", "Financeiro", new { Area = "g" })',
                error: function ()
                {
                    LibMessageAlert("Atenção", "Falha ao processar os dados <b>" + url + "</b>");
                },
                success: function (result)
                {
                    if (result.errorMessage) {
                        LibMessageError("Atenção", result.errorMessage);
                        return;
                    }
                    var ticks = result.dataTicks;
                    var qtdQuitado = result.dataQuitado;
                    var qtdAberto = result.dataAberto;
                    var qtdTransferido = result.dataTransferido;
                    var qtdTotal = result.dataTotal;

                    var options = {
                        series: { lines: { show: true }, points: { show: true } },
                        tooltip: true,
                        tooltipOpts: {
                            content: function (label, xval, yval) {
                                var content = "Período: <b>" + ticks[xval - 1][1] + "</b><br>%s: <b>" + JsFormatMoney(yval) + "</b>";
                                return content;
                            }
                        },
                        xaxis: {
                            ticks: ticks
                        },
                        yaxis: {
                            tickFormatter: function formatter(val, axis) {
                                return JsFormatMoney(val)
                            }
                        },
                        grid: { hoverable: true },
                    };
                    var plotObj = $.plot($("#flot-custom-4"), [
                        { data: qtdAberto, label: "Abertos", color: "#FFFF00" },
                        { data: qtdTransferido, label: "Transferidos", color: "#FF8000" },
                        { data: qtdQuitado, label: "Quitados", color: "#31B404" },
                        { data: qtdTotal, label: "Total", color: "#848484" }], options);
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsLoadForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    });


</script>
