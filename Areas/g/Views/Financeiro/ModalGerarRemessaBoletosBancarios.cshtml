@model GdiPlataform.Db.g_contas_caixas
@{Layout = null;}
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "formModalGerarRemessaBoletosBancarios_gFinanceiro" }))
{
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title d-flex align-items-center gap-2">
    <i class="fa-solid fa-circle-info fa-sm" aria-hidden="true"></i>
    @Html.Raw(@ViewBag.Title)</h5>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-1">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @if (Model.id_processamento > -1)
                        {
                            @Html.Label("Conta", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                            <div class="col-sm-9 text-sm-start">
                                @Html.DropDownListFor(model => model.id_conta_caixa, ViewBag.comboContasCaixas as List<SelectListItem>, new { @class = "form-control" })
                            </div>
                        }
                        @if (Model.id_processamento == -1)
                        {
                            @Html.Label("Atenção: Realize a pesquisa antes de executar o processo!", htmlAttributes: new { @class = "col-sm-10 col-form-label", @style = "margin-top:5px;color:red" })
                        }
                    </div>
                </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" name="btnCancelar" title="Cancelar" class="btn btn-warning me-auto d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                @if (Model.id_processamento > -1)
                {
                    <button type="button" name="btnSalvar" title="Confirmar" class="btn btn-success d-inline-flex align-items-center gap-2" onclick="jsSendForm()"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>Confirmar</button>
                }
            </div>
        </div>
    </div>
}

<script type="text/javascript">

	$(function ()
    {
        try
        {
            jsInitModal();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });
   
    function jsSendForm()
    {
        try {
            LibMessageProcessando("Processando remessa bancária . . .")
            var form = $('#formModalGerarRemessaBoletosBancarios_gFinanceiro');
            $.ajax({
                cache: false,
                async: true,
                type: "POST",
                url: '@Url.Action("AjaxGerarRemessaBoletosBancarios", "Financeiro", new { area = "g" })',
                data: form.serialize(),
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true) {
                        GdiSwal2.dialog({
                            title: "<i class='fa-solid fa-check' style='color:#008000'>&nbsp&nbsp</i><b>Confirmação</b>",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons: {
                                confirmar: {
                                    label: '&nbsp;OK',
                                    className: 'btn btn-info',
                                    callback: function ()
                                    {
                                        $("#dataTables-Titulos").DataTable().draw(false);
                                        document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                        window.location = '@Url.Action("AjaxGetFileProcessamento", "Global", new { Area = "g" })' + "?id=" + result.idProcessamento;
                                        jsAjaxPesquisarFinanceiro();
                                        GdiSwal2.hideAll();
                                    }
                                }
                            }
                        })
                    }
                    else {
                        GdiAjaxNotifyInconsistencias(result.msg);
                    }
                },
                error: function (result)
                {
                    GdiAjaxNotifyInconsistencias(result.toString());
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsRunFiltroAvancadoModal()
    {
        try
        {
            var msgButton = document.getElementById("btnFiltroAvancado").innerHTML.replace("Filtro Avançado", "Remover Filtro").replace("fa-solid fa-filter", "fa-solid fa-magnifying-glass-minus");
            document.getElementById("btnFiltroAvancado").innerHTML = msgButton;
            document.getElementById("btnFiltroAvancado").title = "Remover Filtro";
            executarFiltroAvancado($('#editIdClienteFornecedor').val().toString() + ";" + emptyIfNull($('#editData1').data('date')).toString() + ";" + emptyIfNull($('#editData2').data('date')).toString());
            document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
        }
        catch (err) {
            LibMessageError("Atenção", "[jsRunFiltroAvancadoModal] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }


</script>

