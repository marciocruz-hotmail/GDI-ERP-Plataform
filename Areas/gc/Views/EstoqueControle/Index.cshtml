@model GdiPlataform.Areas.gc.Models.CstEstoqueControleIndex
@using GdiPlataform.Security
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool podeEditarEstoqueControle = CachePersister.userIdentity.Roles.Contains("gc_EstoqueControle_*")
        || CachePersister.userIdentity.Roles.Contains("gc_EstoqueControle_Actionupdate");
}
<style>
    .gdi-index-estoquecontrole-dt .btnGcEstoqueControleEditRow { gap: 0.125rem; }
</style>
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(ViewBag.Title)</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterController" value="EstoqueControle" name="yesFilterController" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-header m-0 p-1">
                @if ((CachePersister.userIdentity.Roles.Contains("gc_EstoqueControle_*")) || (CachePersister.userIdentity.Roles.Contains("gc_EstoqueControle_Actioncreate")))
                {<button type="button" name="btnRegistroNovo" title="Novo Registro" class="btn btn-outline-success d-inline-flex align-items-center gap-2" onclick="jsModalCreateEditEstoqueControle(0)"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button> }
                else
                { <button type="button" name="btnRegistroNovo" title="Novo Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button>}
            </div>
            <div class="card-body m-0 p-1" style="height: 100%">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Id", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-2">
                            @Html.TextBoxFor(model => model.EstoqueControleIndex_id, new { @class = "form-control", @id = "edit_id_estoquecontrole", @placeholder = "Id.", @onkeypress = "keypressedEstoqueControle(event);" })
                        </div>
                        @Html.Label("Serial", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-5">
                            @Html.TextBoxFor(model => model.EstoqueControleIndex_serial, new { @class = "form-control", @id = "edit_serial_estoquecontrole", @placeholder = "Serial", @onkeypress = "keypressedEstoqueControle(event);" })
                        </div>
                        <div class="col-sm-3 text-sm-start">
                            <button type="button" id="btnPesquisarEstoqueControle" title="Pesquisar controles" class="btn btn-secondary d-inline-flex align-items-center gap-2" onclick="jsAjaxPesquisarEstoqueControle()"><i class="fa-solid fa-search me-2" aria-hidden="true"></i>Pesquisar</button>
                            <button type="button" id="btnLimparFiltroEstoqueControle" title="Limpar filtro e listar todos" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2 ms-1" onclick="jsLimparFiltroEstoqueControle()"><i class="fa-solid fa-magnifying-glass-minus me-2" aria-hidden="true"></i>Limpar</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body m-0 p-1 gdi-index-estoquecontrole-dt" style="max-width: 100%; overflow-x: auto;">
                <div class="form-horizontal m-0 p-0">
                    <div class="table-responsive scroll-body-horizontal" style="width:100%">
                        <table class="table table-sm table-hover gdi-dt-zebra align-middle w-100 display compact" style="width:100%" id="dtGcProdutosControle">
                            <thead>
                                <tr>
                                    <th>[x]</th>
                                    <th>Id.</th>
                                    <th>Serial</th>
                                    <th>Produto</th>
                                    <th>Status</th>
                                    <th>Lote</th>
                                    <th>Validade</th>
                                    @if (podeEditarEstoqueControle)
                                    {
                                        <th><i class="fa-regular fa-edit" data-bs-toggle="tooltip" data-bs-placement="top" title="Editar controle / aferição"></i></th>
                                    }
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var dtGcProdutosControle;

    $(function ()
    {
        try
        {
            jsInitForm();
            @if (ViewBag.RestoreFilterAutoSearch != true)
            {
                <text>document.getElementById("yesFilterField").value = "*";</text>
            }
            jsCreateTable();
            jsAtualizarIndicadorFiltroEstoqueControle('0');
            gdiAplicarFoco('#edit_id_estoquecontrole', true);
            @if (ViewBag.RestoreFilterAutoSearch == true)
            {
                <text>if (jsEstoqueControleTemCriterioFiltro()) { jsAjaxPesquisarEstoqueControle(); }</text>
            }
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function keypressedEstoqueControle(e)
    {
        if (e.keyCode == 13)
        {
            e.preventDefault();
            jsAjaxPesquisarEstoqueControle();
        }
    }

    function jsEstoqueControleTemCriterioFiltro()
    {
        return !isEmpty($('#edit_id_estoquecontrole').val()) || !isEmpty($('#edit_serial_estoquecontrole').val());
    }

    function jsAtualizarIndicadorFiltroEstoqueControle(yesFilterOnOff)
    {
        GdiAtualizarIndicadorFiltro(yesFilterOnOff, {
            btnId: 'btnLimparFiltroEstoqueControle',
            tituloInativo: 'Limpar filtro e listar todos',
            tituloAtivo: 'Filtro ativo — limpar e listar todos os controles'
        });
    }

    function jsAjaxPesquisarEstoqueControle()
    {
        try
        {
            if (!jsEstoqueControleTemCriterioFiltro())
            {
                LibMessageAlert("Atenção", "Preencha ao menos um campo do <b>filtro</b> (Id. ou Serial).");
                return;
            }
            LibMessageProcessando('Pesquisando controles...');
            document.getElementById("yesFilterField").value = "";
            $("#dtGcProdutosControle").DataTable().draw(false);
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsAjaxPesquisarEstoqueControle] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsLimparFiltroEstoqueControle()
    {
        try
        {
            $('#edit_id_estoquecontrole').val('');
            $('#edit_serial_estoquecontrole').val('');
            document.getElementById("yesFilterField").value = "*";
            LibMessageProcessando('Atualizando lista...');
            $("#dtGcProdutosControle").DataTable().draw(false);
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsLimparFiltroEstoqueControle] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsCreateTable()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            dtGcProdutosControle = $('#dtGcProdutosControle').on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) {
                if (GdiDtNotifyJsonErrorMessage(json)) { }
                else if (json && json.yesFilterOnOff !== undefined) {
                    jsAtualizarIndicadorFiltroEstoqueControle(json.yesFilterOnOff);
                }
            }).DataTable({
            processing: true,
            bServerSide: true,
            ajax: {
                url: '@Url.Action("GetDados","EstoqueControle",new { Area = "gc" })',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                dataType: 'json',
                cache: false,
                data: function (d) {
                    return {
                        sEcho: d.draw,
                        iDisplayStart: d.start,
                        iDisplayLength: d.length,
                        yesFilterField: $('#yesFilterField').val().toString(),
                        yesFilterController: $('#yesFilterController').val().toString(),
                        yesCustomField01: emptyIfNull($('#edit_id_estoquecontrole').val()).toString(),
                        yesCustomField02: emptyIfNull($('#edit_serial_estoquecontrole').val()).toString()
                    };
                },
                error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
            },
            responsive: true,
            bFilter: false,
            bLengthChange: false,
            bProcessing: true,
            pageLength: 20,
            scrollX: false,
            scrollCollapse: false,
            fixedColumns: false,
            bAutoWidth: false,
            pagingType: 'full_numbers',
            aoColumnDefs: [
                { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                { "width": "6%", orderable: true, className: 'text-sm-center', targets: [1] },
                { "width": "12%", orderable: true, className: 'text-sm-center', targets: [2] },
                { "width": "35%", orderable: false, className: 'text-sm-start', targets: [3] },
                { "width": "12%", orderable: false, className: 'text-sm-center', targets: [4] },
                { "width": "12%", orderable: false, className: 'text-sm-center', targets: [5] },
                { "width": "12%", orderable: false, className: 'text-sm-center', targets: [6] }
                @if (podeEditarEstoqueControle)
                {
                <text>,
                { "width": "4%", orderable: false, className: 'text-sm-center dt-no-row-select', targets: [7], data: null, defaultContent: "",
                    render: function (data, type, row) {
                        return '<button type="button" title="Editar controle Id. ' + row[1] + '" class="btn btn-outline-warning btn-sm p-1 btnGcEstoqueControleEditRow d-inline-flex align-items-center" onclick="jsGcEstoqueControleEditRow(' + row[1] + ');"><i class="fa-regular fa-edit"></i></button>';
                    }
                }</text>
                }
            ],
            select: {
                style: 'multi',
                selector: 'td:not(.dt-no-row-select)',
                headerCheckbox: true
            },
            order: [[1, 'asc']],
            drawCallback: function (settings) {
                LibMessageProcessandoHide();
                document.querySelectorAll('#dtGcProdutosControle [data-bs-toggle="tooltip"]').forEach(function (el) {
                    bootstrap.Tooltip.getOrCreateInstance(el);
                });
                try { new $.fn.dataTable.Api(settings).columns.adjust(); } catch (e) { }
            },
            language:
            {
                sEmptyTable: 'Informe Id. ou Serial e clique em Pesquisar (ou Limpar para listar todos).',
                sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                sInfoPostFix: '',
                sInfoThousands: '.',
                sLengthMenu: '_MENU_ registros por página',
                sZeroRecords: 'Nenhum registro encontrado',
                sSearch: 'Pesquisar',
                oPaginate:
                {
                    sNext: '>',
                    sPrevious: '<',
                    sFirst: '<<',
                    sLast: '>>'
                },
                select: {
                    rows: {
                        0: "",
                        1: " [ %d registro selecionado ] ",
                        _: " [ %d registros selecionados ] "
                    }
                }
            },
            oAria: {
                sSortAscending: ': Ordenar colunas de forma ascendente',
                sSortDescending: ': Ordenar colunas de forma descendente'
            }
            });
            @if (podeEditarEstoqueControle)
            {
                <text>$('#dtGcProdutosControle tbody').on('dblclick', 'tr td:not(.dt-no-row-select)', function () {
                var data = dtGcProdutosControle.row($(this).closest('tr')).data();
                if (data) { jsGcEstoqueControleEditRow(data[1]); }
            });</text>
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsModalCreateEditEstoqueControle(idProdutoControle)
    {
        try
        {
            LibMessageProcessando("");
            $("#mainModal").load('@Url.Action("ModalCreateEditEstoqueControle", "EstoqueControle", new { area = "gc" })?IdProdutoControle=' + emptyIfNull(idProdutoControle).toString(), function (response, status) {
                LibMessageProcessandoHide();
                LibMessageProcessandoHide();
                if (status === 'error') {
                    LibMessageError("Atenção", "Não foi possível carregar o formulário de controle de estoque.");
                    return;
                }
                var e = document.getElementById('mainModal');
                if (e) { bootstrap.Modal.getOrCreateInstance(e).show(); }
            });
        }
        catch (err) {
            LibMessageProcessandoHide();
            LibMessageError("Atenção", "[jsModalCreateEditEstoqueControle] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsGcEstoqueControleEditRow(idControle)
    {
        try {
            var id = parseInt(idControle, 10);
            if (!id || id <= 0) { return; }
            jsModalCreateEditEstoqueControle(id);
        }
        catch (err) {
            LibMessageError("Atenção", "[jsGcEstoqueControleEditRow] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }
</script>
