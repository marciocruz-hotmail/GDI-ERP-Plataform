@model GdiPlataform.Db.g_produtos_medicoes
@{ Layout = null; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "formModalCreateEditMedicao" }))
{
    <div class="modal-dialog modal modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title d-flex align-items-center gap-2">
    <i class="fa-solid fa-circle-info fa-sm" aria-hidden="true"></i>
    @Html.Raw(ViewBag.Title)</h5>
                @Html.HiddenFor(model => model.id_produto_controle)
                @Html.HiddenFor(model => model.id_coligada)
                @Html.HiddenFor(model => model.id_filial)
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-1">
                <div class="form-horizontal m-0 p-0">
                    <div class="card-body m-0 p-1" style="height: 100%">
                        <div class="card shadow-sm gdi-section-accent-success m-2 p-1">
                            <h5>Produto/Item/Equipamento</h5>
                            <div class="form-group row text-sm-end m-0 pt-1">
                                @Html.Label("Data Medição", htmlAttributes: new { @class = "col-sm-4 col-form-label" })
                                <div class="col-sm-8">
                                    @* id do .input-group distinto do input para Tempus Dominus *@
                                    <div class='input-group date' id='ig_gc_est_ctrl_modal_med'>
                                        @Html.EditorFor(model => model.data_medicao, new { htmlAttributes = new { @class = "form-control", type = "text" } })
                                        <span class="input-group-text"><i class="fa-regular fa-calendar-alt"></i></span>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group row text-sm-end m-0 pt-1">
                                @Html.Label("tensao", "Tensão", htmlAttributes: new { @class = "col-sm-4 col-form-label" })
                                <div class="col-sm-8">
                                    @Html.EditorFor(model => model.tensao, new { htmlAttributes = new { @class = "form-control" } })
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" class="btn btn-warning me-auto d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                <button type="button" class="btn btn-success d-inline-flex align-items-center gap-2" onclick="jsCheckInputs()"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>Gravar Medição</button>
            </div>
        </div>
    </div>
}

<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsDatepicker('#ig_gc_est_ctrl_modal_med');
            jsInitModal();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsLoadForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsCheckInputs()
    {
        try
        {
            if (isEmpty($('#tensao').val().toString().trim()))
            {
                yesMessageAlertSmall("Atenção", "Preencha corretamente os campos");
            }
            else {
                jsSendForm();
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCheckInputs] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsSendForm()
    {
        try {
            LibMessageProcessando("")
            var form = $('#formModalCreateEditMedicao');
            $.ajax({
                cache: false,
                async: true,
                type: "POST",
                url: '@Url.Action("AjaxCreateMedicao", "EstoqueControle", new { area = "gc" })',
                data: form.serialize(),
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        GdiSwal2.alert({
                            title: "<i class='fa-solid fa-check' style='color:#008000'>&nbsp&nbsp&nbsp</i><b>Confirmação</b>",
                            centerVertical: true,
                            message: result.msg,
                            callback: function ()
                            {
                                $("#dtEstoqueControleMedicoes").DataTable().draw(false);
                                document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                GdiSwal2.hideAll();
                            }
                        })
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias(result.msg);
                    }
                },
                error: function (result)
                {
                    GdiAjaxNotifyInconsistencias(result.toString());
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };


</script>

