@model IEnumerable<GdiPlataform.Db.gc_parametros_difal>
@using GdiPlataform.Security
@{Layout = "~/Views/Shared/_Layout.cshtml";}
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(ViewBag.Title)</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterOperador" value="" name="yesFilterOperador" />
                <input type="hidden" id="yesFilterText" value="" name="yesFilterText" />
                <input type="hidden" id="yesFilterAdvancedText" value="" name="yesFilterAdvancedText" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-header m-0 p-1">
                @if ((CachePersister.userIdentity.Roles.Contains("gc_FinanceiroParametroDifal_*")) || (CachePersister.userIdentity.Roles.Contains("gc_FinanceiroParametroDifal_Actionupdate")))
                {<button type="button" name="btnRegistroEditar" title="Editar Registro" class="btn btn-outline-warning d-inline-flex align-items-center gap-2" onclick="JsEditRecord(oTableFinParamDifal, 'Id.', '@Url.Action("Edit","FinanceiroParametroDifal",new { Area = "gc" })/')"><i class="fa-regular fa-edit me-2" aria-hidden="true"></i>Editar</button> }
                else
                { <button type="button" name="btnRegistroEditar" title="Editar Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa-regular fa-edit me-2" aria-hidden="true"></i>Editar</button>}
            </div>
            <div class="card-body m-0 p-1" style="max-width: 100%; overflow-x: auto; ">
                <div class="form-horizontal m-0 p-0">
                    <div class="table-responsive scroll-body-horizontal" style="width:100%">
                        <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dtGcFinanceiroParametrosDifal">
                            <thead>
                                <tr>
                                    <th>[x]</th>
                                    <th>Id.</th>
                                    <th>Sigla</th>
                                    <th>Estado</th>
                                    <th><i class="fa-solid fa-coins"></i><i class="fa-solid fa-sack-dollar"></i></th>
                                    <th><i class="fa-solid fa-coins"></i><i class="fa-solid fa-sack-xmark"></i></th>
                                    <th><i class="fa-solid fa-coins"></i><i class="fa-solid fa-eraser"></i></th>
                                    <th><i class="fa-solid fa-gas-pump"></i><i class="fa-solid fa-sack-dollar"></i></th>
                                    <th><i class="fa-solid fa-gas-pump"></i><i class="fa-solid fa-sack-xmark"></i></th>
                                    <th><i class="fa-solid fa-gas-pump"></i><i class="fa-solid fa-eraser"></i></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var oTableFinParamDifal;

    $(function ()
    {
        try
        {
            jsInitForm();
            jsCreateTable();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsCreateTable()
    {
        try
        {
            if (oTableFinParamDifal == null)
            {
                $.fn.dataTable.ext.errMode = 'none';
                oTableFinParamDifal = $('#dtGcFinanceiroParametrosDifal').on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) { GdiDtNotifyJsonErrorMessage(json); btnFiltro(json.yesFilterOnOff) }).DataTable({
                processing: true,
                bServerSide: true,
                ajax: {
                    url: '@Url.Action("GetDados", "FinanceiroParametroDifal", new { Area = "gc" })',
                    type: 'POST',
                    contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                    dataType: 'json',
                    cache: false,
                    data: function (d) {
                        return {
                            sEcho: d.draw,
                            iDisplayStart: d.start,
                            iDisplayLength: d.length,
                            yesFilterField: $('#yesFilterField').val().toString(),
                            yesFilterOperador: $('#yesFilterOperador').val().toString(),
                            yesFilterText: $('#yesFilterText').val().toString(),
                            yesFilterAdvancedText: $('#yesFilterAdvancedText').val().toString(),
                        };
                    },
                    error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
                },
                responsive: true,
                bFilter: false,
                bLengthChange: false,
                bProcessing: true,
                pageLength: 30,
                scrollX: false,
                scrollCollapse: false,
                fixedColumns: false,
                bAutoWidth: false,
                pagingType: 'full_numbers',
                aoColumnDefs: [
                    { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                    { "width": "8%", orderable: false, className: 'text-sm-center', targets: [1] },
                    { "width": "8%", orderable: false, className: 'text-sm-center', targets: [2] },
                    { "width": "26%", orderable: false, className: 'text-sm-center', targets: [3] },
                    { "width": "9%", orderable: false, className: 'text-sm-center', targets: [4] },
                    { "width": "9%", orderable: false, className: 'text-sm-center', targets: [5] },
                    { "width": "9%", orderable: false, className: 'text-sm-center', targets: [6] },
                    { "width": "9%", orderable: false, className: 'text-sm-center', targets: [7] },
                    { "width": "9%", orderable: false, className: 'text-sm-center', targets: [8] },
                    { "width": "9%", orderable: false, className: 'text-sm-center', targets: [9] }
                ],
                select: {
                    style: 'multi',
                    selector: 'td:not(.dt-no-row-select)',
                    headerCheckbox: true
                },
                order: [[1, 'asc']],
                language:
                {
                    sEmptyTable: 'Nenhum registro encontrado',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
                });
                $('#dtGcFinanceiroParametrosDifal tbody').on('dblclick', 'tr td', function () {
                    var data = oTableFinParamDifal.row($(this).closest('tr')).data();
                    JsEditRecordDoubleClick(data[1],'@Url.Action("Edit", "FinanceiroParametroDifal", new { Area = "gc" })');
                });
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsModalFiltroAvancado()
    {
        try {
            if (document.getElementById("btnFiltroAvancado").innerHTML.indexOf("Remover") > 0) {
                document.getElementById("yesFilterField").value = "*";
                document.getElementById("yesFilterOperador").value = "";
                document.getElementById("yesFilterText").value = "";
                document.getElementById("yesFilterAdvancedText").value = "";
                $("#dtGcFinanceiroParametrosDifal").DataTable().draw(false);
            }
            else {
                $("#mainModal").load('@Url.Action("ModalFiltroAvancadoView", "Cidades", new { Area = "g" })?id=g_cidades_index', function () {
                    var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
                })
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalFiltroAvancado] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsRunFiltroAvancado(FilterAdvancedText)
    {
        try {
            document.getElementById("yesFilterAdvancedText").value = FilterAdvancedText;
            $("#dtGcFinanceiroParametrosDifal").DataTable().draw(false);
        }
        catch (err) {
            LibMessageError("Atenção", "[jsRunFiltroAvancado] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }
</script>


