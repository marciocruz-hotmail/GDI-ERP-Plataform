<style>
    #crud-tabs-content .card-body > .tab-pane {
        display: none;
        margin: 0 !important;
        padding: 0 !important;
    }

    #crud-tabs-content .card-body > .tab-pane.active {
        display: block;
    }
</style>

<script type="text/javascript">

    $(function () {
        try {
            jsInitModal();
            $('#item_quantidade').attr('readonly', 'readonly');
            gdiConferenciaLotesTabsSelect2Init('#ModalConferenciaImportacaoItem', '#mainModal');
        } catch (err) {
            LibMessageError("Atenção", "[jsInitForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsSendForm() {
        try {
            LibMessageProcessando("Atualizando Itens . . .");
            var form = $('#ModalConferenciaImportacaoItem');

            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxConferenciaImportacaoItem", "Estoque", new { area = "gc" })',
                data: form.serialize(),
                success: function (result) {
                    LibMessageProcessandoHide();
                    if (result.success === true) {
                        // CORREÇÃO 4: Verifica se o DataTable já foi inicializado antes de redesenhar
                        var tableEl = $("#dtGcRecebimentoImportacao");
                        if ($.fn.DataTable.isDataTable(tableEl)) {
                            tableEl.DataTable().draw();
                        }
                        document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                    } else {
                        GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.')
                    }
                },
                error: function (xhr, status, error) {
                    // CORREÇÃO 5: Usa parâmetros corretos do callback de erro do jQuery AJAX
                    LibMessageAlert("Erro na requisição", status + ": " + error);
                }
            });
        } catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }
</script>

