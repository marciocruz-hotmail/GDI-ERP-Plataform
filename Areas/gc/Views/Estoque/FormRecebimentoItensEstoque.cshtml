@model GdiPlataform.Db.gc_movimentos
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(ViewBag.Title)</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
                @Html.HiddenFor(model => model.id_movimento)
            </div>
            @if (!string.IsNullOrEmpty(ViewBag.MsgBloqueio as string))
            {
                <div class="card-body m-0 p-1" style="height: 100%">
                    @Html.Partial("_AlertMsg", AlertMsgItem.Maybe(ViewBag.MsgBloqueio as string, "danger"))
                </div>
            }
            else
            {
                <div class="card-body m-0 p-1" style="max-width: 100%; overflow-x: auto; ">
                    <div class="table-responsive scroll-body-horizontal" style="width:100%">
                        <table class="table table-sm table-hover gdi-dt-zebra align-middle w-100 display compact" style="width:100%" id="dtGcRecebimentoEstoque">
                            <thead>
                                <tr>
                                    <th>@Html.Raw("Id.")</th>
                                    <th>@Html.Raw("Item")</th>
                                    <th>@Html.Raw("Qtd")</th>
                                    <th>Hidden</th>
                                    <th><i class="fa-solid fa-list-check fa-lg"></i></th>
                                    <th><i class="fa-solid fa-cart-flatbed fa-lg"></i></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            }
            <div class="card-footer justify-content-between m-0 p-1">
                <button type="button" name="btnSair" title="Sair" onclick="jsYesCancelRecord('@Url.Action("IndexRecebimentoEstoque","Estoque",new { Area = "gc" })')" class="btn btn-primary float-end d-inline-flex align-items-center gap-2"><i class="fa-solid fa-door-open me-2" aria-hidden="true"></i>Sair</button>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var TableRecebimentoEstoque;

    $(function ()
    {
        try
        {
            jsInitForm();
            jsCreateTable();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsLoadForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsCreateTable()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            TableRecebimentoEstoque = $('#dtGcRecebimentoEstoque').on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) { GdiDtNotifyJsonErrorMessage(json); }).DataTable({
                "drawCallback": function (settings) {
                    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function(el){bootstrap.Tooltip.getOrCreateInstance(el);});
                },
                "footerCallback": function (row, data, start, end, display)
                {
                    LibMessageProcessandoHide();
                },
                processing: true,
            bServerSide: true,
            ajax: {
                url: '@Url.Action("GetDadosRecebimentoItensEstoque", "Estoque", new { Area = "gc" })',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                dataType: 'json',
                cache: false,
                data: function (d) {
                    return {
                        sEcho: d.draw,
                        iDisplayStart: d.start,
                        iDisplayLength: d.length,
                        yesFilterField: $('#yesFilterField').val().toString(),
                        yesCustomField01: emptyIfNull($('#id_movimento').val()).toString(),
                        yesCustomField02: emptyIfNull($('#tag_string').val()).toString(),
                    };
                },
                error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
            },

            responsive: true,
            bFilter: false,
            bLengthChange: false,
            bProcessing: true,
            pageLength: 200,
            scrollX: false,
            scrollCollapse: false,
            fixedColumns: false,
            bAutoWidth: false,
            pagingType: 'full_numbers',
            aoColumnDefs: [
                { "width": "6%", orderable: false, className: 'text-sm-center', targets: [0] },
                { "width": "76%", orderable: false, className: 'text-sm-start', targets: [1] },
                { "width": "6%", orderable: false, className: 'text-sm-end', targets: [2] },
                { "width": "0%", visible: false, targets: [3] }, // Status Item Conferido
                { "width": "6%", orderable: false, className: 'text-sm-center', targets: [4] },
                { "width": "6%", orderable: false, className: 'text-sm-center dt-no-row-select', targets: [5], data: null, defaultContent: "", render: function (data, type, row, meta) { return '<button type="button" name="btnReceberItem" title="Receber Item ' + data[0] + '" class="btn btn-outline-warning btnReceberItem d-inline-flex align-items-center gap-2" onclick="jsModalConferenciaEstoqueItem(' + data[0] + ');"><i class="fa-solid fa-cart-flatbed"></i></button>' } }
            ],
            "createdRow": function (row, data, dataIndex) {
                var st = data[3];
                if (st === 1 || st === '1' || st === true || st === 'true') {
                    row.classList.add('table-success');
                } else if (st === 0 || st === '0' || st === false || st === 'false') {
                    row.classList.add('table-warning');
                }
            },
            select: {
                style: 'multi',
                selector: 'td:not(.dt-no-row-select)',
                headerCheckbox: true
            },
            order: [[1, 'asc']],

                language:
                {
                    sEmptyTable: 'Nenhum registro encontrado',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsModalConferenciaEstoqueItem(id)
    {
        try
        {
            LibMessageProcessando("");
            $("#mainModal").load('@Url.Action("ModalConferenciaEstoqueItem", "Estoque", new { area = "gc" })?id=' + id, function () {
                var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
            })
        }
        catch (err)
        {
            LibMessageProcessandoHide();
            LibMessageError("Atenção", "[jsModalConferenciaImportacaoItem] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

</script>
