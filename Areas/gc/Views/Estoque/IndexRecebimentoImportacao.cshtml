@model IEnumerable<GdiPlataform.Db.gc_movimentos>
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(ViewBag.Title)</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterOperador" value="" name="yesFilterOperador" />
                <input type="hidden" id="yesFilterText" value="" name="yesFilterText" />
                <input type="hidden" id="yesFilterAdvancedText" value="" name="yesFilterAdvancedText" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>


            <div class="card-header m-0 p-1">
                @if ((CachePersister.userIdentity.Roles.Contains("gc_Estoque_IndexRecebimentoImportacao_*")) || (CachePersister.userIdentity.Roles.Contains("gc_Estoque_IndexRecebimentoImportacao_Actionmanager")))
                {
                    <div class="btn-group" role="group">
                        <button id="btnGroupDrop1" type="button" class="btn btn-outline-info dropdown-toggle d-inline-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="Processos">
                            <i class="fa-solid fa-cog me-2" aria-hidden="true"></i>Processos
                        </button>
                        <div class="dropdown-menu" aria-labelledby="btnGroupDrop1">
                            <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsFinalizarRecebimentoImportacao(oTableIndexRecebimentoImportacao , 'Id.')"><i class="fa-solid fa-check-to-slot fa-lg me-2" aria-hidden="true"></i>Finalizar Recebimento Importação</a>
                        </div>
                    </div>
                }
            </div>

            <div class="card-body m-0 p-1" style="max-width: 100%; overflow-x: auto; ">
                <div class="table-responsive scroll-body-horizontal" style="width:100%">
                    <table class="table table-sm table-hover gdi-dt-zebra align-middle w-100 display compact" style="width:100%" id="dtGcMovimentosIndexRecebimentoImportacao">
                        <thead>
                            <tr>
                                <th>[x]</th>
                                <th>@Html.Encode("Id.")</th>
                                <th>@Html.Encode("NF")</th>
                                <th>@Html.Raw("Importação")</th>
                                <th>@Html.Encode("Filial")</th>
                                <th>@Html.Encode("CD")</th>
                                <th>@Html.Encode("Data")</th>
                                <th>@Html.Encode("Itens")</th>
                                <th>@Html.Encode("R$ Valor")</th>
                                <th>Hidden</th>
                                <th>Hidden</th>
                                <th><i class="fa-regular fa-file-pdf fa-lg" style="cursor:pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Danfe/PDF"></i></th>
                                <th><i class="fa-solid fa-cart-flatbed fa-lg"></i></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var oTableIndexRecebimentoImportacao ;

    $(function ()
    {
        try
        {
            jsInitForm();
            jsCreateTable();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsCreateTable()
    {
        try
        {
            if (oTableIndexRecebimentoImportacao == null)
            {
                $.fn.dataTable.ext.errMode = 'none';
                oTableIndexRecebimentoImportacao = $('#dtGcMovimentosIndexRecebimentoImportacao')
                    .on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); })
                    .on('xhr.dt', function (e, settings, json, xhr) { GdiDtNotifyJsonErrorMessage(json); btnFiltro(json.yesFilterOnOff); }).DataTable({
                    "drawCallback": function (settings) {
                        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function(el){bootstrap.Tooltip.getOrCreateInstance(el);});
                    },
                processing: true,
                bServerSide: true,
                ajax: {
                    url: '@Url.Action("GetDadosRecebimentoImportacao", "Estoque",new { Area = "gc" })',
                    type: 'POST',
                    contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                    dataType: 'json',
                    cache: false,
                    data: function (d) {
                        return {
                            sEcho: d.draw,
                            iDisplayStart: d.start,
                            iDisplayLength: d.length,
                            yesFilterField: $('#yesFilterField').val().toString(),
                            yesFilterOperador: $('#yesFilterOperador').val().toString(),
                            yesFilterText: $('#yesFilterText').val().toString(),
                            yesFilterAdvancedText: $('#yesFilterAdvancedText').val().toString(),
                        };
                    },
                    error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
                },
                responsive: true,
                bFilter: false,
                bLengthChange: false,
                bProcessing: true,
                pageLength: 20,
                scrollX: false,
                scrollCollapse: false,
                fixedColumns: false,
                bAutoWidth: false,
                pagingType: 'full_numbers',
                aoColumnDefs: [
                    { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                    { "width": "5%", orderable: false, className: 'text-sm-center', targets: [1] },
                    { "width": "12%", orderable: false, className: 'text-sm-center', targets: [2] },
                    { "width": "40%", orderable: false, className: 'text-sm-start', targets: [3] },
                    { "width": "5%", orderable: false, className: 'text-sm-center', targets: [4] },
                    { "width": "5%", orderable: false, className: 'text-sm-center', targets: [5] },
                    { "width": "5%", orderable: false, className: 'text-sm-center', targets: [6] },
                    { "width": "5%", orderable: false, className: 'text-sm-end', targets: [7] },
                    { "width": "7%", orderable: false, className: 'text-sm-end', targets: [8] },
                    { "width": "0%", visible: false, targets: [9] }, // Link Danfe
                    { "width": "0%", visible: false, targets: [10] }, // Importação já processada
                    { "width": "6%", orderable: false, className: 'text-sm-center dt-no-row-select', targets: [11], data: null, defaultContent: "", render: function (data, type, row, meta) { if (data[9] != '0') { return '<button type="button" name="btnPDF" data-bs-toggle="tooltip" data-bs-placement="top" title="Danfe/PDF" class="btn btn-outline-info btnPDF d-inline-flex align-items-center gap-2" onclick="jsPDFNotaFiscal(' + data[9] + ');"><i class="fa-regular fa-file-pdf"></i></button>' } } },
                    { "width": "6%", orderable: false, className: 'text-sm-center dt-no-row-select', targets: [12], data: null, defaultContent: "", render: function (data, type, row, meta) { if (data[10] == '0') { return '<button type="button" name="btnReceberMaterial" title="Receber Importação ' + data[4] + '" class="btn btn-outline-warning btnEditInventario d-inline-flex align-items-center gap-2" onclick="jsFormRecebimentoImportacao(' + data[1] + ');"><i class="fa-solid fa-cart-flatbed"></i></button>' } } }
                ],
                "createdRow": function (row, data, dataIndex) {
                    var st = data[10];
                    if (st === 1 || st === '1' || st === true || st === 'true') {
                        row.classList.add('table-success');
                    } else if (st === 0 || st === '0' || st === false || st === 'false') {
                        row.classList.add('table-warning');
                    }
                },
                select: {
                    style: 'multi',
                    selector: 'td:not(.dt-no-row-select)',
                    headerCheckbox: true
                },
                order: [[1, 'asc']],

                language:
                {
                    sEmptyTable: 'Nenhum registro encontrado',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
                });
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsDownloadFileS3(id)
    {
        try
        {
            if (id.length > 10) {
                LibMessageProcessandoHide();
                window.open(id, '_blank').focus();
            }
            else
            {
                LibMessageProcessando();
                var dataForm =
                {
                    view_ged_arquivos:
                    {
                        'id_arquivo': id,
                    }
                };
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("AjaxDownloadFileS3", "Ged", new { area = "g" })',
                    contentType: "application/json; charset=utf-8",
                    data: JSON.stringify(dataForm),
                    dataType: "json",
                    success: function (result) {
                        LibMessageProcessandoHide();
                        if (result.success == true) {
                            window.open(result.url, 'Ged', '_parent');
                            document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                        }
                        else {
                            LibMessageProcessandoHide();
                            GdiAjaxNotifyInconsistencias(result.msg)
                        }
                    },
                    error: function (result) {
                        LibMessageProcessandoHide();
                        GdiAjaxNotifyInconsistencias(result.toString());
                    }
                })
            }
        }
        catch (e)
        {
            LibMessageError("Atenção", "[jsDownloadFile] " + (e && e.message ? e.message.toString() : String(e)));
        }
    }


    function jsFormRecebimentoImportacao(id)
    {
        try
        {
            LibMessageProcessando("Processando . . .");
            window.location = '@Url.Action("FormRecebimentoItensImportacao", "Estoque", new { area = "gc" })?id=' + id;
        }
        catch (err) {
            LibMessageError("Atenção", "[jsFormRecebimentoImportacao] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsFinalizarRecebimentoImportacao(TableName, columnName)
    {
        try {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            if (!selectedIds || selectedIds.length == 0)
            {
                LibMessageAlert("Atenção", "Selecione a Importação!");
            }
            else {
                if (selectedIds.indexOf(',') == -1)
                {
                    LibMessageProcessando("");

                    var dataForm =
                    {
                        view_g_movimentos:
                        {
                            'id_movimento': selectedIds,
                        }
                    };
                    $.ajax({
                        type: "POST",
                        url: '@Url.Action("AjaxFinalizarRecebimentoImportacao", "Estoque", new { area = "gc" })',
                        contentType: "application/json; charset=utf-8",
                        data: JSON.stringify(dataForm),
                        dataType: "json",
                        success: function (result)
                        {
                            if (result.success == true)
                            {
                                LibMessageProcessandoHide();
                                GdiSwal2.dialog({
                                    title: "<i class='fa-solid fa-check' style='color:#008000'>&nbsp&nbsp</i><b>Confirmação</b>",
                                    closeButton: false,
                                    message: result.msg,
                                    centerVertical: true,
                                    onEscape: false,
                                    backdrop: true,
                                    buttons: {
                                        confirmar: {
                                            label: '&nbsp;OK',
                                            className: 'btn btn-info',
                                            callback: function () {
                                                $("#dtGcMovimentosIndexRecebimentoImportacao").DataTable().draw(false);
                                                GdiSwal2.hideAll();
                                            }
                                        }
                                    }
                                })
                            }
                            else
                            {
                                LibMessageProcessandoHide();
                                GdiSwal2.hideAll();
                                GdiAjaxNotifyInconsistencias(result.msg);
                            }
                        },
                        error: function (result)
                        {
                        }
                    });
                }
                else
                {
                    LibMessageAlert("Atenção", "Selecione apenas 1(uma) Importação!");
                }
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsFinalizarRecebimentoImportacao] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsPDFNotaFiscal(id)
    {
        LibMessageProcessando("Processando . . .")
        var dataForm =
        {
            view_record_gc_movimento_nf:
            {
                'id_movimento_nf': id,
            }
        };
        $.ajax({
            type: "POST",
            url: '@Url.Action("AjaxPDFNotaFiscal", "Movimentos", new { area = "gc" })',
            contentType: "application/json; charset=utf-8",
            data: JSON.stringify(dataForm),
            dataType: "json",
            success: function (result)
            {
                LibMessageProcessandoHide();
                if (result.success == true)
                {
                    window.open(result.msg, '_blank').focus();
                }
                else
                {
                    GdiAjaxNotifyInconsistencias(result.msg);
                }
            },
            error: function (result)
            {
                GdiAjaxNotifyInconsistencias(result.toString());
            }
        });
    };



</script>





