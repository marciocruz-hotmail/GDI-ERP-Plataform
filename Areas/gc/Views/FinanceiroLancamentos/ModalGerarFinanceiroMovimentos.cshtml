<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsDatepicker('#ig_gc_fin_mov_gen_v1');
            jsDatepicker('#ig_gc_fin_mov_gen_v2');
            jsDatepicker('#ig_gc_fin_mov_gen_v3');
            jsDatepicker('#ig_gc_fin_mov_gen_v4');
            jsDatepicker('#ig_gc_fin_mov_gen_v5');
            jsDatepicker('#ig_gc_fin_mov_gen_v6');
            jsDatepicker('#ig_gc_fin_mov_gen_v7');
            jsDatepicker('#ig_gc_fin_mov_gen_v8');
            jsInitModal();
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsSendForm()
    {
        try {
            document.getElementById('btnSalvar').disabled = true;
            LibMessageProcessando();
            var form = $('#FormModalFinanceiroPedido');
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxModalGerarFinanceiroMovimentos", "FinanceiroLancamentos", new { area = "gc" })',
                data: form.serialize(),
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                                                LibMessageSuccess("Confirmação", result.msg, {
                            backdrop: true,
                            callback: function ()
                            {
                            $("#dataTableGCIndexPedido").DataTable().draw(false);
                            document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                            LibMessageHideAll();
                            }
                        });
                    }
                    else
                    {
                        document.getElementById('btnSalvar').disabled = false;
                        GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.')
                    }
                },
                error: function (xhr, textStatus, errorThrown)
                {
                    LibMessageProcessandoHide();
                    document.getElementById('btnSalvar').disabled = false;
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.')
                }
            });
                }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsFinanceiroInfo(idFinanceiro)
    {
        try {
            LibMessageProcessando();
            $.ajax({
                type: "GET",
                url: '@Url.Action("AjaxFinanceiroInfo", "Financeiro", new { area = "g" })' + "?id=" + idFinanceiro,
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                                                LibMessageSuccess("Informações Financeiras", result.msg, {
                            backdrop: true,
                            callback: function ()
                            {
                            LibMessageHideAll();
                            }
                        });
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.')
                    }
                },
                error: function (xhr, textStatus, errorThrown)
                {
                    LibMessageProcessandoHide();
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.');
                }
            });
                }
        catch (err) {
            LibMessageError("Atenção", "[jsFinanceiroInfo] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsFinanceiroBoleto(idFinanceiro)
    {
        try {
            LibMessageProcessando();
            $.ajax({
                type: "GET",
                url: '@Url.Action("AjaxFinanceiroBoletoGCPDF", "FinanceiroLancamentos", new { area = "gc" })' + "?id=" + idFinanceiro,
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        window.location = '@Url.Action("AjaxGetFileProcessamento", "Global", new { Area = "g" })' + "?id=" + result.idProcessamento;
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.')
                    }
                },
                error: function (xhr, textStatus, errorThrown)
                {
                    LibMessageProcessandoHide();
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.');
                }
            });
                }
        catch (err) {
            LibMessageError("Atenção", "[jsFinanceiroBoleto] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsFinanceiroCancelamento(idFinanceiro)
    {
        try
        {
            LibMessageConfirm('Confirmação', 'Deseja Realmente CANCELAR o título financeiro Id: <b>' + idFinanceiro + '</b> ?', {
                icon: 'warning',
                closeButton: false,
                onEscape: false,
                backdrop: true,
                confirmLabel: '<i class="fa-solid fa-save me-2" aria-hidden="true"></i>Confirmar',
                onConfirm: function () {
                    jsFinanceiroCancelamentoExecutar(idFinanceiro);
                    LibMessageHideAll();
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsFinanceiroCancelamento] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsFinanceiroCancelamentoExecutar(idFinanceiro)
    {
        try {
            LibMessageProcessando();
            $.ajax({
                type: "GET",
                url: '@Url.Action("AjaxFinanceiroCancelamento", "Financeiro", new { area = "g" })' + "?id=" + idFinanceiro,
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                                                LibMessageSuccess("Informações Financeiras", result.msg, {
                            backdrop: true,
                            callback: function ()
                            {
                            document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                            LibMessageHideAll();
                            }
                        });
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.')
                    }
                },
                error: function (xhr, textStatus, errorThrown)
                {
                    LibMessageProcessandoHide();
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.');
                }
            });
                }
        catch (err) {
            LibMessageError("Atenção", "[jsFinanceiroCancelamentoExecutar] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

</script>
