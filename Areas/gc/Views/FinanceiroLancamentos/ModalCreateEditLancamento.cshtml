    function jsModalUploadAnexoFinanceiro()
    {
        try
        {
            LibMessageProcessando("");
            yesDestroyModal('#ModalCreateEditLancamento');
            $("#mainModal").load('@Url.Action("ModalUploadAnexoFinanceiro", "FinanceiroLancamentos", new { area = "gc" })?IdLancamento=' + $('#id_lancamento').val().toString(), function () {
                var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
            })
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalUploadFileGed] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsAbrirAnexo(id)
    {
        try
        {
            LibMessageProcessando();
            var dataForm =
            {
                view_ged_arquivos:
                {
                    'id_arquivo': id,
                }
            };
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxDownloadFileS3", "Ged", new { area = "g" })',
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(dataForm),
                dataType: "json",
                success: function (result) {
                    LibMessageProcessandoHide();
                    if (result.success == true) {
                        window.open(result.url, 'Ged', '_parent');
                    }
                    else {
                        LibMessageProcessandoHide();
                        GdiAjaxNotifyInconsistencias(result.msg)
                    }
                },
                error: function (result) {
                    LibMessageProcessandoHide();
                    GdiAjaxNotifyInconsistencias(result.toString());
                }
            })
        }
        catch (e)
        {
            LibMessageError("Atenção", "[jsDownloadFile] " + (e && e.message ? e.message.toString() : String(e)));
        }
    }

    function jsDesativarAnexo(id)
    {
        try
        {
            LibMessageDialog({
                title: "Confirmação",
                message: "Deseja REALMENTE DESATIVAR esse arquivo anexo ?" + "<br/><br/>" + "<b>Atenção:</b> O Log dessa operação ficará armazenado no banco de dados para futuras auditorias!",
                closeButton: false,
                centerVertical: true,
                onEscape: false,
                backdrop: true,
                buttons: {
                    cancelar: {
                        label: '<i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar',
                        className: 'btn-outline-warning',
                        callback: function () {
                            LibMessageHideAll();
                        }
                    },
                    confirmar: {
                        label: '<i class="fa-solid fa-save me-2" aria-hidden="true"></i>Confirmar',
                        className: 'btn-outline-success',
                        callback: function ()
                        {
                            jsAjaxDesativarAnexo(id);
                        }
                    }
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsRemoverAnexo] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsAjaxDesativarAnexo(id)
    {
        try
        {
            LibMessageProcessando("");
            var dataForm =
            {
                ModalGedArquivo:
                {
                    'id_arquivo': id,
                }
            };
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxDesativarAnexo", "Ged", new { area = "g" })',
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(dataForm),
                dataType: "json",
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        $("#dtGedGcLancamentos").DataTable().draw(false);
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias(result.msg);
                    }
                },
                error: function (result)
                {
                    GdiAjaxNotifyInconsistencias(result.toString());
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsAjaxRemoverAnexo] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };


    function jsGcFinanceiroLancamentosKeyPressed(e)
    {
        if (e.keyCode == 13)
        {
            jsCheckInputs();
        }
    }

</script>



