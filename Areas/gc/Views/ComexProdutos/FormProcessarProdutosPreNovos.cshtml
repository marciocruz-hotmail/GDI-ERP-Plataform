@model List<GdiPlataform.Db.gc_comex_produtos>
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "GcComexFormProcessarProdutosPreNovos" }))
{
    <div class="row">
        <div class="col-lg-12 m-0 p-0 min-w-0">
            <div class="card m-0 p-0">
                <div class="card-title m-0 p-1">
                    <h5>@Html.Raw(ViewBag.Title)</h5>
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)
                </div>
                <div class="card-body m-0 p-1 min-w-0">
                    <div class="form-horizontal m-0 p-0">
                        @Html.Partial("_AlertMsg", AlertMsgItem.Maybe(ViewBag.MsgInfo as string, "info"))
                        <div class="table-responsive gdi-form-table-scroll">
                            @if (Model.Count == 0)
                            {
                                <div class="alert alert-danger" role="alert">
                                    Não há itens a serem exibidos
                                </div>
                            }
                            else
                            {
                                <table class="table table-striped table-bordered table-sm gdi-form-table-fixed gdi-form-table-processar-novos-produtos mb-0">
                                    <colgroup>
                                        <col class="gdi-col-pn-width" />
                                        <col />
                                        <col />
                                    </colgroup>
                                    <thead>
                                        <tr>
                                            <th class="gdi-col-pn text-center">PN</th>
                                            <th class="gdi-col-descricao text-start">Description/Tradução</th>
                                            <th class="gdi-col-produto-vinculo text-center">Produto</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < Model.Count; i++)
                                        {
                                            var pn = (Model[i].pn ?? string.Empty).ToString().Trim();
                                            var descricao = (Model[i].description ?? string.Empty).ToString().Trim();
                                            <tr>
                                                @Html.HiddenFor(model => model[i].id_comex_produto)
                                                <td class="gdi-col-pn text-center">@(string.IsNullOrWhiteSpace(pn) ? "—" : pn)</td>
                                                <td class="gdi-col-descricao text-start">@(string.IsNullOrWhiteSpace(descricao) ? "—" : descricao)</td>
                                                <td class="gdi-col-produto-vinculo text-center">@Html.DropDownListFor(model => model[i].id_produto, ViewBag.comboProdutos as List<SelectListItem>, new { @class = "form-control" })</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                </div>
                <div class="card-footer justify-content-between m-0 p-1">
                    <button type="button" name="btnCancelar" title="Cancelar" class="btn btn-warning d-inline-flex align-items-center gap-2" onclick="jsYesCancelRecord('@Url.Action("ProdutosPre","ComexProdutos",new { Area = "gc" })')"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                    @if (Model.Count > 0 )
                    {<button type="button" name="btnSalvar" title="Salvar" onclick="jsSendForm()" class="btn btn-success float-end d-inline-flex align-items-center gap-2"><i class="fa-solid fa-save me-2" aria-hidden="true"></i>Salvar</button>}
                </div>
            </div>
        </div>
    </div>
}
<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsInitForm();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsSendForm()
    {
        try {
            LibMessageProcessando("Processando . . .")
            var form = $('#GcComexFormProcessarProdutosPreNovos');
            windowLoading(true, 2);
            $.ajax({
                cache: false,
                async: true,
                type: "POST",
                url: '@Url.Action("AjaxProcessarProdutosPreNovos", "ComexProdutos", new { area = "gc" })',
                data: form.serialize(),
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                                                LibMessageSuccess("Confirmação", result.msg, {
                            backdrop: true,
                            callback: function () {
                            document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                            LibMessageProcessando("Processando . . .")
                            $(window.document.location).attr('href', '@Url.Action("ProdutosPre", "ComexProdutos",new { Area = "gc" })');
                            LibMessageHideAll();
                            }
                        });
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.')
                    }
                },
                error: function (xhr, textStatus, errorThrown)
                {
                    LibMessageProcessandoHide();
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.')
                }
            });
                }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };
</script>
