@model List<GdiPlataform.Db.gc_comex_produtos>
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "GcComexFormProcessarProdutosPreAtualizar" }))
{
    <div class="row">
        <div class="col-lg-12 m-0 p-0">
            <div class="card m-0 p-0">
                <div class="card-title m-0 p-1">
                    <h5>@Html.Raw(@ViewBag.Title)</h5>
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)
                </div>
                <div class="card-body m-0 p-1" style="max-width: 100%; overflow-x: auto; ">
                    <div class="form-horizontal m-0 p-0">
                        <div class="table-responsive scroll-body-horizontal" style="width:100%">
                            @if (Model.Count == 0)
                            {
                                <div class="alert alert-danger" role="alert">
                                    Não há itens a serem exibidos
                                </div>
                            }
                            else
                            {
                                <table class="table table-striped table-bordered compact">
                                    <thead>
                                        <tr>
                                            <th style="width: 48%" class="text-center">Produto GDI</th>
                                            <th style="width: 48%" class="text-center">Produto Comex</th>
                                            <th style="width: 4%" class="text-center">Atualizar Tradução</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < Model.Count; i++)
                                        {
                                            <tr>
                                                @Html.HiddenFor(model => model[i].id_comex_produto)
                                                <td style="text-align:left;">@Html.LabelFor(model => model[i].description, Model[i].description.ToString(), htmlAttributes: new { @class = "col-form-label" })</td>
                                                <td style="text-align:left;">@Html.TextAreaFor(model => model[i].traducao, new { @class = "form-control", @rows = "3" } )</td>
                                                <td style="text-align:center;"><div class="form-check form-switch d-inline-flex justify-content-center">@Html.CheckBoxFor(model => model[i].tag1, new { @class = "form-check-input", role = "switch" })</div></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                                <br /><br /><br /><br /><br />
                            }
                        </div>
                    </div>
                </div>
                <div class="card-footer justify-content-between m-0 p-1">
                    <button type="button" name="btnCancelar" title="Cancelar" class="btn btn-warning d-inline-flex align-items-center gap-2" onclick="jsYesCancelRecord('@Url.Action("ProdutosPre","ComexProdutos",new { Area = "gc" })')"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                    @if (Model.Count > 0)
                    {<button type="button" name="btnSalvar" title="Salvar" onclick="jsSendForm()" class="btn btn-success float-end d-inline-flex align-items-center gap-2"><i class="fa-solid fa-save me-2" aria-hidden="true"></i>Salvar</button>}
                </div>
            </div>
        </div>
    </div>
}
<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsInitForm();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsSendForm()
    {
        try {
            LibMessageProcessando("Processando . . .")
            var form = $('#GcComexFormProcessarProdutosPreAtualizar');
            windowLoading(true, 2);
            $.ajax({
                cache: false,
                async: true,
                type: "POST",
                url: '@Url.Action("AjaxProcessarProdutosPreAtualizar", "ComexProdutos", new { area = "gc" })',
                data: form.serialize(),
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        GdiSwal2.dialog({
                            title: "<i class='fa-solid fa-check' style='color:#008000'>&nbsp&nbsp</i><b>Confirmação</b>",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons:
                            {
                                confirmar:
                                {
                                    label: '&nbsp;OK',
                                    className: 'btn btn-info',
                                    callback: function () {
                                        document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                        LibMessageProcessando("Processando . . .")
                                        $(window.document.location).attr('href', '@Url.Action("ProdutosPre", "ComexProdutos",new { Area = "gc" })');
                                        GdiSwal2.hideAll();
                                    }
                                }
                            }
                        })
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias(result.msg);
                    }
                },
                error: function (result)
                {
                    LibMessageProcessandoHide();
                    GdiAjaxNotifyInconsistencias(result.msg);
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };
</script>







