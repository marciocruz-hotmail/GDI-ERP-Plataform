@model IEnumerable<GdiPlataform.Db.gc_comex_produtos>
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@ViewBag.Title</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterOperador" value="" name="yesFilterOperador" />
                <input type="hidden" id="yesFilterText" value="" name="yesFilterText" />
                <input type="hidden" id="yesFilterAdvancedText" value="" name="yesFilterAdvancedText" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-header m-0 p-1">
                <button type="button" id="btnFiltroAvancado" name="btnFiltroAvancado" title="Filtro Avançado" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2" onclick="jsModalFiltroAvancado()"><i class="fa-solid fa-filter me-2" aria-hidden="true"></i>Filtro Avançado</button>
                <div class="btn-group" role="group">
                    <button id="btnGroupDrop1" type="button" class="btn btn-outline-info dropdown-toggle d-inline-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="Processos">
                        <i class="fa-solid fa-cog me-2" aria-hidden="true"></i>Processos
                    </button>
                    <div class="dropdown-menu" aria-labelledby="btnGroupDrop1">
                        <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalDesativarProdutoComex(otableGcComexProdutos, 'Id.')"><i class="fa-solid fa-toggle-off me-2" aria-hidden="true"></i>Produto Comex - Desativar o Cadastro</a>
                    </div>
                </div>
            </div>
            <div class="card-body m-0 p-1" style="max-width: 100%; overflow-x: auto; ">
                <div class="form-horizontal m-0 p-0">
                    <div class="table-responsive scroll-body-horizontal" style="width:100%">
                        <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dtGcComexProdutos">
                            <thead>
                                <tr>
                                    <th>[x]</th>
                                    <th>@Html.Encode("Id.")</th>
                                    <th>@Html.DisplayName("Ativo")</th>
                                    <th>@Html.DisplayName("PN")</th>
                                    <th>@Html.DisplayName("Description/Tradução")</th>
                                    <th>@Html.DisplayName("Produto GDI")</th>
                                    <th><i class="fa-regular fa-edit" style="cursor:pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Editar Produto"></i></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var otableGcComexProdutos;

 	$(function ()
    {
        try
        {
            jsInitForm();
            jsCreateTable();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsCreateTable()
    {
        try
        {
            if (otableGcComexProdutos == null)
            {
                $.fn.dataTable.ext.errMode = 'none';
                otableGcComexProdutos = $('#dtGcComexProdutos')
                    .on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); })
                    .on('xhr.dt', function (e, settings, json, xhr) { GdiDtNotifyJsonErrorMessage(json); btnFiltro(json.yesFilterOnOff); })
                    .css("font-size", 14)
                    .DataTable({
                processing: true,
                bServerSide: true,
                ajax: {
                    url: '@Url.Action("GetDados","ComexProdutos",new { Area = "gc" })',
                    type: 'POST',
                    contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                    dataType: 'json',
                    cache: false,
                    data: function (d) {
                        return {
                            sEcho: d.draw,
                            iDisplayStart: d.start,
                            iDisplayLength: d.length,
                            yesFilterField: $('#yesFilterField').val().toString(),
                            yesFilterOperador: $('#yesFilterOperador').val().toString(),
                            yesFilterText: $('#yesFilterText').val().toString(),
                            yesFilterAdvancedText: $('#yesFilterAdvancedText').val().toString(),
                        };
                    },
                    error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
                },
                responsive: true,
                bFilter: false,
                bLengthChange: false,
                bProcessing: true,
                pageLength: 20,
                scrollX: false,
                scrollCollapse: false,
                fixedColumns: false,
                bAutoWidth: false,
                pagingType: 'full_numbers',
                aoColumnDefs: [
                    { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                    { "width": "4%", orderable: false, className: 'text-sm-center', targets: [1] },
                    { "width": "5%", orderable: false, className: 'text-sm-center', targets: [2] },
                    { "width": "10%", orderable: false, className: 'text-sm-start', targets: [3] },
                    { "width": "33%", orderable: false, className: 'text-sm-start', targets: [4] },
                    { "width": "40%", orderable: false, className: 'text-sm-start', targets: [5] },
                    { "width": "4%", orderable: false, className: 'text-sm-center dt-no-row-select', targets: [6], data: null, defaultContent: "", render: function (data, type, row, meta) { return '<button type="button" name="btnGcComexProdutosCreateEdit" title="Editar Produto Idº ' + data[1] + '" class="btn btn-outline-warning btn-sm p-1 btnGcComexProdutosCreateEdit d-inline-flex align-items-center" onclick="jsGcComexProdutosCreateEdit(' + data[1] + ');"><i class="fa-regular fa-edit"></i></button>' } }
                ],
                select: {
                    style: 'multi',
                    selector: 'td:not(.dt-no-row-select)',
                    headerCheckbox: true
                },
                order: [[1, 'asc']],

                language:
                {
                    sEmptyTable: 'Nenhum registro encontrado',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
                });
                $('#dtGcComexProdutos tbody').on('dblclick', 'tr td', function () {
                    var data = otableGcComexProdutos.row($(this).closest('tr')).data();
                    $("#mainModal").load('@Url.Action("ModalCreateEdit", "ComexProdutos", new { area = "gc" })?id=' + data[1], function () {
                        var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
                    })
                });
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };


    function jsGcComexProdutosCreateEdit(id)
    {
        try
        {
            $("#mainModal").load('@Url.Action("ModalCreateEdit", "ComexProdutos", new { area = "gc" })?id=' + id, function () {
                var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
            })
        }
        catch (err) {
            LibMessageError("Atenção", "[jsGcComexProdutosCreateEdit] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }


    function jsModalFiltroDefault()
    {
        try {
            if (document.getElementById("btnFiltroDefault").innerHTML.indexOf("Remover") > 0) {
                document.getElementById("yesFilterField").value = "*";
                document.getElementById("yesFilterOperador").value = "";
                document.getElementById("yesFilterText").value = "";
                document.getElementById("yesFilterAdvancedText").value = "";
                $("#dtGcComexProdutos").DataTable().draw(false);
            }
            else {
                $("#mainModal").load('@Url.Action("ModalFiltroGenericoView", "Filtros", new { Area = "a" })?id=g_Produtos_Index', function () {
                    var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
                })
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalFiltroDefault] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsRunFiltroDefault(filterField, filterOperador, filterText)
    {
        try {
            document.getElementById("yesFilterField").value = filterField;
            document.getElementById("yesFilterOperador").value = filterOperador;
            document.getElementById("yesFilterText").value = filterText;
            document.getElementById("yesFilterAdvancedText").value = "";
            $("#dtGcComexProdutos").DataTable().draw(false);
        }
        catch (err) {
            LibMessageError("Atenção", "[jsRunFiltroDefault] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsRunFiltroAvancado(FilterAdvancedText)
    {
        try
        {
            document.getElementById("yesFilterAdvancedText").value = FilterAdvancedText;
            $("#dtGcComexProdutos").DataTable().draw(false);
        }
			catch (err) {
            LibMessageError("Atenção", "[jsRunFiltroAvancado] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalFiltroAvancado()
    {
        try
        {
            if (document.getElementById("btnFiltroAvancado").innerHTML.indexOf("Remover") > 0) {
                document.getElementById("yesFilterField").value = "*";
                document.getElementById("yesFilterOperador").value = "";
                document.getElementById("yesFilterText").value = "";
                document.getElementById("yesFilterAdvancedText").value = "";
                $("#dtGcComexProdutos").DataTable().draw(false);
            }
            else
            {
                try
                {
                    $("#mainModal").load('@Url.Action("ModalFiltroAvancadoView", "ComexProdutos", new { Area = "gc" })?id=g_Produtos_Index', function () {
                        var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
                    })
                }
                catch (e)
                {
                    LibMessageError("Atenção", "Erro [" + (e != null ? String(e) : "") + "]");
                }
            };
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalFiltroAvancado] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalDesativarProdutoComex(TableName, columnName)
    {
        try {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            if (!selectedIds || selectedIds.length == 0)
            {
                LibMessageAlert("Atenção", "Selecione o registro!");
            }
            else
            {
                if (selectedIds.indexOf(',') == -1)
                {
                    $("#mainModal").load('@Url.Action("ModalDesativarProdutoComex", "ComexProdutos", new { Area = "gc" })?id=' + selectedIds, function () {
                        var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
                    })
                }
                else
                {
                    LibMessageAlert("Atenção", "Para executar esse processo, selecione apenas 1(um) registro!");
                }
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalDesativarProdutoComex] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }


</script>




