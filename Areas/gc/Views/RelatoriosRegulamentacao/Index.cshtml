@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
@Html.AntiForgeryToken()
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(@ViewBag.Title)</h5>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-body m-0 p-1" style="height: 100%">
                <div class="form-horizontal m-0 p-0">
                    <div class="col-6 mx-auto">
                        <div class="card shadow border">
                            <div class="card-body d-flex flex-column align-items-center">
                                <p class="card-text">
                                    <h4>Selecione o relatório desejado</h4>
                                    <br />
                                </p>
                                <div class="table-responsive scroll-body-horizontal" style="width:100%">
                                    <div class="form-group row"><button type="button" name="btnRelatorio1" title="Relatório - ANP" class="btn btn-outline-secondary btn-lg w-100 mx-auto d-block d-inline-flex align-items-center gap-2" onclick="jsModalRelatorioANP()"><i class="fa-solid fa-file-lines fa-xl me-2" aria-hidden="true"></i>Relatório - ANP</button></div>
                                    <div class="form-group row"><button type="button" name="btnRelatorio2" title="Relatório - IBAMA" class="btn btn-outline-secondary btn-lg w-100 mx-auto d-block d-inline-flex align-items-center gap-2" onclick="jsModalRelatorioIBAMA()"><i class="fa-solid fa-file-lines fa-xl me-2" aria-hidden="true"></i>Relatório - IBAMA</button></div>
                                    <div class="form-group row"><button type="button" name="btnRelatorio3" title="Relatório - PF" class="btn btn-outline-secondary btn-lg w-100 mx-auto d-block d-inline-flex align-items-center gap-2" onclick="jsModalRelatorioPF()"><i class="fa-solid fa-file-lines fa-xl me-2" aria-hidden="true"></i>Relatório - PF</button></div>
                                    <div class="form-group row"><button type="button" name="btnRelatorio3" title="Relatório - Jogue Limpo" class="btn btn-outline-secondary btn-lg w-100 mx-auto d-block d-inline-flex align-items-center gap-2" onclick="jsModalRelatorioJogueLimpo()"><i class="fa-solid fa-file-lines fa-xl me-2" aria-hidden="true"></i>Relatório - Jogue Limpo</button></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsInitForm();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsModalRelatorioANP()
    {
        try
        {
            $("#mainModal").load('@Url.Action("ModalRelatorioANP", "RelatoriosRegulamentacao", new { Area = "gc" })', function () {
                var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
            })
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalRelatorioANP] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalRelatorioIBAMA()
    {
        try
        {
            $("#mainModal").load('@Url.Action("ModalRelatorioIBAMA", "RelatoriosRegulamentacao", new { Area = "gc" })', function () {
                var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
            })
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalRelatorioIBAMA] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalRelatorioPF()
    {
        try
        {
            $("#mainModal").load('@Url.Action("ModalRelatorioPF", "RelatoriosRegulamentacao", new { Area = "gc" })', function () {
                var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
            })
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalRelatorioPF] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalRelatorioJogueLimpo()
    {
        try
        {
            $("#mainModal").load('@Url.Action("ModalRelatorioJogueLimpo", "RelatoriosRegulamentacao", new { Area = "gc" })', function () {
                var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
            })
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalRelatorioPF] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }


    

</script>


