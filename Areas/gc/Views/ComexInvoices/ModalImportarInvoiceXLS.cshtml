@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Modal.cshtml"; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "ModalImportarInvoiceXLS" }))
{
    @Html.AntiForgeryToken()
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title d-flex align-items-center gap-2">
    <i class="fa-solid fa-file-import fa-sm" aria-hidden="true"></i>
    @Html.Raw(ViewBag.Title)</h5>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-1">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Arquivo", new { @class = "col-sm-2 col-form-label" })
                        <div class="col-sm-10 text-sm-start">
                            <input type="file" class="form-control" id="customFile" onchange="jsFileInputChange(this)">
                            <div class="form-text" id="customFile_info"></div>
                        </div>
                    </div>
                    </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" class="btn btn-warning me-auto d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                @if (CachePersister.userIdentity.IdUsuario <= 1)
                {<button type="button" class="btn btn-outline-info d-inline-flex align-items-center gap-2" onclick="jsCheckReprocessarPlanilha()"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>ReProcessar Planilha</button>}
                <button type="button" class="btn btn-success d-inline-flex align-items-center gap-2" onclick="jsCheckInputs()"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>Processar Arquivo</button>
            </div>
        </div>
    </div>
}

<script type="text/javascript">

    $(function () {
        try {
            jsInitModal();
            
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsSelectFile()
    {
        try
        {
            $("#customFile").trigger('click');
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSelectFile] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsCheckInputs()
    {
        try
        {
            if (isEmpty($('#customFile').val().toString().trim()))
            {
                GdiAjaxNotifyInconsistencias("Selecione o arquivo a ser processado!");
            }
            else {
                jsSendForm();
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCheckInputs] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsSendForm()
    {
        try {
            LibMessageProcessando("Processando Invoice . . .");
            var formData = new FormData();
            var totalFiles = document.getElementById("customFile").files.length;
            for (var i = 0; i < totalFiles; i++)
            {
                var file = document.getElementById("customFile").files[i];
                formData.append("filesource", file);
            }
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxModalImportarInvoiceXLS", "ComexInvoices", new { Area = "gc" })',
                data: formData,
                dataType: 'json',
                contentType: false,
                processData: false,
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        GdiSwal2.dialog({
                            title: "<i class='fa-solid fa-check' style='color:#008000'>&nbsp&nbsp</i><b>Confirmação</b>",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons: {
                                confirmar: {
                                    label: '&nbsp;OK',
                                    className: 'btn btn-info',
                                    callback: function ()
                                    {
                                        $("#dtGcComexInvoices").DataTable().draw(false);
                                        document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                        GdiSwal2.hideAll();
                                        location.reload();
                                    }
                                }
                            }
                        })
                    }
                    else
                    {
                        GdiSwal2.dialog({
                            title: "<i class='fa-regular fa-window-close' style='color:#ff0000'>&nbsp&nbsp</i><b>Erro no Processamento</b>",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons: {
                                confirmar: {
                                    label: '&nbsp;OK',
                                    className: 'btn btn-info',
                                    callback: function ()
                                    {
                                        document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                        GdiSwal2.hideAll();
                                    }
                                }
                            }
                        })
                    }
                },
                error: function (result)
                {
                    GdiAjaxNotifyInconsistencias(result.toString());
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsCheckReprocessarPlanilha() {
        try {
            if (isEmpty($('#customFile').val().toString().trim())) {
                GdiAjaxNotifyInconsistencias("Selecione o arquivo a ser processado!");
            }
            else {
                jsReprocessarPlanilha();
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCheckInputs] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }


    function jsReprocessarPlanilha()
    {
        try {
            LibMessageProcessando("Reprocessando Invoice . . .");
            var formData = new FormData();
            var totalFiles = document.getElementById("customFile").files.length;
            for (var i = 0; i < totalFiles; i++)
            {
                var file = document.getElementById("customFile").files[i];
                formData.append("filesource", file);
            }
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxModalReprocessarFobXLS", "ComexInvoices", new { Area = "gc" })',
                data: formData,
                dataType: 'json',
                contentType: false,
                processData: false,
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        GdiSwal2.dialog({
                            title: "<i class='fa-solid fa-check' style='color:#008000'>&nbsp&nbsp</i><b>Confirmação</b>",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons: {
                                confirmar: {
                                    label: '&nbsp;OK',
                                    className: 'btn btn-info',
                                    callback: function ()
                                    {
                                        $("#dtGcComexInvoices").DataTable().draw(false);
                                        document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                        GdiSwal2.hideAll();
                                    }
                                }
                            }
                        })
                    }
                    else
                    {
                        GdiSwal2.dialog({
                            title: "<i class='fa-regular fa-window-close' style='color:#ff0000'>&nbsp&nbsp</i><b>Erro no Processamento</b>",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons: {
                                confirmar: {
                                    label: '&nbsp;OK',
                                    className: 'btn btn-info',
                                    callback: function ()
                                    {
                                        document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                        GdiSwal2.hideAll();
                                    }
                                }
                            }
                        })
                    }
                },
                error: function (result)
                {
                    GdiAjaxNotifyInconsistencias(result.toString());
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };


</script>


