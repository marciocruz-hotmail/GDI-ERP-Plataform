@model GdiPlataform.Db.gc_comex_invoices
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Modal.cshtml"; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "FormModalCambioInvoice_gcInvoices" }))
{
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title d-flex align-items-center gap-2">@Html.Raw(ViewBag.Title)</h5>
                @Html.HiddenFor(model => model.id_invoice)
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-1">
                @Html.Partial("_AlertMsg", AlertMsgItem.Maybe(ViewBag.MsgBloqueio as string, "danger"))
                <div class="form-horizontal m-0 p-0">
                @if (string.IsNullOrEmpty(ViewBag.MsgBloqueio as string))
                {
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Câmbio (Débito)", htmlAttributes: new { @class = "col-sm-4 col-form-label" })
                        <div class="col-sm-4">
                            @Html.EditorFor(model => model.cambio_debito, new { htmlAttributes = new { @class = "form-control", @onkeypress = "keypressed(event);", data_autofocus = "select" } })
                        </div>
                    </div>
                }
                </div>
                </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" name="btnCancelar" title="Cancelar" class="btn btn-warning me-auto d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                @if (string.IsNullOrEmpty(ViewBag.MsgBloqueio as string))
                {
                <button type="button" name="btnSalvar" title="Cancelar Título" class="btn btn-success d-inline-flex align-items-center gap-2" onclick="jsCheckInputs()"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>Atualizar Câmbio</button>
                }
            </div>
        </div>
    </div>
}

<script type="text/javascript">

	$(function ()
    {
        try
        {
            jsInitModal();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsLoadForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    $(document).ready(function () {
    });

    function keypressed(e)
    {
        if (e.keyCode == 13)
        {
            e.preventDefault();
            jsCheckInputs();
        }
    }

    function jsCheckInputs()
    {
        try {
            if (isEmpty($('#cambio_debito').val().toString().trim()))
            {
                GdiAjaxNotifyInconsistencias("Informe o valor do <b>Câmbio Débito</b>!");
            }
            else
            {
                var cambioConvertido = jsFormatMoedaReal($('#cambio_debito').val().toString().trim());
                $('#cambio_debito').val(cambioConvertido);
                jsSendForm();
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCheckInputs] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsFormatMoedaReal(valor) {
        try
        {
            valor = valor.replace(" ", "");
            valor = valor.replace("R$", "");
            valor = valor.replace("US$", "");
            valor = valor.replace("$", "");
            valor = valor.replace("S", "");
            valor = valor.replace("U", "");
            valor = valor.replace("R", "");
            if (valor.indexOf('.') == valor.length - 3)
            {
                valor = valor.replace(",", "");
                valor = valor.replace(".", ",");
            }
            else if (valor.indexOf(',') == valor.length - 3) {
                valor = valor.replace(".", "");
            }
            return valor;
        }
        catch (err) {
            LibMessageError("Atenção", "[jsChangeDolarToReal] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsSendForm()
    {
        try {
            LibMessageProcessando("")
            var form = $('#FormModalCambioInvoice_gcInvoices');
            $.ajax({
                cache: false,
                async: true,
                type: "POST",
                url: '@Url.Action("AjaxModalCambioInvoice", "ComexInvoices", new { area = "gc" })',
                data: form.serialize(),
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true) {
                                                LibMessageSuccess("Confirmação", result.msg, {
                            backdrop: true,
                            callback: function ()
                            {
                            $("#dtGcComexInvoices").DataTable().draw(false);
                            document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                            LibMessageHideAll();
                            location.reload();
                            }
                        });
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.')
                    }
                },
                error: function (xhr, textStatus, errorThrown)
                {
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.')
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };
</script>
