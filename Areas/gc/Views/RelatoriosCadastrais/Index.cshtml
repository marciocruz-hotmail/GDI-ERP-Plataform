@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
@Html.AntiForgeryToken()
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(ViewBag.Title)</h5>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-body m-0 p-1" style="height: 100%">
                <div class="form-horizontal m-0 p-0">
                    <div class="col-8 mx-auto">
                        <div class="card shadow border">
                            <div class="card-body d-flex flex-column align-items-left">
                                <p class="card-text">
                                    <h4>Selecione o relatório desejado</h4>
                                    <br />
                                </p>
                                <div class="table-responsive scroll-body-horizontal" style="width:100%">
                                    <div class="form-group row text-sm-end m-0 p-1">
                                        <div class="col-sm-6">
                                            <button type="button" name="btnRelatorio1" title="Relatório - Clientes/Fornecedores" class="btn btn-outline-secondary btn-lg w-100 left-block d-inline-flex align-items-center gap-2" onclick="jsModalRelatorioClientesFornecedores()"><i class="fa-solid fa-file-lines fa-xl me-2" aria-hidden="true"></i>Clientes/Fornecedores</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsInitForm();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsModalRelatorioClientesFornecedores()
    {
        try {
            $("#mainModal").load('@Url.Action("ModalRelatorioClientesFornecedores", "RelatoriosCadastrais", new { Area = "gc" })', function () {
                var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
            })
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalRelatorioClientesFornecedores] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

</script>
