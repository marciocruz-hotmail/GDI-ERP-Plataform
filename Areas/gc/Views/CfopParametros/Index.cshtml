@model GdiPlataform.Areas.gc.Models.CstCfopParametrosIndex
@using GdiPlataform.Security
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool podeEditarCfopParametro = CachePersister.userIdentity.Roles.Contains("gc_CfopParametros_*")
        || CachePersister.userIdentity.Roles.Contains("gc_CfopParametros_Actionupdate");
}
<style>
    .gdi-index-cfop-parametros-dt .btnGcCfopParametrosEditRow { gap: 0.125rem; }
</style>
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(ViewBag.Title)</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterController" value="CfopParametros" name="yesFilterController" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-header m-0 p-1"></div>
            <div class="card-body m-0 p-1" style="height: 100%">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 mt-1 pt-1">
                        @Html.Label("Id", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-2">
                            @Html.TextBoxFor(model => model.CfopParametrosIndex_id, new { @class = "form-control", @id = "edit_id_cfop_parametro", @placeholder = "Id.", @onkeypress = "keypressedCfopParametros(event);" })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Descrição", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-5">
                            @Html.TextBoxFor(model => model.CfopParametrosIndex_descricao, new { @class = "form-control", @id = "edit_descricao", @placeholder = "Descrição da parâmetro", @onkeypress = "keypressedCfopParametros(event);" })
                        </div>
                        <div class="col-sm-3 text-sm-start">
                            <button type="button" id="btnPesquisar" name="btnPesquisar" title="Pesquisar parâmetros CFOP" class="btn btn-secondary d-inline-flex align-items-center gap-2" onclick="jsAjaxPesquisarCfopParametros()"><i class="fa-solid fa-search me-2" aria-hidden="true"></i>Pesquisar</button>
                            <button type="button" id="btnLimparFiltroCfopParametros" name="btnLimparFiltroCfopParametros" title="Limpar filtro e listar todos" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2 ms-1" onclick="jsLimparFiltroCfopParametros()"><i class="fa-solid fa-magnifying-glass-minus me-2" aria-hidden="true"></i>Limpar</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body m-0 p-1 gdi-index-cfop-parametros-dt" style="max-width: 100%; overflow-x: auto;">
                <div class="form-horizontal m-0 p-0">
                    <div class="table-responsive scroll-body-horizontal" style="width:100%">
                        <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dtGcCfopParametros">
                            <thead>
                                <tr>
                                    <th>[x]</th>
                                    <th>Id.</th>
                                    <th>Ativo</th>
                                    <th>Descrição</th>
                                    @if (podeEditarCfopParametro)
                                    {
                                        <th><i class="fa-regular fa-edit" style="cursor: pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Editar parâmetro"></i></th>
                                    }
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var otableGcCfopParametros;

    $(function ()
    {
        try
        {
            jsInitForm();
            @if (ViewBag.RestoreFilterAutoSearch != true)
            {
                <text>document.getElementById("yesFilterField").value = "*";</text>
            }
            jsCreateTable();
            jsAtualizarIndicadorFiltroCfopParametros('0');
            gdiAplicarFoco('#edit_id_cfop_parametro', true);
            @if (ViewBag.RestoreFilterAutoSearch == true)
            {
                <text>if (jsCfopParametrosTemCriterioFiltro()) { jsAjaxPesquisarCfopParametros(); }</text>
            }
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function keypressed(e)
    {
        if (e.keyCode == 13)
        {
            e.preventDefault();
            jsAjaxPesquisarCfopParametros();
        }
    }

    function jsCfopParametrosTemCriterioFiltro()
    {
        return !isEmpty($('#edit_id_cfop_parametro').val()) || !isEmpty($('#edit_descricao').val());
    }

    function jsAtualizarIndicadorFiltroCfopParametros(yesFilterOnOff)
    {
        GdiAtualizarIndicadorFiltro(yesFilterOnOff, {
            btnId: 'btnLimparFiltroCfopParametros',
            tituloInativo: 'Limpar filtro e listar todos',
            tituloAtivo: 'Filtro ativo — limpar e listar todas as parâmetros'
        });
    }

    function jsAjaxPesquisarCfopParametros()
    {
        try
        {
            if (!jsCfopParametrosTemCriterioFiltro())
            {
                LibMessageAlert("Atenção", "Preencha ao menos um campo do <b>filtro</b> (Id. ou Descrição).");
                return;
            }
            LibMessageProcessando('Pesquisando parâmetros CFOP...');
            document.getElementById("yesFilterField").value = "";
            $("#dtGcCfopParametros").DataTable().draw(false);
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsAjaxPesquisarCfopParametros] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsLimparFiltroCfopParametros()
    {
        try
        {
            $('#edit_id_cfop_parametro').val('');
            $('#edit_descricao').val('');
            document.getElementById("yesFilterField").value = "*";
            LibMessageProcessando('Atualizando lista...');
            $("#dtGcCfopParametros").DataTable().draw(false);
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsLimparFiltroCfopParametros] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsCreateTable()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            otableGcCfopParametros = $('#dtGcCfopParametros').on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) {
                if (GdiDtNotifyJsonErrorMessage(json)) { }
                else if (json && json.yesFilterOnOff !== undefined) {
                    jsAtualizarIndicadorFiltroCfopParametros(json.yesFilterOnOff);
                }
            }).DataTable({
            processing: true,
            bServerSide: true,
            ajax: {
                url: '@Url.Action("GetDados","CfopParametros",new { Area = "gc" })',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                dataType: 'json',
                cache: false,
                data: function (d) {
                    return {
                        sEcho: d.draw,
                        iDisplayStart: d.start,
                        iDisplayLength: d.length,
                        yesFilterField: $('#yesFilterField').val().toString(),
                        yesFilterController: $('#yesFilterController').val().toString(),
                        yesCustomField01: emptyIfNull($('#edit_id_cfop_parametro').val()).toString(),
                        yesCustomField02: emptyIfNull($('#edit_descricao').val()).toString()
                    };
                },
                error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
            },
            responsive: true,
            bFilter: false,
            bLengthChange: false,
            bProcessing: true,
            pageLength: 20,
            scrollX: false,
            scrollCollapse: false,
            fixedColumns: false,
            bAutoWidth: false,
            pagingType: 'full_numbers',
            aoColumnDefs: [
                { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                { "width": "8%", orderable: true, className: 'text-sm-center', targets: [1] },
                { "width": "8%", orderable: false, className: 'text-sm-center', targets: [2] },
                { "width": "@(podeEditarCfopParametro ? "72%" : "76%")", orderable: true, targets: [3] }
                @if (podeEditarCfopParametro)
                {
                <text>,
                { "width": "4%", orderable: false, className: 'text-sm-center dt-no-row-select', targets: [4], data: null, defaultContent: "",
                    render: function (data, type, row) {
                        return '<button type="button" title="Editar parâmetro Id. ' + row[1] + '" class="btn btn-outline-warning btn-sm p-1 btnGcCfopParametrosEditRow d-inline-flex align-items-center" onclick="jsGcCfopParametrosEditRow(' + row[1] + ');"><i class="fa-regular fa-edit"></i></button>';
                    }
                }</text>
                }
            ],
            select: {
                style: 'multi',
                selector: 'td:not(.dt-no-row-select)',
                headerCheckbox: true
            },
            order: [[1, 'asc']],
            drawCallback: function (settings) {
                document.querySelectorAll('#dtGcCfopParametros [data-bs-toggle="tooltip"]').forEach(function (el) {
                    bootstrap.Tooltip.getOrCreateInstance(el);
                });
                try { new $.fn.dataTable.Api(settings).columns.adjust(); } catch (e) { }
            },
                language:
                {
                    sEmptyTable: 'Informe Id. ou Descrição e clique em Pesquisar (ou Limpar para listar todos).',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
            });
            @if (podeEditarCfopParametro)
            {
                <text>$('#dtGcCfopParametros tbody').on('dblclick', 'tr td:not(.dt-no-row-select)', function () {
                var data = otableGcCfopParametros.row($(this).closest('tr')).data();
                if (data) { jsGcCfopParametrosEditRow(data[1]); }
            });</text>
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsGcCfopParametrosEditRow(idParametro)
    {
        try {
            var id = parseInt(idParametro, 10);
            if (!id || id <= 0) { return; }
            jsModalCreateEditCfopParametros(id, '', '');
        }
        catch (err) {
            LibMessageError("Atenção", "[jsGcCfopParametrosEditRow] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsModalCreateEditCfopParametros(IdParametro, TableName, columnName)
    {
        try
        {
            if (IdParametro != '0')
            {
                LibMessageProcessando("");
                $("#mainModal").load('@Url.Action("ModalCreateEditParametro", "CfopParametros", new { area = "gc" })?IdParametro=' + IdParametro, function ()
                {
                    var e = document.getElementById('mainModal'); if (e) { bootstrap.Modal.getOrCreateInstance(e).show(); }
                });
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsModalCreateEditCfopParametros] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }
</script>
