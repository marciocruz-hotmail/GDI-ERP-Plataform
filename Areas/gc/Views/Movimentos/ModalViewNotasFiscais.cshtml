@model GdiPlataform.Db.gc_movimentos
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Modal.cshtml"; }
<style>
    #FormModalViewNotasFiscais .modal-body {
        overflow-y: auto;
        max-height: calc(100vh - 170px);
        overflow-x: hidden;
    }

    #divNotasFiscaisDt {
        min-width: 0;
    }
</style>
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "FormModalViewNotasFiscais" }))
{
    <div class="modal-dialog modal-full modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h4 class="modal-title d-flex align-items-center gap-2">

    @Html.Raw((String)ViewBag.Title)</h4>
                @Html.HiddenFor(model => model.id_movimento)
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterController" value="ModalViewNotasFiscais" name="yesFilterController" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-1 min-w-0">
                <div class="form-horizontal m-0 p-0">
                    @if (Model.id_movimento > 0)
                    {
                    <div id="divNotasFiscaisDt" class="gdi-dt-scroll-host min-w-0">
                        <div class="table-responsive scroll-body-horizontal" style="width:100%">
                            <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dataTableGCViewNotasFiscais">
                                    <thead>
                                        <tr>
                                            <th>[x]</th>
                                            <th>Id.</th>
                                            <th>Status</th>
                                            <th>CFOP</th>
                                            <th>Número</th>
                                            <th>Data/Hora</th>
                                            <th>Itens</th>
                                            <th>R$ Valor</th>
                                            <th><i class="fa-regular fa-file-pdf fa-lg" style="cursor:pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Danfe/PDF"></i></th>
                                            <th><i class="fa-regular fa-file-code fa-lg" style="cursor:pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="XML"></i></th>
                                            <th><i class="fa-solid fa-file-invoice fa-lg" style="cursor:pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Informações"></i></th>
                                            <th><i class="fa-solid fa-stamp" style="cursor:pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Termo Convênio ICMS"></i></th>
                                            <th><i class="fa-regular fa-file-code fa-lg" style="cursor:pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="XML Envio Sefaz"></i></th>
                                            <th><i class="fa-solid fa-trash-alt fa-lg" style="cursor:pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Cancelar"></i></th>
                                        </tr>
                                    </thead>
                                    <tfoot align="right">
                                        <tr>
                                            <th></th>
                                            <th></th>
                                            <th></th>
                                            <th></th>
                                            <th></th>
                                            <th></th>
                                            <th></th>
                                            <th></th>
                                            <th></th>
                                            <th></th>
                                            <th></th>
                                            <th></th>
                                            <th></th>
                                            <th></th>
                                        </tr>
                                    </tfoot>
                                    <tbody></tbody>
                                </table>
                        </div>
                    </div>
                    }
                </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" id="btnAtualizarDados" name="btnAtualizarDados" onclick="jsAtualizarDadosNotasFicais()" title="Atualizar" class="btn btn-outline-secondary me-auto d-inline-flex align-items-center gap-2"><i class="fa-solid fa-sync-alt me-2" aria-hidden="true"></i>Atualizar</button>
                <button type="button" name="btnOK" class="btn btn-success d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>OK</button>
            </div>
        </div>
    </div>
}

<script type="text/javascript">

    var otableNotaFiscalPedido;

    $(function ()
    {
        try
        {
            jsInitModal();
            $.ajax({
                type: "POST",
                url: '@Url.Action("SincronizarStatusNotasFiscaisPedido", "Movimentos", new { area = "gc" })',
                data: { idMovimento: '@Model.id_movimento' },
                success: function () { jsCreateTable(); },
                error: function (xhr, textStatus, errorThrown)
                {
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Falha ao sincronizar notas fiscais.');
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

