                "drawCallback": function (settings) {
                    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function(el){bootstrap.Tooltip.getOrCreateInstance(el);});
                    try { new $.fn.dataTable.Api(settings).columns.adjust(); } catch (e) { }
                    var body = document.querySelector('#FormModalViewNotasFiscais .modal-body');
                    if (body) { body.scrollLeft = 0; }
                },
                processing: true,
                bServerSide: true,
                ajax: {
                    url: '@Url.Action("GetNotaFiscalPedido", "Movimentos", new { area = "gc" })',
                    type: 'POST',
                    contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                    dataType: 'json',
                    cache: false,
                    data: function (d) {
                        return {
                            sEcho: d.draw,
                            iDisplayStart: d.start,
                            iDisplayLength: d.length,
                            yesCustomField01: '@Model.id_movimento',
                        };
                    },
                    error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown);
                }
                },
                responsive: true,
                bFilter: false,
                bLengthChange: false,
                bProcessing: true,
                pageLength: 10,
                scrollX: false,
                scrollCollapse: false,
                fixedColumns: false,
                bAutoWidth: true,
                aoColumnDefs: [
                    { orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                    { orderable: false, className: 'text-sm-center', targets: [1, 2, 3, 4, 5, 6, 7] },
                    { orderable: false, className: 'text-sm-center text-nowrap dt-no-row-select', targets: [8], data: null, defaultContent: "", render: function (data, type, row, meta) { return '<button type="button" name="btnPDF" data-bs-toggle="tooltip" data-bs-placement="top" title="Danfe/PDF da NF Nº ' + data[1] + '" class="btn btn-outline-info btn-sm p-1 btnPDF d-inline-flex align-items-center" onclick="jsPDFNotaFiscal(' + data[1] + ');"><i class="fa-regular fa-file-pdf"></i></button>' } },
