                    { orderable: false, className: 'text-sm-center text-nowrap dt-no-row-select', targets: [10], data: null, defaultContent: "", render: function (data, type, row, meta) { return '<button type="button" name="btnInfo" data-bs-toggle="tooltip" data-bs-placement="top" title="Informações da NF Nº ' + data[1] + '" class="btn btn-outline-warning btn-sm p-1 btnInfo d-inline-flex align-items-center" onclick="jsInfoNotaFiscal(' + data[1] + ');"><i class="fa-solid fa-file-invoice"></i></button>' } },
                    { orderable: false, className: 'text-sm-center text-nowrap dt-no-row-select', targets: [11], data: null, defaultContent: "", render: function (data, type, row, meta) { return '<button type="button" name="btnTermoConvenioICMSPDF" data-bs-toggle="tooltip" data-bs-placement="top" title="Termo Convênio ICMS NF Nº ' + data[1] + '" class="btn btn-outline-secondary btn-sm p-1 btnTermoConvenioICMSPDF d-inline-flex align-items-center" onclick="jsAjaxReportTermoConvenioICMSPDF(' + data[1] + ');"><i class="fa-solid fa-stamp"></i></button>' } },
                    { orderable: false, className: 'text-sm-center text-nowrap dt-no-row-select', targets: [12], data: null, defaultContent: "", render: function (data, type, row, meta) { return '<button type="button" name="btnXMLEnvioSefaz" data-bs-toggle="tooltip" data-bs-placement="top" title="XML Envio Sefaz da NF Nº' + data[1] + '" class="btn btn-outline-secondary btn-sm p-1 btnXMLEnvioSefaz d-inline-flex align-items-center" onclick="jsAjaxGetXMLEnvioSefaz(' + data[1] + ');"><i class="fa-regular fa-file-code"></i></button>' } },
                    { orderable: false, className: 'text-sm-center text-nowrap dt-no-row-select', targets: [13], data: null, defaultContent: "", render: function (data, type, row, meta) { return '<button type="button" name="btnCancel" data-bs-toggle="tooltip" data-bs-placement="top" title="Cancelar NF Nº ' + data[1] + '" class="btn btn-outline-danger btn-sm p-1 btnCancel d-inline-flex align-items-center" onclick="jsCancelamentoNF_Step1(' + data[1] + ');"><i class="fa-solid fa-trash-alt"></i></button>' } }
                ],
                select: {
                    style: 'multi',
                    selector: 'td:not(.dt-no-row-select)',
                    headerCheckbox: true
                },

                order: [[0, 'desc']],
                language:
                {
                    sEmptyTable: 'Nenhuma NF',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ NF ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 NF',
                    sInfoFiltered: ' (Filtrados de _MAX_ NF)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ Resultados por página',
                    sZeroRecords: 'Nenhuma NF',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: 'Próximo',
                        sPrevious: 'Anterior',
                        sFirst: 'Primeiro',
                        sLast: 'Último'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d NF selecionada ] ",
                            _: " [ %d NF selecionadas ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function YesDownloadFileXML(data, name = 'file', type = 'text/plain')
    {
        const { createElement } = document
        const { URL: { createObjectURL, revokeObjectURL }, setTimeout } = window

        const blob = new Blob([data], { type })
        const url = createObjectURL(blob)

        const anchor = createElement('a')
        anchor.setAttribute('href', url)
        anchor.setAttribute('download', name)
        anchor.click()

        setTimeout(() => { revokeObjectURL(url) }, 100)
    }

    function jsPDFNotaFiscal(id)
    {
        LibMessageProcessando("Processando . . .")
        var dataForm =
        {
            view_record_gc_movimento_nf:
            {
                'id_movimento_nf': id,
            }
        };
        $.ajax({
            type: "POST",
            url: '@Url.Action("AjaxPDFNotaFiscal", "Movimentos", new { area = "gc" })',
            contentType: "application/json; charset=utf-8",
            data: JSON.stringify(dataForm),
            dataType: "json",
            success: function (result)
            {
                LibMessageProcessandoHide();
                if (result.success == true)
                {
                    window.open(result.msg, '_blank').focus();
                }
                else
                {
                    GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.');
                }
            },
            error: function (xhr, textStatus, errorThrown)
            {
                    LibMessageProcessandoHide();
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.');
                }
        });
    };

