    function jsCancelamentoNF_Step1(id) {
        Swal.fire({
            theme: 'bootstrap-5-light',
            title: "Confirmação",
            html:
                "Deseja <b>CANCELAR</b> a NFº " + id + " ?" +
                "<br><br>" +
                "<b>ATENÇÃO:</b><br>" +
                "Para CANCELAMENTOS após 24 Horas da autorização, deve-se antes, executar os procedimentos de cancelamento extemporâneo de NF-e via SIARE!",
            icon: "question",
            showCancelButton: true,
            confirmButtonText: '<i class="fa-solid fa-save me-2"></i>Confirmo o Cancelamento da NF',
            cancelButtonText: '<i class="fa-solid fa-rotate-left me-2"></i>Desistir',
            reverseButtons: true,
            buttonsStyling: false,
            allowEscapeKey: false,
            customClass: {
                confirmButton: "btn btn-outline-success ms-2",
                cancelButton: "btn btn-outline-warning"
            }
        }).then(function (result) {
            if (result.isConfirmed) {
                jsCancelamentoNF_Step2(id);
            }
        });
    }

    function jsCancelamentoNF_Step2(id) {
        Swal.fire({
            theme: 'bootstrap-5-light',
            title: "Confirmação",
            html:
                "Deseja <b>REALMENTE CANCELAR</b> a NFº " + id + " ?" +
                "<br><br>" +
                "<b>ATENÇÃO:</b><br>" +
                "Para CANCELAMENTOS após 24 Horas da autorização, CERTIFIQUE-SE de já ter sido executado os procedimentos de cancelamento extemporâneo de NF-e via SIARE!" +
                "<br><br>" +
                "<b>***** A Partir dessa ação a Nota Fiscal será cancelada DEFINITIVAMENTE *****</b>!",
            icon: "question",
            showCancelButton: true,
            confirmButtonText: '<i class="fa-solid fa-save me-2"></i>Confirmo o Cancelamento da NF',
            cancelButtonText: '<i class="fa-solid fa-rotate-left me-2"></i>Desistir',
            reverseButtons: true,
            buttonsStyling: false,
            allowEscapeKey: false,
            customClass: {
                confirmButton: "btn btn-outline-success ms-2",
                cancelButton: "btn btn-outline-warning"
            }
        }).then(function (result) {
            if (result.isConfirmed) {
                jsCancelamentoNF_Step3(id);
            }
        });
    }

    function jsCancelamentoNF_Step3(id) {
        try {
            Swal.fire({
                theme: 'bootstrap-5-light',
                target: document.querySelector(".modal.show") || document.body,
                title: "Informe a Justificatica do Cancelamento",
                input: "text",
                inputPlaceholder: "Digite a justificativa do cancelamento",
                showCancelButton: true,
                confirmButtonText: "Confirmar",
                cancelButtonText: "Cancelar",
                reverseButtons: true,
                buttonsStyling: false,
                customClass: {
                    confirmButton: "btn btn-outline-success ms-2",
                    cancelButton: "btn btn-outline-warning"
                },
                inputValidator: function (value) {
                    if (!value || value.trim() === "") {
                        return "Informe a justificativa.";
                    }
                }
            }).then(function (result) {
                if (result.isConfirmed) {
                    jsCancelamentoNF_Step4(id, result.value.trim());
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInputSiare] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsCancelamentoNF_Step4(id, obs) {
        try {
            Swal.fire({
                theme: 'bootstrap-5-light',
                target: document.querySelector(".modal.show") || document.body,
                title: "Informe o nº do protocolo do Siare",
