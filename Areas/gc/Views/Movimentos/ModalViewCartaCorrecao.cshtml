@model GdiPlataform.Db.gc_movimentos
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Modal.cshtml"; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "FormModalViewCartaCorrecao" }))
{
    <div class="modal-dialog modal-full modal-dialog-scrollable">
        <div class="modal-content">
            <div class="scroll-modal-horizontal" style="width:100%">
                <div class="modal-header m-0 p-1">
                    <h4 class="modal-title d-flex align-items-center gap-2">
    
    @Html.Raw((String)ViewBag.Title)</h4>
                    @Html.HiddenFor(model => model.id_movimento)
                    <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                    <input type="hidden" id="yesFilterController" value="ModalViewCartaCorrecao" name="yesFilterController" />
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)
                </div>
                <div class="modal-body m-0 p-0">
                    <div class="form-horizontal m-0 p-0">
                        @if (Model.id_movimento > 0)
                        {
                            <div class="table-responsive scroll-body-horizontal" style="width:100%">
                                <div class="card-body m-0 p-1" style="max-width: 100%; overflow-x: auto; ">
                                    <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dataTablesGCViewCartaCorrecao">
                                        <thead>
                                            <tr>
                                                <th>[x]</th>
                                                <th>Id.</th>
                                                <th>Identificador</th>
                                                <th>Status</th>
                                                <th>Data</th>
                                                <th>Correção/Motivo</th>
                                                <th><i class="fa-solid fa-cloud-download-alt fa-lg" style="cursor:pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Carta Correção"></i></th>
                                                <th><i class="fa-regular fa-file-code fa-lg" style="cursor:pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="XML"></i></th>
                                            </tr>
                                        </thead>
                                        <tfoot align="right">
                                            <tr>
                                                <th></th>
                                                <th></th>
                                                <th></th>
                                                <th></th>
                                                <th></th>
                                                <th></th>
                                                <th></th>
                                                <th></th>
                                            </tr>
                                        </tfoot>
                                        <tbody></tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer justify-content-between m-0 p-1">
                    <button type="button" name="btnCancelar" class="btn btn-warning me-auto d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                    <button type="button" name="btnOK" class="btn btn-success d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>OK</button>
                </div>
            </div>
        </div>
    </div>
}

<script type="text/javascript">
    var otablesGCViewCartaCorrecao;

    $(function ()
    {
        try
        {
            jsInitModal();
            $.ajax({
                type: "POST",
                url: '@Url.Action("SincronizarStatusCartasCorrecaoPedido", "Movimentos", new { area = "gc" })',
                data: { idMovimento: '@Model.id_movimento' },
                success: function () { jsCreateTable(); },
                error: function (xhr, textStatus, errorThrown)
                {
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Falha ao sincronizar cartas de correção.');
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsCreateTable()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            otablesGCViewCartaCorrecao = $('#dataTablesGCViewCartaCorrecao').on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) { GdiDtNotifyJsonErrorMessage(json); }).DataTable({
                "drawCallback": function (settings) {
                    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function(el){bootstrap.Tooltip.getOrCreateInstance(el);});
                },
                processing: true,
                bServerSide: true,
                ajax: {
                    url: '@Url.Action("GetDadosCartaCorrecao", "Movimentos", new { area = "gc" })',
                    type: 'POST',
                    contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                    dataType: 'json',
                    cache: false,
                    data: function (d) {
                        return {
                            sEcho: d.draw,
                            iDisplayStart: d.start,
                            iDisplayLength: d.length,
                            yesCustomField01: '@Model.id_movimento',
                        };
                    },
                    error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
                },
                responsive: true,
                bFilter: false,
                bLengthChange: false,
                bProcessing: true,
                pageLength: 10,
                scrollX: false,
                scrollCollapse: false,
                fixedColumns: false,
                bAutoWidth: false,
                pagingType: 'full_numbers',
                aoColumnDefs: [
                    { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                    { "width": "6%", orderable: false, className: 'text-sm-center', targets: [1] },
                    { "width": "10%", orderable: false, className: 'text-sm-center', targets: [2] },
                    { "width": "20%", orderable: false, className: 'text-sm-center', targets: [3] },
                    { "width": "10%", orderable: false, className: 'text-sm-center', targets: [4] },
                    { "width": "42%", orderable: false, className: 'text-sm-center', targets: [5] },
                    { "width": "4%", orderable: false, className: 'text-sm-center dt-no-row-select', targets: [6], data: null, defaultContent: "", render: function (data, type, row, meta) { return '<button type="button" name="btnPDF" data-bs-toggle="tooltip" data-bs-placement="top" title="Acessar Carta Correção Nº ' + data[1] + '" class="btn btn-outline-info btn-md btnPDF d-inline-flex align-items-center gap-2" onclick="jsPDFCartaCorrecao(' + data[1] + ');"><i class="fa-solid fa-cloud-download-alt"></i></button>' } },
                    { "width": "4%", orderable: false, className: 'text-sm-center dt-no-row-select', targets: [7], data: null, defaultContent: "", render: function (data, type, row, meta) { return '<button type="button" name="btnXML" data-bs-toggle="tooltip" data-bs-placement="top" title="Acessar XML Carta Correção Nº ' + data[1] + '" class="btn btn-outline-info btn-md btnXML d-inline-flex align-items-center gap-2" onclick="jsXMLCartaCorrecao(' + data[1] + ');"><i class="fa-regular fa-file-code"></i></button>' } },
                ],
                select: {
                    style: 'multi',
                    selector: 'td:not(.dt-no-row-select)',
                    headerCheckbox: true
                },

                order: [[0, 'asc']],
                language:
                {
                    sEmptyTable: 'Nenhum registro encontrado',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsXMLCartaCorrecao(id)
    {
        try {
            LibMessageProcessando("Processando . . .")
            var dataForm =
            {
                view_record_g_nfe_carta_correcao:
                {
                    'id_nfe_carta_correcao': id,
                }
            };
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxXMLCartaCorrecao", "Movimentos", new { area = "gc" })',
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(dataForm),
                dataType: "json",
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                                                LibMessageSuccess("Confirmação", result.msg, {
                            backdrop: true,
                            callback: function ()
                            {
                            if (result.idProcessamento != "0") // Se houver processamento, realizar o download do relatório
                            {
                            window.location = '@Url.Action("AjaxGetFileProcessamento", "Global", new { Area = "g" })' + "?id=" + result.idProcessamento;
                            }
                            LibMessageHideAll();
                            }
                        });
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.');
                    }
                },
                error: function (xhr, textStatus, errorThrown)
                {
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.');
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsXMLCartaCorrecao] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsPDFCartaCorrecao(id)
    {
        try {
            LibMessageProcessando("Processando . . .")
            var dataForm =
            {
                view_record_g_nfe_carta_correcao:
                {
                    'id_nfe_carta_correcao': id,
                }
            };
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxPDFCartaCorrecao", "Movimentos", new { area = "gc" })',
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(dataForm),
                dataType: "json",
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                                                LibMessageSuccess("Chave de Acesso", "Na página da Sefaz informe a chave de acesso abaixo:<br/><br/>" + result.chaveacesso, {
                            backdrop: true,
                            callback: function () {
                            document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                            window.open(result.msg, '_blank').focus();
                            }
                        });
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.');
                    }
                },
                error: function (xhr, textStatus, errorThrown)
                {
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.');
                }
            });

        }
        catch (err) {
            LibMessageError("Atenção", "[jsPDFCartaCorrecao] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };



</script>


