<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsInitModal();
            gdiConferenciaLotesTabsSelect2Init('#ModalPedidoSeparacaoLotes', '#containerModalPedidoSeparacaoLotes');
            $('#btnCancelarLote').off('click').on('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                $('#containerModalPedidoSeparacaoLotes').data('pedSepLotesRefreshParent', true);
                JsCreateTablePedidoSeparacaoLotes()
                var _m=document.getElementById('containerModalPedidoSeparacaoLotes');if(_m){var _i=bootstrap.Modal.getInstance(_m);if(_i)_i.hide();}
            });
        } catch (err) {
            console.error('[ModalPedidoSeparacaoLotes] ' + err.message);
        }
    });

    function JsConfirmarSeparacaoLotes()
    {
        try
        {
            document.getElementById('btnSalvarLote').disabled = true;
            LibMessageProcessando();
            var form = $('#ModalPedidoSeparacaoLotes');
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxModalPedidoSeparacaoLotes", "Movimentos", new { area = "gc" })',
                data: form.serialize(),
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        $('#containerModalPedidoSeparacaoLotes').data('pedSepLotesRefreshParent', true);
                        var _m=document.getElementById('containerModalPedidoSeparacaoLotes');if(_m){var _i=bootstrap.Modal.getInstance(_m);if(_i)_i.hide();}
                    }
                    else
                    {
                        document.getElementById('btnSalvarLote').disabled = false;
                        GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.')
                    }
                },
                error: function (xhr, textStatus, errorThrown)
                {
                    LibMessageProcessandoHide();
                    document.getElementById('btnSalvarLote').disabled = false;
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.')
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };
</script>
