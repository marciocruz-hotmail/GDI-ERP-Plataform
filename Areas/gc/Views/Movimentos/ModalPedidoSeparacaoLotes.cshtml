        <button type="button" id="btnSalvarLote" name="btnSalvarLote" class="btn btn-success d-inline-flex align-items-center gap-2" onclick="JsConfirmarSeparacaoLotes()"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>Confirmar lotes</button>
