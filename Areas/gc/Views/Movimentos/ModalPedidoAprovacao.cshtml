@model GdiPlataform.Db.gc_movimentos
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Modal.cshtml"; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "FormModalPedidoAprovacao" }))
{
    <div class="modal-dialog modal-full modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header m-0 p-1" style="background-color: #D5F5E3">
                <h4 class="modal-title d-flex align-items-center gap-2">@Html.Raw((String)ViewBag.Title)</h4>
                @Html.HiddenFor(model => model.id_movimento)
                @Html.HiddenFor(model => model.id_cliente)
                @Html.HiddenFor(model => model.tag)
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-1">
                <div class="form-horizontal m-0 p-0">
                    <div class="card-body m-0 p-0" style="height: 100%">
                        @if (!string.IsNullOrEmpty(ViewBag.MsgBloqueio as string))
                        {
                            <div class="col-sm-12 text-sm-start m-0 p-0">
                                @Html.Partial("_AlertMsg", AlertMsgItem.Maybe(ViewBag.MsgBloqueio as string, "danger"))
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(ViewBag.MsgObservacoes as string))
                        {
                            <div class="col-sm-12 text-sm-start m-0 p-0">
                                @Html.Partial("_AlertMsg", AlertMsgItem.Maybe(ViewBag.MsgObservacoes as string, "warning"))
                            </div>
                        }
                        @if (Model.id_movimento_posicao >= 0) // O Pedido pode estar inclusive aberto
                        {
                            <div class="card shadow-sm gdi-section-accent-secondary m-1 p-0" style="height:100%;">
                                <div class="section-header"><i class="fa-solid fa-file-pen me-1" aria-hidden="true"></i>Dados da Aprovação</div>

                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("movimento_aprovado", "Status", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                    <div class="col-sm-2 text-sm-start" style="margin-top:5px;">
                                        <div class="form-check form-switch form-switch-lg">
                                            @Html.CheckBoxFor(model => model.movimento_aprovado, htmlAttributes: new { @class = "form-check-input switch-success", @id = "movimento_aprovado", role = "switch" })
                                            <label class="form-check-label" for="movimento_aprovado" id="label_movimento_aprovado">Reprovado / Aprovado</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("cotacao_dolar_venda", "US$ Pedido", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.cotacao_dolar_venda, new { htmlAttributes = new { @class = "form-control" } })
                                    </div>
                                    @Html.Label("frete_valor", "R$ Frete", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-1">
                                        @Html.EditorFor(model => model.frete_valor, new { htmlAttributes = new { @class = "form-control" } })
                                    </div>
                                    @Html.Label("valor_total_bruto", "R$ Total", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                    <div class="col-sm-1">
                                        @Html.EditorFor(model => model.valor_total_bruto, new { htmlAttributes = new { @class = "form-control" } })
                                    </div>
                                    @Html.Label("Vendedor", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                    <div class="col-sm-3">
                                        @Html.DropDownListFor(model => model.comissao1_vendedor, ViewBag.comboVendedores as List<SelectListItem>, new { @class = "form-control", @data_container = "body" })
                                    </div>
                                </div>
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("Faturamento", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                    <div class="col-sm-2">
                                        @Html.DropDownListFor(model => model.id_pagrec_condicao, ViewBag.comboPagRecCondicoes as List<SelectListItem>, new { @class = "form-control", @data_container = "body" })
                                    </div>
                                    @Html.Label("frete_gerencial", "R$ Frete Gerencial", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-1">
                                        @Html.EditorFor(model => model.frete_gerencial, new { htmlAttributes = new { @class = "form-control" } })
                                    </div>
                                    @Html.Label("Estoque", "Estoque", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                    <div class="col-sm-1">
                                        @Html.DropDownList("id_local_estoque", ViewBag.comboLocaisEstoqueOrders as List<SelectListItem>, htmlAttributes: new { @id = "id_local_estoque", @class = "form-control", @data_container = "body", @title = "Estoque" })
                                    </div>
                                    @Html.Label("frete1_transportadora", "Transportadora", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                    <div class="col-sm-3">
                                        @Html.DropDownList("frete1_transportadora", ViewBag.comboTransportadora as List<SelectListItem>, htmlAttributes: new { @id = "id_transportadora", @class = "form-control", @data_container = "body", @title = "Transportadora" })
                                    </div>
                                </div>
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("obs_aprovacao", "Obs Aprovação", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                    <div class="col-sm-11">
                                        @Html.TextAreaFor(model => model.obs_aprovacao, new { @class = "form-control", @id = "obs", @rows = "3", @title = "Informações adicionais da aprovação", @placeholder = "Informações adicionais da aprovação\n   - Exemplo: Orientações para Faturamento, Orientações para Envio do Material, Orientações Gerais" })
                                    </div>
                                </div>

                                @if (Model.movimento_aprovado == true) // O Pedido está aprovado
                                {
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("tag_string", "Cancelamento", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                    <div class="col-sm-11">
                                        @Html.EditorFor(model => model.tag_string, new { htmlAttributes = new { @class = "form-control", @title = "Motivo Cancelamento", @placeholder = "Motivo do Cancelamento da Aprovação", Style = "background-color:#fbeee6" } })
                                    </div>
                                </div>
                                }


                                <div class="section-header mt-3"><i class="fa-solid fa-people-group me-1" aria-hidden="true"></i>Contatos a serem notificados (Email Nota Fiscal/Boleto + WhatsApp)</div>
                                
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("id_contato", "Contato", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                    <div class="col-sm-4">
                                        @Html.DropDownListFor(model => model.id_contato, ViewBag.ComboClientesContatos as List<SelectListItem>, new { @class = "form-control", @data_container = "body", @onchange = "jsSetDadosContato();", @onblur = "jsSetDadosContato();" })
                                    </div>
                                    @Html.Label("contato_telefone", "Pessoa de Contato", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.contato_nome, new { htmlAttributes = new { @class = "form-control" } })
                                    </div>
                                    @Html.Label("contato_telefone", "Telefone/Celular", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.contato_telefone, new { htmlAttributes = new { @class = "form-control" } })
                                    </div>
                                </div>
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("notifica_contatos_emails", "Emails Notificações", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                    <div class="col-sm-5">
                                        @Html.TextAreaFor(model => model.notifica_contatos_emails, new { @class = "form-control", @id = "notifica_contatos_emails", @rows = "2", @title = "Emails a serem notificados", @placeholder = "Todos os e-mails que receberão os emails de notificações sobre o pedido\nNão é necessário repetir o email do contato" })
                                    </div>
                                    @Html.Label("contato_email", "Email Contato", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                    <div class="col-sm-5">
                                        @Html.EditorFor(model => model.contato_email, new { htmlAttributes = new { @class = "form-control" } })
                                    </div>
                                </div>
                                <div class="form-group row text-sm-end m-0 pt-1">
                                </div>

                                <div class="section-header mt-3"><i class="fa-solid fa-boxes-stacked me-1" aria-hidden="true"></i>@Html.Raw((String)ViewBag.QtdItensPedido)</div>
                                <div class="modal-body m-0 p-0">
                                    <div class="form-horizontal m-0 p-0">
                                        <div class="card-body m-0 p-1" style="max-width: 100%; overflow-x: auto; ">
                                            <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="DtPedidoAprovacaoItens">
                                                <thead>
                                                    <tr>
                                                        <th style="font-size:12px;">@Html.Encode("Qtd")</th>
                                                        <th style="font-size:12px;">@Html.Encode("Produto")</th>
                                                        <th style="font-size:12px;">@Html.Encode("R$ Unit")</th>
                                                        <th style="font-size:12px;">@Html.Encode("R$ Total")</th>
                                                    </tr>
                                                </thead>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(ViewBag.MsgHistorico as string))
                    {

                        <div class="card-body m-0 p-0" style="height: 100%">
                            <div class="card shadow-sm gdi-section-accent-secondary m-1 mt-2 p-0" style="height:100%;">
                                <div class="section-header"><i class="fa-solid fa-circle-info me-1" aria-hidden="true"></i>Histórico</div>
                                <div class="form-group row text-sm-end m-0 mt-1 p-0">
                                    <div class="col-sm-12">
                                        @Html.TextArea("historico", (String)ViewBag.MsgHistorico, new { @class = "form-control", @id = "hist", @rows = "5", @readonly = true })
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" name="btnCancelar" class="btn btn-warning me-auto d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                @if (string.IsNullOrEmpty(ViewBag.MsgBloqueio as string)) { <button type="button" id="btnSalvar" name="btnSalvar" class="btn btn-success d-inline-flex align-items-center gap-2" onclick="jsSendForm()"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>Confirmar Status do Pedido</button> }
            </div>
        </div>
    </div>
}

<script type="text/javascript">

    var oTablePedidoAprovacaoItens;

    $(function ()
    {
        try
        {
            jsInitModal();
            $('#valor_total_liquido').attr('readonly', 'readonly');
            $('#cotacao_dolar_venda').attr('readonly', 'readonly');
            $('#cotacao_dolar_oficial_venda').attr('readonly', 'readonly');
            $('#valor_venda_reais').attr('readonly', 'readonly');
            $('#frete_valor').attr('readonly', 'readonly');
            $('#valor_total_bruto').attr('readonly', 'readonly');
            $('#id_pagrec_condicao').attr('disabled', true);
            jsCreateOTablePedidoAprovacaoItens();
            if ($("#movimento_aprovado").is(':checked')) { $("#label_movimento_aprovado").html("Aprovado"); } else { $("#label_movimento_aprovado").html("Não Aprovado"); };
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    $("#movimento_aprovado").change(function () {
        $("#label_movimento_aprovado").html("Não Aprovado");
        if ($(this).is(':checked')) {
            $("#label_movimento_aprovado").html("Aprovado");
        }
    });

    function jsSendForm()
    {
        try
        {
            document.getElementById('btnSalvar').disabled = true;
            LibMessageProcessando();
            var form = $('#FormModalPedidoAprovacao');
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxModalPedidoAprovacao", "Movimentos", new { area = "gc" })',
                data: form.serialize(),
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                                                LibMessageSuccess("Confirmação", result.msg, {
                            backdrop: true,
                            callback: function ()
                            {
                            $("#dataTableGCIndexPedido").DataTable().draw(false);
                            document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                            LibMessageHideAll();
                            }
                        });
                    }
                    else
                    {
                        document.getElementById('btnSalvar').disabled = false;
                        GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.')
                    }
                },
                error: function (xhr, textStatus, errorThrown)
                {
                    document.getElementById('btnSalvar').disabled = false;
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.');
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsCreateOTablePedidoAprovacaoItens()
    {
        try
        {
            if (oTablePedidoAprovacaoItens == null)
            {
                $.fn.dataTable.ext.errMode = 'none';
                oTableGcMovimentosCreatePedido = $('#DtPedidoAprovacaoItens').css("font-size", 12).on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) { GdiDtNotifyJsonErrorMessage(json); }).dataTable({
                processing: true,
                bServerSide: true,
                ajax: {
                    url: '@Url.Action("GetDadosModalItensComValor", "Movimentos", new { area = "gc" })',
                    type: 'POST',
                    contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                    dataType: 'json',
                    cache: false,
                    data: function (d) {
                        return {
                            sEcho: d.draw,
                            iDisplayStart: d.start,
                            iDisplayLength: d.length,
                            yesCustomIdPK: $('#id_movimento').val().toString(),
                        };
                    },
                    error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
                },
                responsive: true,
                bFilter: false,
                bLengthChange: false,
                bProcessing: true,
                pageLength: 30,
                scrollX: false,
                scrollCollapse: false,
                fixedColumns: false,
                bAutoWidth: false,
                pagingType: 'full_numbers',
                aoColumnDefs: [
                    { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0] },
                    { "width": "80%", orderable: false, className: 'text-sm-start', targets: [1] },
                    { "width": "8%", orderable: false, className: 'text-sm-end', targets: [2] },
                    { "width": "8%", orderable: false, className: 'text-sm-end', targets: [3] }
                ],
                select: {
                    style: 'multi',
                    selector: 'td:not(.dt-no-row-select)',
                    headerCheckbox: true
                },
                order: [[1, 'asc']],

                language:
                {
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
                });
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsSetDadosContato()
    {
        try
        {
            if (($("#id_contato").val() != null) && ($("#id_contato").val() > 0))
            {
                var dataForm =
                {
                    view_g_clientes_contatos:
                    {
                        'id_contato': $("#id_contato").val(),
                    }
                };
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("AjaxGetDadosContato", "Clientes", new { area = "g" })',
                    contentType: "application/json; charset=utf-8",
                    data: JSON.stringify(dataForm),
                    dataType: "json",
                    success: function (result)
                    {
                        if (result.success == true)
                        {
                            document.getElementById("contato_nome").value = result.contato_nome;
                            document.getElementById("contato_telefone").value = result.contato_telefone;
                            document.getElementById("contato_email").value = result.contato_email;
                        }
                        else
                        {
                            document.getElementById("contato_nome").value = "";
                            document.getElementById("contato_telefone").value = "";
                            document.getElementById("contato_email").value = "";
                        }
                    },
                    error: function (xhr, textStatus, errorThrown)
                    {
                        document.getElementById("contato_nome").value = "";
                        document.getElementById("contato_telefone").value = "";
                        document.getElementById("contato_email").value = "";
                    }
                });
            }
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsSetPrecoVendaProduto] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }



</script>

