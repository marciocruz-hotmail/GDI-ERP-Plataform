    function jsAjaxReportInvoicePDF(TableName, columnName, saida)
    {
        try
        {
            var selectedIds = JsGetSelectedRows(TableName, columnName);
            if (!selectedIds || selectedIds.length == 0)
            {
                LibMessageAlert("Atenção", "Selecione o registro!");
            }
            else
            {
                if (selectedIds.indexOf(',') == -1)
                {
                    LibMessageProcessando();
                    var dataForm =
                    {
                        'id': selectedIds,
                        'saida': saida
                    }
                    $.ajax({
                        type: "POST",
                        url: '@Url.Action("AjaxReportInvoicePDF", "Movimentos", new { area = "gc" })',
                        contentType: "application/json; charset=utf-8",
                        data: JSON.stringify(dataForm),
                        dataType: "json",
                        success: function (result)
                        {
                            if (result.success == true)
                            {
                                window.location = '@Url.Action("AjaxGetFileResultDownload", "Global", new { Area = "g" })' + "?url=" + result.url;
                                LibMessageProcessandoHide();
                            }
                            else
                            {
                                LibMessageProcessandoHide();
                                GdiAjaxNotifyInconsistencias(result.msg)
                            }
                        },
                        error: function (result) {
                            LibMessageProcessandoHide();
                            GdiAjaxNotifyInconsistencias(result.toString());
                        }
                    })
                }
                else
                {
                    LibMessageAlert("Atenção", "Para edição/visualização, selecione apenas 1(um) registro!");
                }
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsAjaxReportInvoicePDF] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

