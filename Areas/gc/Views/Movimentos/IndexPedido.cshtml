@model IEnumerable<GdiPlataform.Db.gc_movimentos>
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
<style>
    /* IndexPedido: botões de ícone um pouco mais compactos (largura da tabela) */
    .gdi-index-pedido-dt .btnGCIndexPedidoAnexos,
    .gdi-index-pedido-dt .btnGCIndexPedidoEditRow { gap: 0.125rem; }
</style>
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5 style="margin: 5px; margin-top: 5px;">@Html.Raw(ViewBag.Title)</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterController" value="IndexPedido" name="yesFilterController" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-header m-0 p-1 bg-body-secondary d-flex flex-wrap align-items-center gap-1">
                @if ((CachePersister.userIdentity.Roles.Contains("gc_Movimentos_*")) || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_IndexPedido_Create")))
                {
                    <button type="button" name="btnNovoCotacao" title="Nova Cotação" class="btn btn-outline-warning d-inline-flex align-items-center gap-2" onclick="JsNewRecord('@Url.Action("CreateCotacao", "Movimentos", new { Area = "gc" })')"><i class="fa-solid fa-clipboard-list me-2" aria-hidden="true"></i>Cotação</button>
                    <button type="button" name="btnNovoPedido" title="Novo Pedido" class="btn btn-outline-success d-inline-flex align-items-center gap-2" onclick="JsNewRecord('@Url.Action("CreatePedido", "Movimentos", new { Area = "gc" })')"><i class="fa-solid fa-boxes me-2" aria-hidden="true"></i>Pedido</button>
                    <button type="button" name="btnNovaOS" title="Nova OS" class="btn btn-outline-success d-inline-flex align-items-center gap-2" onclick="JsNewRecord('@Url.Action("CreateOS", "Movimentos", new { Area = "gc" })')"><i class="fa-solid fa-tools me-2" aria-hidden="true"></i>OS</button>
                }
                @if ((CachePersister.userIdentity.Roles.Contains("gc_Movimentos_*")) || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_IndexPedido_Processos")))
                {
                    <div class="vr mx-1"></div>
                    <div class="btn-group" role="group">
                        <button id="btnGroupDrop1" type="button" class="btn btn-outline-info dropdown-toggle d-inline-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="Processos">
                            <i class="fa-solid fa-cog me-2" aria-hidden="true"></i>Processos
                        </button>
                        <div class="dropdown-menu" aria-labelledby="btnGroupDrop1">
                            <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalPedidoDuplicar(otableGCIndexPedido, 'Id.')"><i class="fa-regular fa-copy me-2" aria-hidden="true"></i>Cotação/Pedido/OS - <b>Duplicar</b></a>
                            <div class="dropdown-divider"></div>
                            <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalPedidoConverterMoeda(otableGCIndexPedido, 'Id.')"><i class="fa-solid fa-dollar-sign me-2" aria-hidden="true"></i>Cotação/Pedido/OS - <b>Converter Moeda</b></a>
                            <div class="dropdown-divider"></div>
                            <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsAjaxReportInvoicePDF(otableGCIndexPedido, 'Id.', 'pdf')"><i class="fa-regular fa-file-pdf me-2" aria-hidden="true"></i>Cotação/Pedido/OS - <b>PDF</b></a>
                            <div class="dropdown-divider"></div>
                            <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsAjaxReportInvoicePDF(otableGCIndexPedido, 'Id.', 'email')"><i class="fa-regular fa-envelope me-2" aria-hidden="true"></i>Cotação/Pedido/OS - <b>Enviar Email</b></a>
                            <div class="dropdown-divider"></div>
                            <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalPedidoAtualizarValorTotal(otableGCIndexPedido, 'Id.')"><i class="fa-solid fa-money-bill-trend-up me-2" aria-hidden="true"></i>Cotação/Pedido/OS - <b>Atualizar Valor Total</b></a>
                        </div>
                    </div>
                }
                @if ((CachePersister.userIdentity.Roles.Contains("gc_Movimentos_*")) || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_IndexPedido_Apontamentos_Button")))
                {
                    <div class="vr mx-1"></div>
                    <div class="btn-group" role="group">
                        <button id="btnGroupDrop2" type="button" class="btn btn-outline-secondary dropdown-toggle d-inline-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="Evolução dos Pedidos">
                            <i class="fa-solid fa-clipboard-check me-2" aria-hidden="true"></i>Apontamentos
                        </button>
                        <div class="dropdown-menu" role="menu" aria-labelledby="btnGroupDrop2">
                            @if ((CachePersister.userIdentity.Roles.Contains("gc_Movimentos_*")) || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_IndexPedido_Apontamentos_Aprovacao")))
                            {
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalPedidoAprovacao(otableGCIndexPedido, 'Id.')"><i class="fa-solid fa-clipboard-check fa-lg me-2" aria-hidden="true"></i><b>1</b> - Aprovação</a>
                            }

                            @if ((CachePersister.userIdentity.Roles.Contains("gc_Movimentos_*")) || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_IndexPedido_Apontamentos_Separacao")))
                            {
                                <div class="dropdown-divider"></div>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalPedidoSeparacao(otableGCIndexPedido, 'Id.')"><i class="fa-solid fa-dolly fa-lg me-2" aria-hidden="true"></i><b>2</b> - Separação</a>
                            }

                            @if ((CachePersister.userIdentity.Roles.Contains("gc_Movimentos_*")) || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_IndexPedido_Apontamentos_Expedicao")))
                            {
                                <div class="dropdown-divider"></div>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalPedidoExpedicao(otableGCIndexPedido, 'Id.')"><i class="fa-solid fa-truck fa-lg me-2" aria-hidden="true"></i><b>5</b> - Expedição</a>
                            }

                            @if ((CachePersister.userIdentity.Roles.Contains("gc_Movimentos_*")) || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_IndexPedido_Apontamentos_Entrega")))
                            {
                                <div class="dropdown-divider"></div>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalPedidoEntrega(otableGCIndexPedido, 'Id.')"><i class="fa-solid fa-people-carry fa-lg me-2" aria-hidden="true"></i><b>6</b> - Entrega</a>
                            }
                        </div>
                    </div>
                }
                @if ((CachePersister.userIdentity.Roles.Contains("gc_Movimentos_PainelPedidos_*"))
                    || (CachePersister.userIdentity.Roles.Contains("gc_FinanceiroLancamentos_*"))
                    || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_IndexPedido_FinanceiroNF_Create"))
                    || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_ReabrirMovimento"))
                    || (CachePersister.userIdentity.Roles.Contains("gc_FinanceiroLancamentos_CancelarMovimentoFinanceiro"))
                    || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_IndexPedido_FinanceiroNF_View"))
                    || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_AjustarComissao"))
                    )
                {
                    <div class="vr mx-1"></div>
                    <div class="btn-group" role="group">
                        <button id="btnGroupDrop2" type="button" class="btn btn-outline-secondary dropdown-toggle d-inline-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="Financeiro / NF">
                            <i class="fa-solid fa-file-invoice-dollar me-2" aria-hidden="true"></i>Financeiro / NF
                        </button>
                        <div class="dropdown-menu" role="menu" aria-labelledby="btnGroupDrop2">
                            @if ((CachePersister.userIdentity.Roles.Contains("gc_Movimentos_*")) || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_IndexPedido_FinanceiroNF_Create")))
                            {
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalGerarFinanceiroMovimentos(otableGCIndexPedido, 'Id.')"><i class="fa-regular fa-credit-card fa-lg me-2" aria-hidden="true"></i><b>3.1</b> - Financeiro - Gerar Lançamentos</a>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalViewFinanceiroMovimentos(otableGCIndexPedido, 'Id.')"><i class="fa-regular fa-folder fa-lg me-2" aria-hidden="true"></i><b>3.2</b> - Financeiro - Visualizar Lançamentos</a>
                                <div class="dropdown-divider"></div>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalPedidoNotaFiscal(otableGCIndexPedido, 'Id.')"><i class="fa-regular fa-file-alt fa-lg me-2" aria-hidden="true"></i><b>4.1</b> - Notas Fiscais - Gerar Nova</a>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalViewNotasFiscais(otableGCIndexPedido, 'Id.')"><i class="fa-regular fa-folder fa-lg me-2" aria-hidden="true"></i><b>4.2</b> - Notas Fiscais - Visualizar</a>
                                <div class="dropdown-divider"></div>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalPedidoCartaCorrecao(otableGCIndexPedido, 'Id.')"><i class="fa-solid fa-eraser fa-lg me-2" aria-hidden="true"></i><b>4.3</b> - Carta de Correção - Gerar Nova</a>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalViewCartaCorrecaoNF(otableGCIndexPedido, 'Id.')"><i class="fa-regular fa-folder fa-lg me-2" aria-hidden="true"></i><b>4.4</b> - Carta de Correção - Visualizar</a>
                                <div class="dropdown-divider"></div>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalNotificacaoCliente(otableGCIndexPedido, 'Id.')"><i class="fa-regular fa-paper-plane me-2" aria-hidden="true"></i><b>4.5</b> - Notificar Cliente</a>
                            }
                            else if ((CachePersister.userIdentity.Roles.Contains("gc_Movimentos_*")) || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_IndexPedido_FinanceiroNF_View")))
                            {
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalViewFinanceiroMovimentos(otableGCIndexPedido, 'Id.')"><i class="fa-regular fa-folder fa-lg me-2" aria-hidden="true"></i><b>3.2</b> - Financeiro - Visualizar Lançamentos</a>
                                <div class="dropdown-divider"></div>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalViewNotasFiscais(otableGCIndexPedido, 'Id.')"><i class="fa-regular fa-folder fa-lg me-2" aria-hidden="true"></i><b>4.2</b> - Notas Fiscais - Visualizar</a>
                                <div class="dropdown-divider"></div>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalViewCartaCorrecaoNF(otableGCIndexPedido, 'Id.')"><i class="fa-regular fa-folder fa-lg me-2" aria-hidden="true"></i><b>4.4</b> - Carta de Correção - Visualizar</a>
                            }
                            @if ((CachePersister.userIdentity.Roles.Contains("gc_FinanceiroLancamentos_*")) || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_ReabrirMovimento")))
                            {
                                <div class="dropdown-divider"></div>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalReabrirMovimento(otableGCIndexPedido, 'Id.')"><i class="fa-solid fa-building-lock me-2" aria-hidden="true"></i><b class="text-accent-menu">9.1 - Reabrir Cotação/Pedido/OS</b></a>
                            }
                            @if ((CachePersister.userIdentity.Roles.Contains("gc_FinanceiroLancamentos_*")) || (CachePersister.userIdentity.Roles.Contains("gc_FinanceiroLancamentos_CancelarMovimentoFinanceiro")))
                            {
                                <div class="dropdown-divider"></div>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalCancelarMovimentoFinanceiro(otableGCIndexPedido, 'Id.')"><i class="fa-solid fa-building-lock me-2" aria-hidden="true"></i><b class="text-accent-menu">9.2 - Cancelar Financeiro</b></a>
                            }
                            @if ((CachePersister.userIdentity.Roles.Contains("gc_FinanceiroLancamentos_*")) || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_CancelarPedido")))
                            {
                                <div class="dropdown-divider"></div>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalCancelarPedido(otableGCIndexPedido, 'Id.')"><i class="fa-solid fa-building-lock me-2" aria-hidden="true"></i><b class="text-accent-menu">9.3 - Cancelar Pedido</b></a>
                            }
                            @if ((CachePersister.userIdentity.Roles.Contains("gc_FinanceiroLancamentos_*")) || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_*")) || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_AjustarComissao")))
                            {
                                <div class="dropdown-divider"></div>
                                <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalPedidoAjustarComissao(otableGCIndexPedido, 'Id.')"><i class="fa-solid fa-building-lock me-2" aria-hidden="true"></i><b class="text-accent-menu">9.4 - Ajustes da Comissão</b></a>
                            }
                        </div>
                    </div>
                }
                @if ((CachePersister.userIdentity.Roles.Contains("gc_Movimentos_*")) || (CachePersister.userIdentity.Roles.Contains("gc_Movimentos_IndexPedido_RelatorioPedidos")))
                {
                    <div class="vr mx-1"></div>
                    <div class="btn-group" role="group">
                        <button id="btnGroupDrop3" type="button" class="btn btn-outline-info dropdown-toggle d-inline-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="Informações">
                            <i class="fa-solid fa-chart-area me-2" aria-hidden="true"></i>Informações
                        </button>
                        <div class="dropdown-menu" role="menu" aria-labelledby="btnGroupDrop3">
                            <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalConsultaPedidos()"><i class="fa-solid fa-chart-column me-2" aria-hidden="true"></i>Consulta de Pedidos</a>
                        </div>
                    </div>
                }
            </div>
            <div class="card-body m-0 p-1 min-w-0" style="height: 100%">
                <div class="form-horizontal m-0 p-0 min-w-0">
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("N", "Id/NFe", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-2">
                            @Html.Editor("edit_numero_cotacao", "edit_numero_cotacao", new { htmlAttributes = new { @class = "form-control", @onkeypress = "keypressed(event);", type = "text" } })
                        </div>
                        <div class="col-sm-3">
                            @* id do .input-group distinto do input (Editor) para Tempus Dominus *@
                            <div class='input-group date' id='ig_gc_pedido_idx_d1'>
                                @Html.Editor("edit_data1", "edit_data1", new { htmlAttributes = new { @class = "form-control", type = "text" } })
                                <span class="input-group-text"><i class="fa-regular fa-calendar-alt"></i></span>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class='input-group date' id='ig_gc_pedido_idx_d2'>
                                @Html.Editor("edit_data2", "edit_data2", new { htmlAttributes = new { @class = "form-control", type = "text" } })
                                <span class="input-group-text"><i class="fa-regular fa-calendar-alt"></i></span>
                            </div>
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Cliente", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-8 min-w-0">
                            @Html.DropDownList("Cliente", ViewBag.comboClientes as List<SelectListItem>, htmlAttributes: new { @id = "edit_cliente", @onchange = "jsAjaxPesquisarMovimentos();", @class = "form-control" })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Posição", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-2">
                            @Html.DropDownList("Posicao", ViewBag.comboMovimentosPosicao as List<SelectListItem>, htmlAttributes: new { @id = "edit_posicao", @onchange = "jsAjaxPesquisarMovimentos();", @class = "form-control" })
                        </div>
                        @Html.Label("Status", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-2">
                            @Html.DropDownList("Status", ViewBag.comboStatusMovimentos as List<SelectListItem>, htmlAttributes: new { @id = "edit_status", @onchange = "jsAjaxPesquisarMovimentos();", @class = "form-control" })
                        </div>
                        @Html.Label("R$ Valor", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                        <div class="col-sm-2">
                            @Html.Editor("edit_valor", "edit_valor", new { htmlAttributes = new { @class = "form-control", @onkeypress = "keypressed(event);", type = "text" } })
                        </div>
                        <div class="col-sm-3 text-sm-start" style="margin-bottom:2px">
                            <button type="button" id="btnPesquisar" name="btnPesquisar" title="Pesquisar Pedidos" class="btn btn-secondary d-inline-flex align-items-center gap-2" onclick="jsAjaxPesquisarMovimentos()"><i class="fa-solid fa-search me-2" aria-hidden="true"></i>Pesquisar</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body m-0 p-1 gdi-dt-scroll-host min-w-0 gdi-index-pedido-dt">
                <div class="table-responsive scroll-body-horizontal" style="width:100%">
                    <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dataTableGCIndexPedido">
                        <thead>
                            <tr>
                                <th>[x]</th>
                                <th>@Html.Encode("Id.")</th>
                                <th><i class="fa-solid fa-boxes" style="cursor: pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Tipo (Cotação/Pedido/OS)"></i></th>
                                <th><i class="fa-solid fa-lock-open" style="cursor: pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Status (Aberto/Fechado)"></i></th>
                                <th><i class="fa-solid fa-bolt" style="cursor: pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Operação"></i></th>
                                <th><i class="fa-solid fa-map-pin" style="cursor: pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Posição"></i></th>
                                <th>Cliente/Operação</th>
                                <th>@Html.Encode("Consultor")</th>
                                <th>@Html.Encode("Data")</th>
                                <th><i class="fa-regular fa-calendar-alt" style="cursor: pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Status Prazos"></i></th>
                                <th><i class="fa-solid fa-cart-plus" style="cursor: pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Itens"></i></th>
                                <th><i class="fa-solid fa-warehouse" style="cursor: pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Estoque"></i></th>
                                <th>@Html.Encode("Valor")</th>
                                <th><i class="fa-solid fa-paperclip" style="cursor: pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Anexos"></i></th>
                                <th><i class="fa-regular fa-edit" style="cursor: pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Editar Cotação/Pedido/OS"></i></th>
                            </tr>
                        </thead>
                        <tfoot align="right">
                            <tr>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                            </tr>
                        </tfoot>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

    var otableGCIndexPedido;

    $(function ()
    {
        try
        {
            jsInitForm();
            jsDatepickerFirstDayMonth('#ig_gc_pedido_idx_d1');
            jsDatepickerToday('#ig_gc_pedido_idx_d2');
            jsCreateOtableGCIndexPedido();
            gdiAplicarFoco('#edit_numero_cotacao', true);
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function keypressed(e)
    {
        if (e.keyCode == 13)
        {
            e.preventDefault();
            jsAjaxPesquisarMovimentos()
        }
    }

    function jsCreateOtableGCIndexPedido() {
        try {
            $.fn.dataTable.ext.errMode = 'none';

            otableGCIndexPedido = $('#dataTableGCIndexPedido')
                .on('error.dt', function (e, settings, techNote, message) {
                    GdiDtNotifyLoadFailure(message);
                })
                .on('xhr.dt', function (e, settings, json, xhr) {
                    if (GdiDtNotifyJsonErrorMessage(json)) { return; }
                })
                .DataTable({
                    "drawCallback": function (settings) {
                        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function(el){bootstrap.Tooltip.getOrCreateInstance(el);});
                        try { new $.fn.dataTable.Api(settings).columns.adjust(); } catch (e) { }
                    },
                    "footerCallback": function (row, data, start, end, display) {
                        LibMessageProcessandoHide();
                        gdiAplicarFoco('#edit_numero_cotacao', true);
                    },

                    processing: true,
                    bServerSide: true,
                    ajax: {
                        url: '@Url.Action("GetDadosPedidos","Movimentos",new { Area = "gc" })',
                        type: 'POST',
                        contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                        dataType: 'json',
                        cache: false,
                        data: function (d) {
                            return {
                                sEcho: d.draw,
                                iDisplayStart: d.start,
                                iDisplayLength: d.length,
                                yesFilterField: $('#yesFilterField').val().toString(),
                                yesCustomField01: emptyIfNull($('#edit_numero_cotacao').val()).toString(),
                                yesCustomField02: jsGetDateDDMMYYYY(jsDatepickerGetDate('#ig_gc_pedido_idx_d1')),
                                yesCustomField03: jsGetDateDDMMYYYY(jsDatepickerGetDate('#ig_gc_pedido_idx_d2')),
                                yesCustomField04: emptyIfNull($('#edit_cliente').val()).toString(),
                                yesCustomField05: emptyIfNull($('#edit_posicao').val()).toString(),
                                yesCustomField06: emptyIfNull($('#edit_valor').val()).toString(),
                                yesCustomField07: emptyIfNull($('#edit_status').val()).toString(),
                                yesFilterController: $('#yesFilterController').val().toString(),
                            };
                        },
                        error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
                    },

                    responsive: true,
                    bFilter: false,
                    bLengthChange: false,
                    bProcessing: true,
                    pageLength: 20,
                    scrollX: false,
                    scrollCollapse: false,
                    fixedColumns: false,
                    bAutoWidth: false,
                    pagingType: 'full_numbers',

                    aoColumnDefs: [
                        { "width": "3%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                        { "width": "4%", orderable: false, className: 'text-sm-center', targets: [1] },
