<script type="text/javascript">

    var oTableGcMovimentosCreatePedido;
    var otableGcMovimentosAudit;
    var otableGcMovimentosTarefas;
    var otableGcMovimentosGed;

    $(function ()
    {
        try
        {
            jsInitForm();
            jsDatepicker('#ig_gc_mov_form_ped_create_venc');
            jsDatepicker('#ig_gc_mov_form_ped_create_contato');
            $('#cotacao_dolar_oficial_venda').attr('readonly', 'readonly');
            jsSetDadosCliente();
            jsCreateTableGcMovimentos();
            jsSetCamposReadOnly(1);
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
            if ('@Model.movimento_nf'.toLowerCase() == 'true')
            {
                LibMessageAlert("<b>Atenção</b>", "Prezado usuário,<br/>Os dados desse movimento <b>NÃO</b> poderão ser alterados,<br/>Existem Notas Fiscais relacionadas!");
            }
            else if ((@Model.id_movimento_status > 1) || (@Model.id_movimento_posicao > 0))
            {
                LibMessageAlert("<b>Atenção</b>", "Prezado usuário,<br/>Esse Pedido encontra-se <b>BLOQUEADO</b> para alterações!");
            }
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });


    function jsSetCamposReadOnly(disable)
    {
        try
        {
            if (disable == 1)
            {
                if (@Model.id_movimento > 0)
                {
                    $('#id_moeda').attr('disabled', true);
                }
            }
            else
            {
                $('#id_moeda').attr('disabled', false);
            }
        }
        catch (err)
        {
            LibMessageProcessandoHide();
            LibMessageError("Atenção", "[jsSetCampos] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsSetDadosCliente()
    {
        try
        {
            $("#id_cliente_destinatario").empty();
            if ($("#id_cliente").val() > 0)
            {
                var dataForm =
                {
                    view_g_clientes:
                    {
                        'id_cliente': $("#id_cliente").val(),
                    }
                };
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("AjaxDadosClientesDestinatarios", "Movimentos", new { area = "gc" })',
                    contentType: "application/json; charset=utf-8",
                    data: JSON.stringify(dataForm),
                    dataType: "json",
                    success: function (result)
                    {
                        if (result.success == true)
                        {
                            var array = result.dataSetClientesDestinatarios;

                            if (array.length > 0)
                            {
                                for (var i = 0; i < array.length; i++)
                                {
                                    if ((@Model.id_cliente_destinatario > 0) && (@Model.id_cliente_destinatario == array[i].id_cliente_destinatario)) {
                                        $("#id_cliente_destinatario").append('<option value="' + array[i].id_cliente_destinatario + '" selected>' + "[ " + array[i].nome + " ]" + '</option>');
                                    }
                                    else {
                                        $("#id_cliente_destinatario").append('<option value="' + array[i].id_cliente_destinatario + '">' + "[ " + array[i].nome + " ]" + '</option>');
                                    }
                                }
                                $("#id_cliente_destinatario ").val(@Model.id_cliente_destinatario).change();
                            }
                            else
                            {
                                $("#id_cliente_destinatario").empty();
                            }
                        }
                        else
                        {
                            $("#id_cliente_destinatario").empty();
                        }

                    },
                    error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown || textStatus || '', { hideProcessando: false }); }
                });
            }
        }
        catch (err)
        {
            LibMessageError("Atenção", err != null ? String(err) : "");
        }
    }


    function jsCreateTableGcMovimentos()
    {
        try
        {
            if (oTableGcMovimentosCreatePedido == null)
