@model GdiPlataform.Db.gc_movimentos
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "FormGcMovimentosCreatePedido" }))
{
    <div class="row">
        <div class="col-lg-12 m-0 p-1">
            <div class="card m-0 p-0">
                <div class="card-title m-0 p-1">
                    <h5>@Html.Raw(@ViewBag.Title)</h5>
                    <input type="hidden" id="yesTipoSolicitacao" value="" name="yesTipoSolicitacao" />
                    @Html.HiddenFor(model => model.id_movimento)
                    @Html.HiddenFor(model => model.notifica_contatos_ids)
                    @Html.HiddenFor(model => model.id_contato)
                    @Html.HiddenFor(model => model.notifica_contatos_emails)
                    @Html.HiddenFor(model => model.id_coligada)
                    @Html.HiddenFor(model => model.id_filial)
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)
                </div>
                <div class="card-body m-0 p-0" style="height: 100%">
                    <div class="form-horizontal m-0 p-0">
                        @Html.Partial("_AlertMsg", AlertMsgItem.Maybe(ViewBag.MsgInfo as string, (ViewBag.MsgTipo as string) ?? "danger"))
                        <div class="card-header m-0 p-1">
                            <ul class="nav nav-tabs" id="pedidos-tabs" role="tablist">
                                <li class="nav-item"><a class="d-flex align-items-center nav-link active" id="tabDados_tab" data-bs-toggle="pill" href="#tabDados" role="tab" aria-controls="pedidos-tabs" aria-selected="true"><i class="fa-solid fa-clipboard-check fa-lg me-2" aria-hidden="true"></i>Cotação/Pedido</a></li>
                                <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabFrete_tab" data-bs-toggle="pill" href="#tabFrete" role="tab" aria-controls="pedidos-tabs" aria-selected="false"><i class="fa-solid fa-truck fa-lg me-2" aria-hidden="true"></i>Frete</a></li>
                                <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabDadosComplementares_tab" data-bs-toggle="pill" href="#tabDadosComplementares" role="tab" aria-controls="pedidos-tabs" aria-selected="false"><i class="fa-solid fa-folder-plus me-2" aria-hidden="true"></i>Complemento</a></li>
                                <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabFornecedorCotacao_tab" data-bs-toggle="pill" href="#tabFornecedorCotacao" role="tab" aria-controls="pedidos-tabs" aria-selected="false"><i class="fa-solid fa-boxes-packing me-2" aria-hidden="true"></i>Fornecedor</a></li>
                                <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabInvoice_tab" data-bs-toggle="pill" href="#tabInvoice" role="tab" aria-controls="pedidos-tabs" aria-selected="false"><i class="fa-solid fa-file-invoice-dollar me-2" aria-hidden="true"></i>Invoice/SO</a></li>
                                @if (@Model.id_movimento > 0)
                                {
                                    <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabGED_tab" data-bs-toggle="pill" href="#tabGED" role="tab" aria-controls="crud-tabs" aria-selected="false"><i class="fa-solid fa-paperclip fa-lg me-2" aria-hidden="true"></i>Anexos</a></li>
                                    if (@Model.id_movimento_posicao >= 6)
                                    {
                                        <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabPosVenda_tab" data-bs-toggle="pill" href="#tabPosVenda" role="tab" aria-controls="custom-tabs-one-settings" aria-selected="false"><i class="fa-solid fa-medal me-2" aria-hidden="true"></i>Pós-Venda</a></li>
                                    }
                                    <li class="nav-item"><a class="d-flex align-items-center nav-link" id="tabAudit_tab" data-bs-toggle="pill" href="#tabAudit" role="tab" aria-controls="custom-tabs-one-settings" aria-selected="false"><i class="fa-solid fa-magnifying-glass-arrow-right me-2" aria-hidden="true"></i>Audit</a></li>
                                }
                            </ul>
                        </div>
                        <div class="tab-content" id="pedidos-tabs-content">

                            <!-- Dados - Início -->
                            <div class="tab-pane fade show active" id="tabDados" role="tabpanel" aria-labelledby="tabDados_tab">
                                <div class="card-body m-0 p-0" style="height: 100%">
                                    <div class="card shadow-sm gdi-section-accent-secondary m-1 p-0">
                                        <div class="section-header"><i class="fa-solid fa-file-pen me-1" aria-hidden="true"></i>Dados da Cotação/Pedido</div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("Tipo", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.DropDownList("id_movimento_tipo", ViewBag.comboTiposMovimentosCreateEdit as List<SelectListItem>, htmlAttributes: new { @id = "id_movimento_tipo", @class = "form-control", @title = "Cotação/Pedido/OS" })
                                            </div>
                                            @Html.Label("Vendedor", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.DropDownList("id_vendedor", ViewBag.comboVendedores as List<SelectListItem>, htmlAttributes: new { @id = "id_vendedor", @class = "form-control", @title = "Vendedor" })
                                            </div>
                                            @Html.Label("Finalidade", "Finalidade", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.DropDownList("id_cfop_finalidade", ViewBag.comboCfopFinalidade as List<SelectListItem>, htmlAttributes: new { @id = "id_cfop_finalidade", @class = "form-control", @title = "Finalidade" })
                                            </div>
                                            @Html.Label("Estoque", "Estoque", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.DropDownList("id_local_estoque", ViewBag.comboLocaisEstoqueOrders as List<SelectListItem>, htmlAttributes: new { @id = "id_local_estoque", @class = "form-control", @title = "Estoque" })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("Data Venc", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @* id do .input-group distinto do input (data_vencimento) para Tempus Dominus *@
                                                <div class='input-group date' id='ig_gc_mov_form_ped_create_venc'>
                                                    @Html.EditorFor(model => model.data_vencimento, new { htmlAttributes = new { @class = "form-control", type = "text", @title = "Data de Vencimento" } })
                                                    <span class="input-group-text"><i class="fa-regular fa-calendar-alt"></i></span>
                                                </div>
                                            </div>
                                            @Html.Label("Moeda", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.DropDownList("id_moeda", ViewBag.comboMoedas as List<SelectListItem>, htmlAttributes: new { @id = "id_moeda", @class = "form-control" })
                                            </div>
                                            @Html.Label("cotacao_dolar_venda", "US$. Pedido", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.cotacao_dolar_venda, new { htmlAttributes = new { @class = "form-control", @title = "Cotação Dolar do Pedido", @placeholder = "Cotação Dolar do Pedido" } })
                                            </div>
                                            @Html.Label("cotacao_dolar_oficial_venda", "US$. Oficial", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.cotacao_dolar_oficial_venda, new { htmlAttributes = new { @class = "form-control", @title = "Cotação Dolar Dia", @placeholder = "Cotação Dolar Dia" } })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("PagrecCondicao", "Pagto.", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.DropDownList("id_pagrec_condicao", ViewBag.comboPagRecCondicoes as List<SelectListItem>, htmlAttributes: new { @id = "id_pagrec_condicao", @class = "form-control" })
                                            </div>
                                            @Html.Label("valor_total_adiantamento", "Adiant. (R$)", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.valor_total_adiantamento, new { htmlAttributes = new { @class = "form-control", @title = "Valor do Adiantamento" } })
                                            </div>
                                            @Html.Label("id_cfop_operacao", "Operação", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-5">
                                                @Html.DropDownList("id_cfop_operacao", ViewBag.comboGcCfopOperacao as List<SelectListItem>, htmlAttributes: new { @id = "id_cfop_operacao", @class = "form-control" })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("Cliente", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-6">
                                                @Html.DropDownList("id_cliente", ViewBag.comboClientes as List<SelectListItem>, htmlAttributes: new { @id = "id_cliente", @class = "form-control", @onfocus = "jsSetDadosCliente();", @onchange = "jsSetDadosCliente();", @onblur = "jsSetDadosCliente();" })
                                            </div>
                                            <div class="col-sm-2 mt-1 text-sm-start">
                                                <div class="form-check form-switch form-switch-lg">
                                                    @Html.CheckBoxFor(model => model.has_beneficio_aviacao, htmlAttributes: new { @class = "form-check-input switch-success", @id = "has_beneficio_aviacao", role = "switch" })
                                                    <label class="form-check-label" for="has_beneficio_aviacao" id="label_has_beneficio_aviacao">Benefício Aviação</label>
                                                </div>
                                            </div>
                                            @Html.Label("prefixo", "Prefixo", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.aeronave_prefixo, new { htmlAttributes = new { @class = "form-control", @title = "Prefixo da Aeronave", @placeholder = "Prefixo da Aeronave" } })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("id_cliente_destinatario", "Destinatário", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-6">
                                                @Html.DropDownList("id_cliente_destinatario", ViewBag.comboClienteDestinatarios as List<SelectListItem>, htmlAttributes: new { @id = "id_cliente_destinatario", @class = "form-control" })
                                            </div>
                                            <div class="col-sm-2">
                                                &nbsp;
                                            </div>
                                            @Html.Label("OC", "O.C.", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.oc_numero, new { htmlAttributes = new { @class = "form-control", @title = "Nº da Ordem de Compra", @placeholder = "Nº da Ordem de Compra" } })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("obs", "Obs. Cotação", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-5">
                                                @Html.TextAreaFor(model => model.obs, new { @class = "form-control", @id = "obs", @rows = "2", @title = "Informações adicionais (internas)", @placeholder = "Informações adicionais (internas)" })
                                            </div>
                                            @Html.Label("informacoes_complementares_nf", "Obs. NF", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-5">
                                                @Html.TextAreaFor(model => model.informacoes_complementares_nf, new { @class = "form-control", @id = "informacoes_complementares_nf", @rows = "2", @title = "Informações complementares para a nota fiscal", @placeholder = "Informações complementares para a nota fiscal" })
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card-body m-0 p-0" style="height: 100%">
                                    <div class="card-body m-0 p-0" style="max-width: 100%; overflow-x: auto; ">
                                        <div class="card shadow-sm gdi-section-accent-secondary m-1 p-0">
                                            <div class="section-header"><i class="fa-solid fa-file-pen me-1" aria-hidden="true"></i>Itens da Cotação/Pedido</div>
                                            <div class="table-responsive scroll-body-horizontal" style="width:100%">
                                                <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dtGcMovimentosCreatePedido">
                                                    <thead>
                                                        <tr>
                                                            <th align="center" vertical-align="middle">[x]</th>
                                                            <th>@Html.DisplayName("Id")</th>
                                                            <th>@Html.DisplayName("Nº")</th>
                                                            <th>@Html.DisplayName("Qtd")</th>
                                                            <th>@Html.DisplayName("Produto")</th>
                                                            <th>@Html.DisplayName("Unit")</th>
                                                            <th>@Html.DisplayName("Total")</th>
                                                            <th><i class="fa-solid fa-copy"></i></th>
                                                            <th><i class="fa-regular fa-edit"></i></th>
                                                            <th><i class="fa fa-trash"></i></th>
                                                        </tr>
                                                    </thead>
                                                    <tfoot align="right">
                                                        <tr>
                                                            <th align="right" colspan="6"></th>
                                                            <th align="right">@Html.Label("label_total_pedido", "R$", htmlAttributes: new { @id = "label_total_pedido" })</th>
                                                            <th align="right" colspan="3"></th>
                                                        </tr>
                                                    </tfoot>
                                                    <tbody></tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card-body text-sm-center m-1 p-0">
                                        <div class="row justify-content-center">
                                            <div class="col-4">

                                                @if ((Model.id_movimento_posicao == 0) && (@Model.movimento_nf == false) && (Model.id_movimento == 0))
                                                {
                                                    <div class="btn-group" role="group">
                                                        <button id="btnGroupDrop1" type="button" class="btn btn-outline-secondary dropdown-toggle d-inline-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="Carregar">
                                                            <i class="fa-solid fa-file-import me-2" aria-hidden="true"></i>Carregar
                                                        </button>
                                                        <div class="dropdown-menu" aria-labelledby="btnGroupDrop1">
                                                            <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalSelecionarItensImportacao()"><i class="fa-solid fa-passport me-2" aria-hidden="true"></i>Adicionar Itens Importação</a>
                                                            <div class="dropdown-divider"></div>
                                                            <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalImportarExcelSC()"><i class="fa-regular fa-file-excel me-2" aria-hidden="true"></i>Importar Excel - Southern Cross</a>
                                                            <div class="dropdown-divider"></div>
                                                            <a class="d-flex align-items-center dropdown-item" href="#" onclick="jsModalImportarTxtSC()"><i class="fa-regular fa-file-excel me-2" aria-hidden="true"></i>Importar Lista Itens</a>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                            <div class="col-4">
                                                @if ((Model.id_movimento_posicao == 0) && (@Model.movimento_nf == false))
                                                {
                                                    <button type="button" name="btnInserirItem" title="Inserir Itens" onclick="jsModalInserirItem()" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2"><i class="fa fa-plus me-2" aria-hidden="true"></i>Inserir Itens</button>
                                                }
                                            </div>
                                            <div class="col-4">

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Dados - Fim -->
                            <!-- Aba Frete - Início -->
                            <div class="tab-pane fade" id="tabFrete" role="tabpanel" aria-labelledby="tabFrete_tab">
                                <div class="card-body m-0 p-0" style="height: 100%">
                                    <div class="card shadow-sm gdi-section-accent-secondary m-1 p-0">
                                        <div class="section-header"><i class="fa-solid fa-truck me-1" aria-hidden="true"></i>Frete Principal</div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("frete_valor", "Destacado (R$)", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.frete_valor, new { htmlAttributes = new { @class = "form-control", @title = "Valor do Frete" } })
                                            </div>
                                            @Html.Label("frete_gerencial", "Gerencial (R$)", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.frete_gerencial, new { htmlAttributes = new { @class = "form-control", @title = "Valor do Frete Gerencial" } })
                                            </div>
                                            @Html.Label("frete1_custo", "Custo (R$)", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.frete1_custo, new { htmlAttributes = new { @class = "form-control", @title = "Valor do Frete" } })
                                            </div>
                                            @Html.Label("id_frete_responsavel", "Resp.", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.DropDownListFor(model => model.id_frete_responsavel, ViewBag.comboFreteResponsavel as List<SelectListItem>, new { @class = "form-control" })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("frete1_transportadora", "Transp.", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-5">
                                                @Html.DropDownList("frete1_transportadora", ViewBag.comboTransportadora as List<SelectListItem>, htmlAttributes: new { @id = "id_transportadora", @class = "form-control", @title = "Transportadora" })
                                            </div>
                                            @Html.Label("frete1_documento", "Nº Cotação", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.frete1_documento, new { htmlAttributes = new { @class = "form-control", @title = "Nº Cotação", @placeholder = "Nº Cotação" } })
                                            </div>
                                            @Html.Label("frete1_rastreio", "Nº Rastreio", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.frete1_rastreio, new { htmlAttributes = new { @class = "form-control", @title = "Nº Rastreio", @placeholder = "Nº Rastreio" } })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("frete_observacoes", "Observações", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-5">
                                                @Html.TextAreaFor(model => model.frete_observacoes, new { @class = "form-control", @id = "frete_observacoes", @rows = "2", @title = "Informações/Justificativas referente ao Frete", @placeholder = "Informações/Justificativas referente ao Frete" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card shadow-sm gdi-section-accent-secondary m-1 p-0">
                                        <div class="section-header"><i class="fa-solid fa-truck me-1" aria-hidden="true"></i>Frete Complementar</div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("frete2_transportadora", "Transp.", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-5">
                                                @Html.DropDownList("frete2_transportadora", ViewBag.comboTransportadoraComplementar as List<SelectListItem>, htmlAttributes: new { @id = "frete2_transportadora", @class = "form-control", @title = "Transportadora Complementar" })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                            @Html.Label("frete2_custo", "Custo (R$)", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.frete2_custo, new { htmlAttributes = new { @class = "form-control", @title = "Valor do Frete" } })
                                            </div>
                                            @Html.Label("frete2_documento", "Nº Cotação", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.frete2_documento, new { htmlAttributes = new { @class = "form-control", @title = "Nº Cotação", @placeholder = "Nº Cotação Complementar" } })
                                            </div>
                                            @Html.Label("frete2_rastreio", "Nº Rastreio", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.frete2_rastreio, new { htmlAttributes = new { @class = "form-control", @title = "Nº Rastreio", @placeholder = "Nº Rastreio Complementar" } })
                                            </div>
                                        </div>
                                        <div class="form-group row text-sm-end m-0 pt-1">
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Aba Frete - Fim -->
                            <!-- Aba Dados Complementares - Início -->
                            <div class="tab-pane fade" id="tabDadosComplementares" role="tabpanel" aria-labelledby="tabDadosComplementares_tab">
                                <div class="card-body m-0 p-0" style="height: 100%">

                                    <div class="card shadow-sm gdi-section-accent-secondary m-1 p-0">
                                        <div class="section-header mb-2"><i class="fa-solid fa-note-sticky me-1" aria-hidden="true"></i>Negociação Específica (Observações)</div>
                                        <div class="form-group row text-sm-end m-1 p-0 mb-2">
                                            @Html.Label("obs_negociacao", "Obs", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-10">
                                                @Html.TextAreaFor(model => model.obs_negociacao, new { @class = "form-control", @id = "obs_negociacao", @rows = "5", @title = "Negociação Específica (Observações)", @placeholder = "Negociação Específica (Observações)" })
                                            </div>
                                        </div>
                                    </div>

                                    <div class="card shadow-sm gdi-section-accent-secondary m-1 p-0">
                                        <div class="section-header mb-2"><i class="fa-solid fa-file-pen me-1" aria-hidden="true"></i>Dados Aeronave / ANAC</div>
                                        <div class="form-group row text-sm-end m-1 p-0 mb-2">
                                            @Html.Label("aeronave_modelo", "Modelo", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.aeronave_modelo, new { htmlAttributes = new { @class = "form-control", @title = "Modelo Aeronave" } })
                                            </div>
                                            @Html.Label("aeronave_serie", "Série", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                            <div class="col-sm-2">
                                                @Html.EditorFor(model => model.aeronave_serie, new { htmlAttributes = new { @class = "form-control", @title = "Série da Aeronave" } })
