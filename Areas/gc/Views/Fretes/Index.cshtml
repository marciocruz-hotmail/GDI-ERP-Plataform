@model IEnumerable<GdiPlataform.Db.gc_movimentos>
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5 style="margin: 5px; margin-top: 5px;">@Html.Raw(ViewBag.Title)</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterController" value="IndexFrete" name="yesFilterController" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-header m-0 p-1 bg-body-secondary">
            </div>
            <div class="card-body m-0 p-1" style="height: 100%">
                <div class="form-horizontal m-0 p-0">
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("N", "Id/*NF", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-2">
                            @Html.Editor("edit_numero_cotacao", "edit_numero_cotacao", new { htmlAttributes = new { @class = "form-control", @onkeypress = "keypressed(event);", type = "text" } })
                        </div>
                        <div class="col-sm-3">
                            @* id do .input-group distinto do input (Editor) para Tempus Dominus *@
                            <div class='input-group date' id='ig_gc_fretes_idx_d1'>
                                @Html.Editor("edit_data1", "edit_data1", new { htmlAttributes = new { @class = "form-control", type = "text" } })
                                <span class="input-group-text"><i class="fa-regular fa-calendar-alt"></i></span>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class='input-group date' id='ig_gc_fretes_idx_d2'>
                                @Html.Editor("edit_data2", "edit_data2", new { htmlAttributes = new { @class = "form-control", type = "text" } })
                                <span class="input-group-text"><i class="fa-regular fa-calendar-alt"></i></span>
                            </div>
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Transportadora", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-8">
                            @Html.DropDownList("Transportadora", ViewBag.comboTransportadora as List<SelectListItem>, htmlAttributes: new { @id = "edit_transportadora", @onchange = "jsAjaxPesquisarMovimentos();", @class = "form-control" })
                        </div>
                    </div>
                    <div class="form-group row text-sm-end m-0 pt-1">
                        @Html.Label("Posição", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-2">

                        </div>
                        @Html.Label("Status", htmlAttributes: new { @class = "col-form-label col-sm-1" })
                        <div class="col-sm-2">

                        </div>
                        @Html.Label("R$ Valor", htmlAttributes: new { @class = "col-sm-1 col-form-label" })
                        <div class="col-sm-2">
                            @Html.Editor("edit_valor", "edit_valor", new { htmlAttributes = new { @class = "form-control", @onkeypress = "keypressed(event);", type = "text" } })
                        </div>
                        <div class="col-sm-3 text-sm-start" style="margin-bottom:2px">
                            <button type="button" id="btnPesquisar" name="btnPesquisar" title="Pesquisar Pedidos" class="btn btn-secondary d-inline-flex align-items-center gap-2" onclick="jsAjaxPesquisarMovimentos()"><i class="fa-solid fa-search me-2" aria-hidden="true"></i>Pesquisar</button>
                            <button type="button" id="btnLimparFiltroFretes" name="btnLimparFiltroFretes" title="Limpar filtro e restaurar padrão" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2 ms-1" onclick="jsLimparFiltroFretes()"><i class="fa-solid fa-magnifying-glass-minus me-2" aria-hidden="true"></i>Limpar</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body m-0 p-1" style="max-width: 100%; overflow-x: auto;">
                <div class="table-responsive scroll-body-horizontal" style="width:100%">
                        <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dtGcFretes">
                        <thead>
                            <tr>
                                <th>[x]</th>
                                <th>@Html.Encode("Id.")</th>
                                <th>@Html.Encode("NF")</th>
                                <th>@Html.Encode("Cli/For")</th>
                                <th>@Html.Encode("Transportadora")</th>
                                <th>@Html.Encode("Rastreio")</th>
                                <th>@Html.Encode("Data")</th>
                                <th><i class="fa-regular fa-edit" style="cursor: pointer" data-bs-toggle="tooltip" data-bs-placement="top" title="Editar Cotação/Pedido/OS"></i></th>
                            </tr>
                        </thead>
                        <tfoot align="right">
                            <tr>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                            </tr>
                        </tfoot>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

    var otableGCFretes;
    var _gcFretesSuprimirPesquisaAuto = false;

    $(function ()
    {
        try
        {
            jsInitForm();
            jsDatepickerFirstDayMonth('#ig_gc_fretes_idx_d1');
            jsDatepickerToday('#ig_gc_fretes_idx_d2');
            jsCreateTableGcFretes();
            jsAtualizarIndicadorFiltroFretes('0');
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function keypressed(e)
    {
        if (e.keyCode == 13)
        {
            e.preventDefault();
            jsAjaxPesquisarMovimentos()
        }
    }

    function jsCreateTableGcFretes()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            otableGCFretes = $('#dtGcFretes').on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); }).on('xhr.dt', function (e, settings, json, xhr) {
                if (GdiDtNotifyJsonErrorMessage(json)) { return; }
                if (json && json.yesFilterOnOff !== undefined) {
                    jsAtualizarIndicadorFiltroFretes(json.yesFilterOnOff);
                }
            }).DataTable({
                drawCallback: function (settings) {
                    document.querySelectorAll('#dtGcFretes [data-bs-toggle="tooltip"]').forEach(function (el) {
                        bootstrap.Tooltip.getOrCreateInstance(el);
                    });
                    LibMessageProcessandoHide();
                    gdiAplicarFoco('#edit_numero_cotacao', true);
                    try { new $.fn.dataTable.Api(settings).columns.adjust(); } catch (e) { }
                },
                processing: true,
                bServerSide: true,
                ajax: {
                    url: '@Url.Action("GetDadosFretes","Fretes",new { Area = "gc" })',
                    type: 'POST',
                    contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                    dataType: 'json',
                    cache: false,
                    data: function (d) {
                        return {
                            sEcho: d.draw,
                            iDisplayStart: d.start,
                            iDisplayLength: d.length,
                            yesFilterField: $('#yesFilterField').val().toString(),
                            yesFilterController: $('#yesFilterController').val().toString(),
                            yesCustomField01: emptyIfNull($('#edit_numero_cotacao').val()).toString(),
                            yesCustomField02: jsGetDateDDMMYYYY(jsDatepickerGetDate('#ig_gc_fretes_idx_d1')),
                            yesCustomField03: jsGetDateDDMMYYYY(jsDatepickerGetDate('#ig_gc_fretes_idx_d2')),
                            yesCustomField04: emptyIfNull($('#edit_transportadora').val()).toString(),
                            yesCustomField06: emptyIfNull($('#edit_valor').val()).toString()
                        };
                    },
                    error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
                },
                responsive: true,
                bFilter: false,
                bLengthChange: false,
                bProcessing: true,
                pageLength: 20,
                scrollX: false,
                scrollCollapse: false,
                fixedColumns: false,
                bAutoWidth: false,
                pagingType: 'full_numbers',
                aoColumnDefs: [
                    { width: '4%', orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                    { width: '7%', orderable: false, className: 'text-sm-center', targets: [1] },
                    { width: '8%', orderable: false, className: 'text-sm-center', targets: [2] },
                    { width: '22%', orderable: false, className: 'text-sm-start', targets: [3] },
                    { width: '22%', orderable: false, className: 'text-sm-start', targets: [4] },
                    { width: '15%', orderable: false, className: 'text-sm-start', targets: [5] },
                    { width: '8%', orderable: false, className: 'text-sm-center', targets: [6] },
                    { width: '5%', orderable: false, className: 'text-sm-center dt-no-row-select', targets: [7], data: null, defaultContent: '',
                        render: function (data, type, row) {
                            return '<button type="button" title="Editar pedido Id. ' + row[1] + '" class="btn btn-outline-warning btn-sm p-1 btnGcFretesEditRow d-inline-flex align-items-center" onclick="jsGcFretesEditRow(' + row[1] + ');"><i class="fa-regular fa-edit"></i></button>';
                        }
                    }
                ],
                select: {
                    style: 'multi',
                    selector: 'td:not(.dt-no-row-select)',
                    headerCheckbox: true
                },
                order: [[1, 'desc']],
                language: {
                    sEmptyTable: 'Informe os filtros e clique em Pesquisar.',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate: {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: '',
                            1: ' [ %d registro selecionado ] ',
                            _: ' [ %d registros selecionados ] '
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
            });
            $('#dtGcFretes tbody').on('dblclick', 'tr td:not(.dt-no-row-select)', function () {
                var data = otableGCFretes.row($(this).closest('tr')).data();
                if (data) { jsGcFretesEditRow(data[1]); }
            });
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsCreateTableGcFretes] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsGcFretesEditRow(idMovimento)
    {
        try {
            var id = parseInt(idMovimento, 10);
            if (!id || id <= 0) { return; }
            JsEditRecordDoubleClick(id, '@Url.Action("EditPedido", "Movimentos", new { Area = "gc" })');
        }
        catch (err) {
            LibMessageError("Atenção", "[jsGcFretesEditRow] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsAtualizarIndicadorFiltroFretes(yesFilterOnOff)
    {
        GdiAtualizarIndicadorFiltro(yesFilterOnOff, {
            btnId: 'btnLimparFiltroFretes',
            tituloInativo: 'Limpar filtro e restaurar padrão',
            tituloAtivo: 'Filtro ativo — limpar critérios de pesquisa'
        });
    }

    function jsAjaxPesquisarMovimentos()
    {
        try
        {
            if (_gcFretesSuprimirPesquisaAuto) { return; }
            LibMessageProcessando('Pesquisando Cotações / Pedidos / OS. . .');
            document.getElementById("yesFilterField").value = "*";
            $("#dtGcFretes").DataTable().draw(false);
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsAjaxPesquisarMovimentos] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsLimparFiltroFretes()
    {
        try
        {
            _gcFretesSuprimirPesquisaAuto = true;
            $('#edit_numero_cotacao').val('');
            $('#edit_valor').val('');
            $('#edit_transportadora').val('0').trigger('change');
            jsDatepickerFirstDayMonth('#ig_gc_fretes_idx_d1');
            jsDatepickerToday('#ig_gc_fretes_idx_d2');
            document.getElementById("yesFilterField").value = "";
            LibMessageProcessando('Atualizando lista...');
            $("#dtGcFretes").DataTable().draw(false);
        }
        catch (err)
        {
            LibMessageProcessandoHide();
            LibMessageError("Atenção", "[jsLimparFiltroFretes] " + (err && err.message ? err.message.toString() : String(err)));
        }
        finally
        {
            _gcFretesSuprimirPesquisaAuto = false;
        }
    }

</script>
