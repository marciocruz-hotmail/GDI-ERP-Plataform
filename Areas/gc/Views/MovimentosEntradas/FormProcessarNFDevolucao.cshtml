@model GdiPlataform.Areas.gc.Models.cstMovimentoEntradaNF
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "GcMovimentosFormProcessarNFDevolucao" }))
{
    <div class="row">
        <div class="col-lg-12 m-0 p-0">
            <div class="card m-0 p-0">
                <div class="card-title m-0 p-1">
                    <h5>@Html.Raw(ViewBag.Title)</h5>
                    @Html.HiddenFor(model => model.id_movimento)
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)
                </div>
                <div class="card-body m-0 p-1" style="max-width: 100%; overflow-x: auto; ">
                    <div class="form-horizontal m-0 p-0">
                        <div class="table-responsive scroll-body-horizontal" style="width:100%">
                            @if (Model.movimento_permitido == false)
                            {
                                <div class="alert alert-danger" role="alert">
                                    @Model.msg_erro.ToString()
                                </div>
                            }
                            else
                            {
                                <table class="table table-striped table-bordered compact">
                                    <thead>
                                        <tr>
                                            <th style="width: 5%" class="text-center">Qtd</th>
                                            <th style="width: 50%" class="text-start">Produto ERP</th>
                                            <th style="width: 35%" class="text-center">Produto EXTERNO</th>
                                            <th style="width: 10%" class="text-end">R$ Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < Model.allItens.Count; i++)
                                        {
                                            <tr>
                                                @Html.HiddenFor(model => model.allItens[i].id_movimento_item)
                                                @Html.HiddenFor(model => model.allItens[i].produto_externo_codigo)
                                                @Html.HiddenFor(model => model.allItens[i].produto_externo_nome)
                                                <td style="text-align:center;">@Html.LabelFor(model => model.allItens[i].quantidade_geral, Model.allItens[i].quantidade_geral.ToString(), htmlAttributes: new { @class = "col-form-label" })</td>
                                                <td style="text-align:center;">@Html.DropDownListFor(model => model.allItens[i].id_produto, ViewBag.comboProdutos as List<SelectListItem>, new { @class = "form-control" })</td>
                                                <td style="text-align:left;">@Html.LabelFor(model => model.allItens[i].nome_produto, Model.allItens[i].produto_externo_codigo.ToString() + " - " + Model.allItens[i].produto_externo_nome.ToString(), htmlAttributes: new { @class = "col-form-label" })</td>
                                                <td style="text-align:right;">@Html.LabelFor(model => model.allItens[i].valor_total_formatado, Model.allItens[i].valor_total_formatado.ToString().ToString(), htmlAttributes: new { @class = "col-form-label" })</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                                <br/>
                                <br/>
                                <br/>
                                <br/>
                                <br/>
                            }
                        </div>
                    </div>
                </div>
                <div class="card-footer justify-content-between m-0 p-1">
                    <div class="row justify-content-center">
                        <div class="col-4">
                            <button type="button" name="btnCancelar" title="Cancelar" class="btn btn-warning d-inline-flex align-items-center gap-2" onclick="jsYesCancelRecord('@Url.Action("Index","MovimentosEntradas",new { Area = "gc" })')"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                        </div>
                        <div class="col-4">
                            @if (Model.url_danfe != "")
                            {
                                <button type="button" name="btnPDF" title="Download Danfe" onclick="jsPDFNotaFiscal()" class="btn btn-info d-inline-flex align-items-center gap-2"><i class="fa-regular fa-file-pdf me-2" aria-hidden="true"></i>Download Danfe (Saída)</button>
                            }
                        </div>
                        <div class="col-4">
                            @if (Model.movimento_permitido == true)
                            {
                                <button type="button" name="btnSalvar" title="Salvar" onclick="jsSendForm()" class="btn btn-success float-end d-inline-flex align-items-center gap-2"><i class="fa-solid fa-save me-2" aria-hidden="true"></i>Confirmar Processamento</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsInitForm();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsSendForm()
    {
        try {
            LibMessageProcessando("");
            var form = $('#GcMovimentosFormProcessarNFDevolucao');
            windowLoading(true, 2);
            $.ajax({
                cache: false,
                async: true,
                type: "POST",
                url: '@Url.Action("AjaxProcessarNFDevolucao", "MovimentosEntradas", new { area = "gc" })',
                data: form.serialize(),
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        LibMessageDialog({
                            title: "Confirmação",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons:
                            {
                                confirmar:
                                {
                                    label: 'OK',
                                    callback: function ()
                                    {
                                        LibMessageProcessando("");
                                        window.location = '@Url.Action("Index", "MovimentosEntradas", new { Area = "gc" })';
                                        LibMessageHideAll();
                                    }
                                }
                            }
                        })
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias(result.msg);
                    }
                },
                error: function (result)
                {
                    LibMessageProcessandoHide();
                    GdiAjaxNotifyInconsistencias(result.msg);
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };


    function jsPDFNotaFiscal()
    {
        try
        {
            if ('@Model.url_danfe' != "")
            {
                window.open('@Model.url_danfe', '_blank').focus();
            }
            else {
                GdiAjaxNotifyInconsistencias("Danfe NÃO localizada!");
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsPDFNotaFiscal] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };



</script>

