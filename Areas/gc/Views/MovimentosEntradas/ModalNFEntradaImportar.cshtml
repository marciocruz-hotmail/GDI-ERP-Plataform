@model GdiPlataform.Areas.gc.Models.cstImportacaoNFEntrada
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Modal.cshtml"; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "GcMovimentosModalNFEntradaImportar" }))
{
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title d-flex align-items-center gap-2">
    <i class="fa-solid fa-file-alt fa-sm" aria-hidden="true"></i>
    @Html.Raw(@ViewBag.Title)</h5>
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-0">
                <div class="form-horizontal m-0 p-0">
                    <div class="card m-0 p-1">
                        <div class="card-body m-0 p-1" style="height: 100%">
                            <div class="form-group row text-sm-end m-0 pt-1">
                                @Html.LabelFor(model => model.id_movimento_tipo, new { @class = "col-sm-3 col-form-label" })
                                <div class="col-sm-9 text-sm-start">
                                    @Html.DropDownListFor(model => model.id_movimento_tipo, ViewBag.comboMovimentosTipos as List<SelectListItem>, new { @class = "form-control", @data_container = "body" })
                                </div>
                            </div>
                            <div class="form-group row text-sm-end m-0 pt-1">
                                @Html.Label("Arquivo XML", new { @class = "col-sm-3 col-form-label" })
                                <div class="col-sm-9 text-sm-start">
                                    <input type="file" class="form-control" id="customFileXML" onchange="jsFileInputChange(this)">
                                    <div class="form-text" id="customFileXML_info"></div>
                                </div>
                            </div>
                            <div class="form-group row text-sm-end m-0 pt-1">
                                @Html.Label("Arquivo Danfe", new { @class = "col-sm-3 col-form-label" })
                                <div class="col-sm-9 text-sm-start">
                                    <input type="file" class="form-control" id="customFilePDF" onchange="jsFileInputChange(this)">
                                    <div class="form-text" id="customFilePDF_info"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" name="btnCancelar" class="btn btn-warning me-auto d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                <button type="button" name="btnSalvar" class="btn btn-success d-inline-flex align-items-center gap-2" onclick="jsCheckInputs()"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>Processar Arquivo</button>
            </div>
        </div>
    </div>
}

<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsInitModal();
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsCheckInputs()
    {
        try
        {
            var hasError = false;
            var msgError = "Campos <b>Obrigatórios</b> deverão ser preenchidos!<br/><br/>";
            if (isEmpty($('#customFileXML').val().toString().trim())) {
                hasError = true;
                msgError += " - Arquivo XML não foi selecionado!<br/>";
            }
            if ((@Model.id_movimento_tipo != 6) && (isEmpty($('#customFilePDF').val().toString().trim())))
            {
                hasError = true;
                msgError += " - Arquivo Danfe (pdf) não foi selecionado!<br/>";
            }
            if (hasError) { LibMessageAlert("Atenção", msgError); }
            else {
                jsSendForm();
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[checkInputs] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }

    function jsSendForm()
    {
        try
        {
            LibMessageProcessando("");
            var formData = new FormData();
            var totalFilesXML = document.getElementById("customFileXML").files.length;
            var totalFilesPDF = document.getElementById("customFilePDF").files.length;
            var dataForm =
            {
                record_cstImportacaoNFEntrada: {}
            };
            for (var i = 0; i < totalFilesXML; i++)
            {
                var fileXML = document.getElementById("customFileXML").files[i];
                formData.append("filesourceXML", fileXML);
            }
            for (var i = 0; i < totalFilesPDF; i++) {
                var fileXML = document.getElementById("customFilePDF").files[i];
                formData.append("filesourcePDF", fileXML);
            }
            formData.append("id_movimento_tipo", $('#id_movimento_tipo').val().toString());
            $.ajax({
                type: "POST",
                url: '@Url.Action("AjaxImportarNFEntrada", "MovimentosEntradas", new { Area = "gc" })',
                data: formData,
                dataType: 'json',
                contentType: false,
                processData: false,
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                        GdiSwal2.dialog({
                            title: "<i class='fa-solid fa-check' style='color:#008000'>&nbsp&nbsp</i><b>Confirmação</b>",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons: {
                                confirmar:
                                {
                                    label: '&nbsp;OK',
                                    className: 'btn btn-info',
                                    callback: function ()
                                    {
                                        if ((result.idmovtipo == "5") && (result.idmov != "0")) // Compra Nacional
                                        {
                                            LibMessageProcessando("");
                                            window.location = '@Url.Action("FormProcessarNFCompraNacional", "MovimentosEntradas", new { Area = "gc" })' + "?id=" + result.idmov;
                                        }
                                        else if ((result.idmovtipo == "9") && (result.idmov != "0")) // Devolução
                                        {
                                            LibMessageProcessando("");
                                            window.location = '@Url.Action("FormProcessarNFDevolucao", "MovimentosEntradas", new { Area = "gc" })' + "?id=" + result.idmov;
                                        }
                                        else
                                        {
                                            $("#dtGcMovimentosIndexEntrada").DataTable().draw(false);
                                            document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                            GdiSwal2.hideAll();
                                        }
                                    }
                                }
                            }
                        })
                    }
                    else
                    {
                        GdiSwal2.dialog({
                            title: "<i class='fa-regular fa-window-close' style='color:#ff0000'>&nbsp&nbsp</i><b>Erro no Processamento</b>",
                            closeButton: false,
                            message: result.msg,
                            centerVertical: true,
                            onEscape: false,
                            backdrop: true,
                            buttons: {
                                confirmar: {
                                    label: '&nbsp;OK',
                                    className: 'btn btn-info',
                                    callback: function () {
                                        document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                                        GdiSwal2.hideAll();
                                    }
                                }
                            }
                        })
                    }
                },
                error: function (result)
                {
                    GdiAjaxNotifyInconsistencias(result.toString())
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };
</script>

