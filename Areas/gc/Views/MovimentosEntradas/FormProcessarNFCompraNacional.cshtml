@model GdiPlataform.Areas.gc.Models.CstMovimentoEntradaNF
@using GdiPlataform.Lib.Lookups
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "GcMovimentosFormProcessarNFCompraNacional" }))
{
    <div class="row">
        <div class="col-lg-12 m-0 p-0 min-w-0">
            <div class="card m-0 p-0">
                <div class="card-title m-0 p-1">
                    <h5>@Html.Raw(ViewBag.Title)</h5>
                    @Html.HiddenFor(model => model.id_movimento)
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)
                </div>
                <div class="card-body m-0 p-1 min-w-0">
                    <div class="form-horizontal m-0 p-0">
                        <div class="table-responsive gdi-form-table-scroll">
                            @if (Model.movimento_permitido == false)
                            {
                                <div class="alert alert-danger" role="alert">
                                    @Model.msg_erro.ToString()
                                </div>
                            }
                            else
                            {
                                <table class="table table-striped table-bordered table-sm gdi-form-table-fixed mb-0">
                                    <thead>
                                        <tr>
                                            <th class="gdi-col-qtd text-center">Qtd</th>
                                            <th class="gdi-col-produto text-center">Produto ERP</th>
                                            <th class="gdi-col-produto text-start">Produto EXTERNO</th>
                                            <th class="gdi-col-qtd text-end">R$ Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < Model.allItens.Count; i++)
                                        {
                                            var produtoExterno = string.Format("{0} - {1}",
                                                (Model.allItens[i].produto_externo_codigo ?? string.Empty).ToString().Trim(),
                                                (Model.allItens[i].produto_externo_nome ?? string.Empty).ToString().Trim()).Trim(' ', '-');
                                            var comboProdutoLinha = LookupSearchQueries.BuildComboProdutoEntradaNacionalLinha(
                                                Model.allItens[i].id_produto,
                                                Model.allItens[i].nome_produto);
                                            <tr>
                                                @Html.HiddenFor(model => model.allItens[i].id_movimento_item)
                                                @Html.HiddenFor(model => model.allItens[i].produto_externo_codigo)
                                                @Html.HiddenFor(model => model.allItens[i].produto_externo_nome)
                                                <td class="gdi-col-qtd text-center">@Model.allItens[i].quantidade_geral</td>
                                                <td class="text-center">@Html.DropDownListFor(model => model.allItens[i].id_produto, comboProdutoLinha, new { @class = "form-control", @data_gdi_select2_search = "true", @data_gdi_lookup_url = Url.Action("GetProdutosLookup", "MovimentosEntradas", new { area = "gc" }), @data_gdi_lookup_min_length = "2", @data_container = "body" })</td>
                                                <td class="gdi-col-produto text-start">@(string.IsNullOrWhiteSpace(produtoExterno) ? "—" : produtoExterno)</td>
                                                <td class="gdi-col-qtd text-end">@Model.allItens[i].valor_total_formatado</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                </div>
                <div class="card-footer justify-content-between m-0 p-1">
                    <button type="button" name="btnCancelar" title="Cancelar" class="btn btn-warning d-inline-flex align-items-center gap-2" onclick="jsYesCancelRecord('@Url.Action("Index","MovimentosEntradas",new { Area = "gc" })')"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                    @if (Model.movimento_permitido == true)
                    {
                        <button type="button" name="btnSalvar" title="Salvar" onclick="jsSendForm()" class="btn btn-success float-end d-inline-flex align-items-center gap-2"><i class="fa-solid fa-save me-2" aria-hidden="true"></i>Confirmar Processamento</button>
                    }
                </div>
            </div>
        </div>
    </div>
}
<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsInitForm();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsSendForm()
    {
        try {
            LibMessageProcessando("Processando . . .")
            var form = $('#GcMovimentosFormProcessarNFCompraNacional');
            windowLoading(true, 2);
            $.ajax({
                cache: false,
                async: true,
                type: "POST",
                url: '@Url.Action("AjaxProcessarNFCompraNacional", "MovimentosEntradas", new { area = "gc" })',
                data: form.serialize(),
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                                                LibMessageSuccess("Confirmação", result.msg, {
                            backdrop: true,
                            callback: function () {
                            document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                            LibMessageProcessando("Processando . . .")
                            $(window.document.location).attr('href', '@Url.Action("Index","MovimentosEntradas",new { Area = "gc" })');
                            LibMessageHideAll();
                            }
                        });
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias(result.msg);
                    }
                },
                error: function (result)
                {
                    LibMessageProcessandoHide();
                    GdiAjaxNotifyInconsistencias(result.msg);
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };
</script>
