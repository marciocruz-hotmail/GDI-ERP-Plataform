@model GdiPlataform.Areas.gc.Models.CstMovimentoEntradaNF
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "GcMovimentosFormProcessarNFImportacao" }))
{
    <div class="row">
        <div class="col-lg-12 m-0 p-0 min-w-0">
            <div class="card m-0 p-0">
                <div class="card-title m-0 p-1">
                    <h5>@Html.Raw(ViewBag.Title)</h5>
                    @Html.HiddenFor(model => model.id_movimento)
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)
                </div>
                <div class="card-body m-0 p-1 min-w-0">
                    <div class="form-horizontal m-0 p-0">
                        <div class="table-responsive gdi-form-table-scroll" id="gdiProcessarNfImportacaoTableWrap">

                            @if (Model.movimento_permitido == false)
                            {
                                <div class="alert alert-danger" role="alert">
                                    @Model.msg_erro.ToString()
                                </div>
                            }
                            else
                            {
                                <table class="table table-striped table-bordered table-sm gdi-form-table-fixed mb-0">
                                    <thead>
                                        <tr>
                                            <th class="gdi-col-seq text-center">Seq.</th>
                                            <th class="gdi-col-produto text-start">Produto</th>
                                            <th class="gdi-col-qtd text-center">Qtd</th>
                                            <th class="gdi-col-cd text-center">BH_01</th>
                                            <th class="gdi-col-cd text-center">BH_02</th>
                                            <th class="gdi-col-cd text-center">BH_03</th>
                                            <th class="gdi-col-cd text-center">SP_01</th>
                                            <th class="gdi-col-cd text-center">SP_02</th>
                                            <th class="gdi-col-cd text-center">SP_03</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < Model.allItens.Count; i++)
                                        {
                                            var nomeProduto = (Model.allItens[i].nome_produto ?? string.Empty).ToString().Trim();
                                            <tr>
                                                @Html.HiddenFor(model => model.allItens[i].id_movimento_item)
                                                <td class="gdi-col-seq text-center">@Model.allItens[i].sequencia</td>
                                                <td class="gdi-col-produto text-start">@(string.IsNullOrWhiteSpace(nomeProduto) ? "—" : nomeProduto)</td>
                                                <td class="gdi-col-qtd text-center">@Model.allItens[i].quantidade_geral</td>
                                                <td class="gdi-col-cd text-center">@Html.EditorFor(model => model.allItens[i].qtd_cdbh_01, new { htmlAttributes = new { @class = "form-control", style = "background:#aed6f1;" } })</td>
                                                <td class="gdi-col-cd text-center">@Html.EditorFor(model => model.allItens[i].qtd_cdbh_02, new { htmlAttributes = new { @class = "form-control", style = "background:#aed6f1;" } })</td>
                                                <td class="gdi-col-cd text-center">@Html.EditorFor(model => model.allItens[i].qtd_cdbh_03, new { htmlAttributes = new { @class = "form-control", style = "background:#aed6f1;" } })</td>
                                                <td class="gdi-col-cd text-center">@Html.EditorFor(model => model.allItens[i].qtd_cdsp_01, new { htmlAttributes = new { @class = "form-control", style = "background:#7fb3d5;" } })</td>
                                                <td class="gdi-col-cd text-center">@Html.EditorFor(model => model.allItens[i].qtd_cdsp_02, new { htmlAttributes = new { @class = "form-control", style = "background:#7fb3d5;" } })</td>
                                                <td class="gdi-col-cd text-center">@Html.EditorFor(model => model.allItens[i].qtd_cdsp_03, new { htmlAttributes = new { @class = "form-control", style = "background:#7fb3d5;" } })</td>
                                                @Html.HiddenFor(model => model.allItens[i].id_produto)
                                                @Html.HiddenFor(model => model.allItens[i].sequencia)
                                                @Html.HiddenFor(model => model.allItens[i].nome_produto)
                                                @Html.HiddenFor(model => model.allItens[i].quantidade_geral)
                                                @Html.HiddenFor(model => model.allItens[i].valor_unit)
                                                @Html.HiddenFor(model => model.allItens[i].valor_total)
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                </div>
                <div class="card-footer justify-content-between m-0 p-1">
                    <button type="button" name="btnCancelar" title="Cancelar" class="btn btn-warning d-inline-flex align-items-center gap-2" onclick="jsYesCancelRecord('@Url.Action("Index","MovimentosEntradas",new { Area = "gc" })')"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                    @if (Model.movimento_permitido == true)
                    {<button type="button" name="btnSalvar" title="Salvar" onclick="jsSendForm()" class="btn btn-success float-end d-inline-flex align-items-center gap-2"><i class="fa-solid fa-save me-2" aria-hidden="true"></i>Salvar</button>}
                </div>
            </div>
        </div>
    </div>
}
<script type="text/javascript">

    $(function ()
    {
        try
        {
            jsInitForm();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
            var wrap = document.getElementById('gdiProcessarNfImportacaoTableWrap');
            if (wrap) { wrap.scrollLeft = 0; }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsSendForm()
    {
        try {
            LibMessageProcessando("Processando . . .")
            var form = $('#GcMovimentosFormProcessarNFImportacao');
            windowLoading(true, 2);
            $.ajax({
                cache: false,
                async: true,
                type: "POST",
                url: '@Url.Action("AjaxProcessarNFImportacao", "MovimentosEntradas", new { area = "gc" })',
                data: form.serialize(),
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success == true)
                    {
                                                LibMessageSuccess("Confirmação", result.msg, {
                            backdrop: true,
                            callback: function () {
                            document.querySelectorAll('.modal').forEach(function(m){var i=bootstrap.Modal.getInstance(m);if(i)i.hide();});
                            LibMessageProcessando("Processando . . .")
                            $(window.document.location).attr('href', '@Url.Action("Index","MovimentosEntradas",new { Area = "gc" })');
                            LibMessageHideAll();
                            }
                        });
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.')
                    }
                },
                error: function (xhr, textStatus, errorThrown)
                {
                    LibMessageProcessandoHide();
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.')
                }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsSendForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };
</script>
