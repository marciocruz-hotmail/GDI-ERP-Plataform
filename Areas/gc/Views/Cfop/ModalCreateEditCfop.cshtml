@model GdiPlataform.Db.gc_cfop
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Modal.cshtml"; }
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "FormModalCreateEditGcCfop" }))
{
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h5 class="modal-title d-flex align-items-center gap-2">@Html.Raw(ViewBag.Title)</h5>
                @Html.HiddenFor(model => model.id_cfop)
                @Html.HiddenFor(model => model.id_coligada)
                @Html.HiddenFor(model => model.id_filial)
                @Html.HiddenFor(model => model.id_usuario_cadastro)
                @Html.HiddenFor(model => model.datahora_cadastro)
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-1">
                @Html.Partial("_AlertMsg", AlertMsgItem.Maybe(ViewBag.MsgBloqueio as string, "danger"))
                @if (string.IsNullOrEmpty(ViewBag.MsgBloqueio as string))
                {
                    <div class="form-horizontal m-0 p-0">
                        <div class="card shadow-sm gdi-section-accent-secondary m-1 p-0">
                            <div class="section-header"><i class="fa-solid fa-receipt me-1" aria-hidden="true"></i>Dados do CFOP</div>
                            <div class="card-body m-0 p-1">
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("Ativo", "Ativo", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-1 text-sm-start" style="margin-top:7px;">
                                        <div class="form-check form-switch form-switch-lg">
                                            @Html.CheckBoxFor(model => model.ativo, new { @class = "form-check-input switch-success", role = "switch" })
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("Número", "Número", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-2">
                                        @Html.EditorFor(model => model.numero, new { htmlAttributes = new { @class = "form-control", data_autofocus = "true" } })
                                    </div>
                                </div>
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("Descrição", "Descrição", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-4">
                                        @Html.EditorFor(model => model.descricao, new { htmlAttributes = new { @class = "form-control" } })
                                    </div>
                                </div>
                                <div class="form-group row text-sm-end m-0 pt-1">
                                    @Html.Label("nfe_devolucao", "Nota Devolução.", htmlAttributes: new { @class = "col-sm-2 col-form-label" })
                                    <div class="col-sm-2 text-sm-start" style="margin-top:7px;">
                                        <div class="form-check form-switch form-switch-lg">
                                            @Html.CheckBoxFor(model => model.nfe_devolucao, new { @class = "form-check-input switch-success", role = "switch" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" name="btnCancelar" title="Cancelar" class="btn btn-warning d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa fa-undo me-2" aria-hidden="true"></i>Cancelar</button>
                @if (string.IsNullOrEmpty(ViewBag.MsgBloqueio as string))
                {
                <button type="button" name="btnSalvar" title="Salvar" onclick="jsAjaxCreateEditCfop()" class="btn btn-success float-end d-inline-flex align-items-center gap-2"><i class="fa-solid fa-save me-2" aria-hidden="true"></i>Salvar</button>
                }
            </div>
        </div>
    </div>
}
<script type="text/javascript">
    $(function () {
        try { jsInitModal(); }
        catch (err) { LibMessageError("Atenção", "[jsInitModal] " + (err && err.message ? err.message.toString() : String(err))); }
    });

    function jsAjaxCreateEditCfop()
    {
        try
        {
            if (isEmpty($('#numero').val() == null ? '' : $('#numero').val().toString().trim())) {
                LibMessageAlert('Atenção', 'Campo <b>Número</b> é de preenchimento obrigatório!');
                return;
            }
            if (isEmpty($('#descricao').val() == null ? '' : $('#descricao').val().toString().trim())) {
                LibMessageAlert('Atenção', 'Campo <b>Descrição</b> é de preenchimento obrigatório!');
                return;
            }
            LibMessageProcessando('Salvando CFOP...');
            var form = $('#FormModalCreateEditGcCfop');
            $.ajax({
                type: 'POST',
                url: '@Url.Action("AjaxCreateEditCfop", "Cfop", new { area = "gc" })',
                data: form.serialize(),
                success: function (result)
                {
                    LibMessageProcessandoHide();
                    if (result.success === true)
                    {
                        document.querySelectorAll('.modal').forEach(function (m) { var i = bootstrap.Modal.getInstance(m); if (i) i.hide(); });
                        if (typeof otableGcCfop !== 'undefined' && otableGcCfop) {
                            otableGcCfop.draw(false);
                        } else {
                            $('#dtGcCfop').DataTable().draw(false);
                        }
                        LibMessageHideAll();
                    }
                    else
                    {
                        GdiAjaxNotifyInconsistencias((result && result.msg) ? result.msg : 'Verifique as inconsistências.');
                }
                },
                error: function (xhr, textStatus, errorThrown)
                {
                    LibMessageProcessandoHide();
                    GdiAjaxNotifyInconsistencias(errorThrown || textStatus || 'Verifique as inconsistências.');
                }
            });
        }
        catch (err) {
            LibMessageProcessandoHide();
            LibMessageError('Atenção', '[jsAjaxCreateEditCfop] ' + (err && err.message ? err.message.toString() : String(err)));
        }
    };
</script>
