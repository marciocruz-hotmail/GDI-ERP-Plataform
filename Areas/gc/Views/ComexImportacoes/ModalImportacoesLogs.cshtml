@model GdiPlataform.Db.gc_comex_importacoes
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Modal.cshtml"; }
<style>
    #FormModalImportacoesLogs .modal-body {
        overflow-y: auto;
        max-height: calc(100vh - 170px);
        overflow-x: hidden;
    }

    #divImportacoesLogsDt {
        min-width: 0;
    }

    #divImportacoesLogsDt.gdi-dt-scroll-host {
        overflow-x: hidden;
    }
</style>
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "FormModalImportacoesLogs" }))
{
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header m-0 p-1">
                <h4 class="modal-title d-flex align-items-center gap-2">
    @Html.Raw((String)ViewBag.Title)</h4>
                @Html.HiddenFor(model => model.id_importacao)
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterController" value="ModalImportacoesLogs" name="yesFilterController" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="modal-body m-0 p-2 min-w-0">
                @Html.Partial("_AlertMsg", AlertMsgItem.Maybe(ViewBag.MsgBloqueio as string, "danger"))
                @if (string.IsNullOrEmpty(ViewBag.MsgBloqueio as string))
                {
                <div id="divImportacoesLogsDt" class="card-body m-0 p-1 gdi-dt-scroll-host min-w-0">
                    <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dataTable-ImportacoesLogs">
                        <thead>
                            <tr>
                                <th style="font-size:12px;">Histórico</th>
                            </tr>
                        </thead>
                    </table>
                </div>
                }
            </div>
            <div class="modal-footer justify-content-between m-0 p-1">
                <button type="button" name="btnFechar" title="Fechar" class="btn btn-warning me-auto d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa-regular fa-window-close me-2" aria-hidden="true"></i>Fechar</button>
                <button type="button" name="btnOK" class="btn btn-success d-inline-flex align-items-center gap-2" data-bs-dismiss="modal"><i class="fa-solid fa-check me-2" aria-hidden="true"></i>OK</button>
            </div>
        </div>
    </div>
}

<script type="text/javascript">

    var oTableImportacoesLogs;

    $(function ()
    {
        try
        {
            jsInitModal();
            @if (string.IsNullOrEmpty(ViewBag.MsgBloqueio as string))
            {
            <text>jsCreateOTableImportacoesLogs();</text>
            }
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsCreateOTableImportacoesLogs()
    {
        try
        {
            $.fn.dataTable.ext.errMode = 'none';
            oTableHistoricoMovimento = $('#dataTable-ImportacoesLogs').css("font-size", 12).on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message);
                }).on('xhr.dt', function (e, settings, json, xhr) { GdiDtNotifyJsonErrorMessage(json); }).DataTable({
            processing: true,
            bServerSide: true,
            ajax: {
                url: '@Url.Action("GetDadosImportacoesLogs", "ComexImportacoes",new { Area = "gc" })',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                dataType: 'json',
                cache: false,
                data: function (d) {
                    return {
                        sEcho: d.draw,
                        iDisplayStart: d.start,
                        iDisplayLength: d.length,
                        yesCustomIdPK: $('#id_importacao').val().toString(),
                    };
                },
                error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown);
                }
            },
            responsive: true,
            drawCallback: function (settings) {
                try { new $.fn.dataTable.Api(settings).columns.adjust(); } catch (e) { }
                var host = document.getElementById('divImportacoesLogsDt');
                if (host) { host.scrollLeft = 0; }
                var body = document.querySelector('#FormModalImportacoesLogs .modal-body');
                if (body) { body.scrollLeft = 0; }
            },
            bFilter: false,
            bLengthChange: false,
            bProcessing: true,
            pageLength: 100,
            scrollX: false,
            scrollCollapse: false,
            fixedColumns: false,
            bAutoWidth: false,
            pagingType: 'full_numbers',
            aoColumnDefs: [
                { "width": "100%", orderable: false, className: 'text-sm-center', targets: [0] }
            ],
            order: [[0, 'asc']],

            language:
            {
                sEmptyTable: 'Nenhum registro encontrado',
                sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                sInfoPostFix: '',
                sInfoThousands: '.',
                sLengthMenu: '_MENU_ registros por página',
                sZeroRecords: 'Nenhum registros encontrado',
                sSearch: 'Pesquisar',
                oPaginate: {
                    sNext: '>',
                    sPrevious: '<',
                    sFirst: '<<',
                    sLast: '>>'
                },
            select: {
                rows: {
                    0: "",
                    1: " [ %d registro selecionado ] ",
                    _: " [ %d registros selecionados ] "
                }
            }
            },
            oAria: {
                sSortAscending: ': Ordenar colunas de forma ascendente',
                sSortDescending: ': Ordenar colunas de forma descendente'
            }
            });
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateOTableImportacoesLogs] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

</script>
