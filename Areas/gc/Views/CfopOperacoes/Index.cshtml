@model IEnumerable<GdiPlataform.Db.gc_cfop_operacoes>
@using GdiPlataform.Security
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(ViewBag.Title)</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterOperador" value="" name="yesFilterOperador" />
                <input type="hidden" id="yesFilterText" value="" name="yesFilterText" />
                <input type="hidden" id="yesFilterAdvancedText" value="" name="yesFilterAdvancedText" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>
            <div class="card-header m-0 p-1">
                @if ((CachePersister.userIdentity.Roles.Contains("gc_CfopOperacoes_*")) || (CachePersister.userIdentity.Roles.Contains("gc_CfopOperacoes_Actioncreate")))
                {<button type="button" name="btnRegistroNovo" title="Novo Registro - Não Liberado" class="btn btn-outline-success disabled d-inline-flex align-items-center gap-2" onclick="JsNewRecord('@Url.Action("Create","CfopOperacoes",new { Area = "g" })')"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button> }
                else
                { <button type="button" name="btnRegistroNovo" title="Novo Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa fa-plus me-2" aria-hidden="true"></i>Novo</button>}
                @if ((CachePersister.userIdentity.Roles.Contains("gc_CfopOperacoes_*")) || (CachePersister.userIdentity.Roles.Contains("gc_CfopOperacoes_Actionupdate")))
                {<button type="button" name="btnRegistroEditar" title="Editar Registro" class="btn btn-outline-warning d-inline-flex align-items-center gap-2" onclick="jsModalCreateEditCfopOperacoes('0',otableGcCfopOperacoes, 'Id.')"><i class="fa-regular fa-edit me-2" aria-hidden="true"></i>Editar</button> }
                else
                { <button type="button" name="btnRegistroEditar" title="Editar Registro - Não Liberado" class="btn btn-outline-secondary disabled d-inline-flex align-items-center gap-2"><i class="fa-regular fa-edit me-2" aria-hidden="true"></i>Editar</button>}
            </div>
            <div class="card-body m-0 p-1" style="max-width: 100%; overflow-x: auto; ">
                <div class="table-responsive scroll-body-horizontal" style="width:100%">
                    <table class="table table-sm table-striped table-hover align-middle w-100 display compact" style="width:100%" id="dtGcCfopOperacoes">
                        <thead>
                            <tr>
                                <th>[x]</th>
                                <th>@Html.Encode("Id.")</th>
                                <th>Ativo</th>
                                <th>Descrição</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    var otableGcCfopOperacoes;

    $(function ()
    {
        try
        {
            jsInitForm();
            jsCreateTable();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err)
        {
            LibMessageError("Atenção", "[jsLoadForm] " + (err && err.message ? err.message.toString() : String(err)));
        }
    });

    function jsCreateTable()
    {
        try
        {
            if (otableGcCfopOperacoes == null)
            {
                $.fn.dataTable.ext.errMode = 'none';
                otableGcCfopOperacoes = $('#dtGcCfopOperacoes')
                    .on('error.dt', function (e, settings, techNote, message) { GdiDtNotifyLoadFailure(message); })
                    .on('xhr.dt', function (e, settings, json, xhr) { GdiDtNotifyJsonErrorMessage(json); btnFiltro(json.yesFilterOnOff); }).DataTable({
                processing: true,
                bServerSide: true,
                ajax: {
                    url: '@Url.Action("GetDados", "CfopOperacoes", new { Area = "gc" })',
                    type: 'POST',
                    contentType: 'application/x-www-form-urlencoded; charset=utf-8',
                    dataType: 'json',
                    cache: false,
                    data: function (d) {
                        return {
                            sEcho: d.draw,
                            iDisplayStart: d.start,
                            iDisplayLength: d.length,
                            yesFilterField: $('#yesFilterField').val().toString(),
                            yesFilterOperador: $('#yesFilterOperador').val().toString(),
                            yesFilterText: $('#yesFilterText').val().toString(),
                            yesFilterAdvancedText: $('#yesFilterAdvancedText').val().toString(),
                        };
                    },
                    error: function (xhr, textStatus, errorThrown) { GdiDtNotifyLoadFailure(errorThrown); }
                },
                responsive: true,
                bFilter: false,
                bLengthChange: false,
                bProcessing: true,
                pageLength: 20,
                scrollX: false,
                scrollCollapse: false,
                fixedColumns: false,
                bAutoWidth: false,
                pagingType: 'full_numbers',
                aoColumnDefs: [
                    { "width": "4%", orderable: false, className: 'text-sm-center', targets: [0], render: DataTable.render.select() },
                    { "width": "4%", orderable: false, className: 'text-sm-center', targets: [1] },
                    { "width": "8%", orderable: false, className: 'text-sm-center', targets: [2] },
                    { "width": "84%", orderable: true, targets: [3] }
                ],
                select: {
                    style: 'multi',
                    selector: 'td:not(.dt-no-row-select)',
                    headerCheckbox: true
                },
                order: [[1, 'asc']],
                language:
                {
                    sEmptyTable: 'Nenhum registro encontrado',
                    sInfo: 'Mostrando de _START_ ate _END_   [ _TOTAL_ registros total ]',
                    sInfoEmpty: 'Mostrando 0 ate 0 de 0 registros',
                    sInfoFiltered: ' (Filtrados de _MAX_ registros)',
                    sInfoPostFix: '',
                    sInfoThousands: '.',
                    sLengthMenu: '_MENU_ registros por página',
                    sZeroRecords: 'Nenhum registro encontrado',
                    sSearch: 'Pesquisar',
                    oPaginate:
                    {
                        sNext: '>',
                        sPrevious: '<',
                        sFirst: '<<',
                        sLast: '>>'
                    },
                    select: {
                        rows: {
                            0: "",
                            1: " [ %d registro selecionado ] ",
                            _: " [ %d registros selecionados ] "
                        }
                    }
                },
                oAria: {
                    sSortAscending: ': Ordenar colunas de forma ascendente',
                    sSortDescending: ': Ordenar colunas de forma descendente'
                }
                });
                $('#dtGcCfopOperacoes tbody').on('dblclick', 'tr td', function () {
                    var data = otableGcCfopOperacoes.row($(this).closest('tr')).data();
                    jsModalCreateEditCfopOperacoes(data[1],'','');
                });
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsCreateTable] " + (err && err.message ? err.message.toString() : String(err)));
        }
    };

    function jsModalCreateEditCfopOperacoes(IdOperacao, TableName, columnName)
    {
        try
        {
            if (IdOperacao != '0')
            {
                LibMessageProcessando("");
                $("#mainModal").load('@Url.Action("ModalCreateEditOperacao", "CfopOperacoes", new { area = "gc" })?IdOperacao=' + IdOperacao, function ()
                {
                    var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
                })
            }
            else
            {
                var selectedIds = JsGetSelectedRows(TableName, columnName);
                if (!selectedIds || selectedIds.length == 0) {
                    yesMessageAlertSmall("Atenção", "Selecione o registro");
                }
                else
                {
                    if (selectedIds.indexOf(',') == -1)
                    {
                        LibMessageProcessando("");
                        $("#mainModal").load('@Url.Action("ModalCreateEditOperacao", "CfopOperacoes", new { area = "gc" })?IdOperacao=' + selectedIds, function ()
                        {
                            var e=document.getElementById('mainModal');if(e){bootstrap.Modal.getOrCreateInstance(e).show();}
                        })
                    }
                    else {
                        yesMessageAlertSmall("Atenção", "Selecione apenas 1(um) registro!");
                    }
                }
            }
        }
        catch (err) {
            LibMessageError("Atenção", "[jsYesEditRecord] " + (err && err.message ? err.message.toString() : String(err)));
        }
    }
</script>


