    $('#id_cliente_contato').change(function ()
    {
        try
        {
            var selectedText = [];
            var selectedValues = [];
            var emails = "";
            var ids = "";
            $('#id_cliente_contato :selected').each(function (i, value) {
                selectedValues[i] = value;
                selectedText[i] = $(value).text();
                if ($(value).val() != "0") {
                    emails += $(value).text().replace("[", "").replace("]", "") + "; ";
                    ids += $(value).val() + ";";
                }
            });
            $("#notifica_contatos_emails").val(emails);
            $("#notifica_contatos_ids").val(ids);
        }
        catch (err) {
            LibMessageError("Atenção", err != null ? String(err) : "");
        }
    });

