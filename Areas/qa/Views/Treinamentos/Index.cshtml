@model IEnumerable<GdiPlataform.Db.qa_lms_cursos>
@using GdiPlataform.Security
@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="row">
    <div class="col-lg-12 m-0 p-0">
        <div class="card m-0 p-0">
            <div class="card-title m-0 p-1">
                <h5>@Html.Raw(ViewBag.Title)</h5>
                <input type="hidden" id="yesFilterField" value="" name="yesFilterField" />
                <input type="hidden" id="yesFilterController" value="IndexGed" name="yesFilterController" />
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
            </div>

            <div class="card-body m-2 p-2" style="height: 100%">
                <div class="form-horizontal m-1 p-1">
                    <div class="col-10 mx-auto m-0 p-0">
                        <div class="card shadow border m-1 p-1">
                            <div class="section-header"><i class="fa-solid fa-jet-fighter me-1" aria-hidden="true"></i>Treinamentos da Aviação</div>
                            <div class="card-body d-flex flex-column align-items-left m-1 p-1">
                                <div class="table-responsive scroll-body-horizontal m-0 p-0" style="width:100%">
                                    <div class="form-group row text-sm-end m-0 pt-1">
                                        <div class="col-sm-6 m-0 p-1">
                                                <button type="button" name="btnRelatorio7" title="Identificação de Peças Falsas / Não Homologadas" class="btn btn-outline-secondary btn-lg w-100 left-block d-inline-flex align-items-center gap-2" onclick="jsShowTreinamentoAviacao001()"><i class="fa-solid fa-boxes-packing fa-xl me-2" aria-hidden="true"></i>Identificação de Peças Falsas / Não Homologadas</button>
                                        </div>
                                        <div class="col-sm-6 m-0 p-1">
                                        </div>
                                    </div>
                                </div>
                                <div class="table-responsive scroll-body-horizontal" style="width:100%">
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script type="text/javascript">

	$(function ()
    {
        try
        {
            jsInitForm();
            getValidationSummary(@Html.Raw(Json.Encode(((@Html.ValidationSummary()==null)?"":@Html.ValidationSummary().ToHtmlString()))));
        }
        catch (err) {
            LibMessageError("Atenção", "[jsInitForm]" + (err && err.message ? err.message.toString() : String(err)));
        }
    });


function jsShowTreinamentoAviacao001()
{
    try
    {
        $(window.document.location).attr('href', '@Url.Action("IndexTreinamentoAviacao001", "Treinamentos",new { Area = "qa" })');
    }
    catch (err) {
        LibMessageError("Atenção", "[jsShowTreinamentoPecasFalsas] " + (err && err.message ? err.message.toString() : String(err)));
    }
}




</script>
